<Window
    x:Class="Fluxo.Installer.Views.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="clr-namespace:Fluxo.Controls;assembly=Fluxo.Resources"
    xmlns:models="clr-namespace:Fluxo.Installer.Models"
    xmlns:pages="clr-namespace:Fluxo.Installer.Views.Pages"
    Title="Fluxo Installer"
    Width="860"
    Height="560"
    AllowsTransparency="True"
    Background="Transparent"
    ResizeMode="NoResize"
    WindowStartupLocation="CenterScreen"
    WindowStyle="None">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Fluxo.Resources;component/Resources/Theme.xaml" />
                <ResourceDictionary Source="/Fluxo.Resources;component/Resources/Fonts.xaml" />
                <ResourceDictionary Source="/Fluxo.Resources;component/Resources/Icons.xaml" />
                <ResourceDictionary Source="/Fluxo.Resources;component/Resources/Converters.xaml" />

                <ResourceDictionary Source="/Fluxo.Resources;component/Resources/Styles/ContainerStyles.xaml" />
                <ResourceDictionary Source="/Fluxo.Resources;component/Resources/Styles/ButtonStyles.xaml" />
                <ResourceDictionary Source="/Fluxo.Resources;component/Resources/Styles/TextBoxStyles.xaml" />
                <ResourceDictionary Source="/Fluxo.Resources;component/Resources/Styles/GlobalStyles.xaml" />
                <ResourceDictionary Source="/Fluxo.Resources;component/Resources/Styles/PopupStyles.xaml" />
                <ResourceDictionary Source="/Fluxo.Resources;component/Resources/Styles/MainWindowStyles.xaml" />
                <ResourceDictionary Source="/Fluxo.Resources;component/Resources/Styles/SettingsStyle.xaml" />
                <ResourceDictionary Source="/Fluxo.Resources;component/Resources/Styles/StepNavigatorStyle.xaml" />
                <ResourceDictionary Source="/Fluxo.Resources;component/Resources/Styles/QuickSetupWizardStyle.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <Border
        Margin="16"
        Padding="24"
        Background="{StaticResource Brush.Background.Main}"
        BorderBrush="{StaticResource Brush.Border.Subtle}"
        BorderThickness="1"
        CornerRadius="16">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Margin="0,0,0,18">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal">
                    <TextBlock
                        FontFamily="{StaticResource Bold}"
                        FontSize="18"
                        Foreground="{StaticResource Brush.Text.Primary}"
                        Text="Welcome to " />
                    <TextBlock
                        FontFamily="{StaticResource Bold}"
                        FontSize="18"
                        Foreground="{StaticResource Brush.Text.Primary}"
                        Text="flux" />
                    <TextBlock
                        FontFamily="{StaticResource Bold}"
                        FontSize="18"
                        Foreground="{StaticResource Brush.Mint}"
                        Text="o" />
                </StackPanel>

                <Button
                    Grid.Column="1"
                    Width="36"
                    Height="36"
                    Padding="0"
                    Command="{Binding CloseInstallerCommand}">
                    <Button.Style>
                        <Style BasedOn="{StaticResource PopupTextButtonStyle}" TargetType="Button">
                            <Setter Property="Visibility" Value="Visible" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Screen}" Value="{x:Static models:InstallerScreen.Finished}">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                    <Path
                        Width="12"
                        Height="12"
                        Data="{StaticResource Close}"
                        Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                        Stretch="Uniform" />
                </Button>
            </Grid>

            <Grid Grid.Row="1">
                <pages:InstallerWelcomePage>
                    <pages:InstallerWelcomePage.Style>
                        <Style TargetType="{x:Type pages:InstallerWelcomePage}">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Screen}" Value="{x:Static models:InstallerScreen.Welcome}">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </pages:InstallerWelcomePage.Style>
                </pages:InstallerWelcomePage>

                <pages:InstallerProgressPage>
                    <pages:InstallerProgressPage.Style>
                        <Style TargetType="{x:Type pages:InstallerProgressPage}">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Screen}" Value="{x:Static models:InstallerScreen.Progress}">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </pages:InstallerProgressPage.Style>
                </pages:InstallerProgressPage>

                <pages:InstallerFinishedPage>
                    <pages:InstallerFinishedPage.Style>
                        <Style TargetType="{x:Type pages:InstallerFinishedPage}">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Screen}" Value="{x:Static models:InstallerScreen.Finished}">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </pages:InstallerFinishedPage.Style>
                </pages:InstallerFinishedPage>
            </Grid>
        </Grid>
    </Border>
</Window>