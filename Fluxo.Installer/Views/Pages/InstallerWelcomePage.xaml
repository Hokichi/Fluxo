<UserControl
    x:Class="Fluxo.Installer.Views.Pages.InstallerWelcomePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="clr-namespace:Fluxo.Controls;assembly=Fluxo.Resources"
    xmlns:customControls="clr-namespace:Fluxo.Resources.CustomControls;assembly=Fluxo.Resources"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="560"
    d:DesignWidth="860"
    mc:Ignorable="d">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Fluxo.Resources;component/Resources/Theme.xaml" />
                <ResourceDictionary Source="/Fluxo.Resources;component/Resources/Fonts.xaml" />
                <ResourceDictionary Source="/Fluxo.Resources;component/Resources/Icons.xaml" />
                <ResourceDictionary Source="/Fluxo.Resources;component/Resources/Converters.xaml" />

                <ResourceDictionary Source="/Fluxo.Resources;component/Resources/Styles/ContainerStyles.xaml" />
                <ResourceDictionary Source="/Fluxo.Resources;component/Resources/Styles/ButtonStyles.xaml" />
                <ResourceDictionary Source="/Fluxo.Resources;component/Resources/Styles/TextBoxStyles.xaml" />
                <ResourceDictionary Source="/Fluxo.Resources;component/Resources/Styles/GlobalStyles.xaml" />
                <ResourceDictionary Source="/Fluxo.Resources;component/Resources/Styles/PopupStyles.xaml" />
                <ResourceDictionary Source="/Fluxo.Resources;component/Resources/Styles/MainWindowStyles.xaml" />
                <ResourceDictionary Source="/Fluxo.Resources;component/Resources/Styles/SettingsStyle.xaml" />
                <ResourceDictionary Source="/Fluxo.Resources;component/Resources/Styles/StepNavigatorStyle.xaml" />
                <ResourceDictionary Source="/Fluxo.Resources;component/Resources/Styles/QuickSetupWizardStyle.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>

    <Border Style="{StaticResource PanelStyle}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <controls:RisingFlowBackground Grid.RowSpan="2" AccentBrush="{DynamicResource Color.Mint}" />

            <StackPanel Grid.Row="0" VerticalAlignment="Center">
                <Border
                    Width="72"
                    Height="72"
                    HorizontalAlignment="Center"
                    Background="{StaticResource Brush.Background.Surface}"
                    BorderBrush="{StaticResource Brush.Border.Subtle}"
                    BorderThickness="1"
                    CornerRadius="36">
                    <Image
                        Margin="18"
                        Source="/Fluxo.Resources;component/Resources/fluxo.ico"
                        Stretch="Uniform" />
                </Border>

                <StackPanel HorizontalAlignment="Center" Orientation="Horizontal">
                    <TextBlock
                        FontFamily="{StaticResource Bold}"
                        FontSize="36"
                        Foreground="{StaticResource Brush.Text.Primary}"
                        Text="flux" />
                    <TextBlock
                        FontFamily="{StaticResource Bold}"
                        FontSize="36"
                        Foreground="{StaticResource Brush.Mint}"
                        Text="o" />
                </StackPanel>
                <TextBlock
                    Margin="0,8,0,0"
                    HorizontalAlignment="Center"
                    FontFamily="{StaticResource Medium}"
                    FontSize="14"
                    Foreground="{StaticResource Brush.Text.Secondary}"
                    Text="Your finance, simplified." />
            </StackPanel>

            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="16" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="16" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Margin="0,24,0,0">
                    <Grid VerticalAlignment="Center">
                        <TextBlock
                            Margin="2,14,0,0"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center"
                            FontFamily="{StaticResource Medium}"
                            FontSize="11"
                            Foreground="{StaticResource Brush.Text.Secondary}"
                            Text="{Binding StatusMessage}"
                            TextWrapping="Wrap" />
                        <TextBlock
                            VerticalAlignment="Center"
                            Style="{StaticResource FieldLabelStyle}"
                            Text="Install location" />
                    </Grid>
                    <TextBox Style="{StaticResource RoundedTextInputStyle}" Text="{Binding InstallFolder, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                </StackPanel>

                <customControls:BalloonButton
                    Grid.Column="2"
                    Width="36"
                    Height="{Binding RelativeSource={RelativeSource Self}, Path=Width}"
                    Margin="0,0,0,4"
                    VerticalAlignment="Bottom"
                    ButtonIcon="{DynamicResource DotsHorizontal}"
                    Command="{Binding ChangeDirectoryCommand}"
                    CornerRadius="8"
                    Cursor="Hand"
                    DefaultBackground="{DynamicResource Brush.Mint}"
                    HoveredBackground="{DynamicResource Brush.Mint.Muted}"
                    IconSize="16"
                    ToolTip="Change Directory" />
                <customControls:BalloonButton
                    Grid.Column="4"
                    Width="36"
                    Height="{Binding RelativeSource={RelativeSource Self}, Path=Width}"
                    Margin="0,0,0,4"
                    VerticalAlignment="Bottom"
                    ButtonIcon="{DynamicResource ControllerPlay}"
                    Command="{Binding InstallCommand}"
                    CornerRadius="8"
                    Cursor="Hand"
                    DefaultBackground="{DynamicResource Brush.Mint}"
                    HoveredBackground="{DynamicResource Brush.Mint.Muted}"
                    IconSize="12" />
            </Grid>
        </Grid>
    </Border>
</UserControl>