<UserControl
    x:Class="Fluxo.Installer.Views.Pages.InstallerProgressPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="clr-namespace:Fluxo.Controls;assembly=Fluxo.Resources"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="clr-namespace:Fluxo.Installer.Models"
    d:DesignHeight="560"
    d:DesignWidth="860"
    mc:Ignorable="d">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Fluxo.Resources;component/Resources/Theme.xaml" />
                <ResourceDictionary Source="/Fluxo.Resources;component/Resources/Fonts.xaml" />
                <ResourceDictionary Source="/Fluxo.Resources;component/Resources/Icons.xaml" />
                <ResourceDictionary Source="/Fluxo.Resources;component/Resources/Converters.xaml" />

                <ResourceDictionary Source="/Fluxo.Resources;component/Resources/Styles/ContainerStyles.xaml" />
                <ResourceDictionary Source="/Fluxo.Resources;component/Resources/Styles/ButtonStyles.xaml" />
                <ResourceDictionary Source="/Fluxo.Resources;component/Resources/Styles/TextBoxStyles.xaml" />
                <ResourceDictionary Source="/Fluxo.Resources;component/Resources/Styles/GlobalStyles.xaml" />
                <ResourceDictionary Source="/Fluxo.Resources;component/Resources/Styles/PopupStyles.xaml" />
                <ResourceDictionary Source="/Fluxo.Resources;component/Resources/Styles/MainWindowStyles.xaml" />
                <ResourceDictionary Source="/Fluxo.Resources;component/Resources/Styles/SettingsStyle.xaml" />
                <ResourceDictionary Source="/Fluxo.Resources;component/Resources/Styles/StepNavigatorStyle.xaml" />
                <ResourceDictionary Source="/Fluxo.Resources;component/Resources/Styles/QuickSetupWizardStyle.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <Style x:Key="ChecklistStateStyle" TargetType="TextBlock">
                <Setter Property="FontFamily" Value="{StaticResource Bold}" />
                <Setter Property="FontSize" Value="11" />
                <Setter Property="Foreground" Value="{StaticResource Brush.Text.Muted}" />
                <Style.Triggers>
                    <DataTrigger Binding="{Binding State}" Value="{x:Static models:ChecklistStepState.Running}">
                        <Setter Property="Foreground" Value="{StaticResource Brush.Warning}" />
                    </DataTrigger>
                    <DataTrigger Binding="{Binding State}" Value="{x:Static models:ChecklistStepState.Success}">
                        <Setter Property="Foreground" Value="{StaticResource Brush.Success}" />
                    </DataTrigger>
                    <DataTrigger Binding="{Binding State}" Value="{x:Static models:ChecklistStepState.Failed}">
                        <Setter Property="Foreground" Value="{StaticResource Brush.Danger}" />
                    </DataTrigger>
                </Style.Triggers>
            </Style>
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid>

        <Border Style="{StaticResource PanelStyle}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <TextBlock
                    FontFamily="{StaticResource Bold}"
                    FontSize="24"
                    Foreground="{StaticResource Brush.Text.Primary}"
                    Text="Installing fluxo" />

                <TextBlock
                    Grid.Row="1"
                    Margin="0,8,0,0"
                    FontFamily="{StaticResource Medium}"
                    FontSize="12"
                    Foreground="{StaticResource Brush.Text.Secondary}"
                    Text="{Binding StatusMessage}"
                    TextWrapping="Wrap" />

                <ItemsControl
                    Grid.Row="2"
                    Margin="0,18,0,0"
                    ItemsSource="{Binding ChecklistSteps}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border
                                Margin="0,0,0,10"
                                Padding="14,12"
                                Background="{StaticResource Brush.Background.Surface}"
                                BorderBrush="{StaticResource Brush.Border.Subtle}"
                                BorderThickness="1"
                                CornerRadius="12">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <TextBlock
                                        VerticalAlignment="Center"
                                        FontFamily="{StaticResource Medium}"
                                        FontSize="12"
                                        Foreground="{StaticResource Brush.Text.Primary}"
                                        Text="{Binding Label}" />

                                    <TextBlock
                                        Grid.Column="1"
                                        VerticalAlignment="Center"
                                        Style="{StaticResource ChecklistStateStyle}"
                                        Text="{Binding State}" />
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </Grid>
        </Border>

        <controls:FluxoWave Margin="0,400,0,0" ClipToBounds="True" />
    </Grid>
</UserControl>