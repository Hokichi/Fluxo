<UserControl
    x:Class="Fluxo.Installer.Views.Pages.InstallerFinishedPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="clr-namespace:Fluxo.Controls;assembly=Fluxo.Resources"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="clr-namespace:Fluxo.Installer.Models"
    d:DesignHeight="560"
    d:DesignWidth="860"
    mc:Ignorable="d">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Fluxo.Resources;component/Resources/Theme.xaml" />
                <ResourceDictionary Source="/Fluxo.Resources;component/Resources/Fonts.xaml" />
                <ResourceDictionary Source="/Fluxo.Resources;component/Resources/Icons.xaml" />
                <ResourceDictionary Source="/Fluxo.Resources;component/Resources/Converters.xaml" />

                <ResourceDictionary Source="/Fluxo.Resources;component/Resources/Styles/ContainerStyles.xaml" />
                <ResourceDictionary Source="/Fluxo.Resources;component/Resources/Styles/ButtonStyles.xaml" />
                <ResourceDictionary Source="/Fluxo.Resources;component/Resources/Styles/TextBoxStyles.xaml" />
                <ResourceDictionary Source="/Fluxo.Resources;component/Resources/Styles/GlobalStyles.xaml" />
                <ResourceDictionary Source="/Fluxo.Resources;component/Resources/Styles/PopupStyles.xaml" />
                <ResourceDictionary Source="/Fluxo.Resources;component/Resources/Styles/MainWindowStyles.xaml" />
                <ResourceDictionary Source="/Fluxo.Resources;component/Resources/Styles/SettingsStyle.xaml" />
                <ResourceDictionary Source="/Fluxo.Resources;component/Resources/Styles/StepNavigatorStyle.xaml" />
                <ResourceDictionary Source="/Fluxo.Resources;component/Resources/Styles/QuickSetupWizardStyle.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>

    <Border Style="{StaticResource PanelStyle}">
        <Grid>

            <controls:RisingFlowBackground Grid.RowSpan="2" AccentBrush="{DynamicResource Color.Mint}" />

            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <Border
                    Width="84"
                    Height="84"
                    HorizontalAlignment="Center"
                    Background="{StaticResource Brush.Background.Surface}"
                    BorderBrush="{StaticResource Brush.Border.Subtle}"
                    BorderThickness="1"
                    CornerRadius="42">
                    <Image
                        Margin="20"
                        Source="/Fluxo.Resources;component/Resources/fluxo.ico"
                        Stretch="Uniform" />
                </Border>

                <TextBlock
                    Margin="0,24,0,0"
                    HorizontalAlignment="Center"
                    FontFamily="{StaticResource Bold}"
                    FontSize="30"
                    Foreground="{StaticResource Brush.Text.Primary}"
                    Text="{Binding FinishedTitle}" />

                <TextBlock
                    Margin="0,12,0,0"
                    HorizontalAlignment="Center"
                    FontFamily="{StaticResource Medium}"
                    FontSize="13"
                    Foreground="{StaticResource Brush.Text.Secondary}"
                    Text="{Binding FinishedSubtitle}"
                    TextAlignment="Center" />

                <StackPanel
                    Margin="0,28,0,0"
                    HorizontalAlignment="Center"
                    Orientation="Horizontal">
                    <Button Command="{Binding LaunchAppCommand}">
                        <Button.Style>
                            <Style BasedOn="{StaticResource WizardCircleActionButtonStyle}" TargetType="Button">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding State}" Value="{x:Static models:InstallerState.FinishedSuccess}">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                        <Path
                            Width="14"
                            Height="14"
                            Data="{StaticResource RocketSolid}"
                            Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                            Stretch="Uniform" />
                    </Button>

                    <Button
                        Margin="12,0,0,0"
                        Background="{StaticResource Brush.Background.Hover}"
                        Command="{Binding CloseInstallerCommand}"
                        Foreground="{StaticResource Brush.Text.Primary}"
                        Style="{DynamicResource WizardCircleActionButtonStyle}">
                        <Path
                            Width="14"
                            Height="14"
                            Data="{StaticResource Close}"
                            Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                            Stretch="Uniform" />
                    </Button>
                </StackPanel>

                <TextBlock
                    Margin="0,16,0,0"
                    HorizontalAlignment="Center"
                    FontFamily="{StaticResource Medium}"
                    FontSize="11"
                    Foreground="{StaticResource Brush.Text.Muted}"
                    Text="{Binding StatusMessage}"
                    TextAlignment="Center"
                    TextWrapping="Wrap" />
            </StackPanel>
        </Grid>
    </Border>
</UserControl>