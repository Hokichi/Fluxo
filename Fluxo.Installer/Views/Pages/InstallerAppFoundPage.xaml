<UserControl
    x:Class="Fluxo.Installer.Views.Pages.InstallerAppFoundPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:components="clr-namespace:Fluxo.Resources.Components;assembly=Fluxo.Resources"
    xmlns:customControls="clr-namespace:Fluxo.Resources.CustomControls;assembly=Fluxo.Resources"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="560"
    d:DesignWidth="860"
    mc:Ignorable="d">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Fluxo.Resources;component/Resources/Theme.xaml" />
                <ResourceDictionary Source="/Fluxo.Resources;component/Resources/Fonts.xaml" />
                <ResourceDictionary Source="/Fluxo.Resources;component/Resources/Icons.xaml" />
                <ResourceDictionary Source="/Fluxo.Resources;component/Resources/Converters.xaml" />

                <ResourceDictionary Source="/Fluxo.Resources;component/Resources/Styles/ContainerStyles.xaml" />
                <ResourceDictionary Source="/Fluxo.Resources;component/Resources/Styles/ButtonStyles.xaml" />
                <ResourceDictionary Source="/Fluxo.Resources;component/Resources/Styles/TextBoxStyles.xaml" />
                <ResourceDictionary Source="/Fluxo.Resources;component/Resources/Styles/GlobalStyles.xaml" />
                <ResourceDictionary Source="/Fluxo.Resources;component/Resources/Styles/PopupStyles.xaml" />
                <ResourceDictionary Source="/Fluxo.Resources;component/Resources/Styles/MainWindowStyles.xaml" />
                <ResourceDictionary Source="/Fluxo.Resources;component/Resources/Styles/SettingsStyle.xaml" />
                <ResourceDictionary Source="/Fluxo.Resources;component/Resources/Styles/StepNavigatorStyle.xaml" />
                <ResourceDictionary Source="/Fluxo.Resources;component/Resources/Styles/QuickSetupWizardStyle.xaml" />
            </ResourceDictionary.MergedDictionaries>
            <Style
                x:Key="MaintenanceActionButtonStyle"
                BasedOn="{StaticResource ActionButtonStyle}"
                TargetType="Button">
                <Style.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter Property="Background" Value="{StaticResource Brush.Mint}" />
                        <Setter Property="BorderBrush" Value="{StaticResource Brush.Mint}" />
                        <Setter Property="Foreground" Value="{StaticResource Brush.Background.Hover}" />
                    </Trigger>
                    <Trigger Property="IsPressed" Value="True">
                        <Setter Property="Background" Value="{StaticResource Brush.Mint.Muted}" />
                        <Setter Property="BorderBrush" Value="{StaticResource Brush.Mint.Muted}" />
                        <Setter Property="Foreground" Value="{StaticResource Brush.Background.Deepened}" />
                    </Trigger>
                </Style.Triggers>
            </Style>
        </ResourceDictionary>
    </UserControl.Resources>

    <Border Style="{StaticResource CardBorderStyle}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <components:RisingFlowBackground Grid.RowSpan="2" AccentBrush="{DynamicResource Color.Mint}" />

            <StackPanel Grid.Row="0" VerticalAlignment="Center">
                <Border
                    Width="72"
                    Height="72"
                    HorizontalAlignment="Center"
                    Background="{StaticResource Brush.Background.Surface}"
                    BorderBrush="{StaticResource Brush.Border.Subtle}"
                    BorderThickness="1"
                    CornerRadius="36">
                    <Image
                        Margin="18"
                        Source="/Fluxo.Resources;component/Resources/fluxo.ico"
                        Stretch="Uniform" />
                </Border>

                <TextBlock
                    Margin="0,22,0,0"
                    HorizontalAlignment="Center"
                    FontFamily="{StaticResource Bold}"
                    FontSize="28"
                    Foreground="{StaticResource Brush.Text.Primary}"
                    Text="fluxo" />

                <StackPanel
                    Width="360"
                    Margin="0,28,0,0"
                    HorizontalAlignment="Center">
                    <Button
                        Command="{Binding RepairMaintenanceCommand}"
                        Content="Repair"
                        Style="{StaticResource MaintenanceActionButtonStyle}" />
                    <Button
                        Margin="0,10,0,0"
                        Command="{Binding UninstallMaintenanceCommand}"
                        Content="Uninstall"
                        Style="{StaticResource MaintenanceActionButtonStyle}" />
                </StackPanel>
            </StackPanel>
        </Grid>
    </Border>
</UserControl>