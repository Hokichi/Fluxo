<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:c="clr-namespace:Fluxo.Resources.CustomControls">
    <Style x:Key="CardBorderStyle" TargetType="Border">
        <Setter Property="Padding" Value="16" />
        <Setter Property="Background" Value="{StaticResource Brush.Background.Surface}" />
        <Setter Property="BorderBrush" Value="{StaticResource Brush.Border.Default}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="8" />
    </Style>

    <Style TargetType="{x:Type c:CollapsingCard}">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type c:CollapsingCard}">
                    <Border Style="{StaticResource CardBorderStyle}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <TextBlock
                                    VerticalAlignment="Center"
                                    FontFamily="{StaticResource Bold}"
                                    FontSize="13"
                                    Foreground="{StaticResource Brush.Text.Primary}"
                                    Text="{TemplateBinding HeaderText}" />

                                <ContentPresenter
                                    Grid.Column="1"
                                    VerticalAlignment="Center"
                                    Content="{TemplateBinding SubheaderArea}" />
                            </Grid>

                            <ContentPresenter
                                x:Name="PART_Content"
                                Grid.Row="1"
                                Margin="0,12,0,8"
                                Content="{TemplateBinding Content}" />

                            <ToggleButton
                                x:Name="PART_Toggle"
                                Grid.Row="2"
                                HorizontalAlignment="Center"
                                AutomationProperties.Name="Toggle card content"
                                Background="Transparent"
                                BorderBrush="Transparent"
                                BorderThickness="0"
                                Cursor="Hand"
                                FocusVisualStyle="{x:Null}"
                                IsChecked="{Binding IsExpanded, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}"
                                ToolTip="Toggle card content">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border Padding="8,4" Background="{TemplateBinding Background}" CornerRadius="6">
                                            <Path
                                                x:Name="PART_Icon"
                                                Width="12"
                                                Height="12"
                                                Data="{StaticResource AngleDown}"
                                                Fill="{StaticResource Brush.Text.Muted}"
                                                Stretch="Uniform" />
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsChecked" Value="True">
                                                <Setter TargetName="PART_Icon" Property="Data" Value="{StaticResource AngleUp}" />
                                            </Trigger>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="{StaticResource Brush.Background.Hover}" />
                                                <Setter TargetName="PART_Icon" Property="Fill" Value="{StaticResource Brush.Mint}" />
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>
                        </Grid>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsExpanded" Value="False">
                            <Setter TargetName="PART_Content" Property="Visibility" Value="Collapsed" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="VerticalSeparatorBorderStyle" TargetType="Border">
        <Setter Property="Width" Value="1.5" />
        <Setter Property="Margin" Value="12,0" />
        <Setter Property="Background" Value="{StaticResource Brush.Border.Subtle}" />
    </Style>

    <Style x:Key="HorizontalSeparatorBorderStyle" TargetType="Border">
        <Setter Property="Height" Value="1.5" />
        <Setter Property="Margin" Value="0,12" />
        <Setter Property="Background" Value="{StaticResource Brush.Border.Subtle}" />
    </Style>
</ResourceDictionary>
