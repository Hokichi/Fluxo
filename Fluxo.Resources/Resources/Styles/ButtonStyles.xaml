                            </MultiDataTrigger.Conditions>

                            <Setter TargetName="DayBackground" Property="Background" Value="{StaticResource Brush.Background.Hover}" />
                        </MultiDataTrigger>

                        <DataTrigger Binding="{Binding IsCurrentMonth}" Value="False">
