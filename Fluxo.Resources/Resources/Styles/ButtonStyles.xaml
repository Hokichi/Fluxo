<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:c="clr-namespace:Fluxo.Resources.CustomControls"
    xmlns:components="clr-namespace:Fluxo.Resources.Components">
    <Style TargetType="{x:Type c:BalloonControl}">
        <Setter Property="Background" Value="{Binding DefaultBackground, RelativeSource={RelativeSource Self}}" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Foreground" Value="White" />
        <Setter Property="FocusVisualStyle" Value="{x:Null}" />
        <Setter Property="Width" Value="{Binding RelativeSource={RelativeSource Self}, Path=ButtonSize}" />
        <Setter Property="Height" Value="{Binding RelativeSource={RelativeSource Self}, Path=ButtonSize}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type c:BalloonControl}">
                    <Grid>
                        <!--  Balloon shape  -->
                        <Path x:Name="PART_Shape" Fill="{TemplateBinding DefaultBackground}" />
                        <!--  Pressed overlay shares geometry with PART_Shape via code-behind  -->
                        <Path
                            x:Name="PART_Overlay"
                            Fill="Black"
                            IsHitTestVisible="False"
                            Opacity="0" />
                        <!--  Content area, inset by Padding to clear the bulging edges  -->
                        <Grid
                            x:Name="PART_ContentHost"
                            Margin="{TemplateBinding Padding}"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            ClipToBounds="True">
                            <StackPanel
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Orientation="Horizontal">
                                <Grid
                                    x:Name="PART_IconSlot"
                                    Width="{TemplateBinding IconSize}"
                                    VerticalAlignment="Center">
                                    <Path
                                        x:Name="PART_Icon"
                                        Width="{TemplateBinding IconSize}"
                                        Height="{TemplateBinding IconSize}"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        IsHitTestVisible="False"
                                        Stretch="Uniform">
                                        <Path.Fill>
                                            <MultiBinding Converter="{StaticResource ForegroundForBackgroundBrushConverter}">
                                                <Binding Path="Background" RelativeSource="{RelativeSource TemplatedParent}" />
                                                <Binding Path="Foreground" RelativeSource="{RelativeSource TemplatedParent}" />
                                            </MultiBinding>
                                        </Path.Fill>
                                    </Path>
                                </Grid>
                                <Border
                                    x:Name="PART_TextReveal"
                                    Width="0"
                                    ClipToBounds="True"
                                    Opacity="0">
                                    <TextBlock
                                        x:Name="PART_ButtonText"
                                        Margin="8,0,0,0"
                                        VerticalAlignment="Center"
                                        FontFamily="{StaticResource Bold}"
                                        FontSize="{TemplateBinding FontSize}"
                                        Opacity="0"
                                        Text="{TemplateBinding ButtonText}"
                                        TextTrimming="CharacterEllipsis"
                                        TextWrapping="NoWrap">
                                        <TextBlock.Foreground>
                                            <MultiBinding Converter="{StaticResource ForegroundForBackgroundBrushConverter}">
                                                <Binding Path="Background" RelativeSource="{RelativeSource TemplatedParent}" />
                                                <Binding Path="Foreground" RelativeSource="{RelativeSource TemplatedParent}" />
                                            </MultiBinding>
                                        </TextBlock.Foreground>
                                    </TextBlock>
                                </Border>
                            </StackPanel>
                        </Grid>
                        <Popup
                            x:Name="PART_StatePopup"
                            AllowsTransparency="True"
                            Placement="Bottom"
                            PlacementTarget="{Binding RelativeSource={RelativeSource TemplatedParent}}"
                            StaysOpen="False">
                            <Border Padding="4" Background="Transparent">
                                <ItemsControl ItemsSource="{Binding States, RelativeSource={RelativeSource TemplatedParent}}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <StackPanel />
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <c:BalloonButton
                                                Margin="0,4,0,0"
                                                HorizontalAlignment="Right"
                                                ButtonIcon="{Binding ButtonIcon}"
                                                ButtonSize="40"
                                                ButtonText="{Binding ButtonText}"
                                                CommandParameter="{Binding}"
                                                CornerRadius="12"
                                                DefaultBackground="{Binding DefaultBackground}"
                                                HoveredBackground="{Binding HoverBackground}"
                                                IconSize="12"
                                                ShouldExpand="True"
                                                ShouldShowText="False" />
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </Border>
                        </Popup>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="PART_Overlay" Property="Opacity" Value="0.3" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="{Binding HoveredBackground, RelativeSource={RelativeSource Self}}" />
            </Trigger>
            <Trigger Property="IsEnabled" Value="False">
                <Setter Property="Opacity" Value="0.4" />
                <Setter Property="Cursor" Value="Arrow" />
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style BasedOn="{StaticResource {x:Type c:BalloonControl}}" TargetType="{x:Type c:BalloonButton}" />

    <Style BasedOn="{StaticResource {x:Type c:BalloonControl}}" TargetType="{x:Type c:BalloonToggle}" />

    <Style BasedOn="{StaticResource {x:Type c:BalloonControl}}" TargetType="{x:Type c:BalloonCheckBox}">
        <Setter Property="CheckedBackground" Value="{StaticResource Brush.Mint}" />
        <Style.Triggers>
            <Trigger Property="IsChecked" Value="True">
                <Setter Property="Background" Value="{Binding CheckedBackground, RelativeSource={RelativeSource Self}}" />
            </Trigger>
            <MultiDataTrigger>
                <MultiDataTrigger.Conditions>
                    <Condition Binding="{Binding IsChecked, RelativeSource={RelativeSource Self}}" Value="True" />
                    <Condition Binding="{Binding IsMouseOver, RelativeSource={RelativeSource Self}}" Value="True" />
                </MultiDataTrigger.Conditions>
                <Setter Property="Background" Value="{Binding HoveredBackground, RelativeSource={RelativeSource Self}}" />
            </MultiDataTrigger>
        </Style.Triggers>
    </Style>

    <Style
        x:Key="MainWindowBalloonButtonChromeStyle"
        BasedOn="{StaticResource {x:Type c:BalloonButton}}"
        TargetType="{x:Type c:BalloonButton}">
        <Setter Property="ButtonSize" Value="28" />
        <Setter Property="Margin" Value="8,0,0,0" />
        <Setter Property="CornerRadius" Value="8" />
        <Setter Property="CurveHeight" Value="8" />
    </Style>

    <Style
        x:Key="HeaderCheckBoxStyle"
        BasedOn="{StaticResource {x:Type c:BalloonCheckBox}}"
        TargetType="{x:Type c:BalloonCheckBox}">
        <Setter Property="ButtonSize" Value="28" />
        <Setter Property="Margin" Value="8,0,0,0" />
        <Setter Property="CornerRadius" Value="8" />
        <Setter Property="CurveHeight" Value="8" />
        <Setter Property="DefaultBackground" Value="{StaticResource Brush.Background.Surface}" />
        <Setter Property="IconSize" Value="8" />
    </Style>

    <Style TargetType="{x:Type c:SwipeRevealContainer}">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type c:SwipeRevealContainer}">
                    <Grid ClipToBounds="True">
                        <!--  Left action (revealed on swipe right)  -->
                        <ContentPresenter
                            HorizontalAlignment="Left"
                            VerticalAlignment="Center"
                            Content="{TemplateBinding LeftContent}">
                            <ContentPresenter.Style>
                                <Style TargetType="ContentPresenter">
                                    <Setter Property="Opacity" Value="0" />
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsLeftContentRevealed, RelativeSource={RelativeSource TemplatedParent}}" Value="True">
                                            <Setter Property="Visibility" Value="Visible" />
                                            <Setter Property="Opacity" Value="1" />
                                            <DataTrigger.EnterActions>
                                                <BeginStoryboard>
                                                    <Storyboard>
                                                        <DoubleAnimation
                                                            Storyboard.TargetProperty="Opacity"
                                                            From="0"
                                                            To="1"
                                                            Duration="0:0:0.16" />
                                                    </Storyboard>
                                                </BeginStoryboard>
                                            </DataTrigger.EnterActions>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </ContentPresenter.Style>
                        </ContentPresenter>

                        <!--  Right action (revealed on swipe left)  -->
                        <ContentPresenter
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center"
                            Content="{TemplateBinding RightContent}">
                            <ContentPresenter.Style>
                                <Style TargetType="ContentPresenter">
                                    <Setter Property="Opacity" Value="0" />
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsRightContentRevealed, RelativeSource={RelativeSource TemplatedParent}}" Value="True">
                                            <Setter Property="Visibility" Value="Visible" />
                                            <Setter Property="Opacity" Value="1" />
                                            <DataTrigger.EnterActions>
                                                <BeginStoryboard>
                                                    <Storyboard>
                                                        <DoubleAnimation
                                                            Storyboard.TargetProperty="Opacity"
                                                            From="0"
                                                            To="1"
                                                            Duration="0:0:0.16" />
                                                    </Storyboard>
                                                </BeginStoryboard>
                                            </DataTrigger.EnterActions>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </ContentPresenter.Style>
                        </ContentPresenter>

                        <!--  Main slideable content  -->
                        <Border x:Name="PART_ContentBorder" Background="Transparent">
                            <ContentPresenter Content="{TemplateBinding Content}" />
                        </Border>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="PopupTextButtonStyle" TargetType="Button">
        <Setter Property="Height" Value="40" />
        <Setter Property="Padding" Value="14,0" />
        <Setter Property="Background" Value="{StaticResource Brush.Background.Elevated}" />
        <Setter Property="BorderBrush" Value="{StaticResource Brush.Border.Subtle}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="FocusVisualStyle" Value="{x:Null}" />
        <Setter Property="FontFamily" Value="{StaticResource Bold}" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="Foreground" Value="{StaticResource Brush.Text.Primary}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border
                        x:Name="RootBorder"
                        Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}"
                        CornerRadius="12">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="RootBorder" Property="Background" Value="{StaticResource Brush.Background.Hover}" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="RootBorder" Property="Opacity" Value="0.4" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="TabButtonStyle" TargetType="RadioButton">
        <Setter Property="Margin" Value="0,0,0,8" />
        <Setter Property="Height" Value="42" />
        <Setter Property="Foreground" Value="{StaticResource Brush.Text.Muted}" />
        <Setter Property="FontFamily" Value="{StaticResource Bold}" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="RadioButton">
                    <Border x:Name="RootBorder" CornerRadius="8">
                        <Grid Background="Transparent">
                            <Border
                                x:Name="SelectedStrip"
                                Width="4"
                                Margin="0,8"
                                HorizontalAlignment="Left"
                                Background="{StaticResource Brush.Mint}"
                                CornerRadius="0 4 4 0"
                                Visibility="Collapsed" />
                            <StackPanel
                                Margin="16,0,12,0"
                                VerticalAlignment="Center"
                                Orientation="Horizontal">
                                <ContentPresenter />
                                <TextBlock
                                    Margin="12,0,0,0"
                                    VerticalAlignment="Center"
                                    FontFamily="{TemplateBinding FontFamily}"
                                    FontSize="{TemplateBinding FontSize}"
                                    Foreground="{TemplateBinding Foreground}"
                                    Text="{TemplateBinding Tag}" />
                            </StackPanel>
                        </Grid>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Foreground" Value="{StaticResource Brush.Text.Primary}" />
                            <Setter TargetName="RootBorder" Property="Background" Value="{StaticResource Brush.Background.Hover}" />
                        </Trigger>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter Property="Foreground" Value="{StaticResource Brush.Text.Primary}" />
                            <Setter TargetName="RootBorder" Property="Background" Value="{StaticResource Brush.Background.Hover}" />
                            <Setter TargetName="SelectedStrip" Property="Visibility" Value="Visible" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style
        x:Key="StepperButtonStyle"
        BasedOn="{StaticResource {x:Type c:BalloonButton}}"
        TargetType="c:BalloonButton">
        <Setter Property="ButtonSize" Value="24" />
        <Setter Property="IconSize" Value="8" />
        <Setter Property="CornerRadius" Value="8" />
        <Setter Property="DefaultBackground" Value="{StaticResource Brush.Background.Deepened}" />
    </Style>

    <Style
        x:Key="ToolbarActionBalloonButtonStyle"
        BasedOn="{StaticResource MainWindowBalloonButtonChromeStyle}"
        TargetType="{x:Type c:BalloonButton}">
        <Setter Property="IconSize" Value="10" />
        <Setter Property="DefaultBackground" Value="{StaticResource Brush.Background.Surface}" />
        <Setter Property="HoveredBackground" Value="{StaticResource Brush.Background.Hover}" />
    </Style>

    <Style x:Key="TagDeleteButtonStyle" TargetType="Button">
        <Setter Property="Margin" Value="0,0,8,8" />
        <Setter Property="Padding" Value="12,7" />
        <Setter Property="Background" Value="{StaticResource Brush.Background.Surface}" />
        <Setter Property="BorderBrush" Value="{StaticResource Brush.Border.Subtle}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="IsHitTestVisible" Value="{Binding IsSystemTag}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border
                        x:Name="TagBorder"
                        Padding="{TemplateBinding Padding}"
                        Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}">
                        <Border.CornerRadius>
                            <MultiBinding Converter="{StaticResource CornerRadiusConverter}">
                                <Binding Path="ActualWidth" RelativeSource="{RelativeSource Self}" />
                                <Binding Path="ActualHeight" RelativeSource="{RelativeSource Self}" />
                            </MultiBinding>
                        </Border.CornerRadius>
                        <StackPanel Orientation="Horizontal">
                            <Grid Width="10" Height="10">
                                <Ellipse Fill="{Binding HexCode}" />
                                <components:Icon
                                    x:Name="DotCloseIcon"
                                    Margin="2"
                                    Opacity="0"
                                    Path="{StaticResource Close}"
                                    Color="{StaticResource Brush.Background.Surface}" />
                            </Grid>
                            <TextBlock
                                Margin="8,0,0,0"
                                FontFamily="{StaticResource Bold}"
                                Foreground="{StaticResource Brush.Text.Primary}"
                                Text="{Binding Name}" />
                        </StackPanel>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="TagBorder" Property="Background" Value="{StaticResource Brush.Background.Hover}" />
                            <Setter TargetName="DotCloseIcon" Property="Opacity" Value="1" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="ToggleSwitchStyle" TargetType="ToggleButton">
        <Setter Property="Width" Value="40" />
        <Setter Property="Height" Value="20" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ToggleButton">
                    <Border
                        x:Name="Track"
                        Background="{StaticResource Brush.Background.Deepened}"
                        BorderBrush="{StaticResource Brush.Border.Subtle}"
                        BorderThickness="1"
                        CornerRadius="10">
                        <Ellipse
                            x:Name="Thumb"
                            Width="8"
                            Height="8"
                            Margin="4"
                            HorizontalAlignment="Left"
                            Fill="{StaticResource Brush.Text.Primary}">
                            <Ellipse.RenderTransform>
                                <TranslateTransform x:Name="ThumbTransform" X="0" />
                            </Ellipse.RenderTransform>
                        </Ellipse>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="Track" Property="Background" Value="{StaticResource Brush.Mint}" />
                            <Setter TargetName="Thumb" Property="Fill" Value="{StaticResource Brush.Background.Surface}" />
                            <Trigger.EnterActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation
                                            Storyboard.TargetName="ThumbTransform"
                                            Storyboard.TargetProperty="X"
                                            To="22"
                                            Duration="0:0:0.14" />
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.EnterActions>
                            <Trigger.ExitActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation
                                            Storyboard.TargetName="ThumbTransform"
                                            Storyboard.TargetProperty="X"
                                            To="0"
                                            Duration="0:0:0.14" />
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.ExitActions>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="AddTileButtonStyle" TargetType="Button">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderBrush" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="FocusVisualStyle" Value="{x:Null}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border
                        Height="80"
                        Background="{StaticResource Brush.Background.Surface}"
                        BorderBrush="{StaticResource Brush.Border.Subtle}"
                        BorderThickness="1"
                        CornerRadius="16">
                        <Grid>
                            <Rectangle
                                RadiusX="16"
                                RadiusY="16"
                                Stroke="{StaticResource Brush.Text.Muted}"
                                StrokeDashArray="6,4"
                                StrokeThickness="1" />
                            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                <components:Icon
                                    x:Name="AddIcon"
                                    Width="24"
                                    Height="24"
                                    Path="{StaticResource PlusSolid}"
                                    Color="{StaticResource Brush.Text.Muted}" />
                                <TextBlock
                                    x:Name="AddLabel"
                                    Margin="0,10,0,0"
                                    HorizontalAlignment="Center"
                                    FontFamily="{StaticResource Bold}"
                                    Foreground="{StaticResource Brush.Text.Secondary}"
                                    Text="Add" />
                            </StackPanel>
                        </Grid>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="AddIcon" Property="Color" Value="{StaticResource Brush.Text.Primary}" />
                            <Setter TargetName="AddLabel" Property="Foreground" Value="{StaticResource Brush.Text.Primary}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="ActionButtonStyle" TargetType="Button">
        <Setter Property="Height" Value="40" />
        <Setter Property="MinWidth" Value="120" />
        <Setter Property="Padding" Value="18,0" />
        <Setter Property="Background" Value="{StaticResource Brush.Background.Surface}" />
        <Setter Property="BorderBrush" Value="{StaticResource Brush.Border.Subtle}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="FontFamily" Value="{StaticResource Bold}" />
        <Setter Property="Foreground" Value="{StaticResource Brush.Text.Primary}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border
                        Padding="{TemplateBinding Padding}"
                        Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}"
                        CornerRadius="12">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style
        x:Key="CardActionButtonStyle"
        BasedOn="{StaticResource MainWindowBalloonButtonChromeStyle}"
        TargetType="c:BalloonButton">
        <Setter Property="IconSize" Value="8" />
    </Style>

    <Style
        x:Key="EditButton"
        BasedOn="{StaticResource CardActionButtonStyle}"
        TargetType="c:BalloonButton">
        <Setter Property="ButtonIcon" Value="{StaticResource Pen}" />
        <Setter Property="Tag" Value="{Binding Id}" />
        <Setter Property="HoveredBackground" Value="{StaticResource Brush.Mint}" />
        <Setter Property="DefaultBackground" Value="{StaticResource Brush.Background.Main}" />
    </Style>

    <Style
        x:Key="DeleteButton"
        BasedOn="{StaticResource CardActionButtonStyle}"
        TargetType="c:BalloonButton">
        <Setter Property="ButtonIcon" Value="{StaticResource Close}" />
        <Setter Property="Tag" Value="{Binding Id}" />
        <Setter Property="HoveredBackground" Value="{StaticResource Brush.Danger}" />
        <Setter Property="DefaultBackground" Value="{StaticResource Brush.Background.Main}" />
    </Style>

    <Style x:Key="SelectorButtonStyle" TargetType="ToggleButton">
        <Setter Property="Background" Value="{StaticResource Brush.Background.Elevated}" />
        <Setter Property="BorderBrush" Value="{StaticResource Brush.Border.Subtle}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Height" Value="40" />
        <Setter Property="FocusVisualStyle" Value="{x:Null}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ToggleButton">
                    <Border
                        x:Name="SelectorBorder"
                        Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}"
                        CornerRadius="8">
                        <Grid Margin="10,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <TextBlock
                                VerticalAlignment="Center"
                                FontFamily="{StaticResource Medium}"
                                FontSize="13"
                                Foreground="{StaticResource Brush.Text.Primary}"
                                Text="{Binding FormattedSelectedDate, ElementName=Root}" />

                            <Path
                                Grid.Column="1"
                                Width="14"
                                Height="14"
                                Margin="12,0,0,0"
                                VerticalAlignment="Center"
                                Data="{StaticResource Calendar}"
                                Fill="{StaticResource Brush.Text.Muted}"
                                Stretch="Uniform" />
                        </Grid>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsKeyboardFocused" Value="True">
                            <Setter TargetName="SelectorBorder" Property="BorderBrush" Value="{StaticResource Brush.Mint}" />
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="{StaticResource Brush.Background.Hover}" />
                        </Trigger>
                        <Trigger Property="Tag" Value="True">
                            <Setter TargetName="SelectorBorder" Property="BorderBrush" Value="{StaticResource Brush.Danger}" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="SelectorBorder" Property="Opacity" Value="0.4" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="CalendarNavButtonStyle" TargetType="Button">
        <Setter Property="Width" Value="28" />
        <Setter Property="Height" Value="28" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderBrush" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="FocusVisualStyle" Value="{x:Null}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border
                        x:Name="ButtonBackground"
                        Background="{TemplateBinding Background}"
                        CornerRadius="10">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="ButtonBackground" Property="Background" Value="{StaticResource Brush.Background.Hover}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="HeaderActionButtonStyle" TargetType="Button">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderBrush" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="FocusVisualStyle" Value="{x:Null}" />
        <Setter Property="Foreground" Value="{StaticResource Brush.Text.Primary}" />
        <Setter Property="FontFamily" Value="{StaticResource Bold}" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="Padding" Value="8,4" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border
                        x:Name="HeaderButtonBackground"
                        Background="{TemplateBinding Background}"
                        CornerRadius="10">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="HeaderButtonBackground" Property="Background" Value="{StaticResource Brush.Background.Hover}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="CalendarDayButtonStyle" TargetType="Button">
        <Setter Property="Width" Value="34" />
        <Setter Property="Height" Value="34" />
        <Setter Property="Margin" Value="2" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="Background" Value="Transparent" />
