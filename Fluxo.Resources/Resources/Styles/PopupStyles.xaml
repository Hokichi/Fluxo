<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:c="clr-namespace:Fluxo.Resources.CustomControls">

    <BooleanToVisibilityConverter x:Key="PopupBoolToVisibility" />

    <Style TargetType="{x:Type c:BasePopup}">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type c:BasePopup}">
                    <Border Background="{StaticResource Brush.Background.Popup}" CornerRadius="16">
                        <Grid x:Name="PART_ContentRoot">
                            <Grid.RowDefinitions>
                                <RowDefinition x:Name="HeaderRow" Height="60" />
                                <RowDefinition Height="1" />
                                <RowDefinition Height="*" />
                                <RowDefinition Height="1" />
                                <RowDefinition x:Name="FooterRow" Height="Auto" />
                            </Grid.RowDefinitions>

                            <Grid x:Name="HeaderHost" Margin="24,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <Grid VerticalAlignment="Center">
                                    <TextBlock
                                        x:Name="PopupTitleText"
                                        VerticalAlignment="Center"
                                        FontFamily="{StaticResource Bold}"
                                        FontSize="18"
                                        Foreground="{StaticResource Brush.Text.Primary}"
                                        Text="{TemplateBinding PopupTitle}"
                                        Visibility="Collapsed" />
                                    <ContentPresenter
                                        x:Name="PopupTitleContentPresenter"
                                        VerticalAlignment="Center"
                                        Content="{TemplateBinding PopupTitleContent}" />
                                </Grid>

                                <c:BalloonButton
                                    x:Name="PART_CloseButton"
                                    Grid.Column="1"
                                    ButtonIcon="{StaticResource Close}"
                                    ButtonText="Close"
                                    DefaultBackground="{StaticResource Brush.BalloonButton.Background.Destructive}"
                                    HoveredBackground="{StaticResource Brush.BalloonButton.Background.Destructive.Hovered}"
                                    ShouldExpand="True"
                                    Style="{StaticResource HeaderButtonStyle}"
                                    SubText="Esc"
                                    Visibility="{TemplateBinding ShowCloseButton,
                                                                 Converter={StaticResource PopupBoolToVisibility}}" />
                            </Grid>

                            <Border
                                x:Name="TopContentSeparator"
                                Grid.Row="1"
                                Background="{StaticResource Brush.Border.Subtle}" />

                            <ContentPresenter Grid.Row="2" Margin="0,16" />

                            <Border
                                x:Name="BottomContentSeparator"
                                Grid.Row="3"
                                Background="{StaticResource Brush.Border.Subtle}" />

                            <Grid
                                x:Name="FooterHost"
                                Grid.Row="4"
                                Margin="24,12"
                                Visibility="Collapsed">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <c:BalloonButton
                                    x:Name="PART_BackButton"
                                    ButtonIcon="{StaticResource AngleLeft}"
                                    ButtonText="Back"
                                    DefaultBackground="{StaticResource Brush.BalloonButton.Background.Surface}"
                                    HoveredBackground="{StaticResource Brush.BalloonButton.Background.Surface.Hovered}"
                                    ShouldShowText="True"
                                    Style="{StaticResource HeaderButtonStyle}"
                                    SubText="Backspace"
                                    Visibility="Collapsed" />

                                <StackPanel
                                    x:Name="ApplyCancelActions"
                                    Grid.Column="2"
                                    Orientation="Horizontal"
                                    Visibility="Collapsed">
                                    <c:BalloonButton
                                        x:Name="PART_ProceedButton"
                                        ButtonIcon="{StaticResource Check}"
                                        ButtonText="Proceed"
                                        DefaultBackground="{StaticResource Brush.BalloonButton.Background.ConfirmSave}"
                                        HoveredBackground="{StaticResource Brush.BalloonButton.Background.ConfirmSave.Hovered}"
                                        ShouldShowText="True"
                                        Style="{StaticResource HeaderButtonStyle}"
                                        SubText="Enter" />
                                    <c:BalloonButton
                                        x:Name="PART_CancelButton"
                                        Margin="8,0,0,0"
                                        ButtonIcon="{StaticResource Ban}"
                                        ButtonText="Cancel"
                                        DefaultBackground="{StaticResource Brush.BalloonButton.Background.Surface}"
                                        HoveredBackground="{StaticResource Brush.BalloonButton.Background.Surface.Hovered}"
                                        ShouldShowText="True"
                                        Style="{StaticResource HeaderButtonStyle}"
                                        SubText="Esc" />
                                </StackPanel>

                                <StackPanel
                                    x:Name="SaveDiscardActions"
                                    Grid.Column="2"
                                    Orientation="Horizontal"
                                    Visibility="Collapsed">
                                    <c:BalloonButton
                                        x:Name="PART_SaveButton"
                                        ButtonIcon="{StaticResource ContentSave}"
                                        ButtonText="Save"
                                        DefaultBackground="{StaticResource Brush.BalloonButton.Background.Default}"
                                        HoveredBackground="{StaticResource Brush.BalloonButton.Background.Default.Hovered}"
                                        IsEnabled="{TemplateBinding IsSaveButtonEnabled}"
                                        ShouldShowText="True"
                                        Style="{StaticResource HeaderButtonStyle}"
                                        SubText="Enter" />
                                    <c:BalloonButton
                                        x:Name="PART_SaveAndCreateNewButton"
                                        Margin="8,0,0,0"
                                        ButtonIcon="{StaticResource ContentSaveMove}"
                                        ButtonText="Save &amp; New"
                                        DefaultBackground="{StaticResource Brush.BalloonButton.Background.ConfirmSave}"
                                        HoveredBackground="{StaticResource Brush.BalloonButton.Background.ConfirmSave.Hovered}"
                                        IsEnabled="{TemplateBinding IsSaveAndCreateNewButtonEnabled}"
                                        ShouldShowText="True"
                                        Style="{StaticResource HeaderButtonStyle}"
                                        SubText="Shift+Enter"
                                        Visibility="{TemplateBinding CanContinue,
                                                                     Converter={StaticResource PopupBoolToVisibility}}" />
                                    <c:BalloonButton
                                        x:Name="PART_DiscardButton"
                                        Margin="8,0,0,0"
                                        ButtonIcon="{StaticResource Ban}"
                                        ButtonText="Discard"
                                        DefaultBackground="{StaticResource Brush.BalloonButton.Background.Destructive}"
                                        HoveredBackground="{StaticResource Brush.BalloonButton.Background.Destructive.Hovered}"
                                        ShouldShowText="True"
                                        Style="{StaticResource HeaderButtonStyle}"
                                        SubText="Esc" />
                                </StackPanel>

                                <StackPanel
                                    x:Name="BackNextActions"
                                    Grid.Column="2"
                                    Orientation="Horizontal"
                                    Visibility="Collapsed">
                                    <c:BalloonButton
                                        x:Name="PART_NextButton"
                                        ButtonIcon="{StaticResource AngleRight}"
                                        ButtonText="Next"
                                        DefaultBackground="{StaticResource Brush.BalloonButton.Background.Default}"
                                        HoveredBackground="{StaticResource Brush.BalloonButton.Background.Default.Hovered}"
                                        ShouldShowText="True"
                                        Style="{StaticResource HeaderButtonStyle}"
                                        SubText="Enter" />
                                    <c:BalloonButton
                                        x:Name="PART_FinishButton"
                                        ButtonIcon="{StaticResource Check}"
                                        ButtonText="Finish"
                                        DefaultBackground="{StaticResource Brush.BalloonButton.Background.ConfirmSave}"
                                        HoveredBackground="{StaticResource Brush.BalloonButton.Background.ConfirmSave.Hovered}"
                                        ShouldShowText="True"
                                        Style="{StaticResource HeaderButtonStyle}"
                                        SubText="Enter"
                                        Visibility="Collapsed" />
                                </StackPanel>

                                <StackPanel
                                    x:Name="FunctionalActions"
                                    Grid.Column="2"
                                    Orientation="Horizontal"
                                    Visibility="Collapsed">
                                    <c:BalloonButton
                                        x:Name="PART_EditButton"
                                        ButtonIcon="{StaticResource Pen}"
                                        ButtonText="Edit"
                                        DefaultBackground="{StaticResource Brush.BalloonButton.Background.Surface}"
                                        HoveredBackground="{StaticResource Brush.BalloonButton.Background.Surface.Hovered}"
                                        ShouldShowText="True"
                                        Style="{StaticResource HeaderButtonStyle}"
                                        Visibility="{TemplateBinding CanEdit,
                                                                     Converter={StaticResource PopupBoolToVisibility}}" />
                                    <c:BalloonButton
                                        x:Name="PART_DeleteButton"
                                        Margin="8,0,0,0"
                                        ButtonIcon="{StaticResource Delete}"
                                        ButtonText="Delete"
                                        DefaultBackground="{StaticResource Brush.BalloonButton.Background.Destructive}"
                                        HoveredBackground="{StaticResource Brush.BalloonButton.Background.Destructive.Hovered}"
                                        ShouldShowText="True"
                                        Style="{StaticResource HeaderButtonStyle}"
                                        Visibility="{TemplateBinding CanDelete,
                                                                     Converter={StaticResource PopupBoolToVisibility}}" />
                                    <c:BalloonButton
                                        x:Name="PART_CloneButton"
                                        Margin="8,0,0,0"
                                        ButtonIcon="{StaticResource CloneRegular}"
                                        ButtonText="Clone"
                                        DefaultBackground="{StaticResource Brush.BalloonButton.Background.Surface}"
                                        HoveredBackground="{StaticResource Brush.BalloonButton.Background.Surface.Hovered}"
                                        ShouldShowText="True"
                                        Style="{StaticResource HeaderButtonStyle}"
                                        Visibility="{TemplateBinding CanClone,
                                                                     Converter={StaticResource PopupBoolToVisibility}}" />
                                    <c:BalloonButton
                                        x:Name="PART_SplitButton"
                                        Margin="8,0,0,0"
                                        ButtonIcon="{StaticResource ArrowsOutLineVertical}"
                                        ButtonText="Split"
                                        DefaultBackground="{StaticResource Brush.BalloonButton.Background.ConfirmSave}"
                                        HoveredBackground="{StaticResource Brush.BalloonButton.Background.ConfirmSave.Hovered}"
                                        ShouldShowText="True"
                                        Style="{StaticResource HeaderButtonStyle}"
                                        Visibility="{TemplateBinding CanSplit,
                                                                     Converter={StaticResource PopupBoolToVisibility}}" />
                                </StackPanel>
                            </Grid>

                            <Rectangle
                                x:Name="PART_PopupOverlay"
                                Grid.RowSpan="5"
                                Fill="#80000000"
                                Opacity="0"
                                Visibility="Collapsed" />
                        </Grid>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="ShowHeader" Value="False">
                            <Setter TargetName="HeaderRow" Property="Height" Value="0" />
                            <Setter TargetName="HeaderHost" Property="Visibility" Value="Collapsed" />
                            <Setter TargetName="TopContentSeparator" Property="Visibility" Value="Collapsed" />
                        </Trigger>
                        <Trigger Property="PopupTitleContent" Value="{x:Null}">
                            <Setter TargetName="PopupTitleText" Property="Visibility" Value="Visible" />
                            <Setter TargetName="PopupTitleContentPresenter" Property="Visibility" Value="Collapsed" />
                        </Trigger>
                        <Trigger Property="Mode" Value="{x:Static c:PopupMode.ApplyCancel}">
                            <Setter TargetName="FooterHost" Property="Visibility" Value="Visible" />
                            <Setter TargetName="ApplyCancelActions" Property="Visibility" Value="Visible" />
                        </Trigger>
                        <Trigger Property="Mode" Value="{x:Static c:PopupMode.SaveDiscard}">
                            <Setter TargetName="FooterHost" Property="Visibility" Value="Visible" />
                            <Setter TargetName="SaveDiscardActions" Property="Visibility" Value="Visible" />
                        </Trigger>
                        <Trigger Property="Mode" Value="{x:Static c:PopupMode.BackNext}">
                            <Setter TargetName="FooterHost" Property="Visibility" Value="Visible" />
                            <Setter TargetName="BackNextActions" Property="Visibility" Value="Visible" />
                            <Setter TargetName="PART_BackButton" Property="Visibility" Value="Visible" />
                        </Trigger>
                        <Trigger Property="Mode" Value="{x:Static c:PopupMode.Functional}">
                            <Setter TargetName="FooterHost" Property="Visibility" Value="Visible" />
                            <Setter TargetName="FunctionalActions" Property="Visibility" Value="Visible" />
                        </Trigger>
                        <Trigger Property="IsFirstStep" Value="True">
                            <Setter TargetName="PART_BackButton" Property="Visibility" Value="Collapsed" />
                        </Trigger>
                        <Trigger Property="IsLastStep" Value="True">
                            <Setter TargetName="PART_NextButton" Property="Visibility" Value="Collapsed" />
                            <Setter TargetName="PART_FinishButton" Property="Visibility" Value="Visible" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
</ResourceDictionary>
