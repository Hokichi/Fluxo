<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:components="clr-namespace:Fluxo.Resources.Components">
    <Style
        x:Key="RowCardStyle"
        BasedOn="{StaticResource CardBorderStyle}"
        TargetType="Border">
        <Setter Property="Margin" Value="0,0,0,10" />
    </Style>

    <Style x:Key="ItemCheckBoxStyle" TargetType="CheckBox">
        <Setter Property="Width" Value="20" />
        <Setter Property="Height" Value="20" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="CheckBox">
                    <Border
                        x:Name="CheckSurface"
                        Width="20"
                        Height="20"
                        Padding="4"
                        CornerRadius="10">
                        <components:Icon
                            x:Name="CheckGlyph"
                            Path="{StaticResource CheckboxBlankOutline}"
                            Color="{StaticResource Brush.Text.Muted}" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="CheckSurface" Property="Background" Value="{StaticResource Brush.Background.Hover}" />
                        </Trigger>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="CheckSurface" Property="BorderBrush" Value="{StaticResource Brush.Mint}" />
                            <Setter TargetName="CheckGlyph" Property="Path" Value="{StaticResource EnableChecks}" />
                            <Setter TargetName="CheckGlyph" Property="Color" Value="{StaticResource Brush.Mint}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="ItemCheckBoxWithContentStyle" TargetType="CheckBox">
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Foreground" Value="{StaticResource Brush.Text.Primary}" />
        <Setter Property="FontFamily" Value="{StaticResource Medium}" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="CheckBox">
                    <StackPanel x:Name="Root" Orientation="Horizontal">
                        <Border
                            x:Name="CheckSurface"
                            Width="20"
                            Height="20"
                            CornerRadius="10">
                            <components:Icon
                                x:Name="CheckGlyph"
                                Margin="2,2,4,4"
                                Path="{StaticResource CheckboxBlankOutline}"
                                Color="{StaticResource Brush.Text.Muted}" />
                        </Border>

                        <ContentPresenter
                            Margin="4,0,0,0"
                            VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                            TextElement.FontFamily="{TemplateBinding FontFamily}"
                            TextElement.FontSize="{TemplateBinding FontSize}"
                            TextElement.Foreground="{TemplateBinding Foreground}" />
                    </StackPanel>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="CheckSurface" Property="Background" Value="{StaticResource Brush.Background.Hover}" />
                        </Trigger>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="CheckSurface" Property="Background" Value="{StaticResource Brush.Background.Hover}" />
                            <Setter TargetName="CheckSurface" Property="BorderBrush" Value="{StaticResource Brush.Mint}" />
                            <Setter TargetName="CheckGlyph" Property="Path" Value="{StaticResource EnableChecks}" />
                            <Setter TargetName="CheckGlyph" Property="Color" Value="{StaticResource Brush.Mint}" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="Root" Property="Opacity" Value="0.4" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="StateIconBadgeStyle" TargetType="Border">
        <Setter Property="Width" Value="22" />
        <Setter Property="Height" Value="22" />
        <Setter Property="Margin" Value="8,0,0,0" />
        <Setter Property="CornerRadius" Value="11" />
        <Setter Property="Background" Value="{StaticResource Brush.Background.Surface}" />
        <Setter Property="BorderBrush" Value="{StaticResource Brush.Border.Subtle}" />
        <Setter Property="BorderThickness" Value="1" />
    </Style>
</ResourceDictionary>
