<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!--  =============================  -->
    <!--  BACKGROUND ELEVATION  -->
    <!--  =============================  -->

    <Color x:Key="Color.Background.Main">#0D1014</Color>
    <Color x:Key="Color.Background.Deepened">#13171C</Color>
    <Color x:Key="Color.Background.Surface">#1A1D22</Color>
    <Color x:Key="Color.Background.Popup">#181B20</Color>
    <Color x:Key="Color.Background.Elevated">#252B33</Color>
    <Color x:Key="Color.Background.Hover">#2D3440</Color>

    <SolidColorBrush x:Key="Brush.Background.Main" Color="{StaticResource Color.Background.Main}" />
    <SolidColorBrush x:Key="Brush.Background.Deepened" Color="{StaticResource Color.Background.Deepened}" />
    <SolidColorBrush x:Key="Brush.Background.Surface" Color="{StaticResource Color.Background.Surface}" />
    <SolidColorBrush x:Key="Brush.Background.Popup" Color="{StaticResource Color.Background.Popup}" />
    <SolidColorBrush x:Key="Brush.Background.Elevated" Color="{StaticResource Color.Background.Elevated}" />
    <SolidColorBrush x:Key="Brush.Background.Hover" Color="{StaticResource Color.Background.Hover}" />

    <!--  =============================  -->
    <!--  BALLOON BUTTON BACKGROUND  -->
    <!--  =============================  -->

    <Color x:Key="Color.BalloonButton.Background.Default">#0B1F3B</Color>
    <Color x:Key="Color.BalloonButton.Background.Default.Hovered">#102748</Color>

    <Color x:Key="Color.BalloonButton.Background.ConfirmSave">#182218</Color>
    <Color x:Key="Color.BalloonButton.Background.ConfirmSave.Hovered">#1E2E1E</Color>

    <Color x:Key="Color.BalloonButton.Background.Destructive">#221818</Color>
    <Color x:Key="Color.BalloonButton.Background.Destructive.Hovered">#2E1E1E</Color>

    <Color x:Key="Color.BalloonButton.Background.Caution">#262018</Color>
    <Color x:Key="Color.BalloonButton.Background.Caution.Hovered">#302818</Color>

    <Color x:Key="Color.BalloonButton.Background.NavInfo">#181E28</Color>
    <Color x:Key="Color.BalloonButton.Background.NavInfo.Hovered">#1E2535</Color>

    <Color x:Key="Color.BalloonButton.Background.Surface">#1A1D21</Color>
    <Color x:Key="Color.BalloonButton.Background.Surface.Hovered">#252B33</Color>

    <Color x:Key="Color.BalloonButton.Background.Neutral.Hovered">#1A1D21</Color>

    <SolidColorBrush x:Key="Brush.BalloonButton.Background.Default" Color="{StaticResource Color.BalloonButton.Background.Default}" />
    <SolidColorBrush x:Key="Brush.BalloonButton.Background.Default.Hovered" Color="{StaticResource Color.BalloonButton.Background.Default.Hovered}" />

    <SolidColorBrush x:Key="Brush.BalloonButton.Background.ConfirmSave" Color="{StaticResource Color.BalloonButton.Background.ConfirmSave}" />
    <SolidColorBrush x:Key="Brush.BalloonButton.Background.ConfirmSave.Hovered" Color="{StaticResource Color.BalloonButton.Background.ConfirmSave.Hovered}" />

    <SolidColorBrush x:Key="Brush.BalloonButton.Background.Destructive" Color="{StaticResource Color.BalloonButton.Background.Destructive}" />
    <SolidColorBrush x:Key="Brush.BalloonButton.Background.Destructive.Hovered" Color="{StaticResource Color.BalloonButton.Background.Destructive.Hovered}" />

    <SolidColorBrush x:Key="Brush.BalloonButton.Background.Caution" Color="{StaticResource Color.BalloonButton.Background.Caution}" />
    <SolidColorBrush x:Key="Brush.BalloonButton.Background.Caution.Hovered" Color="{StaticResource Color.BalloonButton.Background.Caution.Hovered}" />

    <SolidColorBrush x:Key="Brush.BalloonButton.Background.NavInfo" Color="{StaticResource Color.BalloonButton.Background.NavInfo}" />
    <SolidColorBrush x:Key="Brush.BalloonButton.Background.NavInfo.Hovered" Color="{StaticResource Color.BalloonButton.Background.NavInfo.Hovered}" />

    <SolidColorBrush x:Key="Brush.BalloonButton.Background.Surface" Color="{StaticResource Color.BalloonButton.Background.Surface}" />
    <SolidColorBrush x:Key="Brush.BalloonButton.Background.Surface.Hovered" Color="{StaticResource Color.BalloonButton.Background.Surface.Hovered}" />

    <SolidColorBrush x:Key="Brush.BalloonButton.Background.Neutral" Color="Transparent" />
    <SolidColorBrush x:Key="Brush.BalloonButton.Background.Neutral.Hovered" Color="{StaticResource Color.BalloonButton.Background.Neutral.Hovered}" />

    <!--  =============================  -->
    <!--  ACCENT (MINT GREEN)  -->
    <!--  =============================  -->

    <Color x:Key="Color.Mint">#3FE0A1</Color>
    <Color x:Key="Color.Mint.Muted">#2BBE89</Color>
    <Color x:Key="Color.Mint.Dark">#0F2E1A</Color>

    <SolidColorBrush x:Key="Brush.Mint" Color="{StaticResource Color.Mint}" />
    <SolidColorBrush x:Key="Brush.Mint.Muted" Color="{StaticResource Color.Mint.Muted}" />
    <SolidColorBrush x:Key="Brush.Mint.Dark" Color="{StaticResource Color.Mint.Dark}" />

    <!--  =============================  -->
    <!--  TEXT  -->
    <!--  =============================  -->

    <Color x:Key="Color.Text.Primary">#E6EAF0</Color>
    <Color x:Key="Color.Text.Secondary">#9BA3AE</Color>
    <Color x:Key="Color.Text.Muted">#6B7280</Color>
    <Color x:Key="Color.Text.Primary.Dark">#1A1D21</Color>
    <Color x:Key="Color.Text.Secondary.Dark">#20242A</Color>
    <Color x:Key="Color.Text.Muted.Dark">#232830</Color>

    <SolidColorBrush x:Key="Brush.Text.Primary" Color="{StaticResource Color.Text.Primary}" />
    <SolidColorBrush x:Key="Brush.Text.Secondary" Color="{StaticResource Color.Text.Secondary}" />
    <SolidColorBrush x:Key="Brush.Text.Muted" Color="{StaticResource Color.Text.Muted}" />
    <SolidColorBrush x:Key="Brush.Text.Primary.Dark" Color="{StaticResource Color.Text.Primary.Dark}" />
    <SolidColorBrush x:Key="Brush.Text.Secondary.Dark" Color="{StaticResource Color.Text.Secondary.Dark}" />

    <!--  =============================  -->
    <!--  BORDER  -->
    <!--  =============================  -->

    <!--  Three-step ramp for control state progression  -->
    <Color x:Key="Color.Border.Subtle">#262C35</Color>
    <!--  dividers, idle container edges  -->
    <Color x:Key="Color.Border.Default">#333D4D</Color>
    <!--  inputs, cards, popups at rest  -->
    <Color x:Key="Color.Border.Strong">#445060</Color>
    <!--  hover state  -->

    <!--  Semantic / state borders  -->
    <Color x:Key="Color.Border.Focus">#3FE0A1</Color>
    <!--  focused input ring  -->
    <Color x:Key="Color.Border.Danger">#FF5C5C</Color>
    <!--  validation error  -->
    <Color x:Key="Color.Border.Warning">#FFB020</Color>
    <!--  overdue, caution  -->
    <Color x:Key="Color.Border.Info">#4DA3FF</Color>
    <!--  informational callout  -->

    <!--  Selected but not focused (mint @ ~35% alpha)  -->
    <Color x:Key="Color.Border.Accent.Muted">#5D3FE0A1</Color>

    <SolidColorBrush x:Key="Brush.Border.Subtle" Color="{StaticResource Color.Border.Subtle}" />
    <SolidColorBrush x:Key="Brush.Border.Default" Color="{StaticResource Color.Border.Default}" />
    <SolidColorBrush x:Key="Brush.Border.Strong" Color="{StaticResource Color.Border.Strong}" />
    <SolidColorBrush x:Key="Brush.Border.Focus" Color="{StaticResource Color.Border.Focus}" />
    <SolidColorBrush x:Key="Brush.Border.Danger" Color="{StaticResource Color.Border.Danger}" />
    <SolidColorBrush x:Key="Brush.Border.Warning" Color="{StaticResource Color.Border.Warning}" />
    <SolidColorBrush x:Key="Brush.Border.Info" Color="{StaticResource Color.Border.Info}" />
    <SolidColorBrush x:Key="Brush.Border.Accent.Muted" Color="{StaticResource Color.Border.Accent.Muted}" />

    <!--  =============================  -->
    <!--  STATE / SEMANTIC  -->
    <!--  =============================  -->

    <Color x:Key="Color.Success">#3FE0A1</Color>
    <Color x:Key="Color.Warning">#FFB020</Color>
    <Color x:Key="Color.Danger">#FF5C5C</Color>
    <Color x:Key="Color.Info">#4DA3FF</Color>

    <Color x:Key="Color.Success.Dark">#0F2E1A</Color>
    <Color x:Key="Color.Warning.Dark">#2E2200</Color>
    <Color x:Key="Color.Danger.Dark">#2E0F0F</Color>
    <Color x:Key="Color.Info.Dark">#0F1E35</Color>

    <SolidColorBrush x:Key="Brush.Success" Color="{StaticResource Color.Success}" />
    <SolidColorBrush x:Key="Brush.Warning" Color="{StaticResource Color.Warning}" />
    <SolidColorBrush x:Key="Brush.Danger" Color="{StaticResource Color.Danger}" />
    <SolidColorBrush x:Key="Brush.Info" Color="{StaticResource Color.Info}" />
    <SolidColorBrush x:Key="Brush.Success.Dark" Color="{StaticResource Color.Success.Dark}" />
    <SolidColorBrush x:Key="Brush.Warning.Dark" Color="{StaticResource Color.Warning.Dark}" />
    <SolidColorBrush x:Key="Brush.Danger.Dark" Color="{StaticResource Color.Danger.Dark}" />
    <SolidColorBrush x:Key="Brush.Info.Dark" Color="{StaticResource Color.Info.Dark}" />

    <!--  =============================  -->
    <!--  CATEGORY  -->
    <!--  =============================  -->

    <Color x:Key="Color.Category.Needs">#E6EAF0</Color>
    <Color x:Key="Color.Category.Wants">#FFB86C</Color>
    <Color x:Key="Color.Category.Investments">#3FE0A1</Color>

    <SolidColorBrush x:Key="Brush.Category.Needs" Color="{StaticResource Color.Category.Needs}" />
    <SolidColorBrush x:Key="Brush.Category.Wants" Color="{StaticResource Color.Category.Wants}" />
    <SolidColorBrush x:Key="Brush.Category.Investments" Color="{StaticResource Color.Category.Investments}" />

    <!--  =============================  -->
    <!--  ACCOUNTS  -->
    <!--  =============================  -->

    <!--  Accent (text/icon tint)  -->
    <Color x:Key="Color.Account.Checking">#5ABAFF</Color>
    <Color x:Key="Color.Account.Cash">#3FE0A1</Color>
    <Color x:Key="Color.Account.Credit">#C4AAFF</Color>
    <Color x:Key="Color.Account.Saving">#E8A855</Color>

    <!--  Background fill for account badges/chips  -->
    <Color x:Key="Color.Account.Checking.Dark">#1B3F6A</Color>
    <Color x:Key="Color.Account.Cash.Dark">#1A4035</Color>
    <Color x:Key="Color.Account.Credit.Dark">#3B2D5C</Color>
    <Color x:Key="Color.Account.Saving.Dark">#3D2E0F</Color>

    <SolidColorBrush x:Key="Brush.Account.Checking" Color="{StaticResource Color.Account.Checking}" />
    <SolidColorBrush x:Key="Brush.Account.Cash" Color="{StaticResource Color.Account.Cash}" />
    <SolidColorBrush x:Key="Brush.Account.Credit" Color="{StaticResource Color.Account.Credit}" />
    <SolidColorBrush x:Key="Brush.Account.Saving" Color="{StaticResource Color.Account.Saving}" />
    <SolidColorBrush x:Key="Brush.Account.Checking.Dark" Color="{StaticResource Color.Account.Checking.Dark}" />
    <SolidColorBrush x:Key="Brush.Account.Cash.Dark" Color="{StaticResource Color.Account.Cash.Dark}" />
    <SolidColorBrush x:Key="Brush.Account.Credit.Dark" Color="{StaticResource Color.Account.Credit.Dark}" />
    <SolidColorBrush x:Key="Brush.Account.Saving.Dark" Color="{StaticResource Color.Account.Saving.Dark}" />

    <!--  =============================  -->
    <!--  OVERLAY  -->
    <!--  =============================  -->

    <Color x:Key="Color.Overlay">#B2000000</Color>
    <SolidColorBrush x:Key="Brush.Overlay" Color="{StaticResource Color.Overlay}" />

</ResourceDictionary>
