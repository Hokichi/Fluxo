<UserControl
    x:Name="Root"
    x:Class="Fluxo.Resources.Components.AnalyticsBarChart"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <UserControl.Resources>
        <DataTemplate x:Key="AnalyticsTrendBarItemTemplate">
            <Grid Margin="4,0,4,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="6" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="8" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Grid Grid.Row="2" ClipToBounds="True">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="4" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Border
                        MinHeight="10"
                        Margin="0"
                        HorizontalAlignment="Stretch"
                        VerticalAlignment="Stretch"
                        BorderBrush="{StaticResource Brush.Border.Subtle}"
                        BorderThickness="1"
                        CornerRadius="4"
                        RenderTransformOrigin="0.5,1"
                        ToolTip="{Binding ValueText}">
                        <Border.RenderTransform>
                            <ScaleTransform ScaleY="{Binding BarHeightRatio}" />
                        </Border.RenderTransform>
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Grid.ColumnSpan" Value="3" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsExpenseMode}" Value="True">
                                        <Setter Property="Background" Value="{StaticResource Brush.Danger}" />
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding IsIncomeMode}" Value="True">
                                        <Setter Property="Background" Value="{StaticResource Brush.Mint}" />
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding HasSecondaryBar}" Value="True">
                                        <Setter Property="Grid.ColumnSpan" Value="1" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                    </Border>

                    <Border
                        MinHeight="10"
                        Margin="0"
                        HorizontalAlignment="Stretch"
                        VerticalAlignment="Stretch"
                        BorderBrush="{StaticResource Brush.Border.Subtle}"
                        BorderThickness="1"
                        CornerRadius="4"
                        RenderTransformOrigin="0.5,1"
                        ToolTip="{Binding SecondaryValueText}">
                        <Border.RenderTransform>
                            <ScaleTransform ScaleY="{Binding SecondaryBarHeightRatio}" />
                        </Border.RenderTransform>
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Setter Property="Grid.ColumnSpan" Value="3" />
                                <Setter Property="Grid.Column" Value="2" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding HasSecondaryBar}" Value="True">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding IsSecondaryExpenseMode}" Value="True">
                                        <Setter Property="Background" Value="{StaticResource Brush.Danger}" />
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding IsSecondaryIncomeMode}" Value="True">
                                        <Setter Property="Background" Value="{StaticResource Brush.Mint}" />
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding HasSecondaryBar}" Value="True">
                                        <Setter Property="Grid.ColumnSpan" Value="1" />
                                        <Setter Property="Grid.Column" Value="2" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                    </Border>
                </Grid>

                <TextBlock
                    Grid.Row="4"
                    Margin="0,4,0,0"
                    HorizontalAlignment="Center"
                    FontFamily="{StaticResource Bold}"
                    FontSize="13"
                    Foreground="{StaticResource Brush.Text.Muted}"
                    Text="{Binding Label}">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Foreground" Value="{StaticResource Brush.Text.Muted}" />
                            <Setter Property="Height" Value="16" />
                            <Setter Property="LayoutTransform">
                                <Setter.Value>
                                    <RotateTransform Angle="0" />
                                </Setter.Value>
                            </Setter>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsHighlighted}" Value="True">
                                    <Setter Property="Foreground" Value="{StaticResource Brush.Mint}" />
                                </DataTrigger>
                                <DataTrigger Binding="{Binding RotateLabelVertical}" Value="True">
                                    <Setter Property="LayoutTransform">
                                        <Setter.Value>
                                            <RotateTransform Angle="90" />
                                        </Setter.Value>
                                    </Setter>
                                    <Setter Property="Width" Value="48" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
            </Grid>
        </DataTemplate>

        <ItemsPanelTemplate x:Key="TrendBarLayerItemsPanelTemplate">
            <UniformGrid Rows="1" />
        </ItemsPanelTemplate>
    </UserControl.Resources>

    <Grid
        Grid.IsSharedSizeScope="True"
        ClipToBounds="True">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" SharedSizeGroup="TrendScaleLabelColumn" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <ItemsControl
            Grid.ColumnSpan="2"
            Margin="0,6,0,28"
            IsHitTestVisible="False"
            ItemsSource="{Binding GridLinesSource, ElementName=Root, Mode=OneWay}">
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <UniformGrid Rows="5" />
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" SharedSizeGroup="TrendScaleLabelColumn" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <TextBlock
                            Margin="0,0,8,-8"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Bottom"
                            FontFamily="{StaticResource Bold}"
                            FontSize="12"
                            Foreground="{StaticResource Brush.Text.Muted}"
                            Text="{Binding Mode=OneWay}" />
                        <Border
                            Grid.Column="1"
                            VerticalAlignment="Bottom"
                            BorderBrush="{StaticResource Brush.Border.Subtle}"
                            BorderThickness="0,0,0,1" />
                    </Grid>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>

        <ItemsControl
            x:Name="LayerA"
            Grid.Column="1"
            ItemTemplate="{StaticResource AnalyticsTrendBarItemTemplate}"
            ItemsPanel="{StaticResource TrendBarLayerItemsPanelTemplate}" />

        <ItemsControl
            x:Name="LayerB"
            Grid.Column="1"
            ItemTemplate="{StaticResource AnalyticsTrendBarItemTemplate}"
            ItemsPanel="{StaticResource TrendBarLayerItemsPanelTemplate}"
            Opacity="0" />
    </Grid>
</UserControl>
