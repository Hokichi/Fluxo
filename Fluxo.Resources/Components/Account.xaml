<UserControl
    x:Class="Fluxo.Resources.Components.Account"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:components="clr-namespace:Fluxo.Resources.Components"
    xmlns:converters="clr-namespace:Fluxo.Resources.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Width="140"
    Height="60"
    Visibility="{Binding PinnedOnUI, Converter={StaticResource BoolToVisibilityConverter}}"
    mc:Ignorable="d">

    <UserControl.Resources>
        <Style x:Key="AccountAccentStyle" TargetType="Border">
            <Style.Triggers>
                <DataTrigger Binding="{Binding AccountType}" Value="Checking">
                    <Setter Property="Background" Value="{StaticResource Brush.Account.Checking}" />
                    <Setter Property="BorderBrush" Value="{StaticResource Brush.Account.Checking}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding AccountType}" Value="Cash">
                    <Setter Property="Background" Value="{StaticResource Brush.Account.Cash}" />
                    <Setter Property="BorderBrush" Value="{StaticResource Brush.Account.Cash}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding AccountType}" Value="Credit">
                    <Setter Property="Background" Value="{StaticResource Brush.Account.Credit}" />
                    <Setter Property="BorderBrush" Value="{StaticResource Brush.Account.Credit}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding AccountType}" Value="Saving">
                    <Setter Property="Background" Value="{StaticResource Brush.Account.Saving}" />
                    <Setter Property="BorderBrush" Value="{StaticResource Brush.Account.Saving}" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Border
            x:Name="BGCard"
            BorderThickness="1"
            CornerRadius="8"
            Opacity="0.1"
            Style="{StaticResource AccountAccentStyle}" />

        <Border
            x:Name="AccountCard"
            BorderThickness="0"
            CornerRadius="8"
            MouseLeftButtonDown="OnRootMouseLeftButtonDown"
            PreviewMouseRightButtonUp="OnRootPreviewMouseRightButtonUp">
            <Border.Background>
                <SolidColorBrush Color="{StaticResource Color.Background.Deepened}" />
            </Border.Background>

            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="BorderBrush" Value="{StaticResource Brush.Border.Subtle}" />
                    <Setter Property="Opacity" Value="0" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsSelected}" Value="True">
                            <Setter Property="BorderBrush" Value="{StaticResource Brush.Mint}" />
                        </DataTrigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Trigger.EnterActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation
                                            Storyboard.TargetProperty="Opacity"
                                            To="0.5"
                                            Duration="0:0:0.2" />
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.EnterActions>
                            <Trigger.ExitActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation
                                            Storyboard.TargetProperty="Opacity"
                                            To="0"
                                            Duration="0:0:0.2" />
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.ExitActions>
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
        </Border>

        <Border
            Padding="8"
            HorizontalAlignment="Right"
            VerticalAlignment="Bottom">
            <components:Icon
                Width="12"
                Height="16"
                Path="{StaticResource Check}"
                Visibility="{Binding IsSelected, Converter={StaticResource BoolToVisibilityConverter}}"
                Color="{Binding ElementName=BGCard, Path=Background}" />
        </Border>

        <Border
            Background="Transparent"
            BorderThickness="2"
            CornerRadius="8"
            IsHitTestVisible="False"
            Opacity="0.5"
            Style="{StaticResource AccountAccentStyle}" />

        <Grid>
            <StackPanel Margin="12,8" IsHitTestVisible="False">
                <TextBlock
                    VerticalAlignment="Bottom"
                    FontFamily="{StaticResource SemiBold}"
                    FontSize="11"
                    Foreground="{Binding ElementName=BGCard, Path=Background}"
                    Text="{Binding Name}" />

                <TextBlock
                    Margin="0,4,0,0"
                    VerticalAlignment="Center"
                    FontFamily="{StaticResource Bold}"
                    FontSize="20"
                    Foreground="{Binding Difference, Converter={StaticResource DifferenceToBrushConverter}}"
                    Text="{Binding Difference, Converter={StaticResource NumberWithCommasConverter}}"
                    ToolTip="{Binding SpentAmount, Converter={StaticResource MoneyFullDisplayConverter}}" />
            </StackPanel>
        </Grid>

        <Popup
            x:Name="AccountActionsPopup"
            AllowsTransparency="True"
            IsOpen="False"
            Placement="Bottom"
            PlacementTarget="{Binding ElementName=AccountCard}"
            PopupAnimation="Fade"
            StaysOpen="False"
            VerticalOffset="8">
            <Border
                Width="220"
                Padding="8"
                Background="{StaticResource Brush.Background.Elevated}"
                BorderBrush="{StaticResource Brush.Border.Subtle}"
                BorderThickness="1"
                CornerRadius="18">
                <StackPanel>
                    <Button Click="OnViewActionClick" Style="{StaticResource HeaderMenuActionButtonStyle}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="16" />
                                <ColumnDefinition Width="12" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <components:Icon
                                Width="14"
                                Height="14"
                                Path="{StaticResource Eye}"
                                Color="{StaticResource Brush.Info}" />
                            <TextBlock
                                Grid.Column="2"
                                VerticalAlignment="Center"
                                FontFamily="{StaticResource Bold}"
                                Foreground="{StaticResource Brush.Text.Primary}"
                                Text="View" />
                        </Grid>
                    </Button>

                    <Button Click="OnDeleteActionClick" Style="{StaticResource HeaderMenuActionButtonStyle}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="16" />
                                <ColumnDefinition Width="12" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <components:Icon
                                Width="14"
                                Height="14"
                                Path="{StaticResource Delete}"
                                Color="{StaticResource Brush.Danger}" />
                            <TextBlock
                                Grid.Column="2"
                                VerticalAlignment="Center"
                                FontFamily="{StaticResource Bold}"
                                Foreground="{StaticResource Brush.Text.Primary}"
                                Text="Delete" />
                        </Grid>
                    </Button>

                    <Button Click="OnHideActionClick" Style="{StaticResource HeaderMenuActionButtonStyle}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="16" />
                                <ColumnDefinition Width="12" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <components:Icon
                                Width="14"
                                Height="14"
                                Path="{StaticResource Unpin}"
                                Color="{StaticResource Brush.Warning}" />
                            <TextBlock
                                Grid.Column="2"
                                VerticalAlignment="Center"
                                FontFamily="{StaticResource Bold}"
                                Foreground="{StaticResource Brush.Text.Primary}"
                                Text="Unpin" />
                        </Grid>
                    </Button>

                    <Button
                        Click="OnDisableActionClick"
                        IsEnabled="{Binding IsEnabled}"
                        Style="{StaticResource HeaderMenuActionButtonStyle}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="16" />
                                <ColumnDefinition Width="12" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <components:Icon
                                Width="14"
                                Height="14"
                                Path="{StaticResource LightningSlashFill}"
                                Color="{StaticResource Brush.Warning}" />
                            <TextBlock
                                Grid.Column="2"
                                VerticalAlignment="Center"
                                FontFamily="{StaticResource Bold}"
                                Foreground="{StaticResource Brush.Text.Primary}"
                                Text="Disable" />
                        </Grid>
                    </Button>

                    <Button
                        Click="OnTransferActionClick"
                        IsEnabled="{Binding CanTransfer}"
                        Style="{StaticResource HeaderMenuActionButtonStyle}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="16" />
                                <ColumnDefinition Width="12" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <components:Icon
                                Width="14"
                                Height="14"
                                Path="{StaticResource Exchange}"
                                Color="{StaticResource Brush.Mint}" />
                            <TextBlock
                                Grid.Column="2"
                                VerticalAlignment="Center"
                                FontFamily="{StaticResource Bold}"
                                Foreground="{StaticResource Brush.Text.Primary}"
                                Text="Transfer" />
                        </Grid>
                    </Button>

                    <Button
                        Click="OnRepaymentActionClick"
                        Style="{StaticResource HeaderMenuActionButtonStyle}"
                        Visibility="{Binding CanRepay, Converter={StaticResource BoolToVisibilityConverter}}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="16" />
                                <ColumnDefinition Width="12" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <components:Icon
                                Width="14"
                                Height="14"
                                Path="{StaticResource Bill}"
                                Color="{StaticResource Brush.Mint}" />
                            <TextBlock
                                Grid.Column="2"
                                VerticalAlignment="Center"
                                FontFamily="{StaticResource Bold}"
                                Foreground="{StaticResource Brush.Text.Primary}"
                                Text="Repayment" />
                        </Grid>
                    </Button>

                    <Button
                        Click="OnReconciliationActionClick"
                        Style="{StaticResource HeaderMenuActionButtonStyle}"
                        Visibility="{Binding CanReconcile, Converter={StaticResource BoolToVisibilityConverter}}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="16" />
                                <ColumnDefinition Width="12" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <components:Icon
                                Width="14"
                                Height="14"
                                Path="{StaticResource MoneyExchange}"
                                Color="{StaticResource Brush.Warning}" />
                            <TextBlock
                                Grid.Column="2"
                                VerticalAlignment="Center"
                                FontFamily="{StaticResource Bold}"
                                Foreground="{StaticResource Brush.Text.Primary}"
                                Text="Reconciliation" />
                        </Grid>
                    </Button>
                </StackPanel>
            </Border>
        </Popup>
    </Grid>
</UserControl>
