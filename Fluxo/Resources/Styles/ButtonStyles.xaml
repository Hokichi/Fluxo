<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:c="clr-namespace:Fluxo.Resources.CustomControls">
    <Style TargetType="{x:Type c:BalloonButton}">
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Foreground" Value="White" />
        <Setter Property="FocusVisualStyle" Value="{x:Null}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type c:BalloonButton}">
                    <Grid>
                        <!--  Balloon shape  -->
                        <Path x:Name="PART_Shape" Fill="{TemplateBinding DefaultBackground}" />
                        <!--  Pressed overlay — shares geometry with PART_Shape via code-behind  -->
                        <Path
                            x:Name="PART_Overlay"
                            Fill="Black"
                            IsHitTestVisible="False"
                            Opacity="0" />
                        <!--  Content area, inset by Padding to clear the bulging edges  -->
                        <StackPanel
                            Margin="{TemplateBinding Padding}"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center">
                            <Path
                                x:Name="PART_Icon"
                                Width="{TemplateBinding IconSize}"
                                Height="{TemplateBinding IconSize}"
                                HorizontalAlignment="Center"
                                Fill="{TemplateBinding Foreground}"
                                IsHitTestVisible="False"
                                Stretch="Uniform" />
                        </StackPanel>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="PART_Overlay" Property="Opacity" Value="0.3" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="{x:Type c:SwipeRevealContainer}">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type c:SwipeRevealContainer}">
                    <Grid ClipToBounds="True">
                        <!--  Left action (revealed on swipe right)  -->
                        <ContentPresenter
                            HorizontalAlignment="Left"
                            VerticalAlignment="Center"
                            Content="{TemplateBinding LeftContent}" />

                        <!--  Right action (revealed on swipe left)  -->
                        <ContentPresenter
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center"
                            Content="{TemplateBinding RightContent}" />

                        <!--  Main slideable content  -->
                        <Border x:Name="PART_ContentBorder" Background="{StaticResource Brush.Background.Main}">
                            <ContentPresenter Content="{TemplateBinding Content}" />
                        </Border>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
</ResourceDictionary>