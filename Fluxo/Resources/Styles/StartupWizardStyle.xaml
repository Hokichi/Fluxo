<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Style x:Key="PanelStyle" TargetType="Border">
        <Setter Property="Padding" Value="18" />
        <Setter Property="Background" Value="{StaticResource Brush.Background.Elevated}" />
        <Setter Property="BorderBrush" Value="{StaticResource Brush.Border.Subtle}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="18" />
    </Style>

    <Style x:Key="CardStyle" TargetType="Border">
        <Setter Property="Padding" Value="16" />
        <Setter Property="Background" Value="{StaticResource Brush.Background.Surface}" />
        <Setter Property="BorderBrush" Value="{StaticResource Brush.Border.Subtle}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="16" />
    </Style>





    <Style x:Key="FieldLabelStyle" TargetType="TextBlock">
        <Setter Property="Margin" Value="0,0,0,8" />
        <Setter Property="FontFamily" Value="{StaticResource Bold}" />
        <Setter Property="Foreground" Value="{StaticResource Brush.Text.Primary}" />
    </Style>

    <Style x:Key="WizardCircleActionButtonStyle" TargetType="Button">
        <Setter Property="Width" Value="44" />
        <Setter Property="Height" Value="44" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="Background" Value="{StaticResource Brush.Mint}" />
        <Setter Property="BorderBrush" Value="{StaticResource Brush.Mint}" />
        <Setter Property="Foreground" Value="{StaticResource Brush.Background.Surface}" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="FocusVisualStyle" Value="{x:Null}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border
                        x:Name="ButtonBackground"
                        Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}"
                        CornerRadius="22">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="ButtonBackground" Property="Background" Value="{StaticResource Brush.Mint.Muted}" />
                            <Setter TargetName="ButtonBackground" Property="BorderBrush" Value="{StaticResource Brush.Mint.Muted}" />
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="ButtonBackground" Property="Opacity" Value="0.85" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="ButtonBackground" Property="Opacity" Value="0.45" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>




    <Style x:Key="SidebarStepStyle" TargetType="Border">
        <Setter Property="Height" Value="38" />
        <Setter Property="Margin" Value="0,0,0,4" />
        <Setter Property="CornerRadius" Value="10" />
        <Setter Property="Background" Value="Transparent" />
    </Style>
    <Style
        x:Key="Step1SidebarStepStyle"
        BasedOn="{StaticResource SidebarStepStyle}"
        TargetType="Border">
        <Style.Triggers>
            <DataTrigger Binding="{Binding IsStep2Active}" Value="True">
                <Setter Property="Background" Value="{StaticResource Brush.Background.Hovered}" />
            </DataTrigger>
        </Style.Triggers>
    </Style>
    <Style
        x:Key="Step2SidebarStepStyle"
        BasedOn="{StaticResource SidebarStepStyle}"
        TargetType="Border">
        <Style.Triggers>
            <DataTrigger Binding="{Binding IsStep3Active}" Value="True">
                <Setter Property="Background" Value="{StaticResource Brush.Background.Hovered}" />
            </DataTrigger>
        </Style.Triggers>
    </Style>
    <Style
        x:Key="Step3SidebarStepStyle"
        BasedOn="{StaticResource SidebarStepStyle}"
        TargetType="Border">
        <Style.Triggers>
            <DataTrigger Binding="{Binding IsStep4Active}" Value="True">
                <Setter Property="Background" Value="{StaticResource Brush.Background.Hovered}" />
            </DataTrigger>
        </Style.Triggers>
    </Style>
    <Style
        x:Key="Step4SidebarStepStyle"
        BasedOn="{StaticResource SidebarStepStyle}"
        TargetType="Border">
        <Style.Triggers>
            <DataTrigger Binding="{Binding IsStep5Active}" Value="True">
                <Setter Property="Background" Value="{StaticResource Brush.Background.Hovered}" />
            </DataTrigger>
        </Style.Triggers>
    </Style>
    <Style
        x:Key="Step5SidebarStepStyle"
        BasedOn="{StaticResource SidebarStepStyle}"
        TargetType="Border">
        <Style.Triggers>
            <DataTrigger Binding="{Binding IsStep6Active}" Value="True">
                <Setter Property="Background" Value="{StaticResource Brush.Background.Hovered}" />
            </DataTrigger>
        </Style.Triggers>
    </Style>
    <Style
        x:Key="Step6SidebarStepStyle"
        BasedOn="{StaticResource SidebarStepStyle}"
        TargetType="Border">
        <Style.Triggers>
            <DataTrigger Binding="{Binding IsStep7Active}" Value="True">
                <Setter Property="Background" Value="{StaticResource Brush.Background.Hovered}" />
            </DataTrigger>
        </Style.Triggers>
    </Style>





</ResourceDictionary>


