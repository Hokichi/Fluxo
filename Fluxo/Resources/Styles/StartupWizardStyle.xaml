<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:c="clr-namespace:Fluxo.Resources.CustomControls">
        <Style x:Key="PanelStyle" TargetType="Border">
            <Setter Property="Padding" Value="18" />
            <Setter Property="Background" Value="{StaticResource Brush.Background.Elevated}" />
            <Setter Property="BorderBrush" Value="{StaticResource Brush.Border.Subtle}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="18" />
        </Style>

        <Style x:Key="CardStyle" TargetType="Border">
            <Setter Property="Padding" Value="16" />
            <Setter Property="Background" Value="{StaticResource Brush.Background.Surface}" />
            <Setter Property="BorderBrush" Value="{StaticResource Brush.Border.Subtle}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="16" />
        </Style>

        <Style x:Key="AddTileButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border
                            Height="80"
                            Background="{StaticResource Brush.Background.Surface}"
                            BorderBrush="{StaticResource Brush.Border.Subtle}"
                            BorderThickness="1"
                            CornerRadius="16">
                            <Grid>
                                <Rectangle
                                    RadiusX="16"
                                    RadiusY="16"
                                    Stroke="{StaticResource Brush.Text.Muted}"
                                    StrokeDashArray="6,4"
                                    StrokeThickness="1" />
                                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <Viewbox
                                        Width="24"
                                        Height="24"
                                        Stretch="Uniform">
                                        <Path
                                            x:Name="AddIcon"
                                            Data="{StaticResource PlusSolid}"
                                            Fill="{StaticResource Brush.Text.Muted}" />
                                    </Viewbox>
                                    <TextBlock
                                        x:Name="AddLabel"
                                        Margin="0,10,0,0"
                                        HorizontalAlignment="Center"
                                        FontFamily="{StaticResource Bold}"
                                        Foreground="{StaticResource Brush.Text.Secondary}"
                                        Text="Add" />
                                </StackPanel>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="AddIcon" Property="Fill" Value="{StaticResource Brush.Text.Primary}" />
                                <Setter TargetName="AddLabel" Property="Foreground" Value="{StaticResource Brush.Text.Primary}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ActionButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="40" />
            <Setter Property="MinWidth" Value="120" />
            <Setter Property="Padding" Value="18,0" />
            <Setter Property="Background" Value="{StaticResource Brush.Background.Surface}" />
            <Setter Property="BorderBrush" Value="{StaticResource Brush.Border.Subtle}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FontFamily" Value="{StaticResource Bold}" />
            <Setter Property="Foreground" Value="{StaticResource Brush.Text.Primary}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border
                            Padding="{TemplateBinding Padding}"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="12">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style
            x:Key="PrimaryActionButtonStyle"
            BasedOn="{StaticResource ActionButtonStyle}"
            TargetType="Button">
            <Setter Property="Background" Value="{StaticResource Brush.Mint}" />
            <Setter Property="BorderBrush" Value="{StaticResource Brush.Mint}" />
            <Setter Property="Foreground" Value="{StaticResource Brush.Background.Surface}" />
            <Style.Triggers>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Opacity" Value="0.4" />
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="FieldLabelStyle" TargetType="TextBlock">
            <Setter Property="Margin" Value="0,0,0,8" />
            <Setter Property="FontFamily" Value="{StaticResource Bold}" />
            <Setter Property="Foreground" Value="{StaticResource Brush.Text.Primary}" />
        </Style>
        <Style
            x:Key="FieldTextBoxStyle"
            BasedOn="{StaticResource PopupTextInputStyle}"
            TargetType="TextBox">
            <Setter Property="Padding" Value="12,10" />
            <Setter Property="Background" Value="{StaticResource Brush.Background.Surface}" />
            <Setter Property="BorderBrush" Value="{StaticResource Brush.Border.Subtle}" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>
        <Style
            x:Key="StepperButtonStyle"
            BasedOn="{StaticResource PopupTextButtonStyle}"
            TargetType="Button">
            <Setter Property="Width" Value="32" />
            <Setter Property="Height" Value="32" />
            <Setter Property="MinWidth" Value="32" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0" />
        </Style>
        <Style x:Key="ToggleSwitchStyle" TargetType="ToggleButton">
            <Setter Property="Width" Value="40" />
            <Setter Property="Height" Value="20" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border
                            x:Name="Track"
                            Background="{StaticResource Brush.Background.Hover}"
                            BorderBrush="{StaticResource Brush.Border.Subtle}"
                            BorderThickness="1"
                            CornerRadius="10">
                            <Ellipse
                                x:Name="Thumb"
                                Width="8"
                                Height="8"
                                Margin="4"
                                HorizontalAlignment="Left"
                                Fill="{StaticResource Brush.Text.Primary}">
                                <Ellipse.RenderTransform>
                                    <TranslateTransform x:Name="ThumbTransform" X="0" />
                                </Ellipse.RenderTransform>
                            </Ellipse>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Track" Property="Background" Value="{StaticResource Brush.Mint}" />
                                <Setter TargetName="Thumb" Property="Fill" Value="{StaticResource Brush.Background.Surface}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SidebarStepStyle" TargetType="Border">
            <Setter Property="Height" Value="38" />
            <Setter Property="Margin" Value="0,0,0,4" />
            <Setter Property="CornerRadius" Value="10" />
            <Setter Property="Background" Value="Transparent" />
        </Style>
        <Style
            x:Key="Step1SidebarStepStyle"
            BasedOn="{StaticResource SidebarStepStyle}"
            TargetType="Border">
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsStep1Active}" Value="True">
                    <Setter Property="Background" Value="{StaticResource Brush.Background.Hovered}" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
        <Style
            x:Key="Step2SidebarStepStyle"
            BasedOn="{StaticResource SidebarStepStyle}"
            TargetType="Border">
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsStep2Active}" Value="True">
                    <Setter Property="Background" Value="{StaticResource Brush.Background.Hovered}" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
        <Style
            x:Key="Step3SidebarStepStyle"
            BasedOn="{StaticResource SidebarStepStyle}"
            TargetType="Border">
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsStep3Active}" Value="True">
                    <Setter Property="Background" Value="{StaticResource Brush.Background.Hovered}" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
        <Style
            x:Key="Step4SidebarStepStyle"
            BasedOn="{StaticResource SidebarStepStyle}"
            TargetType="Border">
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsStep4Active}" Value="True">
                    <Setter Property="Background" Value="{StaticResource Brush.Background.Hovered}" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
        <Style
            x:Key="Step5SidebarStepStyle"
            BasedOn="{StaticResource SidebarStepStyle}"
            TargetType="Border">
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsStep5Active}" Value="True">
                    <Setter Property="Background" Value="{StaticResource Brush.Background.Hovered}" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
        <Style
            x:Key="Step6SidebarStepStyle"
            BasedOn="{StaticResource SidebarStepStyle}"
            TargetType="Border">
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsStep6Active}" Value="True">
                    <Setter Property="Background" Value="{StaticResource Brush.Background.Hovered}" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
        <Style
            x:Key="Step7SidebarStepStyle"
            BasedOn="{StaticResource SidebarStepStyle}"
            TargetType="Border">
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsStep7Active}" Value="True">
                    <Setter Property="Background" Value="{StaticResource Brush.Background.Hovered}" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="WizardStepDotStyle" TargetType="Ellipse">
            <Setter Property="Fill" Value="{StaticResource Brush.Text.Muted}" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsActive}" Value="True">
                    <Setter Property="Fill" Value="{StaticResource Brush.Mint}" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style
            x:Key="CardActionButtonStyle"
            BasedOn="{StaticResource {x:Type c:BalloonButton}}"
            TargetType="c:BalloonButton">
            <Setter Property="Width" Value="28" />
            <Setter Property="Height" Value="28" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="IconSize" Value="8" />
        </Style>

        <Style
            x:Key="EditButton"
            BasedOn="{StaticResource CardActionButtonStyle}"
            TargetType="c:BalloonButton">
            <Setter Property="ButtonIcon" Value="{StaticResource Pen}" />
            <Setter Property="Tag" Value="{Binding Id}" />
            <Setter Property="HoveredBackground" Value="{StaticResource Brush.Mint}" />
            <Setter Property="DefaultBackground" Value="{StaticResource Brush.Background.Main}" />

        </Style>

        <Style
            x:Key="DeleteButton"
            BasedOn="{StaticResource CardActionButtonStyle}"
            TargetType="c:BalloonButton">
            <Setter Property="ButtonIcon" Value="{StaticResource Close}" />
            <Setter Property="Margin" Value="4,0,0,0" />
            <Setter Property="Tag" Value="{Binding Id}" />
            <Setter Property="HoveredBackground" Value="{StaticResource Brush.Danger}" />
            <Setter Property="DefaultBackground" Value="{StaticResource Brush.Background.Main}" />

        </Style>
</ResourceDictionary>
