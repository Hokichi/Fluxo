<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:c="clr-namespace:Fluxo.Resources.CustomControls">
        <Style x:Key="PanelStyle" TargetType="Border">
            <Setter Property="Padding" Value="18" />
            <Setter Property="Background" Value="{StaticResource Brush.Background.Elevated}" />
            <Setter Property="BorderBrush" Value="{StaticResource Brush.Border.Subtle}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="18" />
        </Style>

        <Style x:Key="TabButtonStyle" TargetType="RadioButton">
            <Setter Property="Margin" Value="0,0,0,8" />
            <Setter Property="Height" Value="42" />
            <Setter Property="Foreground" Value="{StaticResource Brush.Text.Muted}" />
            <Setter Property="FontFamily" Value="{StaticResource Bold}" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="RootBorder">
                            <Grid Background="Transparent">
                                <Border
                                    x:Name="SelectedStrip"
                                    Width="4"
                                    HorizontalAlignment="Left"
                                    Background="{StaticResource Brush.Mint}"
                                    Visibility="Collapsed" />
                                <StackPanel
                                    Margin="16,0,12,0"
                                    VerticalAlignment="Center"
                                    Orientation="Horizontal">
                                    <ContentPresenter />
                                    <TextBlock
                                        Margin="12,0,0,0"
                                        VerticalAlignment="Center"
                                        FontFamily="{TemplateBinding FontFamily}"
                                        FontSize="{TemplateBinding FontSize}"
                                        Foreground="{TemplateBinding Foreground}"
                                        Text="{TemplateBinding Tag}" />
                                </StackPanel>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Foreground" Value="{StaticResource Brush.Text.Primary}" />
                                <Setter TargetName="RootBorder" Property="Background" Value="{StaticResource Brush.Background.Hover}" />
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter Property="Foreground" Value="{StaticResource Brush.Text.Primary}" />
                                <Setter TargetName="RootBorder" Property="Background" Value="{StaticResource Brush.Background.Hovered}" />
                                <Setter TargetName="SelectedStrip" Property="Visibility" Value="Visible" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style
            x:Key="StepperButtonStyle"
            BasedOn="{StaticResource PopupTextButtonStyle}"
            TargetType="Button">
            <Setter Property="Width" Value="32" />
            <Setter Property="Height" Value="32" />
            <Setter Property="MinWidth" Value="32" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0" />
        </Style>

        <Style x:Key="RowCardStyle" TargetType="Border">
            <Setter Property="Margin" Value="0,0,0,10" />
            <Setter Property="Padding" Value="14" />
            <Setter Property="Background" Value="{StaticResource Brush.Background.Surface}" />
            <Setter Property="BorderBrush" Value="{StaticResource Brush.Border.Subtle}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="14" />
        </Style>

        <Style
            x:Key="ToolbarActionBalloonButtonStyle"
            BasedOn="{StaticResource {x:Type c:BalloonButton}}"
            TargetType="{x:Type c:BalloonButton}">
            <Setter Property="Width" Value="32" />
            <Setter Property="Height" Value="32" />
            <Setter Property="Margin" Value="8,0,0,0" />
            <Setter Property="Foreground" Value="{StaticResource Brush.Text.Primary}" />
            <Setter Property="CornerRadius" Value="10" />
            <Setter Property="CurveHeight" Value="8" />
            <Setter Property="IconSize" Value="10" />
            <Setter Property="DefaultBackground" Value="{StaticResource Brush.Background.Surface}" />
            <Setter Property="HoveredBackground" Value="{StaticResource Brush.Background.Hovered}" />
        </Style>

        <Style
            x:Key="RowActionBalloonButtonStyle"
            BasedOn="{StaticResource ToolbarActionBalloonButtonStyle}"
            TargetType="{x:Type c:BalloonButton}">
            <Setter Property="Width" Value="28" />
            <Setter Property="Height" Value="28" />
            <Setter Property="Margin" Value="6,0,0,0" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="IconSize" Value="9" />
        </Style>

        <Style x:Key="ItemCheckBoxStyle" TargetType="CheckBox">
            <Setter Property="Width" Value="20" />
            <Setter Property="Height" Value="20" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <Border
                            x:Name="CheckSurface"
                            Width="20"
                            Height="20"
                            CornerRadius="10">
                            <Viewbox Margin="2,2,4,4" Stretch="Uniform">
                                <Path
                                    x:Name="CheckGlyph"
                                    Data="{StaticResource CheckboxBlankOutline}"
                                    Fill="{StaticResource Brush.Text.Muted}" />
                            </Viewbox>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="CheckSurface" Property="Background" Value="{StaticResource Brush.Background.Hovered}" />
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="CheckSurface" Property="Background" Value="{StaticResource Brush.Background.Hovered}" />
                                <Setter TargetName="CheckSurface" Property="BorderBrush" Value="{StaticResource Brush.Mint}" />
                                <Setter TargetName="CheckGlyph" Property="Data" Value="{StaticResource CheckboxMarked}" />
                                <Setter TargetName="CheckGlyph" Property="Fill" Value="{StaticResource Brush.Mint}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="StateIconBadgeStyle" TargetType="Border">
            <Setter Property="Width" Value="22" />
            <Setter Property="Height" Value="22" />
            <Setter Property="Margin" Value="8,0,0,0" />
            <Setter Property="CornerRadius" Value="11" />
            <Setter Property="Background" Value="{StaticResource Brush.Background.Surface}" />
            <Setter Property="BorderBrush" Value="{StaticResource Brush.Border.Subtle}" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>

        <Style x:Key="TagDeleteButtonStyle" TargetType="Button">
            <Setter Property="Margin" Value="0,0,8,8" />
            <Setter Property="Padding" Value="12,7" />
            <Setter Property="Background" Value="{StaticResource Brush.Background.Surface}" />
            <Setter Property="BorderBrush" Value="{StaticResource Brush.Border.Subtle}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border
                            x:Name="TagBorder"
                            Padding="{TemplateBinding Padding}"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="12">
                            <StackPanel Orientation="Horizontal">
                                <Grid Width="10" Height="10">
                                    <Ellipse Fill="{Binding HexCode}" />
                                    <Rectangle
                                        x:Name="DotCloseIcon"
                                        Margin="2"
                                        Fill="{StaticResource Brush.Background.Surface}"
                                        Opacity="0">
                                        <Rectangle.OpacityMask>
                                            <DrawingBrush Stretch="Uniform">
                                                <DrawingBrush.Drawing>
                                                    <GeometryDrawing Geometry="{StaticResource Close}">
                                                        <GeometryDrawing.Brush>
                                                            <SolidColorBrush Color="Black" />
                                                        </GeometryDrawing.Brush>
                                                    </GeometryDrawing>
                                                </DrawingBrush.Drawing>
                                            </DrawingBrush>
                                        </Rectangle.OpacityMask>
                                    </Rectangle>
                                </Grid>
                                <TextBlock
                                    Margin="8,0,0,0"
                                    FontFamily="{StaticResource Bold}"
                                    Foreground="{StaticResource Brush.Text.Primary}"
                                    Text="{Binding Name}" />
                            </StackPanel>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="TagBorder" Property="Background" Value="{StaticResource Brush.Background.Hovered}" />
                                <Setter TargetName="DotCloseIcon" Property="Opacity" Value="1" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style
            x:Key="TagAddBalloonButtonStyle"
            BasedOn="{StaticResource ToolbarActionBalloonButtonStyle}"
            TargetType="{x:Type c:BalloonButton}">
            <Setter Property="Width" Value="30" />
            <Setter Property="Height" Value="30" />
            <Setter Property="Margin" Value="0" />
            <Setter Property="ButtonIcon" Value="{StaticResource PlusSolid}" />
            <Setter Property="HoveredBackground" Value="{StaticResource Brush.Mint}" />
        </Style>

        <Style x:Key="ToggleSwitchStyle" TargetType="ToggleButton">
            <Setter Property="Width" Value="40" />
            <Setter Property="Height" Value="20" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border
                            x:Name="Track"
                            Background="{StaticResource Brush.Background.Hover}"
                            BorderBrush="{StaticResource Brush.Border.Subtle}"
                            BorderThickness="1"
                            CornerRadius="10">
                            <Ellipse
                                x:Name="Thumb"
                                Width="8"
                                Height="8"
                                Margin="4"
                                HorizontalAlignment="Left"
                                Fill="{StaticResource Brush.Text.Primary}">
                                <Ellipse.RenderTransform>
                                    <TranslateTransform x:Name="ThumbTransform" X="0" />
                                </Ellipse.RenderTransform>
                            </Ellipse>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Track" Property="Background" Value="{StaticResource Brush.Mint}" />
                                <Setter TargetName="Thumb" Property="Fill" Value="{StaticResource Brush.Background.Surface}" />
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation
                                                Storyboard.TargetName="ThumbTransform"
                                                Storyboard.TargetProperty="X"
                                                To="22"
                                                Duration="0:0:0.14" />
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation
                                                Storyboard.TargetName="ThumbTransform"
                                                Storyboard.TargetProperty="X"
                                                To="0"
                                                Duration="0:0:0.14" />
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style
            x:Key="DangerActionButtonStyle"
            BasedOn="{StaticResource PopupTextButtonStyle}"
            TargetType="Button">
            <Setter Property="Foreground" Value="{StaticResource Brush.Danger}" />
        </Style>
        <Style x:Key="BudgetAllocationContainerStyle" TargetType="StackPanel">
            <Style.Triggers>
                <DataTrigger Binding="{Binding HasSpendingSources}" Value="False">
                    <Setter Property="Effect">
                        <Setter.Value>
                            <BlurEffect Radius="15" />
                        </Setter.Value>
                    </Setter>
                    <Setter Property="Opacity" Value="0.4" />
                    <Setter Property="IsHitTestVisible" Value="False" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
</ResourceDictionary>
