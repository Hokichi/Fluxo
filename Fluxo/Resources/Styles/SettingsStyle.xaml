<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x='http://schemas.microsoft.com/winfx/2006/xaml'
    xmlns:components='clr-namespace:Fluxo.Views.Components'
    xmlns:c="clr-namespace:Fluxo.Resources.CustomControls">
    <Style x:Key="PanelStyle" TargetType="Border">
        <Setter Property="Padding" Value="18" />
        <Setter Property="Background" Value="{StaticResource Brush.Background.Elevated}" />
        <Setter Property="BorderBrush" Value="{StaticResource Brush.Border.Subtle}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="18" />
    </Style>

    <Style x:Key="RowCardStyle" TargetType="Border">
        <Setter Property="Margin" Value="0,0,0,10" />
        <Setter Property="Padding" Value="14" />
        <Setter Property="Background" Value="{StaticResource Brush.Background.Surface}" />
        <Setter Property="BorderBrush" Value="{StaticResource Brush.Border.Subtle}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="14" />
    </Style>

    <Style x:Key="ItemCheckBoxStyle" TargetType="CheckBox">
        <Setter Property="Width" Value="20" />
        <Setter Property="Height" Value="20" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="CheckBox">
                    <Border
                        x:Name="CheckSurface"
                        Width="20"
                        Height="20"
                        CornerRadius="10">
                        <components:Icon Margin='2,2,4,4' x:Name='CheckGlyph' Path='{StaticResource SettingsStyle.CheckboxBlankOutline}' Color='{StaticResource Brush.Text.Muted}' />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="CheckSurface" Property="Background" Value="{StaticResource Brush.Background.Hovered}" />
                        </Trigger>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="CheckSurface" Property="Background" Value="{StaticResource Brush.Background.Hovered}" />
                            <Setter TargetName="CheckSurface" Property="BorderBrush" Value="{StaticResource Brush.Mint}" />
                            <Setter TargetName="CheckGlyph" Property="Path" Value="{StaticResource SettingsStyle.CheckboxMarked}" />
                            <Setter TargetName="CheckGlyph" Property="Color" Value="{StaticResource Brush.Mint}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="ItemCheckBoxWithContentStyle" TargetType="CheckBox">
        <Setter Property="Width" Value="20" />
        <Setter Property="Height" Value="20" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="CheckBox">
                    <StackPanel Orientation="Horizontal">
                        <Border
                            x:Name="CheckSurface"
                            Width="20"
                            Height="20"
                            CornerRadius="10">
                            <components:Icon Margin='2,2,4,4' x:Name='CheckGlyph' Path='{StaticResource SettingsStyle.CheckboxBlankOutline}' Color='{StaticResource Brush.Text.Muted}' />
                        </Border>

                        <ContentPresenter />
                    </StackPanel>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="CheckSurface" Property="Background" Value="{StaticResource Brush.Background.Hovered}" />
                        </Trigger>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="CheckSurface" Property="Background" Value="{StaticResource Brush.Background.Hovered}" />
                            <Setter TargetName="CheckSurface" Property="BorderBrush" Value="{StaticResource Brush.Mint}" />
                            <Setter TargetName="CheckGlyph" Property="Path" Value="{StaticResource SettingsStyle.CheckboxMarked}" />
                            <Setter TargetName="CheckGlyph" Property="Color" Value="{StaticResource Brush.Mint}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="StateIconBadgeStyle" TargetType="Border">
        <Setter Property="Width" Value="22" />
        <Setter Property="Height" Value="22" />
        <Setter Property="Margin" Value="8,0,0,0" />
        <Setter Property="CornerRadius" Value="11" />
        <Setter Property="Background" Value="{StaticResource Brush.Background.Surface}" />
        <Setter Property="BorderBrush" Value="{StaticResource Brush.Border.Subtle}" />
        <Setter Property="BorderThickness" Value="1" />
    </Style>

    <Style x:Key="BudgetAllocationContainerStyle" TargetType="StackPanel">
        <Style.Triggers>
            <DataTrigger Binding="{Binding HasSpendingSources}" Value="False">
                <Setter Property="Effect">
                    <Setter.Value>
                        <BlurEffect Radius="15" />
                    </Setter.Value>
                </Setter>
                <Setter Property="Opacity" Value="0.4" />
                <Setter Property="IsHitTestVisible" Value="False" />
            </DataTrigger>
        </Style.Triggers>
    </Style>
</ResourceDictionary>
