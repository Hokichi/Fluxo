<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:c="clr-namespace:Fluxo.Resources.CustomControls">

    <BooleanToVisibilityConverter x:Key="PopupBoolToVisibility" />

    <Style x:Key="PopupTextButtonStyle" TargetType="Button">
        <Setter Property="Height" Value="40" />
        <Setter Property="Padding" Value="14,0" />
        <Setter Property="Background" Value="{StaticResource Brush.Background.Hover}" />
        <Setter Property="BorderBrush" Value="{StaticResource Brush.Border.Subtle}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="FocusVisualStyle" Value="{x:Null}" />
        <Setter Property="FontFamily" Value="{StaticResource Bold}" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="Foreground" Value="{StaticResource Brush.Text.Primary}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border
                        x:Name="RootBorder"
                        Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}"
                        CornerRadius="12">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="RootBorder" Property="Background" Value="{StaticResource Brush.Background.Elevated}" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="RootBorder" Property="Opacity" Value="0.45" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="PopupTextBoxStyle" TargetType="TextBox">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="CaretBrush" Value="{DynamicResource Brush.Text.Primary}" />
        <Setter Property="Foreground" Value="{DynamicResource Brush.Text.Primary}" />
        <Setter Property="FontFamily" Value="{DynamicResource Medium}" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
    </Style>

    <Style x:Key="RoundedTextInputStyle" TargetType="TextBox">
        <Setter Property="Padding" Value="8,6" />
        <Setter Property="Background" Value="{DynamicResource Brush.Background.Surface}" />
        <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border.Subtle}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CaretBrush" Value="{DynamicResource Brush.Text.Primary}" />
        <Setter Property="Foreground" Value="{DynamicResource Brush.Text.Primary}" />
        <Setter Property="FontFamily" Value="{DynamicResource Medium}" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="TextBox">
                    <Border
                        x:Name="InputRoot"
                        Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}"
                        CornerRadius="12">
                        <ScrollViewer
                            x:Name="PART_ContentHost"
                            Margin="{TemplateBinding Padding}"
                            VerticalAlignment="{TemplateBinding VerticalContentAlignment}" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsKeyboardFocused" Value="True">
                            <Setter TargetName="InputRoot" Property="BorderBrush" Value="{DynamicResource Brush.Mint}" />
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="InputRoot" Property="Background" Value="{DynamicResource Brush.Background.Hovered}" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="InputRoot" Property="Opacity" Value="0.6" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style
        x:Key="PopupTextInputStyle"
        BasedOn="{StaticResource RoundedTextInputStyle}"
        TargetType="TextBox">
        <Setter Property="FontSize" Value="13" />
    </Style>

    <Style BasedOn="{StaticResource RoundedTextInputStyle}" TargetType="TextBox" />

    <Style TargetType="{x:Type c:BasePopup}">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type c:BasePopup}">
                    <Border
                        Background="{StaticResource Brush.Background.Main}"
                        BorderBrush="{StaticResource Brush.Border.Subtle}"
                        BorderThickness="1"
                        CornerRadius="16">
                        <Grid x:Name="PART_ContentRoot">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="60" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <!--  Header  -->
                            <Grid Grid.Row="0" Margin="24,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <!--  Popup Title  -->
                                <TextBlock
                                    Grid.Column="0"
                                    VerticalAlignment="Center"
                                    FontFamily="{StaticResource Bold}"
                                    FontSize="18"
                                    Foreground="{StaticResource Brush.Text.Primary}"
                                    Text="{TemplateBinding PopupTitle}" />

                                <!--  Action Buttons  -->
                                <StackPanel
                                    Grid.Column="1"
                                    HorizontalAlignment="Right"
                                    Orientation="Horizontal">

                                    <!--  Clone  -->
                                    <c:BalloonButton
                                        x:Name="PART_CloneButton"
                                        Width="28"
                                        Height="28"
                                        Margin="8,0,0,0"
                                        ButtonIcon="{StaticResource CloneRegular}"
                                        CornerRadius="8"
                                        CurveHeight="8"
                                        DefaultBackground="{StaticResource Brush.Background.Surface}"
                                        HoveredBackground="{StaticResource Brush.Mint}"
                                        IconSize="8"
                                        Visibility="{TemplateBinding ShowCloneButton,
                                                                     Converter={StaticResource PopupBoolToVisibility}}" />

                                    <!--  Delete  -->
                                    <c:BalloonButton
                                        x:Name="PART_DeleteButton"
                                        Width="28"
                                        Height="28"
                                        Margin="8,0,0,0"
                                        ButtonIcon="{StaticResource CircleMinusSolid}"
                                        CornerRadius="8"
                                        CurveHeight="8"
                                        DefaultBackground="{StaticResource Brush.Background.Surface}"
                                        HoveredBackground="{StaticResource Brush.Danger}"
                                        IconSize="8"
                                        Visibility="{TemplateBinding ShowDeleteButton,
                                                                     Converter={StaticResource PopupBoolToVisibility}}" />

                                    <!--  Edit  -->
                                    <c:BalloonButton
                                        x:Name="PART_EditButton"
                                        Width="28"
                                        Height="28"
                                        Margin="8,0,0,0"
                                        ButtonIcon="{StaticResource Edit}"
                                        CornerRadius="8"
                                        CurveHeight="8"
                                        DefaultBackground="{StaticResource Brush.Background.Surface}"
                                        HoveredBackground="{StaticResource Brush.Primary.Hover}"
                                        IconSize="8"
                                        Visibility="{TemplateBinding ShowEditButton,
                                                                     Converter={StaticResource PopupBoolToVisibility}}" />

                                    <!--  Revert  -->
                                    <c:BalloonButton
                                        x:Name="PART_RevertButton"
                                        Width="28"
                                        Height="28"
                                        Margin="8,0,0,0"
                                        ButtonIcon="{StaticResource RegularUndo}"
                                        CornerRadius="8"
                                        CurveHeight="8"
                                        DefaultBackground="{StaticResource Brush.Background.Surface}"
                                        HoveredBackground="{StaticResource Brush.Warning}"
                                        IconSize="8"
                                        Visibility="{TemplateBinding ShowRevertButton,
                                                                     Converter={StaticResource PopupBoolToVisibility}}" />

                                    <!--  Apply  -->
                                    <c:BalloonButton
                                        x:Name="PART_ApplyButton"
                                        Width="28"
                                        Height="28"
                                        Margin="8,0,0,0"
                                        ButtonIcon="{StaticResource Check}"
                                        CornerRadius="8"
                                        CurveHeight="8"
                                        DefaultBackground="{StaticResource Brush.Background.Surface}"
                                        HoveredBackground="{StaticResource Brush.Success}"
                                        IconSize="8"
                                        Visibility="{TemplateBinding ShowApplyButton,
                                                                     Converter={StaticResource PopupBoolToVisibility}}" />

                                    <!--  Cancel  -->
                                    <c:BalloonButton
                                        x:Name="PART_CancelButton"
                                        Width="28"
                                        Height="28"
                                        Margin="8,0,0,0"
                                        ButtonIcon="{StaticResource Ban}"
                                        CornerRadius="8"
                                        CurveHeight="8"
                                        DefaultBackground="{StaticResource Brush.Background.Surface}"
                                        HoveredBackground="{StaticResource Brush.Warning}"
                                        IconSize="8"
                                        Visibility="{TemplateBinding ShowCancelButton,
                                                                     Converter={StaticResource PopupBoolToVisibility}}" />

                                    <!--  Save and Create New  -->
                                    <c:BalloonButton
                                        x:Name="PART_SaveAndCreateNewButton"
                                        Width="28"
                                        Height="28"
                                        Margin="8,0,0,0"
                                        ButtonIcon="{StaticResource ContentSaveMove}"
                                        CornerRadius="8"
                                        CurveHeight="8"
                                        DefaultBackground="{StaticResource Brush.Background.Surface}"
                                        HoveredBackground="{StaticResource Brush.Mint.Muted}"
                                        IconSize="8"
                                        Visibility="{TemplateBinding ShowSaveAndCreateNewButton,
                                                                     Converter={StaticResource PopupBoolToVisibility}}" />

                                    <!--  Save  -->
                                    <c:BalloonButton
                                        x:Name="PART_SaveButton"
                                        Width="28"
                                        Height="28"
                                        Margin="8,0,0,0"
                                        ButtonIcon="{StaticResource ContentSave}"
                                        CornerRadius="8"
                                        CurveHeight="8"
                                        DefaultBackground="{StaticResource Brush.Background.Surface}"
                                        HoveredBackground="{StaticResource Brush.Mint}"
                                        IconSize="8"
                                        Visibility="{TemplateBinding ShowSaveButton,
                                                                     Converter={StaticResource PopupBoolToVisibility}}" />

                                    <!--  Close (always visible)  -->
                                    <c:BalloonButton
                                        x:Name="PART_CloseButton"
                                        Width="28"
                                        Height="28"
                                        Margin="8,0,0,0"
                                        ButtonIcon="{StaticResource Close}"
                                        CornerRadius="8"
                                        CurveHeight="8"
                                        DefaultBackground="{StaticResource Brush.Background.Surface}"
                                        HoveredBackground="{StaticResource Brush.Danger}"
                                        IconSize="8" />
                                </StackPanel>
                            </Grid>

                            <!--  Main Content  -->
                            <ContentPresenter Grid.Row="1" />

                            <!--  Popup overlay: dims and blocks interaction when a child popup is open  -->
                            <Rectangle
                                x:Name="PART_PopupOverlay"
                                Grid.RowSpan="2"
                                Fill="#80000000"
                                Opacity="0"
                                Visibility="Collapsed" />
                        </Grid>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
</ResourceDictionary>
