<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:c="clr-namespace:Fluxo.Views.CustomControls">

    <BooleanToVisibilityConverter x:Key="PopupBoolToVisibility" />

    <Style TargetType="{x:Type c:BasePopup}">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type c:BasePopup}">
                    <Border
                        Background="{StaticResource Brush.Background.Main}"
                        BorderBrush="{StaticResource Brush.Border.Subtle}"
                        BorderThickness="1"
                        CornerRadius="16">
                        <Grid x:Name="PART_ContentRoot">
                            <Grid.RowDefinitions>
                                <RowDefinition x:Name="HeaderRow" Height="60" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <!--  Header  -->
                            <Grid x:Name="HeaderHost" Grid.Row="0" Margin="24,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <!--  Popup Title  -->
                                <Grid Grid.Column="0" VerticalAlignment="Center">
                                    <TextBlock
                                        x:Name="PopupTitleText"
                                        VerticalAlignment="Center"
                                        FontFamily="{StaticResource Bold}"
                                        FontSize="18"
                                        Foreground="{StaticResource Brush.Text.Primary}"
                                        Text="{TemplateBinding PopupTitle}"
                                        Visibility="Collapsed" />
                                    <ContentPresenter
                                        x:Name="PopupTitleContentPresenter"
                                        VerticalAlignment="Center"
                                        Content="{TemplateBinding PopupTitleContent}" />
                                </Grid>

                                <!--  Action Buttons  -->
                                <StackPanel
                                    Grid.Column="1"
                                    HorizontalAlignment="Right"
                                    Orientation="Horizontal">

                                    <!--  Clone  -->
                                    <c:BalloonButton
                                        x:Name="PART_CloneButton"
                                        ButtonIcon="{StaticResource PopupStyles.CloneRegular}"
                                        HoveredBackground="{StaticResource Brush.Mint}"
                                        Style="{StaticResource HeaderButtonStyle}"
                                        Visibility="{TemplateBinding ShowCloneButton,
                                                                     Converter={StaticResource PopupBoolToVisibility}}" />

                                    <!--  Delete  -->
                                    <c:BalloonButton
                                        x:Name="PART_DeleteButton"
                                        ButtonIcon="{StaticResource PopupStyles.CircleMinusSolid}"
                                        HoveredBackground="{StaticResource Brush.Danger}"
                                        Style="{StaticResource HeaderButtonStyle}"
                                        Visibility="{TemplateBinding ShowDeleteButton,
                                                                     Converter={StaticResource PopupBoolToVisibility}}" />

                                    <!--  Edit  -->
                                    <c:BalloonButton
                                        x:Name="PART_EditButton"
                                        ButtonIcon="{StaticResource PopupStyles.Edit}"
                                        HoveredBackground="{StaticResource Brush.Primary.Hover}"
                                        Style="{StaticResource HeaderButtonStyle}"
                                        Visibility="{TemplateBinding ShowEditButton,
                                                                     Converter={StaticResource PopupBoolToVisibility}}" />

                                    <!--  Revert  -->
                                    <c:BalloonButton
                                        x:Name="PART_RevertButton"
                                        ButtonIcon="{StaticResource PopupStyles.RegularUndo}"
                                        HoveredBackground="{StaticResource Brush.Warning}"
                                        Style="{StaticResource HeaderButtonStyle}"
                                        Visibility="{TemplateBinding ShowRevertButton,
                                                                     Converter={StaticResource PopupBoolToVisibility}}" />

                                    <!--  Apply  -->
                                    <c:BalloonButton
                                        x:Name="PART_ApplyButton"
                                        ButtonIcon="{StaticResource PopupStyles.Check}"
                                        HoveredBackground="{StaticResource Brush.Success}"
                                        Style="{StaticResource HeaderButtonStyle}"
                                        Visibility="{TemplateBinding ShowApplyButton,
                                                                     Converter={StaticResource PopupBoolToVisibility}}" />

                                    <!--  Cancel  -->
                                    <c:BalloonButton
                                        x:Name="PART_CancelButton"
                                        ButtonIcon="{StaticResource PopupStyles.Ban}"
                                        HoveredBackground="{StaticResource Brush.Warning}"
                                        Style="{StaticResource HeaderButtonStyle}"
                                        Visibility="{TemplateBinding ShowCancelButton,
                                                                     Converter={StaticResource PopupBoolToVisibility}}" />

                                    <!--  Save and Create New  -->
                                    <c:BalloonButton
                                        x:Name="PART_SaveAndCreateNewButton"
                                        ButtonIcon="{StaticResource PopupStyles.ContentSaveMove}"
                                        HoveredBackground="{StaticResource Brush.Mint.Muted}"
                                        IsEnabled="{TemplateBinding IsSaveAndCreateNewButtonEnabled}"
                                        Style="{StaticResource HeaderButtonStyle}"
                                        Visibility="{TemplateBinding ShowSaveAndCreateNewButton,
                                                                     Converter={StaticResource PopupBoolToVisibility}}" />

                                    <!--  Save  -->
                                    <c:BalloonButton
                                        x:Name="PART_SaveButton"
                                        ButtonIcon="{StaticResource PopupStyles.ContentSave}"
                                        HoveredBackground="{StaticResource Brush.Mint}"
                                        IsEnabled="{TemplateBinding IsSaveButtonEnabled}"
                                        Style="{StaticResource HeaderButtonStyle}"
                                        Visibility="{TemplateBinding ShowSaveButton,
                                                                     Converter={StaticResource PopupBoolToVisibility}}" />

                                    <!--  Close (always visible)  -->
                                    <c:BalloonButton
                                        x:Name="PART_CloseButton"
                                        ButtonIcon="{StaticResource PopupStyles.Close}"
                                        HoveredBackground="{StaticResource Brush.Danger}"
                                        Style="{StaticResource HeaderButtonStyle}"
                                        Visibility="{TemplateBinding ShowCloseButton,
                                                                     Converter={StaticResource PopupBoolToVisibility}}" />
                                </StackPanel>
                            </Grid>

                            <!--  Main Content  -->
                            <ContentPresenter Grid.Row="1" />

                            <!--  Popup overlay: dims and blocks interaction when a child popup is open  -->
                            <Rectangle
                                x:Name="PART_PopupOverlay"
                                Grid.RowSpan="2"
                                Fill="#80000000"
                                Opacity="0"
                                Visibility="Collapsed" />
                        </Grid>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="ShowHeader" Value="False">
                            <Setter TargetName="HeaderRow" Property="Height" Value="0" />
                            <Setter TargetName="HeaderHost" Property="Visibility" Value="Collapsed" />
                        </Trigger>
                        <Trigger Property="PopupTitleContent" Value="{x:Null}">
                            <Setter TargetName="PopupTitleText" Property="Visibility" Value="Visible" />
                            <Setter TargetName="PopupTitleContentPresenter" Property="Visibility" Value="Collapsed" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
</ResourceDictionary>
