<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net10.0-windows</TargetFramework>
    <Nullable>enable</Nullable>
	  <ImplicitUsings>enable</ImplicitUsings>
	  <UseWPF>true</UseWPF>
	  <StartupObject>Fluxo.App</StartupObject>
	  <EnableDefaultItems>true</EnableDefaultItems>
	  <ApplicationIcon>..\Fluxo.Resources\Resources\fluxo.ico</ApplicationIcon>
	  <Version>1.0.4</Version>
	  <RuntimeIdentifier>win-x64</RuntimeIdentifier>
	  <SatelliteResourceLanguages>en</SatelliteResourceLanguages>
	  <AssemblyTitle>fluxo</AssemblyTitle>
	  <AssemblyName>fluxo</AssemblyName>
	  <RootNamespace>Fluxo</RootNamespace>
	  <LegacyPrimaryArtifactsToDelete>'Fluxo.exe', 'Fluxo.dll', 'Fluxo.deps.json', 'Fluxo.runtimeconfig.json', 'Fluxo.pdb'</LegacyPrimaryArtifactsToDelete>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="AutoMapper" Version="16.1.1" />
    <PackageReference Include="CommunityToolkit.Mvvm" Version="8.4.0" />
    <PackageReference Include="Microsoft.EntityFrameworkCore.Design" Version="10.0.5">
      <PrivateAssets>all</PrivateAssets>
      <IncludeAssets>runtime; build; native; contentfiles; analyzers; buildtransitive</IncludeAssets>
    </PackageReference>
    <PackageReference Include="Microsoft.Extensions.Hosting" Version="10.0.3" />
    <PackageReference Include="Newtonsoft.Json" Version="13.0.4" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\Fluxo.Core\Fluxo.Core.csproj" />
    <ProjectReference Include="..\Fluxo.Data\Fluxo.Data.csproj" />
    <ProjectReference Include="..\Fluxo.Services\Fluxo.Services.csproj" />
    <ProjectReference Include="..\Fluxo.Resources\Fluxo.Resources.csproj" />
  </ItemGroup>

  <ItemGroup>
    <FrameworkReference Include="Microsoft.WindowsDesktop.App.WindowsForms" />
  </ItemGroup>

  <Target Name="CleanupLegacyPrimaryArtifactsBeforeBuild" BeforeTargets="Build" Condition="'$(DesignTimeBuild)' != 'true'">
    <Exec Command="powershell -NoProfile -ExecutionPolicy Bypass -Command &quot;$ErrorActionPreference = 'Stop'; $cleanupDir = $env:FLUXO_LEGACY_CLEANUP_DIR; $legacyNames = @($(LegacyPrimaryArtifactsToDelete)); Get-ChildItem -LiteralPath $cleanupDir -File | Where-Object { $legacyNames -ccontains $_.Name } | ForEach-Object { Remove-Item -LiteralPath $_.FullName -Force }&quot;"
          EnvironmentVariables="FLUXO_LEGACY_CLEANUP_DIR=$(TargetDir)"
          Condition="Exists('$(TargetDir)')" />
  </Target>

  <Target Name="CleanupLegacyPrimaryArtifactsBeforePublish" BeforeTargets="Publish" Condition="'$(DesignTimeBuild)' != 'true'">
    <Exec Command="powershell -NoProfile -ExecutionPolicy Bypass -Command &quot;$ErrorActionPreference = 'Stop'; $cleanupDir = $env:FLUXO_LEGACY_CLEANUP_DIR; $legacyNames = @($(LegacyPrimaryArtifactsToDelete)); Get-ChildItem -LiteralPath $cleanupDir -File | Where-Object { $legacyNames -ccontains $_.Name } | ForEach-Object { Remove-Item -LiteralPath $_.FullName -Force }&quot;"
          EnvironmentVariables="FLUXO_LEGACY_CLEANUP_DIR=$(PublishDir)"
          Condition="Exists('$(PublishDir)')" />
  </Target>

  <Target Name="OrganizeOutputAfterBuild" AfterTargets="Build" Condition="'$(DesignTimeBuild)' != 'true' and '$(PublishDir)' == ''">
    <PropertyGroup>
      <OrganizeOutputDir>$(TargetDir)</OrganizeOutputDir>
    </PropertyGroup>

    <ItemGroup Condition="Exists('$(OrganizeOutputDir)')">
      <FirstPartyDlls Include="$(OrganizeOutputDir)Fluxo*.dll" />
      <VendorDlls Include="$(OrganizeOutputDir)*.dll" Exclude="@(FirstPartyDlls)" />
    </ItemGroup>

    <MakeDir Directories="$(OrganizeOutputDir)libs" Condition="Exists('$(OrganizeOutputDir)') and '@(FirstPartyDlls)' != ''" />
    <MakeDir Directories="$(OrganizeOutputDir)vendor" Condition="Exists('$(OrganizeOutputDir)') and '@(VendorDlls)' != ''" />

    <Move SourceFiles="@(FirstPartyDlls)" DestinationFolder="$(OrganizeOutputDir)libs" Condition="'@(FirstPartyDlls)' != ''" />

    <Move SourceFiles="@(VendorDlls)" DestinationFolder="$(OrganizeOutputDir)vendor" Condition="'@(VendorDlls)' != ''" />

    <!-- Keep a root path for project-reference copy steps without duplicating the file. -->
    <Exec Command="cmd /c mklink /H &quot;$(OrganizeOutputDir)$(TargetFileName)&quot; &quot;$(OrganizeOutputDir)libs\$(TargetFileName)&quot;" Condition="Exists('$(OrganizeOutputDir)libs\\$(TargetFileName)') and !Exists('$(OrganizeOutputDir)$(TargetFileName)')" />
  </Target>

  <Target Name="OrganizeOutputAfterPublish" AfterTargets="Publish" Condition="'$(DesignTimeBuild)' != 'true'">
    <Exec Command="powershell -NoProfile -ExecutionPolicy Bypass -Command &quot;$ErrorActionPreference = 'Stop'; $publishDir = $env:FLUXO_PUBLISH_DIR; if ([string]::IsNullOrWhiteSpace($publishDir) -or !(Test-Path -LiteralPath $publishDir)) { return }; $libsDir = Join-Path $publishDir 'libs'; $vendorDir = Join-Path $publishDir 'vendor'; @($libsDir, $vendorDir) | Where-Object { Test-Path -LiteralPath $_ } | ForEach-Object { Remove-Item -LiteralPath $_ -Recurse -Force }; Get-ChildItem -LiteralPath $publishDir -Recurse -File -Filter '*.pdb' | Remove-Item -Force; $createdumpPath = Join-Path $publishDir 'createdump.exe'; if (Test-Path -LiteralPath $createdumpPath) { Remove-Item -LiteralPath $createdumpPath -Force }; $runtimePackDlls = [System.Collections.Generic.HashSet[string]]::new([System.StringComparer]::OrdinalIgnoreCase); $depsFile = if ([string]::IsNullOrWhiteSpace($env:FLUXO_DEPS_FILE)) { [IO.Path]::ChangeExtension($env:FLUXO_TARGET_FILE_NAME, '.deps.json') } else { $env:FLUXO_DEPS_FILE }; $depsPath = Join-Path $publishDir $depsFile; if (Test-Path -LiteralPath $depsPath) { $deps = Get-Content -LiteralPath $depsPath -Raw | ConvertFrom-Json; $target = ($deps.targets.PSObject.Properties | Select-Object -Last 1).Value; foreach ($library in $deps.libraries.PSObject.Properties) { if ($library.Value.type -eq 'runtimepack') { $targetLibrary = $target.PSObject.Properties | Where-Object { $_.Name -eq $library.Name } | Select-Object -First 1; if ($null -ne $targetLibrary -and $null -ne $targetLibrary.Value.runtime) { foreach ($runtimeAsset in $targetLibrary.Value.runtime.PSObject.Properties) { if ([IO.Path]::GetExtension($runtimeAsset.Name) -eq '.dll') { [void]$runtimePackDlls.Add([IO.Path]::GetFileName($runtimeAsset.Name)) } } } } } }; Get-ChildItem -LiteralPath $publishDir -File -Filter '*.dll' | ForEach-Object { $isManaged = $true; try { [void][Reflection.AssemblyName]::GetAssemblyName($_.FullName) } catch { $isManaged = $false }; if ($isManaged -and !$runtimePackDlls.Contains($_.Name)) { $destinationDir = if ($_.Name -clike 'Fluxo*.dll') { $libsDir } elseif ($_.Name -ne $env:FLUXO_TARGET_FILE_NAME) { $vendorDir } else { $null }; if ($null -ne $destinationDir) { New-Item -ItemType Directory -Path $destinationDir -Force | Out-Null; Move-Item -LiteralPath $_.FullName -Destination $destinationDir -Force } } }&quot;"
          EnvironmentVariables="FLUXO_PUBLISH_DIR=$(PublishDir);FLUXO_TARGET_FILE_NAME=$(TargetFileName);FLUXO_DEPS_FILE=$(ProjectDepsFileName)"
          Condition="Exists('$(PublishDir)')" />
  </Target>

  <Target Name="CleanupOutputAfterBuild" AfterTargets="OrganizeOutputAfterBuild" Condition="'$(DesignTimeBuild)' != 'true'">
    <ItemGroup Condition="Exists('$(TargetDir)')">
      <BuildArtifactsToDelete Include="$(TargetDir)*.pdb" />
    </ItemGroup>

    <Delete Files="@(BuildArtifactsToDelete)" />
  </Target>

</Project>
