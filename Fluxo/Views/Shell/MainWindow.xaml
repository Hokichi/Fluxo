<Window
    x:Class="Fluxo.Views.Shell.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:c="clr-namespace:Fluxo.Resources.CustomControls"
    xmlns:components="clr-namespace:Fluxo.Views.Components"
    xmlns:coreEnums="clr-namespace:Fluxo.Core.Enums;assembly=Fluxo.Core"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:icons="http://metro.mahapps.com/winfx/xaml/iconpacks"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
    Title="MainWindow"
    Width="1600"
    Height="900"
    MinWidth="1600"
    MinHeight="900"
    AllowsTransparency="True"
    Background="Transparent"
    WindowStartupLocation="CenterScreen"
    WindowStyle="None"
    mc:Ignorable="d">

    <Window.CommandBindings>
        <CommandBinding Command="{x:Static SystemCommands.CloseWindowCommand}" Executed="OnCloseWindow" />
        <CommandBinding Command="{x:Static SystemCommands.MinimizeWindowCommand}" Executed="OnMinimizeWindow" />
        <CommandBinding Command="{x:Static SystemCommands.MaximizeWindowCommand}" Executed="OnMaximizeWindow" />
        <CommandBinding Command="{x:Static SystemCommands.RestoreWindowCommand}" Executed="OnRestoreWindow" />
    </Window.CommandBindings>

    <Window.Resources>
        <Style
            x:Key="HeaderButtonStyle"
            BasedOn="{StaticResource {x:Type c:BalloonButton}}"
            TargetType="c:BalloonButton">
            <Setter Property="Width" Value="28" />
            <Setter Property="Height" Value="{Binding RelativeSource={RelativeSource Self}, Path=Width}" />
            <Setter Property="Margin" Value="8,0,0,0" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="CurveHeight" Value="8" />
            <Setter Property="DefaultBackground" Value="{StaticResource Brush.Background.Surface}" />
            <Setter Property="IconSize" Value="8" />
        </Style>

        <Style x:Key="HeaderText" TargetType="TextBlock">
            <Setter Property="HorizontalAlignment" Value="Left" />
            <Setter Property="FontFamily" Value="{StaticResource Bold}" />
            <Setter Property="FontSize" Value="18" />
            <Setter Property="Foreground" Value="{StaticResource Brush.Text.Primary}" />
        </Style>

        <Style x:Key="ListViewItemStyle" TargetType="ListViewItem">
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0,0,0,12" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="VerticalContentAlignment" Value="Stretch" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListViewItem">
                        <ContentPresenter />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DaysOfWeekStyle" TargetType="ListViewItem">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListViewItem">
                        <RadioButton GroupName="DaysOfWeek" IsChecked="{Binding IsSelected}">
                            <RadioButton.Template>
                                <ControlTemplate TargetType="RadioButton">
                                    <Grid>
                                        <StackPanel
                                            Width="48"
                                            VerticalAlignment="Center"
                                            Background="Transparent">
                                            <TextBlock
                                                x:Name="DayOfWeekName"
                                                Margin="0,0,0,6"
                                                HorizontalAlignment="Center"
                                                VerticalAlignment="Center"
                                                FontFamily="{StaticResource Bold}"
                                                FontSize="12"
                                                Text="{Binding DayName}">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Foreground" Value="{StaticResource Brush.Text.Muted}" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                                <Setter Property="Foreground" Value="{StaticResource Brush.Mint}" />
                                                                <Setter Property="Effect">
                                                                    <Setter.Value>
                                                                        <DropShadowEffect
                                                                            BlurRadius="5"
                                                                            Opacity="0.5"
                                                                            ShadowDepth="0"
                                                                            Color="{StaticResource Color.Mint}" />
                                                                    </Setter.Value>
                                                                </Setter>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                            <TextBlock
                                                x:Name="DayOfWeekDate"
                                                Margin="0,0,0,8"
                                                HorizontalAlignment="Center"
                                                VerticalAlignment="Center"
                                                FontFamily="{StaticResource Black}"
                                                FontSize="14"
                                                Text="{Binding DayNumber}">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Foreground" Value="{StaticResource Brush.Text.Muted}" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                                <Setter Property="Foreground" Value="{StaticResource Brush.Text.Primary}" />
                                                                <Setter Property="Effect">
                                                                    <Setter.Value>
                                                                        <DropShadowEffect
                                                                            BlurRadius="5"
                                                                            Opacity="0.5"
                                                                            ShadowDepth="0"
                                                                            Color="{StaticResource Color.Text.Primary}" />
                                                                    </Setter.Value>
                                                                </Setter>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </StackPanel>
                                        <Border
                                            Width="32"
                                            Height="4"
                                            VerticalAlignment="Bottom"
                                            Background="{StaticResource Brush.Mint}"
                                            CornerRadius="4 4 0 0">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Opacity" Value="0" />
                                                    <Style.Triggers>
                                                        <MultiDataTrigger>
                                                            <MultiDataTrigger.Conditions>
                                                                <Condition Binding="{Binding IsSelected}" Value="False" />
                                                                <Condition Binding="{Binding IsMouseOver, RelativeSource={RelativeSource AncestorType=RadioButton}}" Value="True" />
                                                            </MultiDataTrigger.Conditions>
                                                            <MultiDataTrigger.EnterActions>
                                                                <BeginStoryboard>
                                                                    <Storyboard>
                                                                        <DoubleAnimation
                                                                            Storyboard.TargetProperty="Opacity"
                                                                            To="0.5"
                                                                            Duration="0:0:0.2" />
                                                                    </Storyboard>
                                                                </BeginStoryboard>
                                                            </MultiDataTrigger.EnterActions>
                                                            <MultiDataTrigger.ExitActions>
                                                                <BeginStoryboard x:Name="HoverExitStoryboard">
                                                                    <Storyboard>
                                                                        <DoubleAnimation
                                                                            Storyboard.TargetProperty="Opacity"
                                                                            To="0"
                                                                            Duration="0:0:0.2" />
                                                                    </Storyboard>
                                                                </BeginStoryboard>
                                                            </MultiDataTrigger.ExitActions>
                                                        </MultiDataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <Border.Effect>
                                                <DropShadowEffect
                                                    BlurRadius="10"
                                                    ShadowDepth="0"
                                                    Color="{StaticResource Color.Mint}" />
                                            </Border.Effect>
                                        </Border>

                                        <Border
                                            Width="32"
                                            Height="4"
                                            VerticalAlignment="Bottom"
                                            Background="{StaticResource Brush.Mint}"
                                            CornerRadius="4 4 0 0">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Opacity" Value="0" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                            <DataTrigger.EnterActions>
                                                                <BeginStoryboard>
                                                                    <Storyboard>
                                                                        <DoubleAnimation
                                                                            Storyboard.TargetProperty="Opacity"
                                                                            To="1"
                                                                            Duration="0:0:0.1" />
                                                                    </Storyboard>
                                                                </BeginStoryboard>
                                                            </DataTrigger.EnterActions>
                                                            <DataTrigger.ExitActions>
                                                                <BeginStoryboard x:Name="HoverExitStoryboard">
                                                                    <Storyboard>
                                                                        <DoubleAnimation
                                                                            Storyboard.TargetProperty="Opacity"
                                                                            To="0"
                                                                            Duration="0:0:0.1" />
                                                                    </Storyboard>
                                                                </BeginStoryboard>
                                                            </DataTrigger.ExitActions>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <Border.Effect>
                                                <DropShadowEffect
                                                    BlurRadius="10"
                                                    ShadowDepth="0"
                                                    Color="{StaticResource Color.Mint}" />
                                            </Border.Effect>
                                        </Border>
                                    </Grid>
                                </ControlTemplate>
                            </RadioButton.Template>
                        </RadioButton>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <DataTemplate x:Key="ExpenseListTemplate">
            <Grid>
                <Border
                    x:Name="ExpenseItemBGBorder"
                    Padding="12,10"
                    Background="{StaticResource Brush.Background.Hover}"
                    CornerRadius="12"
                    Visibility="{Binding RelativeSource={RelativeSource FindAncestor, AncestorType=ListViewItem}, Path=IsMouseOver, Converter={StaticResource BoolToVisibilityConverter}}" />
                <Border
                    x:Name="ExpenseItemBorder"
                    Padding="12,10"
                    Background="Transparent"
                    CornerRadius="12">
                    <Grid
                        MaxWidth="{Binding RelativeSource={RelativeSource AncestorType=ListView}, Path=ActualWidth}"
                        HorizontalAlignment="Stretch"
                        ClipToBounds="True">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Margin="0,0,8,0" HorizontalAlignment="Stretch">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock
                                    VerticalAlignment="Center"
                                    FontFamily="{StaticResource Bold}"
                                    FontSize="13"
                                    Foreground="{StaticResource Brush.Text.Primary}"
                                    Text="{Binding Expense.Name}"
                                    TextTrimming="CharacterEllipsis"
                                    TextWrapping="NoWrap" />
                            </StackPanel>
                            <StackPanel Margin="0,8,0,0" Orientation="Horizontal">
                                <TextBlock
                                    FontFamily="{StaticResource Regular}"
                                    FontSize="10"
                                    Foreground="{StaticResource Brush.Text.Muted}"
                                    Text="{Binding DeductedOn, Converter={StaticResource DateTimeToRelativeDateConverter}}" />

                                <Border
                                    x:Name="ExpenseTagBorder"
                                    Margin="8,0,0,0"
                                    Padding="5,2"
                                    VerticalAlignment="Center"
                                    Background="{Binding Expense.ExpenseTag.HexCode}">
                                    <Border.CornerRadius>
                                        <MultiBinding Converter="{StaticResource CornerRadiusConverter}">
                                            <Binding Path="ActualWidth" RelativeSource="{RelativeSource Self}" />
                                            <Binding Path="ActualHeight" RelativeSource="{RelativeSource Self}" />
                                        </MultiBinding>
                                    </Border.CornerRadius>
                                    <TextBlock
                                        VerticalAlignment="Center"
                                        FontFamily="{StaticResource Medium}"
                                        FontSize="10"
                                        Foreground="{Binding Expense.ExpenseTag.HexCode, Converter={StaticResource BrushToLighterBrushConverter}}"
                                        Text="{Binding Expense.ExpenseTag.Name}" />
                                </Border>
                            </StackPanel>
                        </StackPanel>

                        <StackPanel
                            Grid.Column="1"
                            MinWidth="0"
                            HorizontalAlignment="Right">
                            <TextBlock
                                HorizontalAlignment="Right"
                                FontFamily="{StaticResource Bold}"
                                FontSize="13"
                                Foreground="{StaticResource Brush.Text.Primary}"
                                Text="{Binding Amount, Converter={StaticResource NumberWithCommasConverter}, StringFormat={}${0}}" />
                            <TextBlock
                                MaxWidth="120"
                                Margin="0,8,0,0"
                                HorizontalAlignment="Right"
                                FontFamily="{StaticResource Regular}"
                                FontSize="10"
                                Foreground="{StaticResource Brush.Text.Muted}"
                                Text="{Binding SpendingSource.Name}"
                                TextTrimming="CharacterEllipsis"
                                TextWrapping="NoWrap" />
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>
        </DataTemplate>

        <DataTemplate x:Key="Tags">
            <Grid>
                <Border
                    Height="24"
                    Margin="16,0,0,0"
                    Padding="12,0"
                    Background="{StaticResource Brush.Background.Surface}"
                    BorderBrush="{StaticResource Brush.Border.Subtle}"
                    BorderThickness="1"
                    CornerRadius="12"
                    Visibility="{Binding RelativeSource={RelativeSource FindAncestor, AncestorType=ListViewItem}, Path=IsSelected, Converter={StaticResource BoolToVisibilityInvertedConverter}}">
                    <StackPanel Orientation="Horizontal">
                        <Ellipse
                            Width="8"
                            Height="8"
                            Fill="{Binding HexCode}" />

                        <TextBlock
                            Margin="8,0,0,0"
                            VerticalAlignment="Center"
                            FontFamily="{StaticResource Bold}"
                            Foreground="{StaticResource Brush.Text.Primary}"
                            Text="{Binding Name}" />
                    </StackPanel>
                </Border>

                <Border
                    Height="24"
                    Margin="16,0,0,0"
                    Padding="12,0"
                    Background="{Binding HexCode}"
                    BorderThickness="1"
                    CornerRadius="12"
                    Visibility="{Binding RelativeSource={RelativeSource FindAncestor, AncestorType=ListViewItem}, Path=IsSelected, Converter={StaticResource BoolToVisibilityConverter}}">
                    <StackPanel Orientation="Horizontal">
                        <Ellipse
                            Width="8"
                            Height="8"
                            Fill="{StaticResource Brush.Background.Surface}" />

                        <TextBlock
                            Margin="8,0,0,0"
                            VerticalAlignment="Center"
                            FontFamily="{StaticResource Bold}"
                            Foreground="{StaticResource Brush.Background.Surface}"
                            Text="{Binding Name}" />
                    </StackPanel>
                </Border>
            </Grid>
        </DataTemplate>
    </Window.Resources>

    <Border
        Background="{StaticResource Brush.Background.Main}"
        CornerRadius="16"
        MouseMove="MainWindow_OnMouseMove">
        <Grid Margin="0,16,0,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="60" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Margin="24,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <StackPanel
                    Margin="32,0,0,0"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Center"
                    Orientation="Horizontal">
                    <icons:PackIconMaterialDesign
                        Width="24"
                        Height="{Binding RelativeSource={RelativeSource Self}, Path=Width}"
                        VerticalAlignment="Center"
                        Foreground="{StaticResource Brush.Mint}"
                        Kind="AccountBalanceWallet" />

                    <TextBlock
                        Margin="12,1,0,0"
                        VerticalAlignment="Center"
                        FontFamily="{StaticResource Bold}"
                        FontSize="18"
                        Foreground="{StaticResource Brush.Text.Primary}"
                        Text="Fluxo" />

                    <Border
                        Width="1"
                        Height="32"
                        Margin="24,0"
                        Background="{StaticResource Brush.Text.Muted}" />
                </StackPanel>

                <Grid Grid.Column="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="40" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="40" />
                    </Grid.ColumnDefinitions>

                    <icons:PackIconUnicons
                        Height="12"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Center"
                        Foreground="{StaticResource Brush.Text.Muted}"
                        Kind="AngleLeft" />

                    <ListView
                        Grid.Column="1"
                        HorizontalAlignment="Center"
                        shell:WindowChrome.IsHitTestVisibleInChrome="True"
                        Background="Transparent"
                        BorderBrush="Transparent"
                        BorderThickness="0"
                        ItemContainerStyle="{StaticResource DaysOfWeekStyle}"
                        ItemsSource="{Binding DaysOfWeek}"
                        SelectedItem="{Binding SelectedDay}">
                        <ListView.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Horizontal" />
                            </ItemsPanelTemplate>
                        </ListView.ItemsPanel>
                    </ListView>

                    <icons:PackIconUnicons
                        Grid.Column="2"
                        Height="12"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center"
                        Foreground="{StaticResource Brush.Text.Muted}"
                        Kind="AngleRight" />
                </Grid>

                <StackPanel
                    Grid.Column="2"
                    HorizontalAlignment="Right"
                    Orientation="Horizontal">
                    <c:BalloonButton
                        ButtonIcon="{StaticResource Cog}"
                        CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=Window}}"
                        HoveredBackground="{StaticResource Brush.Primary.Hover}"
                        IconSize="12"
                        Style="{StaticResource HeaderButtonStyle}" />

                    <c:BalloonButton
                        ButtonIcon="{StaticResource RegularBell}"
                        CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=Window}}"
                        HoveredBackground="{StaticResource Brush.Primary.Hover}"
                        IconSize="12"
                        Style="{StaticResource HeaderButtonStyle}" />

                    <Border
                        Width="2"
                        Height="24"
                        Margin="8,0,0,0"
                        Background="{StaticResource Brush.Text.Muted}" />

                    <c:BalloonButton
                        ButtonIcon="{StaticResource Minus}"
                        Command="{x:Static SystemCommands.MinimizeWindowCommand}"
                        CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=Window}}"
                        HoveredBackground="{StaticResource Brush.Primary.Hover}"
                        Style="{StaticResource HeaderButtonStyle}" />

                    <c:BalloonButton
                        x:Name="ExpandRestoreButton"
                        ButtonIcon="{StaticResource ExpandAlt}"
                        Click="OnExpandRestoreWindow"
                        HoveredBackground="{StaticResource Brush.Primary.Hover}"
                        Style="{StaticResource HeaderButtonStyle}" />

                    <c:BalloonButton
                        ButtonIcon="{StaticResource Close}"
                        Command="{x:Static SystemCommands.CloseWindowCommand}"
                        CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=Window}}"
                        HoveredBackground="{StaticResource Brush.Danger}"
                        Style="{StaticResource HeaderButtonStyle}" />
                </StackPanel>
            </Grid>

            <Grid
                x:Name="MainContentGrid"
                Grid.Row="1"
                Margin="80,48">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="240" />
                </Grid.ColumnDefinitions>

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <TextBlock Style="{StaticResource HeaderText}" Text="Accounts &amp; Income" />

                    <c:FadingScrollViewer
                        Grid.Row="1"
                        Margin="0,20,0,0"
                        HorizontalAlignment="Stretch"
                        CanContentScroll="False"
                        HorizontalScrollBarVisibility="Auto"
                        VerticalScrollBarVisibility="Disabled">
                        <StackPanel Orientation="Horizontal">
                            <ListView
                                HorizontalAlignment="Left"
                                Background="Transparent"
                                BorderBrush="Transparent"
                                BorderThickness="0"
                                ItemsSource="{Binding SpendingSources}"
                                ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                ScrollViewer.VerticalScrollBarVisibility="Disabled">
                                <ListView.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <StackPanel Orientation="Horizontal" />
                                    </ItemsPanelTemplate>
                                </ListView.ItemsPanel>
                                <ListView.ItemContainerStyle>
                                    <Style TargetType="ListViewItem">
                                        <Setter Property="Margin" Value="0,0,8,0" />
                                        <Setter Property="Padding" Value="0" />
                                        <Setter Property="Background" Value="Transparent" />
                                        <Setter Property="BorderThickness" Value="0" />
                                        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                        <Setter Property="VerticalContentAlignment" Value="Stretch" />
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="ListViewItem">
                                                    <ContentPresenter />
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding ShowOnUI}" Value="False">
                                                <Setter Property="Margin" Value="0" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </ListView.ItemContainerStyle>
                                <ListView.ItemTemplate>
                                    <DataTemplate>
                                        <components:IncomeSource />
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>

                            <Grid Width="80" Height="100">
                                <Rectangle
                                    RadiusX="16"
                                    RadiusY="16"
                                    Stroke="{StaticResource Brush.Text.Muted}"
                                    StrokeDashArray="5"
                                    StrokeThickness="1" />

                                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <icons:PackIconEntypo
                                        Width="24"
                                        Height="24"
                                        Margin="0,0,0,8"
                                        HorizontalAlignment="Center"
                                        Foreground="{StaticResource Brush.Text.Muted}"
                                        Kind="CircleWithPlus" />

                                    <TextBlock
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        FontFamily="{StaticResource Bold}"
                                        FontSize="12"
                                        Foreground="{StaticResource Brush.Text.Muted}"
                                        Text="Add" />
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </c:FadingScrollViewer>

                    <StackPanel Grid.Row="3" Orientation="Horizontal">
                        <!--  "All" tag button  -->
                        <Grid Margin="16,0,0,0" VerticalAlignment="Center">
                            <!--  Unselected state (outlined) - visible when a tag IS selected  -->
                            <Border
                                x:Name="AllTagUnselected"
                                Height="24"
                                Padding="12,0"
                                Background="{StaticResource Brush.Background.Surface}"
                                BorderBrush="{StaticResource Brush.Border.Subtle}"
                                BorderThickness="1"
                                CornerRadius="12"
                                Cursor="Hand">
                                <Border.InputBindings>
                                    <MouseBinding Command="{Binding ClearSelectedTagCommand}" MouseAction="LeftClick" />
                                </Border.InputBindings>
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Visibility" Value="Visible" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding SelectedTag}" Value="{x:Null}">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <TextBlock
                                    VerticalAlignment="Center"
                                    FontFamily="{StaticResource Bold}"
                                    Foreground="{StaticResource Brush.Text.Primary}"
                                    Text="All" />
                            </Border>

                            <!--  Selected state (filled) - visible when NO tag is selected  -->
                            <Border
                                x:Name="AllTagSelected"
                                Height="24"
                                Padding="12,0"
                                Background="{StaticResource Brush.Mint}"
                                BorderThickness="1"
                                CornerRadius="12"
                                Cursor="Hand">
                                <Border.InputBindings>
                                    <MouseBinding Command="{Binding ClearSelectedTagCommand}" MouseAction="LeftClick" />
                                </Border.InputBindings>
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding SelectedTag}" Value="{x:Null}">
                                                <Setter Property="Visibility" Value="Visible" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <TextBlock
                                    VerticalAlignment="Center"
                                    FontFamily="{StaticResource Bold}"
                                    Foreground="{StaticResource Brush.Background.Surface}"
                                    Text="All" />
                            </Border>
                        </Grid>

                        <ListView
                            Margin="0,12,0,0"
                            VerticalAlignment="Center"
                            Background="Transparent"
                            BorderThickness="0"
                            ItemContainerStyle="{StaticResource ListViewItemStyle}"
                            ItemTemplate="{StaticResource Tags}"
                            ItemsSource="{Binding Tags}"
                            PreviewMouseLeftButtonDown="OnTagListPreviewMouseLeftButtonDown"
                            ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                            SelectedItem="{Binding SelectedTag}">
                            <ListView.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Orientation="Horizontal" />
                                </ItemsPanelTemplate>
                            </ListView.ItemsPanel>
                        </ListView>
                    </StackPanel>

                    <Grid Grid.Row="4" Margin="0,8,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition />
                            <ColumnDefinition Width="16" />
                            <ColumnDefinition />
                            <ColumnDefinition Width="16" />
                            <ColumnDefinition />
                        </Grid.ColumnDefinitions>

                        <components:ExpensesList
                            Title="NEEDS"
                            DotColor="{StaticResource Brush.Category.Needs}"
                            IsListEmpty="{Binding IsNeedsEmpty}"
                            ItemsSource="{Binding Needs}" />

                        <components:ExpensesList
                            Title="WANTS"
                            Grid.Column="2"
                            DotColor="{StaticResource Brush.Category.Wants}"
                            IsListEmpty="{Binding IsWantsEmpty}"
                            ItemsSource="{Binding Wants}" />

                        <components:ExpensesList
                            Title="INVEST &amp; SAVINGS"
                            Grid.Column="4"
                            DotColor="{StaticResource Brush.Category.Investments}"
                            IsListEmpty="{Binding IsWantsEmpty}"
                            ItemsSource="{Binding Invest}" />
                    </Grid>
                </Grid>
            </Grid>
        </Grid>
    </Border>
</Window>