<Window
    x:Class="Fluxo.Views.Shell.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:c="clr-namespace:Fluxo.Resources.CustomControls"
    xmlns:components="clr-namespace:Fluxo.Views.Components"
    xmlns:coreEnums="clr-namespace:Fluxo.Core.Enums;assembly=Fluxo.Core"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:icons="http://metro.mahapps.com/winfx/xaml/iconpacks"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
    xmlns:viewModels="clr-namespace:Fluxo.ViewModels.Shell"
    Title="MainWindow"
    Width="1600"
    Height="900"
    MinWidth="1600"
    MinHeight="900"
    AllowsTransparency="True"
    Background="Transparent"
    WindowStartupLocation="CenterScreen"
    WindowStyle="None"
    mc:Ignorable="d">

    <Window.CommandBindings>
        <CommandBinding Command="{x:Static SystemCommands.CloseWindowCommand}" Executed="OnCloseWindow" />
        <CommandBinding Command="{x:Static SystemCommands.MinimizeWindowCommand}" Executed="OnMinimizeWindow" />
        <CommandBinding Command="{x:Static SystemCommands.MaximizeWindowCommand}" Executed="OnMaximizeWindow" />
        <CommandBinding Command="{x:Static SystemCommands.RestoreWindowCommand}" Executed="OnRestoreWindow" />
    </Window.CommandBindings>

    <Window.Resources>
        <Style
            x:Key="HeaderButtonStyle"
            BasedOn="{StaticResource {x:Type c:BalloonButton}}"
            TargetType="c:BalloonButton">
            <Setter Property="Width" Value="28" />
            <Setter Property="Height" Value="{Binding RelativeSource={RelativeSource Self}, Path=Width}" />
            <Setter Property="Margin" Value="8,0,0,0" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="CurveHeight" Value="8" />
            <Setter Property="DefaultBackground" Value="{StaticResource Brush.Background.Surface}" />
            <Setter Property="IconSize" Value="8" />
        </Style>

        <Style x:Key="HeaderText" TargetType="TextBlock">
            <Setter Property="HorizontalAlignment" Value="Left" />
            <Setter Property="FontFamily" Value="{StaticResource Bold}" />
            <Setter Property="FontSize" Value="18" />
            <Setter Property="Foreground" Value="{StaticResource Brush.Text.Primary}" />
        </Style>

        <Style x:Key="ListViewItemStyle" TargetType="ListViewItem">
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0,0,0,12" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="VerticalContentAlignment" Value="Stretch" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListViewItem">
                        <ContentPresenter />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="NotificationAccentStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource Brush.Info}" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding Severity}" Value="{x:Static coreEnums:NotificationSeverity.Success}">
                    <Setter Property="Background" Value="{StaticResource Brush.Success}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Severity}" Value="{x:Static coreEnums:NotificationSeverity.Warning}">
                    <Setter Property="Background" Value="{StaticResource Brush.Warning}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Severity}" Value="{x:Static coreEnums:NotificationSeverity.Danger}">
                    <Setter Property="Background" Value="{StaticResource Brush.Danger}" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="NotificationActionButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Foreground" Value="{StaticResource Brush.Text.Secondary}" />
            <Setter Property="FontFamily" Value="{StaticResource Medium}" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <ContentPresenter />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Foreground" Value="{StaticResource Brush.Text.Primary}" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <DataTemplate x:Key="NotificationTemplate">
            <Border
                Margin="0,0,0,12"
                Padding="12"
                Background="{StaticResource Brush.Background.Hover}"
                BorderBrush="{StaticResource Brush.Border.Subtle}"
                BorderThickness="1"
                CornerRadius="16">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="4" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <Border
                        Margin="0,0,12,0"
                        CornerRadius="999"
                        Style="{StaticResource NotificationAccentStyle}" />

                    <StackPanel Grid.Column="1">
                        <TextBlock
                            FontFamily="{StaticResource Bold}"
                            FontSize="12"
                            Foreground="{StaticResource Brush.Text.Primary}"
                            Text="{Binding Title}"
                            TextWrapping="Wrap" />
                        <TextBlock
                            Margin="0,6,0,0"
                            FontFamily="{StaticResource Regular}"
                            FontSize="11"
                            Foreground="{StaticResource Brush.Text.Secondary}"
                            Text="{Binding Message}"
                            TextWrapping="Wrap" />
                        <TextBlock
                            Margin="0,10,0,0"
                            FontFamily="{StaticResource Medium}"
                            FontSize="10"
                            Foreground="{StaticResource Brush.Text.Muted}"
                            Text="{Binding CreatedOn, StringFormat={}{0:MMM d, h:mm tt}}" />
                    </StackPanel>

                    <Button
                        Grid.Column="2"
                        Margin="12,0,0,0"
                        VerticalAlignment="Top"
                        Command="{Binding DataContext.DismissNotificationCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                        CommandParameter="{Binding}"
                        Content="Dismiss"
                        Style="{StaticResource NotificationActionButtonStyle}" />
                </Grid>
            </Border>
        </DataTemplate>

        <Style x:Key="DashboardPanelStyle" TargetType="Border">
            <Setter Property="Padding" Value="16" />
            <Setter Property="Background" Value="{StaticResource Brush.Background.Elevated}" />
            <Setter Property="BorderBrush" Value="{StaticResource Brush.Border.Subtle}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="16" />
        </Style>

        <Style x:Key="DashboardCountBadgeStyle" TargetType="Border">
            <Setter Property="Padding" Value="8,4" />
            <Setter Property="Background" Value="{StaticResource Brush.Background.Hover}" />
            <Setter Property="BorderBrush" Value="{StaticResource Brush.Border.Subtle}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="999" />
        </Style>

        <SolidColorBrush
            x:Key="MainContentViewToggleSelectedBackgroundBrush"
            Opacity="0.16"
            Color="{StaticResource Color.Mint}" />

        <Style x:Key="MainContentViewToggleButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Foreground" Value="{StaticResource Brush.Text.Muted}" />
            <Setter Property="FontFamily" Value="{StaticResource Bold}" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="Width" Value="80" />
            <Setter Property="Padding" Value="14,6" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="10">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource Brush.Background.Hover}" />
                    <Setter Property="Foreground" Value="{StaticResource Brush.Text.Primary}" />
                </Trigger>
                <DataTrigger Binding="{Binding Tag, RelativeSource={RelativeSource Self}}" Value="True">
                    <Setter Property="Background" Value="{StaticResource MainContentViewToggleSelectedBackgroundBrush}" />
                    <Setter Property="Foreground" Value="{StaticResource Brush.Mint}" />
                </DataTrigger>
                <MultiDataTrigger>
                    <MultiDataTrigger.Conditions>
                        <Condition Binding="{Binding Tag, RelativeSource={RelativeSource Self}}" Value="True" />
                        <Condition Binding="{Binding IsMouseOver, RelativeSource={RelativeSource Self}}" Value="True" />
                    </MultiDataTrigger.Conditions>
                    <Setter Property="Background" Value="{StaticResource MainContentViewToggleSelectedBackgroundBrush}" />
                    <Setter Property="Foreground" Value="{StaticResource Brush.Mint}" />
                </MultiDataTrigger>
            </Style.Triggers>
        </Style>

        <DataTemplate x:Key="DashboardNotificationTemplate">
            <Border
                Margin="0,0,0,10"
                Padding="10"
                Background="{StaticResource Brush.Background.Hover}"
                BorderBrush="{StaticResource Brush.Border.Subtle}"
                BorderThickness="1"
                CornerRadius="16">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="4" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Border
                        Margin="0,0,10,0"
                        CornerRadius="999"
                        Style="{StaticResource NotificationAccentStyle}" />

                    <StackPanel Grid.Column="1">
                        <TextBlock
                            FontFamily="{StaticResource Bold}"
                            FontSize="11"
                            Foreground="{StaticResource Brush.Text.Primary}"
                            Text="{Binding Title}"
                            TextWrapping="Wrap" />
                        <TextBlock
                            Margin="0,6,0,0"
                            FontFamily="{StaticResource Regular}"
                            FontSize="10"
                            Foreground="{StaticResource Brush.Text.Secondary}"
                            Text="{Binding Message}"
                            TextWrapping="Wrap" />
                        <TextBlock
                            Margin="0,8,0,0"
                            FontFamily="{StaticResource Medium}"
                            FontSize="9"
                            Foreground="{StaticResource Brush.Text.Muted}"
                            Text="{Binding CreatedOn, StringFormat={}{0:MMM d, h:mm tt}}" />
                    </StackPanel>
                </Grid>
            </Border>
        </DataTemplate>

        <DataTemplate x:Key="SavingGoalTemplate">
            <Border
                Margin="0,0,0,12"
                Padding="12"
                Background="{StaticResource Brush.Background.Hover}"
                BorderBrush="{StaticResource Brush.Border.Subtle}"
                BorderThickness="1"
                CornerRadius="8">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="12" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Grid Width="64" Height="64">
                        <Canvas
                            Width="56"
                            Height="56"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center">
                            <Ellipse
                                Canvas.Left="4"
                                Canvas.Top="4"
                                Width="48"
                                Height="48"
                                Stroke="{StaticResource Brush.Background.Surface}"
                                StrokeThickness="8" />
                            <Path
                                Canvas.Left="4"
                                Canvas.Top="4"
                                Data="{Binding ProgressRatio, Converter={StaticResource ProgressToArcGeometryConverter}, ConverterParameter=48}"
                                Stroke="{StaticResource Brush.Mint}"
                                StrokeEndLineCap="Round"
                                StrokeLineJoin="Round"
                                StrokeStartLineCap="Round"
                                StrokeThickness="8" />
                        </Canvas>

                        <TextBlock
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            FontFamily="{StaticResource Bold}"
                            FontSize="12"
                            Foreground="{StaticResource Brush.Text.Primary}"
                            Text="{Binding ProgressPercentage, StringFormat={}{0}%}" />
                    </Grid>

                    <StackPanel Grid.Column="2" VerticalAlignment="Center">
                        <TextBlock
                            FontFamily="{StaticResource Bold}"
                            FontSize="13"
                            Foreground="{StaticResource Brush.Text.Primary}"
                            Text="{Binding Name}"
                            TextWrapping="Wrap" />
                        <TextBlock
                            Margin="0,8,0,0"
                            FontFamily="{StaticResource Medium}"
                            FontSize="11"
                            Foreground="{StaticResource Brush.Text.Secondary}">
                            <Run Text="$" />
                            <Run Text="{Binding CurrentAmount, Converter={StaticResource NumberWithCommasConverter}}" />
                            <Run Text="/" />
                            <Run Text="$" />
                            <Run Text="{Binding TargetAmount, Converter={StaticResource NumberWithCommasConverter}}" />
                        </TextBlock>
                    </StackPanel>
                </Grid>
            </Border>
        </DataTemplate>

        <Style x:Key="DaysOfWeekStyle" TargetType="ListViewItem">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListViewItem">
                        <RadioButton GroupName="DaysOfWeek" IsChecked="{Binding IsSelected}">
                            <RadioButton.Template>
                                <ControlTemplate TargetType="RadioButton">
                                    <Grid>
                                        <StackPanel
                                            Width="48"
                                            VerticalAlignment="Center"
                                            Background="Transparent">
                                            <TextBlock
                                                x:Name="DayOfWeekName"
                                                Margin="0,0,0,6"
                                                HorizontalAlignment="Center"
                                                VerticalAlignment="Center"
                                                FontFamily="{StaticResource Bold}"
                                                FontSize="12"
                                                Text="{Binding DayName}">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Foreground" Value="{StaticResource Brush.Text.Muted}" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                                <Setter Property="Foreground" Value="{StaticResource Brush.Mint}" />
                                                                <Setter Property="Effect">
                                                                    <Setter.Value>
                                                                        <DropShadowEffect
                                                                            BlurRadius="5"
                                                                            Opacity="0.5"
                                                                            ShadowDepth="0"
                                                                            Color="{StaticResource Color.Mint}" />
                                                                    </Setter.Value>
                                                                </Setter>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                            <TextBlock
                                                x:Name="DayOfWeekDate"
                                                Margin="0,0,0,8"
                                                HorizontalAlignment="Center"
                                                VerticalAlignment="Center"
                                                FontFamily="{StaticResource Black}"
                                                FontSize="14"
                                                Text="{Binding DayNumber}">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Foreground" Value="{StaticResource Brush.Text.Muted}" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                                <Setter Property="Foreground" Value="{StaticResource Brush.Text.Primary}" />
                                                                <Setter Property="Effect">
                                                                    <Setter.Value>
                                                                        <DropShadowEffect
                                                                            BlurRadius="5"
                                                                            Opacity="0.5"
                                                                            ShadowDepth="0"
                                                                            Color="{StaticResource Color.Text.Primary}" />
                                                                    </Setter.Value>
                                                                </Setter>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </StackPanel>
                                        <Border
                                            Width="32"
                                            Height="4"
                                            VerticalAlignment="Bottom"
                                            Background="{StaticResource Brush.Mint}"
                                            CornerRadius="4 4 0 0">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Opacity" Value="0" />
                                                    <Style.Triggers>
                                                        <MultiDataTrigger>
                                                            <MultiDataTrigger.Conditions>
                                                                <Condition Binding="{Binding IsSelected}" Value="False" />
                                                                <Condition Binding="{Binding IsMouseOver, RelativeSource={RelativeSource AncestorType=RadioButton}}" Value="True" />
                                                            </MultiDataTrigger.Conditions>
                                                            <MultiDataTrigger.EnterActions>
                                                                <BeginStoryboard>
                                                                    <Storyboard>
                                                                        <DoubleAnimation
                                                                            Storyboard.TargetProperty="Opacity"
                                                                            To="0.5"
                                                                            Duration="0:0:0.2" />
                                                                    </Storyboard>
                                                                </BeginStoryboard>
                                                            </MultiDataTrigger.EnterActions>
                                                            <MultiDataTrigger.ExitActions>
                                                                <BeginStoryboard x:Name="HoverExitStoryboard">
                                                                    <Storyboard>
                                                                        <DoubleAnimation
                                                                            Storyboard.TargetProperty="Opacity"
                                                                            To="0"
                                                                            Duration="0:0:0.2" />
                                                                    </Storyboard>
                                                                </BeginStoryboard>
                                                            </MultiDataTrigger.ExitActions>
                                                        </MultiDataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <Border.Effect>
                                                <DropShadowEffect
                                                    BlurRadius="10"
                                                    ShadowDepth="0"
                                                    Color="{StaticResource Color.Mint}" />
                                            </Border.Effect>
                                        </Border>

                                        <Border
                                            Width="32"
                                            Height="4"
                                            VerticalAlignment="Bottom"
                                            Background="{StaticResource Brush.Mint}"
                                            CornerRadius="4 4 0 0">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Opacity" Value="0" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                            <DataTrigger.EnterActions>
                                                                <BeginStoryboard>
                                                                    <Storyboard>
                                                                        <DoubleAnimation
                                                                            Storyboard.TargetProperty="Opacity"
                                                                            To="1"
                                                                            Duration="0:0:0.1" />
                                                                    </Storyboard>
                                                                </BeginStoryboard>
                                                            </DataTrigger.EnterActions>
                                                            <DataTrigger.ExitActions>
                                                                <BeginStoryboard x:Name="HoverExitStoryboard">
                                                                    <Storyboard>
                                                                        <DoubleAnimation
                                                                            Storyboard.TargetProperty="Opacity"
                                                                            To="0"
                                                                            Duration="0:0:0.1" />
                                                                    </Storyboard>
                                                                </BeginStoryboard>
                                                            </DataTrigger.ExitActions>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <Border.Effect>
                                                <DropShadowEffect
                                                    BlurRadius="10"
                                                    ShadowDepth="0"
                                                    Color="{StaticResource Color.Mint}" />
                                            </Border.Effect>
                                        </Border>
                                    </Grid>
                                </ControlTemplate>
                            </RadioButton.Template>
                        </RadioButton>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <DataTemplate x:Key="Tags">
            <Grid>
                <Border
                    Height="24"
                    Margin="16,0,0,0"
                    Padding="12,0"
                    Background="{StaticResource Brush.Background.Surface}"
                    BorderBrush="{StaticResource Brush.Border.Subtle}"
                    BorderThickness="1"
                    CornerRadius="12"
                    Visibility="{Binding RelativeSource={RelativeSource FindAncestor, AncestorType=ListViewItem}, Path=IsSelected, Converter={StaticResource BoolToVisibilityInvertedConverter}}">
                    <StackPanel Orientation="Horizontal">
                        <Ellipse
                            Width="8"
                            Height="8"
                            Fill="{Binding HexCode}" />

                        <TextBlock
                            Margin="8,0,0,0"
                            VerticalAlignment="Center"
                            FontFamily="{StaticResource Bold}"
                            Foreground="{StaticResource Brush.Text.Primary}"
                            Text="{Binding Name}" />
                    </StackPanel>
                </Border>

                <Border
                    Height="24"
                    Margin="16,0,0,0"
                    Padding="12,0"
                    Background="{Binding HexCode}"
                    BorderThickness="1"
                    CornerRadius="12"
                    Visibility="{Binding RelativeSource={RelativeSource FindAncestor, AncestorType=ListViewItem}, Path=IsSelected, Converter={StaticResource BoolToVisibilityConverter}}">
                    <StackPanel Orientation="Horizontal">
                        <Ellipse
                            Width="8"
                            Height="8"
                            Fill="{StaticResource Brush.Background.Surface}" />

                        <TextBlock
                            Margin="8,0,0,0"
                            VerticalAlignment="Center"
                            FontFamily="{StaticResource Bold}"
                            Foreground="{StaticResource Brush.Background.Surface}"
                            Text="{Binding Name}" />
                    </StackPanel>
                </Border>
            </Grid>
        </DataTemplate>
    </Window.Resources>

    <Border
        Background="{StaticResource Brush.Background.Main}"
        BorderBrush="{StaticResource Brush.Border.Subtle}"
        BorderThickness="1"
        CornerRadius="16"
        MouseMove="MainWindow_OnMouseMove">
        <Grid Margin="0,16,0,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="60" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Margin="24,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <StackPanel
                    Margin="32,0,0,0"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Center"
                    Orientation="Horizontal">
                    <icons:PackIconMaterialDesign
                        Width="24"
                        Height="{Binding RelativeSource={RelativeSource Self}, Path=Width}"
                        VerticalAlignment="Center"
                        Foreground="{StaticResource Brush.Mint}"
                        Kind="AccountBalanceWallet" />

                    <TextBlock
                        Margin="12,1,0,0"
                        VerticalAlignment="Center"
                        FontFamily="{StaticResource Bold}"
                        FontSize="18"
                        Foreground="{StaticResource Brush.Text.Primary}"
                        Text="Fluxo" />
                </StackPanel>

                <Grid Grid.Column="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="40" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="40" />
                    </Grid.ColumnDefinitions>

                    <icons:PackIconUnicons
                        Height="12"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Center"
                        Foreground="{StaticResource Brush.Text.Muted}"
                        Kind="AngleLeft" />

                    <ListView
                        Grid.Column="1"
                        HorizontalAlignment="Center"
                        shell:WindowChrome.IsHitTestVisibleInChrome="True"
                        Background="Transparent"
                        BorderBrush="Transparent"
                        BorderThickness="0"
                        ItemContainerStyle="{StaticResource DaysOfWeekStyle}"
                        ItemsSource="{Binding DaysOfWeek}"
                        SelectedItem="{Binding SelectedDay}">
                        <ListView.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Horizontal" />
                            </ItemsPanelTemplate>
                        </ListView.ItemsPanel>
                    </ListView>

                    <icons:PackIconUnicons
                        Grid.Column="2"
                        Height="12"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center"
                        Foreground="{StaticResource Brush.Text.Muted}"
                        Kind="AngleRight" />
                </Grid>

                <StackPanel
                    Grid.Column="2"
                    HorizontalAlignment="Right"
                    Orientation="Horizontal">
                    <c:BalloonButton
                        ButtonIcon="{StaticResource Cog}"
                        CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=Window}}"
                        HoveredBackground="{StaticResource Brush.Primary.Hover}"
                        IconSize="12"
                        Style="{StaticResource HeaderButtonStyle}" />

                    <c:BalloonButton
                        ButtonIcon="{StaticResource Minus}"
                        Command="{x:Static SystemCommands.MinimizeWindowCommand}"
                        CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=Window}}"
                        HoveredBackground="{StaticResource Brush.Primary.Hover}"
                        Style="{StaticResource HeaderButtonStyle}" />

                    <c:BalloonButton
                        x:Name="ExpandRestoreButton"
                        ButtonIcon="{StaticResource ExpandAlt}"
                        Click="OnExpandRestoreWindow"
                        HoveredBackground="{StaticResource Brush.Primary.Hover}"
                        Style="{StaticResource HeaderButtonStyle}" />

                    <c:BalloonButton
                        ButtonIcon="{StaticResource Close}"
                        Command="{x:Static SystemCommands.CloseWindowCommand}"
                        CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=Window}}"
                        HoveredBackground="{StaticResource Brush.Danger}"
                        Style="{StaticResource HeaderButtonStyle}" />
                </StackPanel>
            </Grid>

            <Border
                Grid.Row="1"
                Height="32"
                Margin="0,16"
                Padding="4"
                HorizontalAlignment="Center"
                VerticalAlignment="Top"
                Background="{StaticResource Brush.Background.Surface}"
                BorderBrush="{StaticResource Brush.Border.Subtle}"
                BorderThickness="1"
                CornerRadius="14">
                <StackPanel Orientation="Horizontal">
                    <Button
                        Command="{Binding SetSelectedMainContentViewCommand}"
                        CommandParameter="{x:Static viewModels:MainContentViewMode.Daily}"
                        Content="Day"
                        Style="{StaticResource MainContentViewToggleButtonStyle}"
                        Tag="{Binding IsDailyViewSelected}" />
                    <Button
                        Margin="4,0,0,0"
                        Command="{Binding SetSelectedMainContentViewCommand}"
                        CommandParameter="{x:Static viewModels:MainContentViewMode.Weekly}"
                        Content="Week"
                        Style="{StaticResource MainContentViewToggleButtonStyle}"
                        Tag="{Binding IsWeeklyViewSelected}" />
                    <Button
                        Margin="4,0,0,0"
                        Command="{Binding SetSelectedMainContentViewCommand}"
                        CommandParameter="{x:Static viewModels:MainContentViewMode.Monthly}"
                        Content="Month"
                        Style="{StaticResource MainContentViewToggleButtonStyle}"
                        Tag="{Binding IsMonthlyViewSelected}" />
                </StackPanel>
            </Border>

            <Grid
                x:Name="MainContentGrid"
                Grid.Row="1"
                Margin="160,48">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <TextBlock
                        VerticalAlignment="Center"
                        Style="{StaticResource HeaderText}"
                        Text="Accounts &amp; Income" />
                </Grid>

                <c:FadingScrollViewer
                    Grid.Row="1"
                    Margin="0,20,0,0"
                    HorizontalAlignment="Stretch"
                    CanContentScroll="False"
                    HorizontalScrollBarVisibility="Auto"
                    VerticalScrollBarVisibility="Disabled">
                    <StackPanel Orientation="Horizontal">
                        <ListView
                            HorizontalAlignment="Left"
                            Background="Transparent"
                            BorderBrush="Transparent"
                            BorderThickness="0"
                            ItemsSource="{Binding SpendingSources}"
                            ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                            ScrollViewer.VerticalScrollBarVisibility="Disabled">
                            <ListView.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Orientation="Horizontal" />
                                </ItemsPanelTemplate>
                            </ListView.ItemsPanel>
                            <ListView.ItemContainerStyle>
                                <Style TargetType="ListViewItem">
                                    <Setter Property="Margin" Value="0,0,8,0" />
                                    <Setter Property="Padding" Value="0" />
                                    <Setter Property="Background" Value="Transparent" />
                                    <Setter Property="BorderThickness" Value="0" />
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                    <Setter Property="VerticalContentAlignment" Value="Stretch" />
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="ListViewItem">
                                                <ContentPresenter />
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding ShowOnUI}" Value="False">
                                            <Setter Property="Margin" Value="0" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </ListView.ItemContainerStyle>
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <components:IncomeSource />
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>

                        <Grid Width="80" Height="100">
                            <Rectangle
                                RadiusX="16"
                                RadiusY="16"
                                Stroke="{StaticResource Brush.Text.Muted}"
                                StrokeDashArray="5"
                                StrokeThickness="1" />

                            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                <icons:PackIconEntypo
                                    Width="24"
                                    Height="24"
                                    Margin="0,0,0,8"
                                    HorizontalAlignment="Center"
                                    Foreground="{StaticResource Brush.Text.Muted}"
                                    Kind="CircleWithPlus" />

                                <TextBlock
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    FontFamily="{StaticResource Bold}"
                                    FontSize="12"
                                    Foreground="{StaticResource Brush.Text.Muted}"
                                    Text="Add" />
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </c:FadingScrollViewer>

                <Grid Grid.Row="2" Margin="0,8,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="360" />
                    </Grid.ColumnDefinitions>

                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <Border
                            Height="120"
                            Margin="0,16"
                            BorderBrush="{StaticResource Brush.Border.Subtle}"
                            BorderThickness="1"
                            CornerRadius="16">
                            <Grid Margin="80,0" VerticalAlignment="Center">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="2*" />
                                </Grid.ColumnDefinitions>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock
                                        FontFamily="{StaticResource Light}"
                                        Foreground="{StaticResource Brush.Text.Muted}"
                                        Text="SPENT TODAY" />
                                    <TextBlock
                                        Margin="0,12,0,0"
                                        FontFamily="{StaticResource Bold}"
                                        FontSize="24"
                                        Foreground="{StaticResource Brush.Text.Primary}"
                                        Text="{Binding TotalSpent, Converter={StaticResource NumberWithCommasConverter}, StringFormat={}${0}}" />
                                </StackPanel>
                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <TextBlock
                                        FontFamily="{StaticResource Light}"
                                        Foreground="{StaticResource Brush.Text.Muted}"
                                        Text="DAILY ALLOWANCE" />
                                    <TextBlock
                                        Margin="0,12,0,0"
                                        FontFamily="{StaticResource Bold}"
                                        FontSize="24"
                                        Foreground="{StaticResource Brush.Text.Primary}"
                                        Text="{Binding DailyAllowance, Converter={StaticResource NumberWithCommasConverter}, StringFormat={}${0}}" />
                                </StackPanel>

                                <Grid Grid.Column="2">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition />
                                        <ColumnDefinition />
                                        <ColumnDefinition />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                        <TextBlock>
                                            <Run
                                                FontFamily="{StaticResource Bold}"
                                                FontSize="24"
                                                Foreground="{StaticResource Brush.Text.Primary}"
                                                Text="{Binding NeedsAvailable, Converter={StaticResource NumberWithCommasConverter}, StringFormat={}${0}}" />
                                        </TextBlock>
                                        <TextBlock
                                            Margin="0,8,0,0"
                                            FontFamily="{StaticResource Light}"
                                            Foreground="{StaticResource Brush.Text.Muted}">
                                            <Run Text="NEEDS" />
                                            <Run Text="|" />
                                            <Run Text="{Binding NeedsPercentage, StringFormat={}{0}%}" />
                                            <Run Text="SPENT" />
                                        </TextBlock>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                        <TextBlock>
                                            <Run
                                                FontFamily="{StaticResource Bold}"
                                                FontSize="24"
                                                Foreground="{StaticResource Brush.Text.Primary}"
                                                Text="{Binding WantsAvailable, Converter={StaticResource NumberWithCommasConverter}, StringFormat={}${0}}" />
                                        </TextBlock>
                                        <TextBlock
                                            Margin="0,8,0,0"
                                            FontFamily="{StaticResource Light}"
                                            Foreground="{StaticResource Brush.Text.Muted}">
                                            <Run Text="WANTS" />
                                            <Run Text="|" />
                                            <Run Text="{Binding WantsPercentage, StringFormat={}{0}%}" />
                                            <Run Text="SPENT" />
                                        </TextBlock>
                                    </StackPanel>
                                    <StackPanel Grid.Column="2" VerticalAlignment="Center">
                                        <TextBlock>
                                            <Run
                                                FontFamily="{StaticResource Bold}"
                                                FontSize="24"
                                                Foreground="{StaticResource Brush.Text.Primary}"
                                                Text="{Binding InvestAvailable, Converter={StaticResource NumberWithCommasConverter}, StringFormat={}${0}}" />
                                        </TextBlock>
                                        <TextBlock
                                            Margin="0,9,0,0"
                                            FontFamily="{StaticResource Light}"
                                            Foreground="{StaticResource Brush.Text.Muted}">
                                            <Run Text="INVEST" />
                                            <Run Text="|" />
                                            <Run Text="{Binding InvestPercentage, StringFormat={}{0}%}" />
                                            <Run Text="SPENT" />
                                        </TextBlock>
                                    </StackPanel>
                                </Grid>
                            </Grid>
                        </Border>

                        <StackPanel
                            Grid.Row="1"
                            Margin="0,0,0,16"
                            Orientation="Horizontal">
                            <!--  "All" tag button  -->
                            <Grid Margin="16,0,0,0" VerticalAlignment="Center">
                                <!--  Unselected state (outlined) - visible when a tag IS selected  -->
                                <Border
                                    x:Name="AllTagUnselected"
                                    Height="24"
                                    Padding="12,0"
                                    Background="{StaticResource Brush.Background.Surface}"
                                    BorderBrush="{StaticResource Brush.Border.Subtle}"
                                    BorderThickness="1"
                                    CornerRadius="12"
                                    Cursor="Hand">
                                    <Border.InputBindings>
                                        <MouseBinding Command="{Binding ClearSelectedTagCommand}" MouseAction="LeftClick" />
                                    </Border.InputBindings>
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Visibility" Value="Visible" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding SelectedTag}" Value="{x:Null}">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <TextBlock
                                        VerticalAlignment="Center"
                                        FontFamily="{StaticResource Bold}"
                                        Foreground="{StaticResource Brush.Text.Primary}"
                                        Text="All" />
                                </Border>

                                <!--  Selected state (filled) - visible when NO tag is selected  -->
                                <Border
                                    x:Name="AllTagSelected"
                                    Height="24"
                                    Padding="12,0"
                                    Background="{StaticResource Brush.Mint}"
                                    BorderThickness="1"
                                    CornerRadius="12"
                                    Cursor="Hand">
                                    <Border.InputBindings>
                                        <MouseBinding Command="{Binding ClearSelectedTagCommand}" MouseAction="LeftClick" />
                                    </Border.InputBindings>
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding SelectedTag}" Value="{x:Null}">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <TextBlock
                                        VerticalAlignment="Center"
                                        FontFamily="{StaticResource Bold}"
                                        Foreground="{StaticResource Brush.Background.Surface}"
                                        Text="All" />
                                </Border>
                            </Grid>

                            <ListView
                                Margin="0,12,0,0"
                                VerticalAlignment="Center"
                                Background="Transparent"
                                BorderThickness="0"
                                ItemContainerStyle="{StaticResource ListViewItemStyle}"
                                ItemTemplate="{StaticResource Tags}"
                                ItemsSource="{Binding Tags}"
                                PreviewMouseLeftButtonDown="OnTagListPreviewMouseLeftButtonDown"
                                ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                SelectedItem="{Binding SelectedTag}">
                                <ListView.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <StackPanel Orientation="Horizontal" />
                                    </ItemsPanelTemplate>
                                </ListView.ItemsPanel>
                            </ListView>
                        </StackPanel>

                        <Grid Grid.Row="2">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition />
                                <ColumnDefinition Width="16" />
                                <ColumnDefinition />
                                <ColumnDefinition Width="16" />
                                <ColumnDefinition />
                            </Grid.ColumnDefinitions>

                            <components:ExpensesList
                                Title="NEEDS"
                                DotColor="{StaticResource Brush.Category.Needs}"
                                IsListEmpty="{Binding IsNeedsEmpty}"
                                ItemsSource="{Binding Needs}"
                                SpentAmount="{Binding NeedsSpent}" />

                            <components:ExpensesList
                                Title="WANTS"
                                Grid.Column="2"
                                DotColor="{StaticResource Brush.Category.Wants}"
                                IsListEmpty="{Binding IsWantsEmpty}"
                                ItemsSource="{Binding Wants}"
                                SpentAmount="{Binding WantsSpent}" />

                            <components:ExpensesList
                                Title="INVEST &amp; SAVINGS"
                                Grid.Column="4"
                                DotColor="{StaticResource Brush.Category.Investments}"
                                IsListEmpty="{Binding IsInvestEmpty}"
                                ItemsSource="{Binding Invest}"
                                SpentAmount="{Binding InvestSpent}" />
                        </Grid>
                    </Grid>

                    <Grid Grid.Column="1" Margin="16,16,0,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="250" />
                            <RowDefinition Height="16" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <Border Style="{StaticResource DashboardPanelStyle}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="12" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <TextBlock
                                        FontFamily="{StaticResource Bold}"
                                        FontSize="13"
                                        Foreground="{StaticResource Brush.Text.Primary}"
                                        Text="Notifications" />

                                    <Border Grid.Column="1" Style="{StaticResource DashboardCountBadgeStyle}">
                                        <TextBlock
                                            FontFamily="{StaticResource Bold}"
                                            FontSize="9"
                                            Foreground="{StaticResource Brush.Text.Secondary}"
                                            Text="{Binding NotificationCount}" />
                                    </Border>
                                </Grid>

                                <TextBlock
                                    Grid.Row="2"
                                    VerticalAlignment="Center"
                                    FontFamily="{StaticResource Medium}"
                                    FontSize="11"
                                    Foreground="{StaticResource Brush.Text.Muted}"
                                    Text="You're all caught up."
                                    TextAlignment="Center"
                                    Visibility="{Binding HasNotifications, Converter={StaticResource BoolToVisibilityInvertedConverter}}" />

                                <ScrollViewer
                                    Grid.Row="2"
                                    VerticalScrollBarVisibility="Auto"
                                    Visibility="{Binding HasNotifications, Converter={StaticResource BoolToVisibilityConverter}}">
                                    <ItemsControl ItemTemplate="{StaticResource DashboardNotificationTemplate}" ItemsSource="{Binding Notifications}" />
                                </ScrollViewer>
                            </Grid>
                        </Border>

                        <Border Grid.Row="2" Style="{StaticResource DashboardPanelStyle}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="12" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <TextBlock
                                        FontFamily="{StaticResource Bold}"
                                        FontSize="13"
                                        Foreground="{StaticResource Brush.Text.Primary}"
                                        Text="Saving Goals" />

                                    <Border Grid.Column="1" Style="{StaticResource DashboardCountBadgeStyle}">
                                        <TextBlock
                                            FontFamily="{StaticResource Bold}"
                                            FontSize="9"
                                            Foreground="{StaticResource Brush.Text.Secondary}"
                                            Text="{Binding SavingGoals.Count}" />
                                    </Border>
                                </Grid>

                                <TextBlock
                                    Grid.Row="2"
                                    VerticalAlignment="Center"
                                    FontFamily="{StaticResource Medium}"
                                    FontSize="11"
                                    Foreground="{StaticResource Brush.Text.Muted}"
                                    Text="Add a saving goal to track progress here."
                                    TextAlignment="Center"
                                    Visibility="{Binding HasSavingGoals, Converter={StaticResource BoolToVisibilityInvertedConverter}}" />

                                <ScrollViewer
                                    Grid.Row="2"
                                    VerticalScrollBarVisibility="Auto"
                                    Visibility="{Binding HasSavingGoals, Converter={StaticResource BoolToVisibilityConverter}}">
                                    <ItemsControl ItemTemplate="{StaticResource SavingGoalTemplate}" ItemsSource="{Binding SavingGoals}" />
                                </ScrollViewer>
                            </Grid>
                        </Border>
                    </Grid>
                </Grid>
            </Grid>
        </Grid>
    </Border>
</Window>
