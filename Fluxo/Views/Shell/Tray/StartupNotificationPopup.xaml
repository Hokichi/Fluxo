<Window
    x:Class="Fluxo.Views.Shell.Tray.StartupNotificationPopup"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    AllowsTransparency="True"
    Background="Transparent"
    ShowInTaskbar="False"
    SizeToContent="WidthAndHeight"
    Topmost="True"
    WindowStyle="None">
    <Border
        Margin="8"
        Padding="14"
        Background="{StaticResource Brush.Background.Surface}"
        BorderBrush="{StaticResource Brush.Border.Subtle}"
        BorderThickness="1"
        CornerRadius="12">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <TextBlock
                x:Name="SummaryTextBlock"
                Margin="0,0,14,0"
                VerticalAlignment="Center"
                FontFamily="{StaticResource Medium}"
                FontSize="12"
                Foreground="{StaticResource Brush.Text.Primary}"
                Text="Fluxo is running in tray mode."
                TextWrapping="Wrap" />

            <StackPanel Grid.Column="1" Orientation="Vertical">
                <Button
                    Click="OnOpenAppClick"
                    Style="{StaticResource WizardCircleActionButtonStyle}">
                    <Path
                        Width="14"
                        Height="14"
                        Data="{StaticResource AngleRight}"
                        Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                        Stretch="Uniform" />
                </Button>

                <Button
                    Margin="0,8,0,0"
                    Background="{StaticResource Brush.Background.Hover}"
                    Click="OnCloseClick"
                    Foreground="{StaticResource Brush.Text.Primary}"
                    Style="{StaticResource WizardCircleActionButtonStyle}">
                    <TextBlock
                        FontFamily="{StaticResource Bold}"
                        FontSize="10"
                        Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                        Text="Close" />
                </Button>
            </StackPanel>
        </Grid>
    </Border>
</Window>
