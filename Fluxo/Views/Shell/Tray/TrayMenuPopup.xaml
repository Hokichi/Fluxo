<Window
    x:Class="Fluxo.Views.Shell.Tray.TrayMenuPopup"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    AllowsTransparency="True"
    Background="Transparent"
    ShowInTaskbar="False"
    SizeToContent="WidthAndHeight"
    Topmost="True"
    WindowStyle="None">
    <Window.Resources>
        <Style x:Key="TrayMenuOptionTextStyle" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="{StaticResource Medium}" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Foreground" Value="{StaticResource Brush.Text.Primary}" />
        </Style>

        <Style x:Key="TrayMenuButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Padding" Value="12,10" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border
                            x:Name="ItemBackground"
                            Margin="2"
                            Padding="{TemplateBinding Padding}"
                            Background="Transparent"
                            CornerRadius="12">
                            <ContentPresenter
                                TextElement.FontFamily="{StaticResource Black}"
                                TextElement.FontSize="13"
                                TextElement.Foreground="{StaticResource Brush.Text.Primary}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ItemBackground" Property="Background" Value="{StaticResource Brush.Background.Hover}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ItemBackground" Property="Opacity" Value="0.9" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border
        Margin="8"
        Padding="10"
        Background="{StaticResource Brush.Background.Surface}"
        BorderBrush="{StaticResource Brush.Border.Subtle}"
        BorderThickness="1"
        CornerRadius="12">
        <StackPanel Width="220">
            <StackPanel
                Margin="8,6,8,10"
                HorizontalAlignment="Left"
                Orientation="Horizontal">
                <TextBlock
                    FontFamily="{StaticResource Black}"
                    FontSize="16"
                    Foreground="{StaticResource Brush.Text.Primary}"
                    Text="flux" />
                <TextBlock
                    FontFamily="{StaticResource Black}"
                    FontSize="16"
                    Foreground="{StaticResource Brush.Mint}"
                    Text="o" />
            </StackPanel>

            <Button Click="OnOpenFluxoClick" Style="{StaticResource TrayMenuButtonStyle}">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Style="{StaticResource TrayMenuOptionTextStyle}" Text="Open" />
                    <TextBlock
                        FontFamily="{StaticResource Black}"
                        Style="{StaticResource TrayMenuOptionTextStyle}"
                        Text=" flux" />
                    <TextBlock
                        FontFamily="{StaticResource Black}"
                        FontSize="13"
                        Foreground="{StaticResource Brush.Mint}"
                        Text="o" />
                </StackPanel>
            </Button>
            <Button Click="OnCheckUpdatesClick" Style="{StaticResource TrayMenuButtonStyle}">
                <TextBlock Style="{StaticResource TrayMenuOptionTextStyle}" Text="Check for updates" />
            </Button>
            <Button Click="OnRestartFluxoClick" Style="{StaticResource TrayMenuButtonStyle}">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Style="{StaticResource TrayMenuOptionTextStyle}" Text="Restart" />
                    <TextBlock
                        FontFamily="{StaticResource Black}"
                        Style="{StaticResource TrayMenuOptionTextStyle}"
                        Text=" flux" />
                    <TextBlock
                        FontFamily="{StaticResource Black}"
                        FontSize="13"
                        Foreground="{StaticResource Brush.Mint}"
                        Text="o" />
                </StackPanel>
            </Button>
            <Button Click="OnExitClick" Style="{StaticResource TrayMenuButtonStyle}">
                <TextBlock Style="{StaticResource TrayMenuOptionTextStyle}" Text="Exit" />
            </Button>
        </StackPanel>
    </Border>
</Window>
