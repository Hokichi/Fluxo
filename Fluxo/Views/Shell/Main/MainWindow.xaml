<Window
    x:Class="Fluxo.Views.Shell.Main.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:components="clr-namespace:Fluxo.Views.Components"
    xmlns:controls="clr-namespace:Fluxo.Views.Shell.Main.Controls"
    xmlns:customControls="clr-namespace:Fluxo.Views.CustomControls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:sections="clr-namespace:Fluxo.Views.Shell.Main.Sections"
    Title="Fluxo"
    Width="1600"
    Height="900"
    MinWidth="1600"
    MinHeight="900"
    AllowsTransparency="True"
    Background="Transparent"
    Icon="/Fluxo;component/Resources/fluxo.ico"
    WindowStartupLocation="CenterScreen"
    WindowStyle="None"
    mc:Ignorable="d">

    <Window.CommandBindings>
        <CommandBinding Command="{x:Static SystemCommands.CloseWindowCommand}" Executed="OnCloseWindow" />
        <CommandBinding Command="{x:Static SystemCommands.MinimizeWindowCommand}" Executed="OnMinimizeWindow" />
    </Window.CommandBindings>

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Fluxo;component/Resources/Styles/MainWindowStyles.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <ItemsPanelTemplate x:Key="MainWindowSpendingSourcesItemsPanelTemplate">
                <StackPanel Orientation="Horizontal" />
            </ItemsPanelTemplate>

            <DataTemplate x:Key="MainWindowSpendingSourceItemTemplate">
                <components:IncomeSource />
            </DataTemplate>

            <Style x:Key="AnalyticsDrawerTabButtonStyle" TargetType="Button">
                <Setter Property="Background" Value="Transparent" />
                <Setter Property="BorderBrush" Value="Transparent" />
                <Setter Property="BorderThickness" Value="0" />
                <Setter Property="Cursor" Value="Hand" />
                <Setter Property="FocusVisualStyle" Value="{x:Null}" />
                <Setter Property="FontFamily" Value="{StaticResource Bold}" />
                <Setter Property="FontSize" Value="12" />
                <Setter Property="Foreground" Value="{StaticResource Brush.Text.Primary}" />
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border
                                x:Name="ButtonSurface"
                                Margin="0,0,0,-2"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="12,12,0,0">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Foreground" Value="{StaticResource Brush.Mint}" />
                                    <Setter TargetName="ButtonSurface" Property="Background" Value="{StaticResource Brush.Background.Surface}" />
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="ButtonSurface" Property="Opacity" Value="0.9" />
                                    <Setter Property="Foreground" Value="{StaticResource Brush.Mint.Muted}" />
                                </Trigger>
                                <Trigger Property="IsKeyboardFocused" Value="True">
                                    <Setter Property="Foreground" Value="{StaticResource Brush.Mint.Muted}" />
                                    <Setter TargetName="ButtonSurface" Property="BorderBrush" Value="{StaticResource Brush.Mint}" />
                                    <Setter TargetName="ButtonSurface" Property="BorderThickness" Value="1" />
                                </Trigger>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter Property="Opacity" Value="0.55" />
                                    <Setter Property="Cursor" Value="Arrow" />
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>
        </ResourceDictionary>
    </Window.Resources>

    <Border
        x:Name="RootBorder"
        Background="{StaticResource Brush.Background.Main}"
        BorderBrush="{StaticResource Brush.Border.Subtle}"
        BorderThickness="1"
        CornerRadius="16"
        MouseMove="MainWindow_OnMouseMove">
        <Grid>
            <Grid x:Name="ContentGrid" Margin="0,16,0,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="60" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Border
                    x:Name="TopBorderHitArea"
                    Grid.Row="0"
                    Margin="24,0"
                    Background="Transparent"
                    MouseLeftButtonDown="OnTopBorderHitAreaMouseLeftButtonDown" />

                <Grid Grid.Row="0" Margin="24,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <StackPanel
                        Margin="32,0,0,0"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Center"
                        Orientation="Horizontal">
                        <Image
                            Width="24"
                            Height="24"
                            VerticalAlignment="Center"
                            Source="/Fluxo;component/Resources/fluxo.ico"
                            Stretch="Uniform" />

                        <TextBlock
                            Margin="8,1,0,0"
                            VerticalAlignment="Center"
                            FontFamily="{StaticResource Black}"
                            FontSize="18"
                            Foreground="{StaticResource Brush.Text.Primary}"
                            Text="flux" />

                        <TextBlock
                            Margin="0,1,0,0"
                            VerticalAlignment="Center"
                            FontFamily="{StaticResource Black}"
                            FontSize="18"
                            Foreground="{StaticResource Brush.Mint}"
                            Text="o" />

                        <Border
                            Width="1"
                            Height="32"
                            Margin="16,0"
                            Background="{StaticResource Brush.Border.Subtle}" />

                        <TextBlock
                            Margin="0,4,0,0"
                            VerticalAlignment="Center"
                            FontSize="14">
                            <Run
                                FontFamily="{StaticResource Medium}"
                                Foreground="{StaticResource Brush.Text.Primary}"
                                Text="Welcome back," />
                            <Run
                                FontFamily="{StaticResource Bold}"
                                Foreground="{StaticResource Brush.Text.Primary}"
                                Text="{Binding Username}" />
                        </TextBlock>
                    </StackPanel>

                    <controls:DaySpinnerControl
                        x:Name="DaySpinnerControlHost"
                        Grid.Column="1"
                        DataContext="{Binding DaySpinner}" />

                    <StackPanel
                        Grid.Column="2"
                        HorizontalAlignment="Right"
                        Orientation="Horizontal">
                        <customControls:BalloonButton
                            x:Name="HeaderMenuButton"
                            ButtonIcon="{StaticResource BarsSolid}"
                            Click="OnHeaderMenuButtonClick"
                            CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=Window}}"
                            HoveredBackground="{StaticResource Brush.Background.Hover}"
                            IconSize="9"
                            MouseEnter="OnHeaderMenuButtonMouseEnter"
                            MouseLeave="OnHeaderMenuButtonMouseLeave"
                            Style="{StaticResource HeaderButtonStyle}" />

                        <Popup
                            x:Name="HeaderMenuPopup"
                            AllowsTransparency="True"
                            IsOpen="False"
                            Placement="Bottom"
                            PlacementTarget="{Binding ElementName=HeaderMenuButton}"
                            PopupAnimation="Fade"
                            StaysOpen="True"
                            VerticalOffset="8">
                            <Border
                                x:Name="HeaderMenuPopupRoot"
                                Width="220"
                                Padding="8"
                                Background="{StaticResource Brush.Background.Elevated}"
                                BorderBrush="{StaticResource Brush.Border.Subtle}"
                                BorderThickness="1"
                                CornerRadius="18"
                                MouseEnter="OnHeaderMenuPopupMouseEnter"
                                MouseLeave="OnHeaderMenuPopupMouseLeave">
                                <Border.Resources>
                                    <Style x:Key="HeaderMenuShortcutTextStyle" TargetType="TextBlock">
                                        <Setter Property="VerticalAlignment" Value="Center" />
                                        <Setter Property="HorizontalAlignment" Value="Right" />
                                        <Setter Property="FontFamily" Value="{StaticResource Medium}" />
                                        <Setter Property="FontSize" Value="11" />
                                        <Setter Property="Foreground" Value="{StaticResource Brush.Text.Muted}" />
                                        <Setter Property="Visibility" Value="Collapsed" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsMouseOver, RelativeSource={RelativeSource AncestorType=Button}}" Value="True">
                                                <Setter Property="Visibility" Value="Visible" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Resources>
                                <StackPanel>
                                    <Button Click="OnQuickAddButtonClick" Style="{StaticResource HeaderMenuActionButtonStyle}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="16" />
                                                <ColumnDefinition Width="12" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="8" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <components:Icon
                                                Width="14"
                                                Height="14"
                                                Path="{StaticResource PlusSolid}"
                                                Color="{StaticResource Brush.Mint}" />
                                            <TextBlock
                                                Grid.Column="2"
                                                VerticalAlignment="Center"
                                                FontFamily="{StaticResource Bold}"
                                                Foreground="{StaticResource Brush.Text.Primary}"
                                                Text="Add" />
                                            <TextBlock
                                                Grid.Column="4"
                                                Style="{StaticResource HeaderMenuShortcutTextStyle}"
                                                Text="Ctrl+N" />
                                        </Grid>
                                    </Button>

                                    <Button Click="OnSpendingSourcesButtonClick" Style="{StaticResource HeaderMenuActionButtonStyle}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="16" />
                                                <ColumnDefinition Width="12" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="8" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <components:Icon
                                                Width="14"
                                                Height="14"
                                                Path="{StaticResource Bank}"
                                                Color="{StaticResource Brush.Mint}" />
                                            <TextBlock
                                                Grid.Column="2"
                                                VerticalAlignment="Center"
                                                FontFamily="{StaticResource Bold}"
                                                Foreground="{StaticResource Brush.Text.Primary}"
                                                Text="Sources" />
                                            <TextBlock
                                                Grid.Column="4"
                                                Style="{StaticResource HeaderMenuShortcutTextStyle}"
                                                Text="Ctrl+L" />
                                        </Grid>
                                    </Button>

                                    <Button Click="OnPlanningButtonClick" Style="{StaticResource HeaderMenuActionButtonStyle}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="16" />
                                                <ColumnDefinition Width="12" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="8" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <components:Icon
                                                Width="14"
                                                Height="14"
                                                Path="{StaticResource PlusSolid}"
                                                Color="{StaticResource Brush.Warning}" />
                                            <TextBlock
                                                Grid.Column="2"
                                                VerticalAlignment="Center"
                                                FontFamily="{StaticResource Bold}"
                                                Foreground="{StaticResource Brush.Text.Primary}"
                                                Text="Planning" />
                                            <TextBlock
                                                Grid.Column="4"
                                                Style="{StaticResource HeaderMenuShortcutTextStyle}"
                                                Text="Ctrl+P" />
                                        </Grid>
                                    </Button>

                                    <Button Click="OnAnalyticsButtonClick" Style="{StaticResource HeaderMenuActionButtonStyle}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="16" />
                                                <ColumnDefinition Width="12" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="8" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <components:Icon
                                                Width="14"
                                                Height="14"
                                                Path="{StaticResource Bank}"
                                                Color="{StaticResource Brush.Info}" />
                                            <TextBlock
                                                Grid.Column="2"
                                                VerticalAlignment="Center"
                                                FontFamily="{StaticResource Bold}"
                                                Foreground="{StaticResource Brush.Text.Primary}"
                                                Text="Analytics" />
                                            <TextBlock
                                                Grid.Column="4"
                                                Style="{StaticResource HeaderMenuShortcutTextStyle}"
                                                Text="Ctrl+A" />
                                        </Grid>
                                    </Button>

                                    <Button
                                        x:Name="UndoMenuButton"
                                        Click="OnUndoButtonClick"
                                        IsEnabled="False"
                                        Style="{StaticResource HeaderMenuActionButtonStyle}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="16" />
                                                <ColumnDefinition Width="12" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="8" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <components:Icon
                                                Width="14"
                                                Height="14"
                                                Path="{StaticResource RegularUndo}"
                                                Color="{StaticResource Brush.Warning}" />
                                            <TextBlock
                                                Grid.Column="2"
                                                VerticalAlignment="Center"
                                                FontFamily="{StaticResource Bold}"
                                                Foreground="{StaticResource Brush.Text.Primary}"
                                                Text="Undo" />
                                            <TextBlock
                                                Grid.Column="4"
                                                Style="{StaticResource HeaderMenuShortcutTextStyle}"
                                                Text="Ctrl+Z" />
                                        </Grid>
                                    </Button>

                                    <Button
                                        x:Name="RedoMenuButton"
                                        Click="OnRedoButtonClick"
                                        IsEnabled="False"
                                        Style="{StaticResource HeaderMenuActionButtonStyle}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="16" />
                                                <ColumnDefinition Width="12" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="8" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <components:Icon
                                                Width="14"
                                                Height="14"
                                                Path="{StaticResource RegularRedo}"
                                                Color="{StaticResource Brush.Info}" />
                                            <TextBlock
                                                Grid.Column="2"
                                                VerticalAlignment="Center"
                                                FontFamily="{StaticResource Bold}"
                                                Foreground="{StaticResource Brush.Text.Primary}"
                                                Text="Redo" />
                                            <TextBlock
                                                Grid.Column="4"
                                                Style="{StaticResource HeaderMenuShortcutTextStyle}"
                                                Text="Ctrl+Y" />
                                        </Grid>
                                    </Button>

                                    <Button Click="OnSettingsButtonClick" Style="{StaticResource HeaderMenuActionButtonStyle}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="16" />
                                                <ColumnDefinition Width="12" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="8" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <components:Icon
                                                Width="14"
                                                Height="14"
                                                Path="{StaticResource Cog}"
                                                Color="{StaticResource Brush.Info}" />
                                            <TextBlock
                                                Grid.Column="2"
                                                VerticalAlignment="Center"
                                                FontFamily="{StaticResource Bold}"
                                                Foreground="{StaticResource Brush.Text.Primary}"
                                                Text="Settings" />
                                            <TextBlock
                                                Grid.Column="4"
                                                Style="{StaticResource HeaderMenuShortcutTextStyle}"
                                                Text="Ctrl+S" />
                                        </Grid>
                                    </Button>
                                </StackPanel>
                            </Border>
                        </Popup>

                        <customControls:BalloonButton
                            ButtonIcon="{StaticResource Minus}"
                            Command="{x:Static SystemCommands.MinimizeWindowCommand}"
                            CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=Window}}"
                            HoveredBackground="{StaticResource Brush.Primary.Hover}"
                            Style="{StaticResource HeaderButtonStyle}" />

                        <customControls:BalloonButton
                            x:Name="ExpandRestoreButton"
                            ButtonIcon="{StaticResource ExpandAlt}"
                            Click="OnExpandRestoreWindow"
                            HoveredBackground="{StaticResource Brush.Primary.Hover}"
                            Style="{StaticResource HeaderButtonStyle}" />

                        <customControls:BalloonButton
                            ButtonIcon="{StaticResource Close}"
                            Command="{x:Static SystemCommands.CloseWindowCommand}"
                            CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=Window}}"
                            HoveredBackground="{StaticResource Brush.Danger}"
                            Style="{StaticResource HeaderButtonStyle}" />
                    </StackPanel>
                </Grid>

                <controls:MainViewModeToggleControl
                    x:Name="ViewModeToggleControlHost"
                    Grid.Row="1"
                    Margin="0,16"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Top"
                    DataContext="{Binding ViewModeToggle}" />

                <Grid
                    x:Name="MainContentGrid"
                    Grid.Row="1"
                    Margin="200,48">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <TextBlock
                            HorizontalAlignment="Left"
                            VerticalAlignment="Center"
                            FontFamily="{StaticResource Bold}"
                            FontSize="18"
                            Foreground="{StaticResource Brush.Text.Primary}"
                            Text="Overview" />

                        <Button
                            Grid.Column="1"
                            VerticalAlignment="Center"
                            Click="OnSpendingSourcesButtonClick"
                            Content="View All Spending Sources"
                            Style="{StaticResource TextOnlyButtonStyle}" />
                    </Grid>

                    <Grid Grid.Row="1" Margin="0,20,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <sections:SpentAllowancePanel
                            x:Name="SpentAllowancePanelHost"
                            Height="80"
                            Margin="0,8,0,0"
                            VerticalAlignment="Top"
                            DataContext="{Binding SpentAllowancePanel}" />

                        <Border
                            Grid.Column="1"
                            Width="1"
                            Height="64"
                            Margin="0,20,12,0"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Top"
                            Background="{StaticResource Brush.Border.Subtle}"
                            SnapsToDevicePixels="True" />

                        <customControls:FadingScrollViewer
                            Grid.Column="2"
                            HorizontalAlignment="Stretch"
                            CanContentScroll="False"
                            HorizontalScrollBarVisibility="Auto"
                            VerticalScrollBarVisibility="Disabled">
                            <StackPanel Orientation="Horizontal">
                                <Button
                                    x:Name="AddSpendingSourceButton"
                                    Margin="0,0,8,0"
                                    Click="OnAddSpendingSourceButtonClick"
                                    Style="{StaticResource SpendingSourceAddButtonStyle}" />

                                <ListView
                                    HorizontalAlignment="Left"
                                    Background="Transparent"
                                    BorderBrush="Transparent"
                                    BorderThickness="0"
                                    ItemContainerStyle="{StaticResource IncomeSources}"
                                    ItemTemplate="{StaticResource MainWindowSpendingSourceItemTemplate}"
                                    ItemsPanel="{StaticResource MainWindowSpendingSourcesItemsPanelTemplate}"
                                    ItemsSource="{Binding SpendingSources}"
                                    ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                    ScrollViewer.VerticalScrollBarVisibility="Disabled" />
                            </StackPanel>
                        </customControls:FadingScrollViewer>
                    </Grid>

                    <Grid Grid.Row="2" Margin="0,8,0,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*" />
                            <RowDefinition Height="180" />
                        </Grid.RowDefinitions>

                        <sections:BudgetAllocationPanel x:Name="BudgetAllocationPanelHost" DataContext="{Binding BudgetPanel}" />

                        <Grid Grid.Row="1">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="1.5*" />
                                <ColumnDefinition Width="16" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <sections:SavingGoalsPanel
                                x:Name="SavingGoalsPanelHost"
                                Grid.Column="0"
                                DataContext="{Binding SavingGoalsPanel}" />

                            <sections:NotificationPanel
                                x:Name="NotificationPanelHost"
                                Grid.Column="2"
                                DataContext="{Binding NotificationPanel}" />
                        </Grid>
                    </Grid>
                </Grid>
            </Grid>

            <Border
                x:Name="AnalyticsDrawerTabHost"
                Width="170"
                Height="28"
                Margin="0"
                HorizontalAlignment="Center"
                VerticalAlignment="Bottom"
                Background="{StaticResource Brush.Background.Elevated}"
                BorderBrush="{StaticResource Brush.Border.Subtle}"
                BorderThickness="1,1,1,0"
                CornerRadius="14,14,0,0">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Background" Value="{StaticResource Brush.Background.Elevated}" />
                        <Setter Property="BorderBrush" Value="{StaticResource Brush.Border.Subtle}" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsMouseOver, ElementName=AnalyticsDrawerTabButton}" Value="True">
                                <Setter Property="Background" Value="{StaticResource Brush.Background.Surface}" />
                                <Setter Property="BorderBrush" Value="{StaticResource Brush.Mint.Muted}" />
                            </DataTrigger>
                            <DataTrigger Binding="{Binding IsKeyboardFocused, ElementName=AnalyticsDrawerTabButton}" Value="True">
                                <Setter Property="BorderBrush" Value="{StaticResource Brush.Mint.Muted}" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <Button
                    x:Name="AnalyticsDrawerTabButton"
                    AutomationProperties.Name="Open Analytics Drawer"
                    Click="OnAnalyticsDrawerTabClick"
                    Style="{StaticResource AnalyticsDrawerTabButtonStyle}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock
                            VerticalAlignment="Center"
                            FontFamily="{StaticResource Bold}"
                            FontSize="12"
                            Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                            Text="Analytics" />
                    </StackPanel>
                </Button>
            </Border>

            <Grid x:Name="AnalyticsDrawerLayer" Panel.ZIndex="20">
                <Border
                    x:Name="AnalyticsDrawerPanel"
                    Margin="24,76,24,0"
                    Background="{StaticResource Brush.Background.Elevated}"
                    BorderBrush="{StaticResource Brush.Border.Subtle}"
                    BorderThickness="1"
                    CornerRadius="18 18 0 0"
                    Visibility="Collapsed">
                    <Border.Effect>
                        <DropShadowEffect
                            BlurRadius="20"
                            Opacity="0.2"
                            ShadowDepth="4" />
                    </Border.Effect>
                    <Border.RenderTransform>
                        <TranslateTransform x:Name="AnalyticsDrawerTransform" Y="1200" />
                    </Border.RenderTransform>
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="60" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0" Margin="20,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <TextBlock
                                VerticalAlignment="Center"
                                FontFamily="{StaticResource Bold}"
                                FontSize="18"
                                Foreground="{StaticResource Brush.Text.Primary}"
                                Text="Analytics" />

                            <Border
                                Grid.Column="0"
                                Grid.ColumnSpan="2"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center">
                                <StackPanel VerticalAlignment="Center" Orientation="Horizontal">
                                    <components:DateSelector SelectedDate="{Binding ElementName=AnalyticsDrawerContentHost, Path=Content.DataContext.StartDate, Mode=TwoWay}" />

                                    <TextBlock
                                        Margin="12,0,8,0"
                                        VerticalAlignment="Center"
                                        FontFamily="{StaticResource Medium}"
                                        Foreground="{StaticResource Brush.Text.Secondary}"
                                        Text="To" />

                                    <components:DateSelector SelectedDate="{Binding ElementName=AnalyticsDrawerContentHost, Path=Content.DataContext.EndDate, Mode=TwoWay}" />
                                </StackPanel>
                            </Border>

                            <Button
                                Grid.Column="1"
                                VerticalAlignment="Center"
                                Click="OnCloseAnalyticsDrawerButtonClick"
                                Content="Return To Dashboard"
                                Style="{StaticResource TextOnlyButtonStyle}" />
                        </Grid>

                        <ContentControl x:Name="AnalyticsDrawerContentHost" Grid.Row="1" />
                    </Grid>
                </Border>
            </Grid>
            <Border
                x:Name="PopupOverlay"
                Panel.ZIndex="30"
                Background="Black"
                CornerRadius="16"
                IsHitTestVisible="False"
                Opacity="0"
                Visibility="Collapsed" />
        </Grid>
    </Border>
</Window>