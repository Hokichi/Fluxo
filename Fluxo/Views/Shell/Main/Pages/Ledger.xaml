<UserControl
    x:Class="Fluxo.Views.Shell.Main.Pages.Ledger"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:components="clr-namespace:Fluxo.Resources.Components;assembly=Fluxo.Resources"
    xmlns:controls="clr-namespace:Fluxo.Views.Shell.Main.Controls"
    xmlns:customControls="clr-namespace:Fluxo.Resources.CustomControls;assembly=Fluxo.Resources"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:main="clr-namespace:Fluxo.ViewModels.Shell.Main"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DataContext="{d:DesignInstance Type=main:LedgerVM}"
    mc:Ignorable="d">

    <UserControl.Resources>
        <Style x:Key="LedgerSummaryCardStyle" TargetType="Border">
            <Setter Property="MinHeight" Value="84" />
            <Setter Property="Padding" Value="16" />
            <Setter Property="Background" Value="{StaticResource Brush.Background.Surface}" />
            <Setter Property="BorderBrush" Value="{StaticResource Brush.Border.Subtle}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="8" />
        </Style>

        <Style x:Key="LedgerFilterComboStyle" TargetType="ComboBox">
            <Setter Property="Validation.ErrorTemplate" Value="{x:Null}" />
            <Setter Property="OverridesDefaultStyle" Value="True" />
            <Setter Property="Height" Value="34" />
            <Setter Property="Background" Value="{StaticResource Brush.Background.Surface}" />
            <Setter Property="BorderBrush" Value="{StaticResource Brush.Border.Subtle}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="{StaticResource Brush.Text.Primary}" />
            <Setter Property="FontFamily" Value="{StaticResource Medium}" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="MaxDropDownHeight" Value="220" />
            <Setter Property="ScrollViewer.CanContentScroll" Value="False" />
            <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Auto" />
            <Setter Property="ItemContainerStyle" Value="{DynamicResource LedgerFilterComboBoxItemStyle}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid SnapsToDevicePixels="True">
                            <ToggleButton
                                x:Name="ToggleButton"
                                Height="{TemplateBinding Height}"
                                HorizontalAlignment="Stretch"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                ClickMode="Press"
                                Focusable="False"
                                Foreground="{TemplateBinding Foreground}"
                                IsChecked="{Binding IsDropDownOpen, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border
                                            Padding="10,0,12,0"
                                            Background="{TemplateBinding Background}"
                                            BorderBrush="{TemplateBinding BorderBrush}"
                                            BorderThickness="{TemplateBinding BorderThickness}"
                                            CornerRadius="8">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>

                                                <TextBlock
                                                    VerticalAlignment="Center"
                                                    FontFamily="{StaticResource Medium}"
                                                    FontSize="13"
                                                    Foreground="{StaticResource Brush.Text.Primary}"
                                                    Text="{Binding Tag, RelativeSource={RelativeSource AncestorType=ComboBox}}" />

                                                <Path
                                                    x:Name="DropDownChevron"
                                                    Grid.Column="1"
                                                    Width="8"
                                                    Height="8"
                                                    VerticalAlignment="Center"
                                                    Data="{StaticResource AngleDown}"
                                                    Fill="{StaticResource Brush.Text.Muted}"
                                                    RenderTransformOrigin="0.5,0.5"
                                                    Stretch="Uniform" />
                                            </Grid>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsChecked" Value="True">
                                                <Setter TargetName="DropDownChevron" Property="RenderTransform">
                                                    <Setter.Value>
                                                        <RotateTransform Angle="180" />
                                                    </Setter.Value>
                                                </Setter>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>

                            <Popup
                                x:Name="PART_Popup"
                                AllowsTransparency="True"
                                Focusable="False"
                                IsOpen="{Binding IsDropDownOpen, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}"
                                Placement="Bottom"
                                PlacementTarget="{Binding RelativeSource={RelativeSource TemplatedParent}}"
                                PopupAnimation="Fade"
                                VerticalOffset="8">
                                <Border
                                    MinWidth="{Binding ActualWidth, RelativeSource={RelativeSource TemplatedParent}}"
                                    MaxHeight="{TemplateBinding MaxDropDownHeight}"
                                    Margin="0,8,0,0"
                                    Background="{StaticResource Brush.Background.Surface}"
                                    BorderBrush="{StaticResource Brush.Border.Subtle}"
                                    BorderThickness="1"
                                    CornerRadius="8">
                                    <customControls:FadingScrollViewer
                                        Margin="4"
                                        CanContentScroll="{TemplateBinding ScrollViewer.CanContentScroll}"
                                        VerticalScrollBarVisibility="Auto">
                                        <ItemsPresenter KeyboardNavigation.DirectionalNavigation="Contained" />
                                    </customControls:FadingScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style
            x:Key="LedgerGroupingComboStyle"
            BasedOn="{StaticResource LedgerFilterComboStyle}"
            TargetType="ComboBox">
            <Setter Property="ScrollViewer.CanContentScroll" Value="False" />
            <Setter Property="ItemContainerStyle" Value="{StaticResource FluxoComboBoxItemStyle}" />
        </Style>

        <Style x:Key="LedgerFilterComboBoxItemStyle" TargetType="ComboBoxItem">
            <Setter Property="Foreground" Value="{StaticResource Brush.Text.Primary}" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <ContentPresenter
                            HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                            Content="{TemplateBinding Content}"
                            ContentStringFormat="{TemplateBinding ContentStringFormat}"
                            ContentTemplate="{TemplateBinding ContentTemplate}" />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <DataTemplate x:Key="LedgerFilterOptionTemplate">
            <Button
                MinWidth="140"
                Padding="8,6"
                HorizontalAlignment="Stretch"
                Background="Transparent"
                BorderThickness="0"
                PreviewMouseLeftButtonDown="OnFilterOptionPreviewMouseLeftButtonDown">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border
                            x:Name="OptionBackground"
                            Padding="{TemplateBinding Padding}"
                            Background="{TemplateBinding Background}"
                            CornerRadius="6">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <TextBlock
                                    VerticalAlignment="Center"
                                    FontFamily="{StaticResource Medium}"
                                    FontSize="12"
                                    Foreground="{StaticResource Brush.Text.Primary}"
                                    Text="{Binding Label}" />

                                <Path
                                    x:Name="SelectedCheckmark"
                                    Grid.Column="1"
                                    Width="10"
                                    Height="10"
                                    Margin="12,0,0,0"
                                    VerticalAlignment="Center"
                                    Data="{StaticResource Check}"
                                    Fill="{StaticResource Brush.Text.Primary}"
                                    Opacity="0"
                                    Stretch="Uniform" />
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="OptionBackground" Property="Background" Value="{StaticResource Brush.Background.Hover}" />
                            </Trigger>
                            <DataTrigger Binding="{Binding IsChecked}" Value="True">
                                <Setter TargetName="OptionBackground" Property="Background" Value="{StaticResource Brush.Background.Hover}" />
                                <Setter TargetName="SelectedCheckmark" Property="Opacity" Value="1" />
                            </DataTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>
        </DataTemplate>

        <Style x:Key="LedgerListViewItemStyle" TargetType="ListViewItem">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListViewItem">
                        <ContentPresenter
                            Margin="0"
                            HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                            Content="{TemplateBinding Content}"
                            ContentStringFormat="{TemplateBinding ContentStringFormat}"
                            ContentTemplate="{TemplateBinding ContentTemplate}"
                            SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}" />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="LedgerEditableTextBoxStyle" TargetType="TextBox">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="CaretBrush" Value="{StaticResource Brush.Text.Primary}" />
            <Setter Property="Foreground" Value="{StaticResource Brush.Text.Primary}" />
            <Setter Property="IsReadOnly" Value="True" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsEditing}" Value="True">
                    <Setter Property="IsReadOnly" Value="False" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="LedgerEditableMoneyTextBoxStyle" TargetType="customControls:MoneyTextBox">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="CaretBrush" Value="{StaticResource Brush.Text.Primary}" />
            <Setter Property="Foreground" Value="{StaticResource Brush.Text.Primary}" />
            <Setter Property="HorizontalContentAlignment" Value="Right" />
            <Setter Property="IsReadOnly" Value="True" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsEditing}" Value="True">
                    <Setter Property="IsReadOnly" Value="False" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <DataTemplate x:Key="LedgerRowTemplate">
            <Border
                x:Name="RowRoot"
                MinHeight="48"
                Margin="0"
                Padding="0"
                Background="Transparent"
                BorderBrush="{StaticResource Brush.Border.Subtle}"
                BorderThickness="0,0,0,1">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="4" />
                        <ColumnDefinition Width="12" />
                        <ColumnDefinition Width="2*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="130" />
                    </Grid.ColumnDefinitions>

                    <Border
                        Grid.Column="0"
                        Margin="0,8,0,8"
                        CornerRadius="0,4,4,0">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Background" Value="{StaticResource Brush.Mint}" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding CategoryLabel}" Value="Wants">
                                        <Setter Property="Background" Value="#E59F3A" />
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding CategoryLabel}" Value="Invest">
                                        <Setter Property="Background" Value="#7DD3FC" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                    </Border>

                    <StackPanel
                        Grid.Column="2"
                        Margin="0,8,0,8"
                        Orientation="Horizontal">
                        <TextBox
                            MinWidth="120"
                            VerticalContentAlignment="Center"
                            FontFamily="{StaticResource Bold}"
                            FontSize="13"
                            Style="{StaticResource LedgerEditableTextBoxStyle}"
                            Text="{Binding Name, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                        <Border
                            Margin="8,0,0,0"
                            Padding="5,1"
                            Background="{StaticResource Brush.Background.Hover}"
                            CornerRadius="4">
                            <TextBlock
                                FontFamily="{StaticResource Bold}"
                                FontSize="9"
                                Foreground="{StaticResource Brush.Text.Primary}"
                                Text="GOAL" />
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsGoal}" Value="True">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                        </Border>
                        <Border
                            Margin="6,0,0,0"
                            Padding="5,1"
                            Background="#FFEBD2"
                            CornerRadius="4">
                            <TextBlock
                                FontFamily="{StaticResource Bold}"
                                FontSize="9"
                                Foreground="#7A4A00"
                                Text="RECURRING" />
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsRecurring}" Value="True">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                        </Border>
                    </StackPanel>

                    <Border
                        Grid.Column="3"
                        MaxWidth="160"
                        Padding="8,2"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Center"
                        Background="{Binding TagHexCode}"
                        CornerRadius="8">
                        <TextBlock
                            FontFamily="{StaticResource Medium}"
                            FontSize="11"
                            Foreground="{StaticResource Brush.Text.Primary}"
                            Text="{Binding TagName}" />
                    </Border>

                    <Border
                        Grid.Column="4"
                        MaxWidth="180"
                        Padding="8,3"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Center"
                        Background="{StaticResource Brush.Background.Hover}"
                        CornerRadius="8">
                        <TextBlock
                            FontFamily="{StaticResource Medium}"
                            FontSize="11"
                            Foreground="{StaticResource Brush.Mint}"
                            Text="{Binding SpendingSourceName}" />
                    </Border>

                    <TextBlock
                        Grid.Column="5"
                        Margin="0,8,16,8"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center"
                        FontFamily="{StaticResource Bold}"
                        FontSize="12"
                        Text="{Binding SignedAmount, StringFormat={}{0:+#,##0.00;-#,##0.00;$0.00}}">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Foreground" Value="{StaticResource Brush.Danger}" />
                                <Setter Property="Visibility" Value="{Binding IsEditing, Converter={StaticResource BoolToVisibilityInvertedConverter}}" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Kind}" Value="{x:Static main:LedgerTransactionKind.Income}">
                                        <Setter Property="Foreground" Value="{StaticResource Brush.Success}" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>

                    <customControls:MoneyTextBox
                        Grid.Column="5"
                        Margin="0,8,16,8"
                        FontFamily="{StaticResource Bold}"
                        FontSize="12"
                        Style="{StaticResource LedgerEditableMoneyTextBoxStyle}"
                        Text="{Binding Amount, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                        Visibility="{Binding IsEditing, Converter={StaticResource BoolToVisibilityConverter}}" />

                    <Border
                        x:Name="RowActions"
                        Grid.Column="5"
                        HorizontalAlignment="Right"
                        Background="{StaticResource Brush.Background.Surface}"
                        Opacity="0"
                        Visibility="Collapsed">
                        <StackPanel Margin="0,0,16,0" Orientation="Horizontal">
                            <customControls:BalloonButton
                                Width="30"
                                Height="30"
                                ButtonIcon="{StaticResource Pen}"
                                Command="{Binding DataContext.EditTransactionCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                CommandParameter="{Binding}"
                                IconSize="12"
                                Style="{StaticResource HeaderButtonStyle}" />
                            <customControls:BalloonButton
                                Width="30"
                                Height="30"
                                ButtonIcon="{StaticResource CircleMinusSolid}"
                                Click="OnRemoveTransactionClick"
                                CommandParameter="{Binding}"
                                HoveredBackground="{StaticResource Brush.Danger}"
                                IconSize="12"
                                Style="{StaticResource HeaderButtonStyle}" />
                        </StackPanel>
                    </Border>
                </Grid>
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Background" Value="Transparent" />
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{StaticResource Brush.Background.Hover}" />
                                <Setter Property="BorderBrush" Value="{StaticResource Brush.Mint.Muted}" />
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
            </Border>
            <DataTemplate.Triggers>
                <Trigger SourceName="RowRoot" Property="IsMouseOver" Value="True">
                    <Setter TargetName="RowActions" Property="Visibility" Value="Visible" />
                    <Setter TargetName="RowActions" Property="Opacity" Value="1" />
                </Trigger>
            </DataTemplate.Triggers>
        </DataTemplate>

        <Style x:Key="LedgerGroupItemStyle" TargetType="GroupItem">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="GroupItem">
                        <Border
                            Margin="0,0,0,8"
                            Background="{StaticResource Brush.Background.Surface}"
                            BorderBrush="{StaticResource Brush.Border.Subtle}"
                            BorderThickness="1"
                            CornerRadius="8">
                            <StackPanel>
                                <ToggleButton
                                    x:Name="LedgerGroupHeaderToggle"
                                    Margin="0,10,0,4"
                                    Content="{Binding Name}"
                                    Cursor="Hand"
                                    IsChecked="True">
                                    <ToggleButton.Template>
                                        <ControlTemplate TargetType="ToggleButton">
                                            <Grid
                                                Height="20"
                                                Margin="8,0,0,0"
                                                Background="Transparent">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>

                                                <TextBlock
                                                    x:Name="LedgerGroupHeaderText"
                                                    VerticalAlignment="Center"
                                                    FontFamily="{StaticResource Bold}"
                                                    FontSize="11"
                                                    Foreground="{StaticResource Brush.Text.Muted}"
                                                    Text="{TemplateBinding Content}" />

                                                <Border
                                                    x:Name="LedgerGroupHeaderLine"
                                                    Grid.Column="1"
                                                    Height="1"
                                                    Margin="8,0,0,0"
                                                    VerticalAlignment="Center"
                                                    Background="{StaticResource Brush.Border.Subtle}" />
                                            </Grid>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="LedgerGroupHeaderText" Property="Foreground" Value="{StaticResource Brush.Text.Primary}" />
                                                    <Setter TargetName="LedgerGroupHeaderLine" Property="Background" Value="{StaticResource Brush.Mint}" />
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </ToggleButton.Template>
                                </ToggleButton>

                                <ItemsPresenter x:Name="LedgerGroupItemsPresenter" />
                            </StackPanel>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger SourceName="LedgerGroupHeaderToggle" Property="IsChecked" Value="False">
                                <Setter TargetName="LedgerGroupItemsPresenter" Property="Visibility" Value="Collapsed" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <GroupStyle x:Key="LedgerGroupStyle" ContainerStyle="{StaticResource LedgerGroupItemStyle}" />
    </UserControl.Resources>

    <Grid Margin="24,0,24,0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <controls:MainViewModeToggleControl
            Margin="0,16"
            HorizontalAlignment="Center"
            VerticalAlignment="Top"
            DataContext="{Binding DataContext.ViewModeToggle, RelativeSource={RelativeSource AncestorType=Window}}" />

        <StackPanel
            Grid.Row="1"
            Margin="0,0,0,2"
            HorizontalAlignment="Right"
            Orientation="Horizontal">
            <TextBlock
                Margin="0,0,8,0"
                VerticalAlignment="Center"
                FontFamily="{StaticResource Medium}"
                FontSize="12"
                Foreground="{StaticResource Brush.Text.Muted}"
                Text="From" />
            <components:DateSelector
                x:Name="LedgerStartDateSelector"
                Width="150"
                MaxSelectableDate="{Binding MaxSelectableDate}"
                SelectedDate="{Binding StartDate, Mode=TwoWay}" />
            <TextBlock
                Margin="14,0,8,0"
                VerticalAlignment="Center"
                FontFamily="{StaticResource Medium}"
                FontSize="12"
                Foreground="{StaticResource Brush.Text.Muted}"
                Text="To" />
            <components:DateSelector
                x:Name="LedgerEndDateSelector"
                Width="150"
                MaxSelectableDate="{Binding MaxSelectableDate}"
                SelectedDate="{Binding EndDate, Mode=TwoWay}" />
        </StackPanel>

        <UniformGrid
            Grid.Row="2"
            Margin="0,18,0,0"
            Columns="4">
            <Border Margin="0,0,8,0" Style="{StaticResource LedgerSummaryCardStyle}">
                <StackPanel>
                    <TextBlock Foreground="{StaticResource Brush.Text.Muted}" Text="Spent" />
                    <TextBlock
                        FontFamily="{StaticResource Bold}"
                        FontSize="22"
                        Foreground="{StaticResource Brush.Danger}"
                        Text="{Binding SpentAmount, StringFormat={}{0:#,##0.00}}" />
                </StackPanel>
            </Border>
            <Border Margin="8,0" Style="{StaticResource LedgerSummaryCardStyle}">
                <StackPanel>
                    <TextBlock Foreground="{StaticResource Brush.Text.Muted}" Text="Earned" />
                    <TextBlock
                        FontFamily="{StaticResource Bold}"
                        FontSize="22"
                        Foreground="{StaticResource Brush.Success}"
                        Text="{Binding EarnedAmount, StringFormat={}{0:#,##0.00}}" />
                </StackPanel>
            </Border>
            <Border Margin="8,0" Style="{StaticResource LedgerSummaryCardStyle}">
                <StackPanel>
                    <TextBlock Foreground="{StaticResource Brush.Text.Muted}" Text="Goals" />
                    <TextBlock
                        FontFamily="{StaticResource Bold}"
                        FontSize="22"
                        Foreground="{StaticResource Brush.Mint}"
                        Text="{Binding GoalAmount, StringFormat={}{0:#,##0.00}}" />
                </StackPanel>
            </Border>
            <Border Margin="8,0,0,0" Style="{StaticResource LedgerSummaryCardStyle}">
                <StackPanel>
                    <TextBlock Foreground="{StaticResource Brush.Text.Muted}" Text="Net" />
                    <TextBlock
                        FontFamily="{StaticResource Bold}"
                        FontSize="22"
                        Foreground="{StaticResource Brush.Text.Primary}"
                        Text="{Binding NetAmount, StringFormat={}{0:#,##0.00}}" />
                </StackPanel>
            </Border>
        </UniformGrid>

        <Grid Grid.Row="3" Margin="0,16,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="3*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <ComboBox
                Grid.Column="0"
                ItemTemplate="{StaticResource LedgerFilterOptionTemplate}"
                ItemsSource="{Binding TypeFilters}"
                Style="{StaticResource LedgerFilterComboStyle}"
                Tag="Type" />
            <ComboBox
                Grid.Column="1"
                Margin="8,0,0,0"
                ItemTemplate="{StaticResource LedgerFilterOptionTemplate}"
                ItemsSource="{Binding SpendingSourceFilters}"
                Style="{StaticResource LedgerFilterComboStyle}"
                Tag="Spending Source" />
            <ComboBox
                Grid.Column="2"
                Margin="8,0,0,0"
                ItemTemplate="{StaticResource LedgerFilterOptionTemplate}"
                ItemsSource="{Binding CategoryFilters}"
                Style="{StaticResource LedgerFilterComboStyle}"
                Tag="Category" />
            <ComboBox
                Grid.Column="3"
                Margin="8,0,0,0"
                ItemTemplate="{StaticResource LedgerFilterOptionTemplate}"
                ItemsSource="{Binding TagFilters}"
                Style="{StaticResource LedgerFilterComboStyle}"
                Tag="Tag" />
            <ComboBox
                x:Name="LedgerGroupingComboBox"
                Grid.Column="4"
                Margin="8,0,0,0"
                ItemsSource="{Binding GroupingModes}"
                SelectedItem="{Binding SelectedGroupingMode, Mode=OneWay}"
                SelectionChanged="OnGroupingModeSelectionChanged"
                Style="{StaticResource LedgerGroupingComboStyle}"
                Tag="Group By" />
            <customControls:BalloonButton
                Grid.Column="5"
                ButtonIcon="{StaticResource Check}"
                ButtonSize="34"
                Click="OnApplyFiltersClick"
                IconSize="14"
                Style="{StaticResource HeaderButtonStyle}" />
            <customControls:BalloonButton
                Grid.Column="6"
                ButtonSize="34"
                Click="OnOrderingButtonClick"
                IconSize="14">
                <customControls:BalloonButton.Style>
                    <Style BasedOn="{StaticResource HeaderButtonStyle}" TargetType="customControls:BalloonButton">
                        <Setter Property="ButtonIcon" Value="{StaticResource ArrowDownWideNarrow}" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding AmountSortDirection}" Value="Ascending">
                                <Setter Property="ButtonIcon" Value="{StaticResource ArrowDownNarrowWide}" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </customControls:BalloonButton.Style>
            </customControls:BalloonButton>
        </Grid>

        <Grid Grid.Row="4">
            <ListView
                x:Name="LedgerTransactionsList"
                Margin="0,0,0,0"
                Background="Transparent"
                BorderThickness="0"
                ItemContainerStyle="{StaticResource LedgerListViewItemStyle}"
                ItemTemplate="{StaticResource LedgerRowTemplate}"
                ItemsSource="{Binding TransactionsView}"
                ScrollViewer.VerticalScrollBarVisibility="Hidden">
                <ListView.GroupStyle>
                    <StaticResource ResourceKey="LedgerGroupStyle" />
                </ListView.GroupStyle>
            </ListView>

            <TextBlock
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                FontFamily="{StaticResource Bold}"
                FontSize="13"
                Foreground="{StaticResource Brush.Text.Muted}"
                Visibility="{Binding HasVisibleTransactions, Converter={StaticResource BoolToVisibilityInvertedConverter}}">
                <Run Text="No ledger data found for " />
                <Run Text="{Binding EmptyStatePeriodText, Mode=OneWay}" />
            </TextBlock>
        </Grid>
    </Grid>
</UserControl>