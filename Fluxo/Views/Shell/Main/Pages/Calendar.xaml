<UserControl
    x:Class="Fluxo.Views.Shell.Main.Pages.Calendar"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:customControls="clr-namespace:Fluxo.Resources.CustomControls;assembly=Fluxo.Resources"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:main="clr-namespace:Fluxo.ViewModels.Shell.Main"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    x:Name="CalendarRoot"
    d:DataContext="{d:DesignInstance Type=main:CalendarVM}"
    d:DesignHeight="810"
    d:DesignWidth="1440"
    Focusable="True"
    mc:Ignorable="d">

    <UserControl.Resources>
        <Style x:Key="CalendarColumnLayoutStyle" TargetType="Grid">
            <Setter Property="Width" Value="480" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding UseExpandedCalendarLayout, ElementName=CalendarRoot}" Value="True">
                    <Setter Property="Width" Value="570" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style
            x:Key="CalendarGridCardStyle"
            BasedOn="{StaticResource CardBorderStyle}"
            TargetType="Border">
            <Setter Property="Width" Value="480" />
            <Setter Property="Height" Value="480" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding UseExpandedCalendarLayout, ElementName=CalendarRoot}" Value="True">
                    <Setter Property="Width" Value="570" />
                    <Setter Property="Height" Value="570" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="CalendarSectionTitleStyle" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="{StaticResource Bold}" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Foreground" Value="{StaticResource Brush.Text.Primary}" />
        </Style>

        <Style x:Key="CalendarCardLabelStyle" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="{StaticResource Bold}" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="Foreground" Value="{StaticResource Brush.Text.Muted}" />
        </Style>

        <Style x:Key="CalendarListItemHoverBorderStyle" TargetType="Border">
            <Setter Property="Margin" Value="0,0,0,8" />
            <Setter Property="Padding" Value="10,8" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="CornerRadius" Value="10" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource Brush.Background.Hover}" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="CalendarListItemsControlStyle" TargetType="ItemsControl">
            <Setter Property="ItemContainerStyle">
                <Setter.Value>
                    <Style TargetType="ContentPresenter">
                        <Setter Property="HorizontalAlignment" Value="Stretch" />
                    </Style>
                </Setter.Value>
            </Setter>
        </Style>

        <Style
            x:Key="CalendarWeekHeaderLabelStyle"
            BasedOn="{StaticResource CalendarCardLabelStyle}"
            TargetType="TextBlock">
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="TextAlignment" Value="Center" />
        </Style>

        <Style x:Key="CalendarValueTextStyle" TargetType="TextBlock">
            <Setter Property="Margin" Value="0,6,0,0" />
            <Setter Property="FontFamily" Value="{StaticResource Bold}" />
            <Setter Property="FontSize" Value="24" />
            <Setter Property="Foreground" Value="{StaticResource Brush.Text.Primary}" />
        </Style>

        <Style
            x:Key="CalendarSummaryInlineValueTextStyle"
            BasedOn="{StaticResource CalendarValueTextStyle}"
            TargetType="TextBlock">
            <Setter Property="Margin" Value="12,0,0,0" />
            <Setter Property="FontSize" Value="20" />
            <Setter Property="HorizontalAlignment" Value="Right" />
        </Style>

        <Style x:Key="CalendarSummaryMaximizedVisibilityStyle" TargetType="Grid">
            <Setter Property="Visibility" Value="Collapsed" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding UseExpandedCalendarLayout, ElementName=CalendarRoot}" Value="True">
                    <Setter Property="Visibility" Value="Visible" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="CalendarSummaryRestoredVisibilityStyle" TargetType="Grid">
            <Setter Property="Visibility" Value="Visible" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding UseExpandedCalendarLayout, ElementName=CalendarRoot}" Value="True">
                    <Setter Property="Visibility" Value="Collapsed" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="CalendarNoDataTextStyle" TargetType="TextBlock">
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="FontFamily" Value="{StaticResource Bold}" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Foreground" Value="{StaticResource Brush.Text.Muted}" />
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>

        <Style x:Key="CalendarDayButtonStyle" TargetType="Button">
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="VerticalAlignment" Value="Stretch" />
            <Setter Property="MinHeight" Value="42" />
            <Setter Property="Margin" Value="2" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="{StaticResource Brush.Border.Subtle}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border
                            x:Name="DayBorder"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="10">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="DayBorder" Property="Background" Value="{StaticResource Brush.Background.Hover}" />
                            </Trigger>
                            <MultiDataTrigger>
                                <MultiDataTrigger.Conditions>
                                    <Condition Binding="{Binding IsSelected}" Value="True" />
                                    <Condition Binding="{Binding IsMouseOver, RelativeSource={RelativeSource TemplatedParent}}" Value="True" />
                                </MultiDataTrigger.Conditions>
                                <Setter TargetName="DayBorder" Property="Background" Value="{StaticResource Brush.Mint.Muted}" />
                            </MultiDataTrigger>
                            <MultiDataTrigger>
                                <MultiDataTrigger.Conditions>
                                    <Condition Binding="{Binding IsCurrentDay}" Value="True" />
                                    <Condition Binding="{Binding IsMouseOver, RelativeSource={RelativeSource TemplatedParent}}" Value="True" />
                                </MultiDataTrigger.Conditions>
                                <Setter TargetName="DayBorder" Property="BorderBrush" Value="{StaticResource Brush.Mint.Muted}" />
                            </MultiDataTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsSelected}" Value="True">
                    <Setter Property="Background" Value="{StaticResource Brush.Mint}" />
                    <Setter Property="BorderBrush" Value="{StaticResource Brush.Mint}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding IsCurrentDay}" Value="True">
                    <Setter Property="BorderBrush" Value="{StaticResource Brush.Mint}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding IsOutsideVisibleMonth}" Value="True">
                    <Setter Property="Opacity" Value="0.45" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <DataTemplate x:Key="CalendarDayTemplate">
            <Button
                x:Name="CalendarDayButton"
                Click="OnCalendarDayButtonClick"
                Command="{Binding DataContext.SelectDateCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                CommandParameter="{Binding}"
                Focusable="False"
                Style="{StaticResource CalendarDayButtonStyle}">
                <TextBlock
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    FontFamily="{StaticResource Bold}"
                    FontSize="14"
                    Text="{Binding DayNumber}">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Foreground" Value="{StaticResource Brush.Text.Primary}" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                    <Setter Property="Foreground" Value="{StaticResource Brush.Text.Primary.Dark}" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
            </Button>
        </DataTemplate>

        <DataTemplate x:Key="CalendarWeekTemplate">
            <ItemsControl
                HorizontalAlignment="Stretch"
                VerticalAlignment="Stretch"
                ItemTemplate="{StaticResource CalendarDayTemplate}"
                ItemsSource="{Binding Days}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <UniformGrid Columns="7" Rows="1" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
            </ItemsControl>
        </DataTemplate>

        <DataTemplate x:Key="ExpenseItemTemplate">
            <Border Style="{StaticResource CalendarListItemHoverBorderStyle}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock
                            FontFamily="{StaticResource Bold}"
                            Foreground="{StaticResource Brush.Text.Primary}"
                            Text="{Binding Name}" />
                        <TextBlock
                            Margin="0,3,0,0"
                            FontFamily="{StaticResource Medium}"
                            FontSize="11"
                            Foreground="{StaticResource Brush.Text.Secondary}"
                            Text="{Binding AccountName}" />
                    </StackPanel>
                    <TextBlock
                        Grid.Column="1"
                        FontFamily="{StaticResource Bold}"
                        Foreground="{StaticResource Brush.Danger}"
                        Text="{Binding AmountText}" />
                </Grid>
            </Border>
        </DataTemplate>

        <DataTemplate x:Key="IncomeItemTemplate">
            <Border Style="{StaticResource CalendarListItemHoverBorderStyle}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock
                            FontFamily="{StaticResource Bold}"
                            Foreground="{StaticResource Brush.Text.Primary}"
                            Text="{Binding Name}" />
                        <TextBlock
                            Margin="0,3,0,0"
                            FontFamily="{StaticResource Medium}"
                            FontSize="11"
                            Foreground="{StaticResource Brush.Text.Secondary}"
                            Text="{Binding AccountName}" />
                    </StackPanel>
                    <TextBlock
                        Grid.Column="1"
                        FontFamily="{StaticResource Bold}"
                        Foreground="{StaticResource Brush.Mint}"
                        Text="{Binding AmountText}" />
                </Grid>
            </Border>
        </DataTemplate>

        <DataTemplate x:Key="GoalDeadlineItemTemplate">
            <Border Style="{StaticResource CalendarListItemHoverBorderStyle}">
                <StackPanel>
                    <TextBlock
                        FontFamily="{StaticResource Bold}"
                        Foreground="{StaticResource Brush.Text.Primary}"
                        Text="{Binding Name}" />
                    <TextBlock
                        Margin="0,3,0,0"
                        FontFamily="{StaticResource Medium}"
                        FontSize="11"
                        Foreground="{StaticResource Brush.Text.Secondary}"
                        Text="{Binding ProgressText}" />
                </StackPanel>
            </Border>
        </DataTemplate>

        <DataTemplate x:Key="RecurringTransactionItemTemplate">
            <Border Style="{StaticResource CalendarListItemHoverBorderStyle}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock
                            FontFamily="{StaticResource Bold}"
                            Foreground="{StaticResource Brush.Text.Primary}"
                            Text="{Binding Name}" />
                        <TextBlock
                            Margin="0,3,0,0"
                            FontFamily="{StaticResource Medium}"
                            FontSize="11"
                            Foreground="{StaticResource Brush.Text.Secondary}">
                            <Run Text="{Binding TypeText}" />
                            <Run Text=" - " />
                            <Run Text="{Binding SourceName}" />
                        </TextBlock>
                    </StackPanel>
                    <TextBlock
                        Grid.Column="1"
                        FontFamily="{StaticResource Bold}"
                        Foreground="{StaticResource Brush.Info}"
                        Text="{Binding AmountText}" />
                </Grid>
            </Border>
        </DataTemplate>
    </UserControl.Resources>

    <Grid Margin="12">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="14" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Grid Style="{StaticResource CalendarColumnLayoutStyle}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="10" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Border Style="{StaticResource CardBorderStyle}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <TextBlock
                        VerticalAlignment="Center"
                        FontFamily="{StaticResource Bold}"
                        FontSize="18"
                        Foreground="{StaticResource Brush.Text.Primary}"
                        Text="{Binding VisibleMonthLabel}" />
                    <StackPanel
                        Grid.Column="1"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center"
                        Orientation="Horizontal">
                        <customControls:BalloonButton
                            ButtonIcon="{StaticResource AngleUp}"
                            Command="{Binding NavigateToPreviousMonthCommand}"
                            Style="{StaticResource ToolbarActionBalloonButtonStyle}"
                            ToolTip="Previous month"
                            DefaultBackground="{StaticResource Brush.BalloonButton.Background.Surface}"
                            HoveredBackground="{StaticResource Brush.BalloonButton.Background.Surface.Hovered}" />
                        <customControls:BalloonButton
                            ButtonIcon="{StaticResource CalendarTodayOutline}"
                            Click="OnCalendarTodayButtonClick"
                            IsEnabled="{Binding IsAtCurrentDay, Converter={StaticResource BoolNegationConverter}}"
                            Style="{StaticResource ToolbarActionBalloonButtonStyle}"
                            ToolTip="Today"
                            DefaultBackground="{StaticResource Brush.BalloonButton.Background.NavInfo}"
                            HoveredBackground="{StaticResource Brush.BalloonButton.Background.NavInfo.Hovered}" />
                        <customControls:BalloonButton
                            ButtonIcon="{StaticResource AngleDown}"
                            Command="{Binding NavigateToNextMonthCommand}"
                            Style="{StaticResource ToolbarActionBalloonButtonStyle}"
                            ToolTip="Next month"
                            DefaultBackground="{StaticResource Brush.BalloonButton.Background.Surface}"
                            HoveredBackground="{StaticResource Brush.BalloonButton.Background.Surface.Hovered}" />
                    </StackPanel>
                </Grid>
            </Border>

            <Border
                Grid.Row="1"
                Margin="0,12,0,0"
                MouseWheel="OnCalendarMouseWheel"
                Style="{StaticResource CalendarGridCardStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <UniformGrid Columns="7">
                        <TextBlock Style="{StaticResource CalendarWeekHeaderLabelStyle}" Text="SUN" />
                        <TextBlock Style="{StaticResource CalendarWeekHeaderLabelStyle}" Text="MON" />
                        <TextBlock Style="{StaticResource CalendarWeekHeaderLabelStyle}" Text="TUE" />
                        <TextBlock Style="{StaticResource CalendarWeekHeaderLabelStyle}" Text="WED" />
                        <TextBlock Style="{StaticResource CalendarWeekHeaderLabelStyle}" Text="THU" />
                        <TextBlock Style="{StaticResource CalendarWeekHeaderLabelStyle}" Text="FRI" />
                        <TextBlock Style="{StaticResource CalendarWeekHeaderLabelStyle}" Text="SAT" />
                    </UniformGrid>

                    <Grid
                        x:Name="CalendarWeekViewport"
                        Grid.Row="1"
                        Margin="0,10,0,0"
                        ClipToBounds="True"
                        Focusable="True"
                        SizeChanged="OnCalendarWeekViewportSizeChanged">
                        <Canvas x:Name="CalendarWeekSurface" ClipToBounds="False">
                            <ItemsControl
                                x:Name="CalendarWeekItemsControl"
                                Width="{Binding ActualWidth, ElementName=CalendarWeekViewport}"
                                ItemTemplate="{StaticResource CalendarWeekTemplate}"
                                ItemsSource="{Binding BufferedWeeks}">
                                <ItemsControl.RenderTransform>
                                    <TranslateTransform x:Name="CalendarWeekTranslateTransform" />
                                </ItemsControl.RenderTransform>
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <UniformGrid Rows="10" />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemContainerStyle>
                                    <Style TargetType="ContentPresenter">
                                        <Setter Property="HorizontalAlignment" Value="Stretch" />
                                        <Setter Property="VerticalAlignment" Value="Stretch" />
                                    </Style>
                                </ItemsControl.ItemContainerStyle>
                            </ItemsControl>
                        </Canvas>
                    </Grid>
                </Grid>
            </Border>

            <Grid Grid.Row="3">
                <Grid Style="{StaticResource CalendarSummaryMaximizedVisibilityStyle}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" />
                        <RowDefinition Height="10" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="10" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="10" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Border Style="{StaticResource CardBorderStyle}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock
                                VerticalAlignment="Center"
                                Style="{StaticResource CalendarCardLabelStyle}"
                                Text="Total Spent" />
                            <TextBlock
                                Grid.Column="1"
                                Foreground="{StaticResource Brush.Danger}"
                                Style="{StaticResource CalendarSummaryInlineValueTextStyle}"
                                Text="{Binding TotalSpentText}" />
                        </Grid>
                    </Border>

                    <Border Grid.Row="2" Style="{StaticResource CardBorderStyle}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock
                                VerticalAlignment="Center"
                                Style="{StaticResource CalendarCardLabelStyle}"
                                Text="Total Earned" />
                            <TextBlock
                                Grid.Column="1"
                                Foreground="{StaticResource Brush.Mint}"
                                Style="{StaticResource CalendarSummaryInlineValueTextStyle}"
                                Text="{Binding TotalEarnedText}" />
                        </Grid>
                    </Border>

                    <Border Grid.Row="4" Style="{StaticResource CardBorderStyle}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock
                                VerticalAlignment="Center"
                                Style="{StaticResource CalendarCardLabelStyle}"
                                Text="Goals Due" />
                            <TextBlock
                                Grid.Column="1"
                                Foreground="{StaticResource Brush.Warning}"
                                Style="{StaticResource CalendarSummaryInlineValueTextStyle}"
                                Text="{Binding GoalsDueText}" />
                        </Grid>
                    </Border>

                    <Border Grid.Row="6" Style="{StaticResource CardBorderStyle}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock
                                VerticalAlignment="Center"
                                Style="{StaticResource CalendarCardLabelStyle}"
                                Text="Payment Due" />
                            <TextBlock
                                Grid.Column="1"
                                Foreground="{StaticResource Brush.Info}"
                                Style="{StaticResource CalendarSummaryInlineValueTextStyle}"
                                Text="{Binding PaymentDueText}" />
                        </Grid>
                    </Border>
                </Grid>

                <Grid Style="{StaticResource CalendarSummaryRestoredVisibilityStyle}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="10" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" />
                        <RowDefinition Height="10" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Border
                        Padding="16,0"
                        HorizontalAlignment="Stretch"
                        Style="{StaticResource CardBorderStyle}">
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Style="{StaticResource CalendarCardLabelStyle}" Text="Total Spent" />
                            <TextBlock
                                Foreground="{StaticResource Brush.Danger}"
                                Style="{StaticResource CalendarValueTextStyle}"
                                Text="{Binding TotalSpentText}" />
                        </StackPanel>
                    </Border>

                    <Border
                        Grid.Column="2"
                        Padding="16,0"
                        HorizontalAlignment="Stretch"
                        Style="{StaticResource CardBorderStyle}">
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Style="{StaticResource CalendarCardLabelStyle}" Text="Total Earned" />
                            <TextBlock
                                Foreground="{StaticResource Brush.Mint}"
                                Style="{StaticResource CalendarValueTextStyle}"
                                Text="{Binding TotalEarnedText}" />
                        </StackPanel>
                    </Border>

                    <Border
                        Grid.Row="2"
                        Padding="16,0"
                        HorizontalAlignment="Stretch"
                        Style="{StaticResource CardBorderStyle}">
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Style="{StaticResource CalendarCardLabelStyle}" Text="Goals Due" />
                            <TextBlock
                                Foreground="{StaticResource Brush.Warning}"
                                Style="{StaticResource CalendarValueTextStyle}"
                                Text="{Binding GoalsDueText}" />
                        </StackPanel>
                    </Border>

                    <Border
                        Grid.Row="2"
                        Grid.Column="2"
                        Padding="16,0"
                        HorizontalAlignment="Stretch"
                        Style="{StaticResource CardBorderStyle}">
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Style="{StaticResource CalendarCardLabelStyle}" Text="Payment Due" />
                            <TextBlock
                                Foreground="{StaticResource Brush.Info}"
                                Style="{StaticResource CalendarValueTextStyle}"
                                Text="{Binding PaymentDueText}" />
                        </StackPanel>
                    </Border>
                </Grid>
            </Grid>
        </Grid>

        <Grid Grid.Column="2">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="14" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="14" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Border Style="{StaticResource CardBorderStyle}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <TextBlock Style="{StaticResource CalendarSectionTitleStyle}" Text="Expenses" />
                        <customControls:FadingScrollViewer
                            Grid.Row="1"
                            Margin="0,14,0,0"
                            VerticalScrollBarVisibility="Auto">
                            <Grid>
                                <ItemsControl
                                    ItemTemplate="{StaticResource ExpenseItemTemplate}"
                                    ItemsSource="{Binding Expenses}"
                                    Style="{StaticResource CalendarListItemsControlStyle}" />
                                <TextBlock
                                    Style="{StaticResource CalendarNoDataTextStyle}"
                                    Text="No expenses for this date."
                                    Visibility="{Binding HasNoExpenses, Converter={StaticResource BoolToVisibilityConverter}}" />
                            </Grid>
                        </customControls:FadingScrollViewer>
                    </Grid>
                </Border>

                <Border Grid.Column="2" Style="{StaticResource CardBorderStyle}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <TextBlock Style="{StaticResource CalendarSectionTitleStyle}" Text="Incomes" />
                        <customControls:FadingScrollViewer
                            Grid.Row="1"
                            Margin="0,14,0,0"
                            VerticalScrollBarVisibility="Auto">
                            <Grid>
                                <ItemsControl
                                    ItemTemplate="{StaticResource IncomeItemTemplate}"
                                    ItemsSource="{Binding Incomes}"
                                    Style="{StaticResource CalendarListItemsControlStyle}" />
                                <TextBlock
                                    Style="{StaticResource CalendarNoDataTextStyle}"
                                    Text="No incomes for this date."
                                    Visibility="{Binding HasNoIncomes, Converter={StaticResource BoolToVisibilityConverter}}" />
                            </Grid>
                        </customControls:FadingScrollViewer>
                    </Grid>
                </Border>

                <Border Grid.Row="2" Style="{StaticResource CardBorderStyle}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <TextBlock Style="{StaticResource CalendarSectionTitleStyle}" Text="Goal Deadlines" />
                        <customControls:FadingScrollViewer
                            Grid.Row="1"
                            Margin="0,14,0,0"
                            VerticalScrollBarVisibility="Auto">
                            <Grid>
                                <ItemsControl
                                    ItemTemplate="{StaticResource GoalDeadlineItemTemplate}"
                                    ItemsSource="{Binding GoalDeadlines}"
                                    Style="{StaticResource CalendarListItemsControlStyle}" />
                                <TextBlock
                                    Style="{StaticResource CalendarNoDataTextStyle}"
                                    Text="No goal deadlines for this date."
                                    Visibility="{Binding HasNoGoalDeadlines, Converter={StaticResource BoolToVisibilityConverter}}" />
                            </Grid>
                        </customControls:FadingScrollViewer>
                    </Grid>
                </Border>

                <Border
                    Grid.Row="2"
                    Grid.Column="2"
                    Style="{StaticResource CardBorderStyle}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <TextBlock Style="{StaticResource CalendarSectionTitleStyle}" Text="Recurring Transactions" />
                        <customControls:FadingScrollViewer
                            Grid.Row="1"
                            Margin="0,14,0,0"
                            VerticalScrollBarVisibility="Auto">
                            <Grid>
                                <ItemsControl
                                    ItemTemplate="{StaticResource RecurringTransactionItemTemplate}"
                                    ItemsSource="{Binding RecurringTransactions}"
                                    Style="{StaticResource CalendarListItemsControlStyle}" />
                                <TextBlock
                                    Style="{StaticResource CalendarNoDataTextStyle}"
                                    Text="No recurring transactions for this date."
                                    Visibility="{Binding HasNoRecurringTransactions, Converter={StaticResource BoolToVisibilityConverter}}" />
                            </Grid>
                        </customControls:FadingScrollViewer>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</UserControl>
