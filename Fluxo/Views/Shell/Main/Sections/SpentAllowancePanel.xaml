<UserControl
    x:Class="Fluxo.Views.Shell.Main.Sections.SpentAllowancePanel"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid VerticalAlignment="Center">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="16" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="16" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border
            Width="120"
            Padding="24,12"
            BorderBrush="{StaticResource Brush.Border.Subtle}"
            BorderThickness="2"
            CornerRadius="8">
            <StackPanel VerticalAlignment="Center">
                <TextBlock
                    VerticalAlignment="Bottom"
                    FontFamily="{StaticResource Light}"
                    Foreground="{StaticResource Brush.Text.Muted}"
                    Text="SPENT" />

                <TextBlock
                    Margin="0,8,0,0"
                    FontFamily="{StaticResource Bold}"
                    FontSize="18"
                    Foreground="{StaticResource Brush.Text.Primary}"
                    Text="{Binding TotalSpent, Converter={StaticResource NumberWithCommasConverter}}"
                    ToolTip="{Binding TotalSpent, Converter={StaticResource MoneyFullDisplayConverter}}" />
            </StackPanel>
        </Border>

        <Border
            Grid.Column="2"
            Width="160"
            Padding="24,12"
            BorderBrush="{StaticResource Brush.Border.Subtle}"
            BorderThickness="2"
            CornerRadius="8">
            <StackPanel>
                <TextBlock
                    VerticalAlignment="Bottom"
                    FontFamily="{StaticResource Light}"
                    Foreground="{StaticResource Brush.Text.Muted}"
                    Text="ALLOWANCE" />

                <TextBlock Margin="0,8,0,0" ToolTip="{Binding Allowance, Converter={StaticResource MoneyFullDisplayConverter}}">
                    <Run
                        FontFamily="{StaticResource Bold}"
                        FontSize="18"
                        Foreground="{StaticResource Brush.Text.Primary}"
                        Text="{Binding Allowance, Converter={StaticResource NumberWithCommasConverter}}" />
                    <Run
                        FontFamily="{StaticResource Medium}"
                        FontSize="12"
                        Foreground="{StaticResource Brush.Text.Secondary}"
                        Text="/ day" />
                </TextBlock>
            </StackPanel>
        </Border>

        <Border
            Grid.Column="4"
            Width="120"
            Padding="24,12"
            BorderBrush="{StaticResource Brush.Border.Subtle}"
            BorderThickness="2"
            CornerRadius="8">
            <StackPanel VerticalAlignment="Center">
                <TextBlock
                    VerticalAlignment="Bottom"
                    FontFamily="{StaticResource Light}"
                    Foreground="{StaticResource Brush.Text.Muted}"
                    Text="NET" />

                <TextBlock
                    Margin="0,8,0,0"
                    FontFamily="{StaticResource Bold}"
                    FontSize="18"
                    Foreground="{Binding Net, Converter={StaticResource DifferenceToBrushConverter}}"
                    Text="{Binding Net, Converter={StaticResource NumberWithCommasConverter}}"
                    ToolTip="{Binding Net, Converter={StaticResource MoneyFullDisplayConverter}}" />
            </StackPanel>
        </Border>
    </Grid>
</UserControl>