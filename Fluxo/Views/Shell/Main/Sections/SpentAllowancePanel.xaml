<UserControl
    x:Class="Fluxo.Views.Shell.Main.Sections.SpentAllowancePanel"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Border
        MinWidth="280"
        Margin="0,12,12,16"
        Padding="24,16"
        BorderBrush="{StaticResource Brush.Border.Subtle}"
        BorderThickness="1"
        CornerRadius="16">
        <Grid Margin="24,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="16" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Grid.RowDefinitions>
                <RowDefinition />
                <RowDefinition />
            </Grid.RowDefinitions>
            <TextBlock
                VerticalAlignment="Bottom"
                FontFamily="{StaticResource Light}"
                Foreground="{StaticResource Brush.Text.Muted}"
                Text="SPENT" />
            <TextBlock
                Grid.Row="1"
                Margin="0,8,0,0"
                FontFamily="{StaticResource Bold}"
                FontSize="18"
                Foreground="{StaticResource Brush.Text.Primary}"
                Text="{Binding TotalSpent, Converter={StaticResource NumberWithCommasConverter}}"
                ToolTip="{Binding TotalSpent, Converter={StaticResource MoneyFullDisplayConverter}}" />
            <TextBlock
                Grid.Column="2"
                VerticalAlignment="Bottom"
                FontFamily="{StaticResource Light}"
                Foreground="{StaticResource Brush.Text.Muted}"
                Text="DAILY&#10;ALLOWANCE" />
            <TextBlock
                Grid.Row="1"
                Grid.Column="2"
                Margin="0,8,0,0"
                FontFamily="{StaticResource Bold}"
                FontSize="18"
                Foreground="{StaticResource Brush.Text.Primary}"
                Text="{Binding Allowance, Converter={StaticResource NumberWithCommasConverter}}"
                ToolTip="{Binding Allowance, Converter={StaticResource MoneyFullDisplayConverter}}" />
        </Grid>
    </Border>
</UserControl>
