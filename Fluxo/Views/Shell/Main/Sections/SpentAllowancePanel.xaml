<UserControl
    x:Class="Fluxo.Views.Shell.Main.Sections.SpentAllowancePanel"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:customControls="clr-namespace:Fluxo.Resources.CustomControls;assembly=Fluxo.Resources">

    <customControls:SpacedUniformGrid
        Width="400"
        VerticalAlignment="Center"
        HorizontalGap="8"
        VerticalGap="8">
        <Border
            Padding="12,8"
            BorderBrush="{StaticResource Brush.Border.Subtle}"
            BorderThickness="2"
            CornerRadius="8">
            <Border.Background>
                <SolidColorBrush Opacity="0.5" Color="{StaticResource Color.Background.Elevated}" />
            </Border.Background>
            <Grid VerticalAlignment="Center">
                <TextBlock
                    VerticalAlignment="Center"
                    FontFamily="{StaticResource Light}"
                    Foreground="{StaticResource Brush.Text.Muted}"
                    Text="SPENT" />

                <TextBlock
                    HorizontalAlignment="Right"
                    VerticalAlignment="Center"
                    FontFamily="{StaticResource Bold}"
                    FontSize="18"
                    Foreground="{StaticResource Brush.Text.Primary}"
                    Text="{Binding TotalSpent, Converter={StaticResource NumberWithCommasConverter}}"
                    ToolTip="{Binding TotalSpent, Converter={StaticResource MoneyFullDisplayConverter}}" />
            </Grid>
        </Border>

        <Border
            Padding="12,8"
            BorderBrush="{StaticResource Brush.Border.Subtle}"
            BorderThickness="2"
            CornerRadius="8">
            <Border.Background>
                <SolidColorBrush Opacity="0.5" Color="{StaticResource Color.Background.Elevated}" />
            </Border.Background>
            <Grid VerticalAlignment="Center">
                <TextBlock
                    VerticalAlignment="Center"
                    FontFamily="{StaticResource Light}"
                    Foreground="{StaticResource Brush.Text.Muted}"
                    Text="EARNED" />

                <TextBlock
                    HorizontalAlignment="Right"
                    VerticalAlignment="Center"
                    FontFamily="{StaticResource Bold}"
                    FontSize="18"
                    Foreground="{Binding TotalEarned, Converter={StaticResource DifferenceToBrushConverter}}"
                    Text="{Binding TotalEarned, Converter={StaticResource NumberWithCommasConverter}}"
                    ToolTip="{Binding TotalEarned, Converter={StaticResource MoneyFullDisplayConverter}}" />
            </Grid>
        </Border>

        <Border
            Padding="12,8"
            BorderBrush="{StaticResource Brush.Border.Subtle}"
            BorderThickness="2"
            CornerRadius="8">
            <Border.Background>
                <SolidColorBrush Opacity="0.5" Color="{StaticResource Color.Background.Elevated}" />
            </Border.Background>
            <Grid VerticalAlignment="Center">
                <TextBlock
                    VerticalAlignment="Center"
                    FontFamily="{StaticResource Light}"
                    Foreground="{StaticResource Brush.Text.Muted}"
                    Text="ALLOWANCE" />

                <TextBlock
                    HorizontalAlignment="Right"
                    VerticalAlignment="Center"
                    ToolTip="{Binding Allowance, Converter={StaticResource MoneyFullDisplayConverter}}">
                    <Run
                        FontFamily="{StaticResource Bold}"
                        FontSize="18"
                        Foreground="{StaticResource Brush.Text.Primary}"
                        Text="{Binding Allowance, Converter={StaticResource NumberWithCommasConverter}}" />
                    <Run
                        FontFamily="{StaticResource Medium}"
                        FontSize="12"
                        Foreground="{StaticResource Brush.Text.Secondary}"
                        Text="/ day" />
                </TextBlock>
            </Grid>
        </Border>

        <Border
            Padding="12,8"
            BorderBrush="{StaticResource Brush.Border.Subtle}"
            BorderThickness="2"
            CornerRadius="8">
            <Border.Background>
                <SolidColorBrush Opacity="0.3" Color="{StaticResource Color.Background.Elevated}" />
            </Border.Background>
            <Grid VerticalAlignment="Center">
                <TextBlock
                    VerticalAlignment="Center"
                    FontFamily="{StaticResource Light}"
                    Foreground="{StaticResource Brush.Text.Muted}"
                    Text="NET" />

                <TextBlock
                    HorizontalAlignment="Right"
                    VerticalAlignment="Center"
                    FontFamily="{StaticResource Bold}"
                    FontSize="18"
                    Foreground="{Binding Net, Converter={StaticResource DifferenceToBrushConverter}}"
                    Text="{Binding Net, Converter={StaticResource NumberWithCommasConverter}}"
                    ToolTip="{Binding Net, Converter={StaticResource MoneyFullDisplayConverter}}" />
            </Grid>
        </Border>
    </customControls:SpacedUniformGrid>
</UserControl>
