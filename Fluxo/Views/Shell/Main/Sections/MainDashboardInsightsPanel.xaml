<UserControl
    x:Class="Fluxo.Views.Shell.Main.Sections.MainDashboardInsightsPanel"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="16" />
            <RowDefinition Height="2*" />
        </Grid.RowDefinitions>

        <Border Style="{StaticResource DashboardPanelStyle}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="12" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <TextBlock
                        FontFamily="{StaticResource Bold}"
                        FontSize="13"
                        Foreground="{StaticResource Brush.Text.Primary}"
                        Text="Notifications" />

                    <Border Grid.Column="1" Style="{StaticResource DashboardCountBadgeStyle}">
                        <TextBlock
                            FontFamily="{StaticResource Bold}"
                            FontSize="9"
                            Foreground="{StaticResource Brush.Text.Secondary}"
                            Text="{Binding NotificationCount}" />
                    </Border>
                </Grid>

                <TextBlock
                    Grid.Row="2"
                    VerticalAlignment="Center"
                    FontFamily="{StaticResource Medium}"
                    FontSize="11"
                    Foreground="{StaticResource Brush.Text.Muted}"
                    Text="You're all caught up."
                    TextAlignment="Center"
                    Visibility="{Binding HasNotifications, Converter={StaticResource BoolToVisibilityInvertedConverter}}" />

                <ScrollViewer
                    Grid.Row="2"
                    VerticalScrollBarVisibility="Auto"
                    Visibility="{Binding HasNotifications, Converter={StaticResource BoolToVisibilityConverter}}">
                    <ItemsControl ItemTemplate="{StaticResource DashboardNotificationTemplate}" ItemsSource="{Binding Notifications}" />
                </ScrollViewer>
            </Grid>
        </Border>

        <Border Grid.Row="2" Style="{StaticResource DashboardPanelStyle}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="12" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <TextBlock
                        FontFamily="{StaticResource Bold}"
                        FontSize="13"
                        Foreground="{StaticResource Brush.Text.Primary}"
                        Text="Saving Goals" />

                    <Border Grid.Column="1" Style="{StaticResource DashboardCountBadgeStyle}">
                        <TextBlock
                            FontFamily="{StaticResource Bold}"
                            FontSize="9"
                            Foreground="{StaticResource Brush.Text.Secondary}"
                            Text="{Binding SavingGoals.Count}" />
                    </Border>
                </Grid>

                <TextBlock
                    Grid.Row="2"
                    VerticalAlignment="Center"
                    FontFamily="{StaticResource Medium}"
                    FontSize="11"
                    Foreground="{StaticResource Brush.Text.Muted}"
                    Text="Add a saving goal to track progress here."
                    TextAlignment="Center"
                    Visibility="{Binding HasSavingGoals, Converter={StaticResource BoolToVisibilityInvertedConverter}}" />

                <ScrollViewer
                    Grid.Row="2"
                    VerticalScrollBarVisibility="Auto"
                    Visibility="{Binding HasSavingGoals, Converter={StaticResource BoolToVisibilityConverter}}">
                    <ItemsControl ItemTemplate="{StaticResource SavingGoalTemplate}" ItemsSource="{Binding SavingGoals}" />
                </ScrollViewer>
            </Grid>
        </Border>
    </Grid>
</UserControl>
