<UserControl
    x:Class="Fluxo.Views.Shell.Main.Sections.UpcomingEventsPanel"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <UserControl.Resources>
        <DataTemplate x:Key="UpcomingEventItemTemplate">
            <Border
                x:Name="UpcomingEventItemSurface"
                Height="{Binding UpcomingEventItemHeight, RelativeSource={RelativeSource AncestorType=UserControl}}"
                Margin="0,0,0,10"
                Padding="8"
                Background="Transparent"
                BorderBrush="{StaticResource Brush.Border.Subtle}"
                BorderThickness="1"
                CornerRadius="8">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="48" />
                        <ColumnDefinition Width="12" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="12" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <Border
                        Width="40"
                        Height="40"
                        Background="{StaticResource Brush.Background.Surface}"
                        BorderBrush="{StaticResource Brush.Border.Subtle}"
                        BorderThickness="1"
                        CornerRadius="8">
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock
                                HorizontalAlignment="Center"
                                FontFamily="{StaticResource Bold}"
                                FontSize="9"
                                Foreground="{StaticResource Brush.Text.Muted}"
                                Text="{Binding MonthText}" />
                            <TextBlock
                                Margin="0,2,0,0"
                                HorizontalAlignment="Center"
                                FontFamily="{StaticResource Black}"
                                FontSize="16"
                                Foreground="{StaticResource Brush.Text.Primary}"
                                Text="{Binding DayText}" />
                        </StackPanel>
                    </Border>

                    <StackPanel Grid.Column="2" VerticalAlignment="Center">
                        <TextBlock
                            FontFamily="{StaticResource Bold}"
                            FontSize="13"
                            Foreground="{StaticResource Brush.Text.Primary}"
                            Text="{Binding Title}"
                            TextTrimming="CharacterEllipsis" />
                        <TextBlock
                            Margin="0,4,0,0"
                            FontFamily="{StaticResource Medium}"
                            FontSize="11"
                            Foreground="{StaticResource Brush.Text.Secondary}"
                            Text="{Binding AmountText}"
                            TextTrimming="CharacterEllipsis" />
                    </StackPanel>

                    <Border
                        x:Name="UpcomingEventTypeBadge"
                        Grid.Column="4"
                        MinWidth="52"
                        Padding="8,4"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center"
                        Background="{StaticResource Brush.Background.Surface}"
                        BorderBrush="{StaticResource Brush.Border.Subtle}"
                        BorderThickness="1"
                        CornerRadius="8">
                        <TextBlock
                            HorizontalAlignment="Center"
                            FontFamily="{StaticResource Bold}"
                            FontSize="10"
                            Foreground="{StaticResource Brush.Text.Muted}"
                            Text="{Binding EventTypeText}"
                            TextTrimming="CharacterEllipsis" />
                    </Border>
                </Grid>
            </Border>
            <DataTemplate.Triggers>
                <Trigger SourceName="UpcomingEventItemSurface" Property="IsMouseOver" Value="True">
                    <Setter TargetName="UpcomingEventItemSurface" Property="Background" Value="{StaticResource Brush.Background.Hover}" />
                    <Setter TargetName="UpcomingEventItemSurface" Property="BorderBrush" Value="{StaticResource Brush.Mint}" />
                </Trigger>
            </DataTemplate.Triggers>
        </DataTemplate>
    </UserControl.Resources>

    <Border Style="{StaticResource DashboardPanelStyle}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="12" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <TextBlock
                VerticalAlignment="Center"
                FontFamily="{StaticResource Bold}"
                FontSize="13"
                Foreground="{StaticResource Brush.Text.Primary}"
                Text="Upcoming Events" />

            <Grid Grid.Row="2">
                <ScrollViewer
                    x:Name="UpcomingEventsScrollViewer"
                    HorizontalScrollBarVisibility="Disabled"
                    SizeChanged="OnUpcomingEventsScrollViewerSizeChanged"
                    VerticalScrollBarVisibility="Auto">
                    <ItemsControl ItemTemplate="{StaticResource UpcomingEventItemTemplate}" ItemsSource="{Binding Events}" />
                </ScrollViewer>

                <TextBlock
                    VerticalAlignment="Center"
                    FontFamily="{StaticResource Medium}"
                    FontSize="11"
                    Foreground="{StaticResource Brush.Text.Muted}"
                    Text="No upcoming events."
                    TextAlignment="Center"
                    TextWrapping="Wrap"
                    Visibility="{Binding HasEvents, Converter={StaticResource BoolToVisibilityInvertedConverter}}" />
            </Grid>
        </Grid>
    </Border>
</UserControl>
