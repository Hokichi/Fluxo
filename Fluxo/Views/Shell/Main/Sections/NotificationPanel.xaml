<UserControl
    x:Class="Fluxo.Views.Shell.Main.Sections.NotificationPanel"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:customControls="clr-namespace:Fluxo.Resources.CustomControls;assembly=Fluxo.Resources">
    <UserControl.Resources>
        <DataTemplate x:Key="DashboardNotificationGroupTemplate">
            <Border
                Margin="0,0,0,10"
                Padding="10"
                Background="{StaticResource Brush.Background.Hover}"
                BorderBrush="{StaticResource Brush.Border.Subtle}"
                BorderThickness="1"
                CornerRadius="16">
                <Grid>
                    <StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock
                                VerticalAlignment="Center"
                                FontFamily="{StaticResource Bold}"
                                FontSize="12"
                                Foreground="{StaticResource Brush.Text.Primary}"
                                Text="{Binding Header}"
                                TextWrapping="Wrap" />

                            <Border
                                x:Name="NotificationCountBadge"
                                Width="18"
                                Height="18"
                                Margin="6,0,0,0"
                                VerticalAlignment="Center"
                                Background="{StaticResource Brush.Mint}"
                                CornerRadius="9">
                                <TextBlock
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    FontFamily="{StaticResource Bold}"
                                    FontSize="10"
                                    Foreground="{StaticResource Brush.Text.Primary.Dark}"
                                    Text="{Binding Count}" />
                            </Border>
                        </StackPanel>

                        <TextBlock
                            Margin="0,4,0,0"
                            FontFamily="{StaticResource Medium}"
                            FontSize="9"
                            Foreground="{StaticResource Brush.Text.Muted}"
                            Text="{Binding LatestCreatedOn, Converter={StaticResource DateTimeToRelativeDateConverter}}" />
                    </StackPanel>

                    <StackPanel
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center"
                        Orientation="Horizontal">
                        <customControls:BalloonButton
                            Width="24"
                            Height="24"
                            Margin="4,0,0,0"
                            ButtonIcon="{StaticResource Pen}"
                            ButtonText="Process"
                            Command="{Binding DataContext.OpenNotificationActionCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                            CommandParameter="{Binding}"
                            HoveredBackground="{StaticResource Brush.BalloonButton.Background.ConfirmSave.Hovered}"
                            ShouldExpand="True"
                            Style="{StaticResource ToolbarActionBalloonButtonStyle}"
                            Visibility="{Binding HasActionCta, Converter={StaticResource BoolToVisibilityConverter}}"
                            DefaultBackground="{StaticResource Brush.BalloonButton.Background.ConfirmSave}" />

                        <customControls:BalloonButton
                            Width="24"
                            Height="24"
                            ButtonIcon="{StaticResource Ban}"
                            ButtonText="Clear"
                            Command="{Binding DataContext.ClearNotificationGroupCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                            CommandParameter="{Binding}"
                            HoveredBackground="{StaticResource Brush.BalloonButton.Background.Surface.Hovered}"
                            IconSize="11"
                            ShouldExpand="True"
                            Style="{StaticResource ToolbarActionBalloonButtonStyle}"
                            Visibility="{Binding HasMultipleNotifications, Converter={StaticResource BoolToVisibilityConverter}}"
                            DefaultBackground="{StaticResource Brush.BalloonButton.Background.Surface}" />
                    </StackPanel>
                </Grid>
            </Border>
        </DataTemplate>
    </UserControl.Resources>

    <Border Style="{StaticResource CardBorderStyle}">
        <Border.Background>
            <SolidColorBrush Opacity="1" Color="{StaticResource Color.Background.Elevated}" />
        </Border.Background>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="12" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <TextBlock
                VerticalAlignment="Center"
                FontFamily="{StaticResource Bold}"
                FontSize="13"
                Foreground="{StaticResource Brush.Text.Primary}"
                Text="Notifications" />

            <Grid Grid.Row="2">
                <ScrollViewer
                    x:Name="NotificationListScrollViewer"
                    HorizontalScrollBarVisibility="Disabled"
                    VerticalScrollBarVisibility="Auto">
                    <ItemsControl
                        x:Name="NotificationItemsList"
                        ItemTemplate="{StaticResource DashboardNotificationGroupTemplate}"
                        ItemsSource="{Binding NotificationItems}" />
                </ScrollViewer>

                <TextBlock
                    x:Name="EmptyStateText"
                    VerticalAlignment="Center"
                    FontFamily="{StaticResource Medium}"
                    FontSize="11"
                    Foreground="{StaticResource Brush.Text.Muted}"
                    Text="You're all caught up."
                    TextAlignment="Center"
                    TextWrapping="Wrap">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding HasNotifications}" Value="False">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
            </Grid>

            <StackPanel
                Grid.Row="3"
                Margin="0,12,0,0"
                HorizontalAlignment="Right"
                Orientation="Horizontal"
                Visibility="{Binding HasNotifications, Converter={StaticResource BoolToVisibilityConverter}}">
                <customControls:BalloonButton
                    x:Name="SnoozeAllNotificationsButton"
                    Width="24"
                    Height="24"
                    ButtonIcon="{StaticResource SleepLine}"
                    ButtonText="Snooze"
                    Command="{Binding SnoozeAllNotificationsCommand}"
                    HoveredBackground="{StaticResource Brush.BalloonButton.Background.Caution.Hovered}"
                    ShouldExpand="True"
                    Style="{StaticResource ToolbarActionBalloonButtonStyle}"
                            DefaultBackground="{StaticResource Brush.BalloonButton.Background.Caution}" />
                <customControls:BalloonButton
                    x:Name="ClearAllNotificationsButton"
                    Width="24"
                    Height="24"
                    Margin="6,0,0,0"
                    ButtonIcon="{StaticResource Delete}"
                    ButtonText="Clear All"
                    Command="{Binding ClearAllNotificationsCommand}"
                    HoveredBackground="{StaticResource Brush.BalloonButton.Background.Surface.Hovered}"
                    ShouldExpand="True"
                    Style="{StaticResource ToolbarActionBalloonButtonStyle}"
                            DefaultBackground="{StaticResource Brush.BalloonButton.Background.Surface}" />
            </StackPanel>
        </Grid>
    </Border>
</UserControl>
