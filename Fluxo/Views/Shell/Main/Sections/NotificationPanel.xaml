<UserControl
    x:Class="Fluxo.Views.Shell.Main.Sections.NotificationPanel"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <UserControl.Resources>
        <Style x:Key="PanelActionTextButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Padding" Value="2" />
            <Setter Property="FontFamily" Value="{StaticResource Medium}" />
            <Setter Property="FontSize" Value="10" />
            <Setter Property="Foreground" Value="{StaticResource Brush.Text.Muted}" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Foreground" Value="{StaticResource Brush.Mint}" />
                </Trigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <Border Style="{StaticResource DashboardPanelStyle}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="12" />
                <RowDefinition Height="*" />
                <RowDefinition Height="8" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock
                    FontFamily="{StaticResource Bold}"
                    FontSize="13"
                    Foreground="{StaticResource Brush.Text.Primary}"
                    Text="Notifications" />

                <Border Grid.Column="1" Style="{StaticResource DashboardCountBadgeStyle}">
                    <TextBlock
                        FontFamily="{StaticResource Bold}"
                        FontSize="9"
                        Foreground="{StaticResource Brush.Text.Secondary}"
                        Text="{Binding NotificationCount}" />
                </Border>
            </Grid>

            <TextBlock
                Grid.Row="2"
                VerticalAlignment="Center"
                FontFamily="{StaticResource Medium}"
                FontSize="11"
                Foreground="{StaticResource Brush.Text.Muted}"
                Text="You're all caught up."
                TextAlignment="Center"
                Visibility="{Binding HasNotifications, Converter={StaticResource BoolToVisibilityInvertedConverter}}" />

            <ScrollViewer
                Grid.Row="2"
                VerticalScrollBarVisibility="Auto"
                Visibility="{Binding HasNotifications, Converter={StaticResource BoolToVisibilityConverter}}">
                <ItemsControl ItemTemplate="{StaticResource DashboardNotificationTemplate}" ItemsSource="{Binding Notifications}" />
            </ScrollViewer>

            <Button
                Grid.Row="4"
                HorizontalAlignment="Right"
                Command="{Binding ClearAllNotificationsCommand}"
                Content="Clear All Notifications"
                Style="{StaticResource PanelActionTextButtonStyle}"
                Visibility="{Binding HasNotifications, Converter={StaticResource BoolToVisibilityConverter}}" />
        </Grid>
    </Border>
</UserControl>
