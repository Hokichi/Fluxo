<UserControl
    x:Class="Fluxo.Views.Shell.Main.Sections.NotificationPanel"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:customControls="clr-namespace:Fluxo.Views.CustomControls">
    <UserControl.Resources>
        <Style
            x:Key="NotificationHeaderNavBalloonButtonStyle"
            BasedOn="{StaticResource ToolbarActionBalloonButtonStyle}"
            TargetType="{x:Type customControls:BalloonButton}">
            <Setter Property="Width" Value="24" />
            <Setter Property="Height" Value="24" />
            <Setter Property="IconSize" Value="11" />
        </Style>

        <DataTemplate x:Key="DashboardNotificationGroupTemplate">
            <Border
                Margin="0,0,0,10"
                Padding="10"
                Background="{StaticResource Brush.Background.Hover}"
                BorderBrush="{StaticResource Brush.Border.Subtle}"
                BorderThickness="1"
                CornerRadius="16">
                <Grid>
                    <Border
                        Width="20"
                        Height="{Binding Width, RelativeSource={RelativeSource Self}}"
                        Margin="8,0,0,0"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Top"
                        Background="{StaticResource Brush.Mint}">
                        <Border.CornerRadius>
                            <MultiBinding Converter="{StaticResource CornerRadiusConverter}">
                                <Binding Path="ActualWidth" RelativeSource="{RelativeSource Self}" />
                                <Binding Path="ActualHeight" RelativeSource="{RelativeSource Self}" />
                            </MultiBinding>
                        </Border.CornerRadius>

                        <TextBlock
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            FontFamily="{StaticResource Bold}"
                            FontSize="10"
                            Foreground="{StaticResource Brush.Background.Main}"
                            Text="{Binding Count, StringFormat={}{0}}" />
                    </Border>

                    <StackPanel>
                        <TextBlock
                            FontFamily="{StaticResource Bold}"
                            FontSize="12"
                            Foreground="{StaticResource Brush.Text.Primary}"
                            Text="{Binding Header}"
                            TextWrapping="Wrap" />

                        <TextBlock
                            Margin="0,6,0,0"
                            FontFamily="{StaticResource Regular}"
                            FontSize="10"
                            Foreground="{StaticResource Brush.Text.Secondary}"
                            Text="{Binding Message}"
                            TextWrapping="Wrap" />
                    </StackPanel>

                    <StackPanel
                        Margin="0,8,0,0"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Bottom"
                        Orientation="Horizontal">
                        <customControls:BalloonButton
                            ButtonIcon="{StaticResource Ban}"
                            Command="{Binding DataContext.ClearNotificationGroupCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                            CommandParameter="{Binding}"
                            HoveredBackground="{StaticResource Brush.Danger}"
                            Style="{StaticResource NotificationHeaderNavBalloonButtonStyle}"
                            ToolTip="Clear notification"
                            Visibility="{Binding HasMultipleNotifications, Converter={StaticResource BoolToVisibilityConverter}}" />

                        <customControls:BalloonButton
                            Margin="4,0,0,0"
                            ButtonIcon="{StaticResource Pen}"
                            Command="{Binding DataContext.OpenNotificationActionCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                            CommandParameter="{Binding}"
                            HoveredBackground="{StaticResource Brush.Mint}"
                            IconSize="10"
                            Style="{StaticResource NotificationHeaderNavBalloonButtonStyle}"
                            ToolTip="Resolve"
                            Visibility="{Binding HasActionCta, Converter={StaticResource BoolToVisibilityConverter}}" />
                    </StackPanel>

                    <TextBlock
                        Margin="02,6,0,0"
                        VerticalAlignment="Bottom"
                        FontFamily="{StaticResource Medium}"
                        FontSize="9"
                        Foreground="{StaticResource Brush.Text.Muted}"
                        Text="{Binding LatestCreatedOn, Converter={StaticResource DateTimeToRelativeDateConverter}}" />
                </Grid>
            </Border>
        </DataTemplate>
    </UserControl.Resources>

    <Border Style="{StaticResource DashboardPanelStyle}">
        <Grid>
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="12" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <TextBlock
                        VerticalAlignment="Center"
                        FontFamily="{StaticResource Bold}"
                        FontSize="13"
                        Foreground="{StaticResource Brush.Text.Primary}"
                        Text="Notifications" />
                </Grid>

                <Grid Grid.Row="2">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Grid
                        x:Name="CarouselViewport"
                        Grid.Row="0"
                        Background="Transparent"
                        ClipToBounds="True"
                        LostMouseCapture="OnCarouselViewportLostMouseCapture"
                        PreviewMouseLeftButtonDown="OnCarouselViewportPreviewMouseLeftButtonDown"
                        PreviewMouseLeftButtonUp="OnCarouselViewportPreviewMouseLeftButtonUp"
                        PreviewMouseMove="OnCarouselViewportPreviewMouseMove">
                        <ContentControl x:Name="CurrentNotificationPresenter" ContentTemplate="{StaticResource DashboardNotificationGroupTemplate}" />

                        <ContentControl
                            x:Name="IncomingNotificationPresenter"
                            ContentTemplate="{StaticResource DashboardNotificationGroupTemplate}"
                            IsHitTestVisible="False"
                            Visibility="Collapsed" />

                        <TextBlock
                            x:Name="EmptyStateText"
                            VerticalAlignment="Center"
                            FontFamily="{StaticResource Medium}"
                            FontSize="11"
                            Foreground="{StaticResource Brush.Text.Muted}"
                            Opacity="0"
                            Text="You're all caught up."
                            TextAlignment="Center"
                            TextWrapping="Wrap"
                            Visibility="Collapsed" />
                    </Grid>

                    <customControls:StepNavigatorControl
                        Grid.Row="1"
                        Margin="0,8,0,0"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center"
                        CurrentStep="{Binding CurrentStepNumber}"
                        ShouldIndicateProgress="False"
                        StepCount="{Binding NotificationStepCount}"
                        Visibility="{Binding HasMultipleNotifications, Converter={StaticResource BoolToVisibilityConverter}}" />
                </Grid>
            </Grid>

            <StackPanel
                Margin="0,12,0,-8"
                VerticalAlignment="Bottom"
                Orientation="Horizontal">
                <customControls:BalloonButton
                    Margin="0"
                    ButtonIcon="{StaticResource AngleRight}"
                    Click="OnNavigatePreviousClick"
                    RenderTransformOrigin="0.5,0.5"
                    Style="{StaticResource NotificationHeaderNavBalloonButtonStyle}"
                    ToolTip="Previous Notification"
                    Visibility="{Binding HasMultipleNotifications, Converter={StaticResource BoolToVisibilityConverter}}">
                    <customControls:BalloonButton.RenderTransform>
                        <ScaleTransform ScaleX="-1" />
                    </customControls:BalloonButton.RenderTransform>
                </customControls:BalloonButton>

                <customControls:BalloonButton
                    ButtonIcon="{StaticResource AngleRight}"
                    Click="OnNavigateNextClick"
                    Style="{StaticResource NotificationHeaderNavBalloonButtonStyle}"
                    ToolTip="Next Notification"
                    Visibility="{Binding HasMultipleNotifications, Converter={StaticResource BoolToVisibilityConverter}}" />

                <Button
                    Margin="8,0,0,0"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Center"
                    Command="{Binding ClearAllNotificationsCommand}"
                    Content="Clear All Notifications"
                    Style="{StaticResource TextOnlyButtonStyle}"
                    Visibility="{Binding HasNotifications, Converter={StaticResource BoolToVisibilityConverter}}" />
            </StackPanel>
        </Grid>
    </Border>
</UserControl>