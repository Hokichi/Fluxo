<UserControl
    x:Class="Fluxo.Views.Shell.Main.Sections.AllocationData"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:components="clr-namespace:Fluxo.Resources.Components;assembly=Fluxo.Resources">

    <Border Style="{StaticResource CardBorderStyle}">
        <Grid VerticalAlignment="Center">
            <Grid.ColumnDefinitions>
                <ColumnDefinition />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition />
            </Grid.ColumnDefinitions>

            <Grid>
                <StackPanel>
                    <Grid Margin="0,0,0,4">
                        <StackPanel Orientation="Horizontal">
                            <Ellipse
                                Width="8"
                                Height="8"
                                Fill="{StaticResource Brush.Category.Needs}" />
                            <TextBlock
                                Margin="8,0,0,0"
                                VerticalAlignment="Center"
                                FontFamily="{StaticResource ExtraBold}"
                                FontSize="14"
                                Foreground="{StaticResource Brush.Category.Needs}"
                                Text="NEEDS" />
                        </StackPanel>
                        <StackPanel HorizontalAlignment="Right" Orientation="Horizontal">
                            <components:Icon
                                Width="14"
                                Height="14"
                                Margin="0,0,8,0"
                                VerticalAlignment="Center"
                                Path="{StaticResource ExclamationTriangle}"
                                Visibility="{Binding IsNeedsOverflowing, Converter={StaticResource BoolToVisibilityConverter}}"
                                Color="{StaticResource Brush.Danger}" />
                            <Border
                                Height="24"
                                Padding="12,0"
                                VerticalAlignment="Center"
                                Background="{StaticResource Brush.Background.Deepened}"
                                BorderBrush="{StaticResource Brush.Border.Subtle}"
                                BorderThickness="2"
                                CornerRadius="4">
                                <TextBlock
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    FontFamily="{StaticResource Light}"
                                    Foreground="{StaticResource Brush.Text.Secondary}"
                                    Text="{Binding NeedsAllocationPercentage, Mode=OneWay, StringFormat={}{0}%}" />
                            </Border>
                        </StackPanel>
                    </Grid>

                    <TextBlock Margin="0,0,0,-8">
                        <Run
                            FontFamily="{StaticResource Bold}"
                            FontSize="24"
                            Foreground="{StaticResource Brush.Text.Primary}"
                            Text="{Binding NeedsSpent, Converter={StaticResource MoneyAmountToCanonicalConverter}}" />
                        <Run
                            FontFamily="{StaticResource Regular}"
                            FontSize="16"
                            Foreground="{StaticResource Brush.Text.Secondary}"
                            Text="/" />
                        <Run
                            FontFamily="{StaticResource Regular}"
                            FontSize="16"
                            Foreground="{StaticResource Brush.Text.Secondary}"
                            Text="{Binding NeedsAvailable, Converter={StaticResource MoneyAmountToCanonicalConverter}}" />
                    </TextBlock>

                    <ProgressBar
                        Height="4"
                        Margin="0,16,0,0"
                        Maximum="100"
                        Minimum="0"
                        Value="{Binding NeedsPercentage, Mode=OneWay}">
                        <ProgressBar.Style>
                            <Style BasedOn="{StaticResource RoundedProgressBarStyle}" TargetType="ProgressBar">
                                <Setter Property="Foreground" Value="{StaticResource Brush.Category.Needs}" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsNeedsOverflowing}" Value="True">
                                        <Setter Property="Foreground" Value="{StaticResource Brush.Danger}" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </ProgressBar.Style>
                    </ProgressBar>

                    <Grid Margin="0,4,0,0">
                        <TextBlock
                            FontFamily="{StaticResource Light}"
                            FontSize="12"
                            Foreground="{StaticResource Brush.Text.Muted}">
                            <Run Text="{Binding NeedsRemainingDisplay, Mode=OneWay, Converter={StaticResource MoneyAmountToCanonicalConverter}}" />
                            <Run Text="{Binding NeedsRemainingLabel, Mode=OneWay}" />
                        </TextBlock>

                        <TextBlock
                            HorizontalAlignment="Right"
                            FontFamily="{StaticResource Light}"
                            FontSize="12"
                            Foreground="{StaticResource Brush.Text.Muted}"
                            Text="{Binding NeedsPercentage, Mode=OneWay, StringFormat={}{0}% spent}" />
                    </Grid>
                </StackPanel>
            </Grid>

            <Border Grid.Column="1" Style="{StaticResource VerticalSeparatorBorderStyle}" />

            <Grid Grid.Column="2">
                <StackPanel>
                    <Grid Margin="0,0,0,4">
                        <StackPanel Orientation="Horizontal">
                            <Ellipse
                                Width="8"
                                Height="8"
                                Fill="{StaticResource Brush.Category.Wants}" />
                            <TextBlock
                                Margin="8,0,0,0"
                                VerticalAlignment="Center"
                                FontFamily="{StaticResource ExtraBold}"
                                FontSize="14"
                                Foreground="{StaticResource Brush.Category.Wants}"
                                Text="WANTS" />
                        </StackPanel>
                        <StackPanel HorizontalAlignment="Right" Orientation="Horizontal">
                            <components:Icon
                                Width="14"
                                Height="14"
                                Margin="0,0,8,0"
                                VerticalAlignment="Center"
                                Path="{StaticResource ExclamationTriangle}"
                                Visibility="{Binding IsWantsOverflowing, Converter={StaticResource BoolToVisibilityConverter}}"
                                Color="{StaticResource Brush.Danger}" />
                            <Border
                                Height="24"
                                Padding="12,0"
                                Background="{StaticResource Brush.Background.Deepened}"
                                BorderBrush="{StaticResource Brush.Border.Subtle}"
                                BorderThickness="2"
                                CornerRadius="4">
                                <TextBlock
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    FontFamily="{StaticResource Light}"
                                    Foreground="{StaticResource Brush.Text.Secondary}"
                                    Text="{Binding WantsAllocationPercentage, Mode=OneWay, StringFormat={}{0}%}" />
                            </Border>
                        </StackPanel>
                    </Grid>

                    <TextBlock Margin="0,0,0,-8">
                        <Run
                            FontFamily="{StaticResource Bold}"
                            FontSize="24"
                            Foreground="{StaticResource Brush.Text.Primary}"
                            Text="{Binding WantsSpent, Converter={StaticResource MoneyAmountToCanonicalConverter}}" />
                        <Run
                            FontFamily="{StaticResource Regular}"
                            FontSize="16"
                            Foreground="{StaticResource Brush.Text.Secondary}"
                            Text="/" />
                        <Run
                            FontFamily="{StaticResource Regular}"
                            FontSize="16"
                            Foreground="{StaticResource Brush.Text.Secondary}"
                            Text="{Binding WantsAvailable, Converter={StaticResource MoneyAmountToCanonicalConverter}}" />
                    </TextBlock>

                    <ProgressBar
                        Height="4"
                        Margin="0,16,0,0"
                        Maximum="100"
                        Minimum="0"
                        Value="{Binding WantsPercentage, Mode=OneWay}">
                        <ProgressBar.Style>
                            <Style BasedOn="{StaticResource RoundedProgressBarStyle}" TargetType="ProgressBar">
                                <Setter Property="Foreground" Value="{StaticResource Brush.Category.Wants}" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsWantsOverflowing}" Value="True">
                                        <Setter Property="Foreground" Value="{StaticResource Brush.Danger}" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </ProgressBar.Style>
                    </ProgressBar>

                    <Grid Margin="0,4,0,0">
                        <TextBlock
                            FontFamily="{StaticResource Light}"
                            FontSize="12"
                            Foreground="{StaticResource Brush.Text.Muted}">
                            <Run Text="{Binding WantsRemainingDisplay, Mode=OneWay, Converter={StaticResource MoneyAmountToCanonicalConverter}}" />
                            <Run Text="{Binding WantsRemainingLabel, Mode=OneWay}" />
                        </TextBlock>

                        <TextBlock
                            HorizontalAlignment="Right"
                            FontFamily="{StaticResource Light}"
                            FontSize="12"
                            Foreground="{StaticResource Brush.Text.Muted}"
                            Text="{Binding WantsPercentage, Mode=OneWay, StringFormat={}{0}% spent}" />
                    </Grid>
                </StackPanel>
            </Grid>

            <Border Grid.Column="3" Style="{StaticResource VerticalSeparatorBorderStyle}" />

            <Grid Grid.Column="4">
                <StackPanel>
                    <Grid Margin="0,0,0,4">
                        <StackPanel Orientation="Horizontal">
                            <Ellipse
                                Width="8"
                                Height="8"
                                Fill="{StaticResource Brush.Category.Investments}" />
                            <TextBlock
                                Margin="8,2,0,0"
                                VerticalAlignment="Center"
                                FontFamily="{StaticResource ExtraBold}"
                                FontSize="14"
                                Foreground="{StaticResource Brush.Category.Investments}"
                                Text="INVEST" />
                        </StackPanel>
                        <StackPanel HorizontalAlignment="Right" Orientation="Horizontal">
                            <components:Icon
                                Width="14"
                                Height="14"
                                Margin="0,0,8,0"
                                VerticalAlignment="Center"
                                Path="{StaticResource ExclamationTriangle}"
                                Visibility="{Binding IsInvestOverflowing, Converter={StaticResource BoolToVisibilityConverter}}"
                                Color="{StaticResource Brush.Danger}" />
                            <Border
                                Height="24"
                                Padding="12,0"
                                VerticalAlignment="Center"
                                Background="{StaticResource Brush.Background.Deepened}"
                                BorderBrush="{StaticResource Brush.Border.Subtle}"
                                BorderThickness="2"
                                CornerRadius="4">
                                <TextBlock
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    FontFamily="{StaticResource Light}"
                                    Foreground="{StaticResource Brush.Text.Secondary}"
                                    Text="{Binding InvestAllocationPercentage, Mode=OneWay, StringFormat={}{0}%}" />
                            </Border>
                        </StackPanel>
                    </Grid>

                    <TextBlock Margin="0,0,0,-8">
                        <Run
                            FontFamily="{StaticResource Bold}"
                            FontSize="24"
                            Foreground="{StaticResource Brush.Text.Primary}"
                            Text="{Binding InvestSpent, Converter={StaticResource MoneyAmountToCanonicalConverter}}" />
                        <Run
                            FontFamily="{StaticResource Regular}"
                            FontSize="16"
                            Foreground="{StaticResource Brush.Text.Secondary}"
                            Text="/" />
                        <Run
                            FontFamily="{StaticResource Regular}"
                            FontSize="16"
                            Foreground="{StaticResource Brush.Text.Secondary}"
                            Text="{Binding InvestAvailable, Converter={StaticResource MoneyAmountToCanonicalConverter}}" />
                    </TextBlock>

                    <ProgressBar
                        Height="4"
                        Margin="0,16,0,0"
                        Maximum="100"
                        Minimum="0"
                        Value="{Binding InvestPercentage, Mode=OneWay}">
                        <ProgressBar.Style>
                            <Style BasedOn="{StaticResource RoundedProgressBarStyle}" TargetType="ProgressBar">
                                <Setter Property="Foreground" Value="{StaticResource Brush.Category.Investments}" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsInvestOverflowing}" Value="True">
                                        <Setter Property="Foreground" Value="{StaticResource Brush.Danger}" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </ProgressBar.Style>
                    </ProgressBar>

                    <Grid Margin="0,4,0,0">
                        <TextBlock
                            FontFamily="{StaticResource Light}"
                            FontSize="12"
                            Foreground="{StaticResource Brush.Text.Muted}">
                            <Run Text="{Binding InvestRemainingDisplay, Mode=OneWay, Converter={StaticResource MoneyAmountToCanonicalConverter}}" />
                            <Run Text="{Binding InvestRemainingLabel, Mode=OneWay}" />
                        </TextBlock>

                        <TextBlock
                            HorizontalAlignment="Right"
                            FontFamily="{StaticResource Light}"
                            FontSize="12"
                            Foreground="{StaticResource Brush.Text.Muted}"
                            Text="{Binding InvestPercentage, Mode=OneWay, StringFormat={}{0}% spent}" />
                    </Grid>
                </StackPanel>
            </Grid>
        </Grid>
    </Border>
</UserControl>