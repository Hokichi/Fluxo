<UserControl
    x:Class="Fluxo.Views.Shell.Main.Sections.AllocationData"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Border
        Padding="12"
        Background="{StaticResource Brush.Background.Surface}"
        BorderBrush="{StaticResource Brush.Border.Subtle}"
        BorderThickness="1"
        CornerRadius="8">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition />
                <ColumnDefinition />
                <ColumnDefinition />
            </Grid.ColumnDefinitions>

            <Grid Margin="0,0,20,0">
                <Grid
                    Width="80"
                    Height="80"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Center">
                    <Canvas Width="80" Height="80">
                        <Ellipse
                            Canvas.Left="8"
                            Canvas.Top="8"
                            Width="64"
                            Height="64"
                            Stroke="{StaticResource Brush.Background.Elevated}"
                            StrokeThickness="6" />
                        <Path
                            Canvas.Left="11"
                            Canvas.Top="11"
                            Data="{Binding NeedsPercentage, Converter={StaticResource ProgressToArcGeometryConverter}, ConverterParameter=58}"
                            Stroke="{StaticResource Brush.Category.Needs}"
                            StrokeEndLineCap="Round"
                            StrokeLineJoin="Round"
                            StrokeStartLineCap="Round"
                            StrokeThickness="6" />
                    </Canvas>
                    <TextBlock
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        FontFamily="{StaticResource Bold}"
                        FontSize="12"
                        Foreground="{StaticResource Brush.Text.Primary}"
                        Text="{Binding NeedsPercentage, StringFormat={}{0}%}" />
                </Grid>

                <StackPanel Margin="0,6,96,0">
                    <StackPanel Orientation="Horizontal">
                        <Ellipse
                            Width="8"
                            Height="8"
                            Margin="0,2,0,0"
                            Fill="{StaticResource Brush.Category.Needs}" />
                        <TextBlock
                            Margin="12,2,0,0"
                            FontFamily="{StaticResource ExtraBold}"
                            FontSize="14"
                            Foreground="{StaticResource Brush.Category.Needs}"
                            Text="NEEDS" />
                        <Border
                            Height="24"
                            Margin="12,0,0,8"
                            Padding="12,0"
                            Background="{StaticResource Brush.Background.Surface}"
                            BorderBrush="{StaticResource Brush.Border.Subtle}"
                            BorderThickness="2"
                            CornerRadius="4">
                            <TextBlock
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                FontFamily="{StaticResource Light}"
                                Foreground="{StaticResource Brush.Text.Secondary}">
                                <Run Text="{Binding NeedsAllocationPercentage, StringFormat={}{0}%}" />
                                <Run Text="alloc" />
                            </TextBlock>
                        </Border>
                    </StackPanel>

                    <TextBlock Margin="0,0,0,-8">
                        <Run
                            FontFamily="{StaticResource Bold}"
                            FontSize="24"
                            Foreground="{StaticResource Brush.Text.Primary}"
                            Text="{Binding NeedsSpent, Converter={StaticResource MoneyAmountToCanonicalConverter}}" />
                        <Run
                            FontFamily="{StaticResource Regular}"
                            FontSize="16"
                            Foreground="{StaticResource Brush.Text.Secondary}"
                            Text="/" />
                        <Run
                            FontFamily="{StaticResource Regular}"
                            FontSize="16"
                            Foreground="{StaticResource Brush.Text.Secondary}"
                            Text="{Binding NeedsAvailable, Converter={StaticResource MoneyAmountToCanonicalConverter}}" />
                    </TextBlock>

                    <TextBlock
                        Margin="0,10,0,0"
                        FontFamily="{StaticResource Light}"
                        FontSize="12"
                        Foreground="{StaticResource Brush.Text.Muted}">
                        <Run Text="{Binding NeedsRemaining, Converter={StaticResource MoneyAmountToCanonicalConverter}}" />
                        <Run Text="remaining" />
                    </TextBlock>
                </StackPanel>
            </Grid>

            <Grid Grid.Column="1" Margin="0,0,20,0">
                <Grid
                    Width="80"
                    Height="80"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Center">
                    <Canvas Width="80" Height="80">
                        <Ellipse
                            Canvas.Left="8"
                            Canvas.Top="8"
                            Width="64"
                            Height="64"
                            Stroke="{StaticResource Brush.Background.Elevated}"
                            StrokeThickness="6" />
                        <Path
                            Canvas.Left="11"
                            Canvas.Top="11"
                            Data="{Binding WantsPercentage, Converter={StaticResource ProgressToArcGeometryConverter}, ConverterParameter=58}"
                            Stroke="{StaticResource Brush.Category.Wants}"
                            StrokeEndLineCap="Round"
                            StrokeLineJoin="Round"
                            StrokeStartLineCap="Round"
                            StrokeThickness="6" />
                    </Canvas>
                    <TextBlock
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        FontFamily="{StaticResource Bold}"
                        FontSize="12"
                        Foreground="{StaticResource Brush.Text.Primary}"
                        Text="{Binding WantsPercentage, StringFormat={}{0}%}" />
                </Grid>

                <StackPanel Margin="0,6,96,0">
                    <StackPanel Orientation="Horizontal">
                        <Ellipse
                            Width="8"
                            Height="8"
                            Margin="0,2,0,0"
                            Fill="{StaticResource Brush.Category.Wants}" />
                        <TextBlock
                            Margin="12,2,0,0"
                            FontFamily="{StaticResource ExtraBold}"
                            FontSize="14"
                            Foreground="{StaticResource Brush.Category.Wants}"
                            Text="WANTS" />
                        <Border
                            Height="24"
                            Margin="12,0,0,8"
                            Padding="12,0"
                            Background="{StaticResource Brush.Background.Surface}"
                            BorderBrush="{StaticResource Brush.Border.Subtle}"
                            BorderThickness="2"
                            CornerRadius="4">
                            <TextBlock
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                FontFamily="{StaticResource Light}"
                                Foreground="{StaticResource Brush.Text.Secondary}">
                                <Run Text="{Binding WantsAllocationPercentage, StringFormat={}{0}%}" />
                                <Run Text="alloc" />
                            </TextBlock>
                        </Border>
                    </StackPanel>

                    <TextBlock Margin="0,0,0,-8">
                        <Run
                            FontFamily="{StaticResource Bold}"
                            FontSize="24"
                            Foreground="{StaticResource Brush.Text.Primary}"
                            Text="{Binding WantsSpent, Converter={StaticResource MoneyAmountToCanonicalConverter}}" />
                        <Run
                            FontFamily="{StaticResource Regular}"
                            FontSize="16"
                            Foreground="{StaticResource Brush.Text.Secondary}"
                            Text="/" />
                        <Run
                            FontFamily="{StaticResource Regular}"
                            FontSize="16"
                            Foreground="{StaticResource Brush.Text.Secondary}"
                            Text="{Binding WantsAvailable, Converter={StaticResource MoneyAmountToCanonicalConverter}}" />
                    </TextBlock>

                    <TextBlock
                        Margin="0,10,0,0"
                        FontFamily="{StaticResource Light}"
                        FontSize="12"
                        Foreground="{StaticResource Brush.Text.Muted}">
                        <Run Text="{Binding WantsRemaining, Converter={StaticResource MoneyAmountToCanonicalConverter}}" />
                        <Run Text="remaining" />
                    </TextBlock>
                </StackPanel>
            </Grid>

            <Grid Grid.Column="2">
                <Grid
                    Width="80"
                    Height="80"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Center">
                    <Canvas Width="80" Height="80">
                        <Ellipse
                            Canvas.Left="8"
                            Canvas.Top="8"
                            Width="64"
                            Height="64"
                            Stroke="{StaticResource Brush.Background.Elevated}"
                            StrokeThickness="6" />
                        <Path
                            Canvas.Left="11"
                            Canvas.Top="11"
                            Data="{Binding InvestPercentage, Converter={StaticResource ProgressToArcGeometryConverter}, ConverterParameter=58}"
                            Stroke="{StaticResource Brush.Category.Investments}"
                            StrokeEndLineCap="Round"
                            StrokeLineJoin="Round"
                            StrokeStartLineCap="Round"
                            StrokeThickness="6" />
                    </Canvas>
                    <TextBlock
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        FontFamily="{StaticResource Bold}"
                        FontSize="12"
                        Foreground="{StaticResource Brush.Text.Primary}"
                        Text="{Binding InvestPercentage, StringFormat={}{0}%}" />
                </Grid>

                <StackPanel Margin="0,6,96,0">
                    <StackPanel Orientation="Horizontal">
                        <Ellipse
                            Width="8"
                            Height="8"
                            Margin="0,2,0,0"
                            Fill="{StaticResource Brush.Category.Investments}" />
                        <TextBlock
                            Margin="12,2,0,0"
                            FontFamily="{StaticResource ExtraBold}"
                            FontSize="14"
                            Foreground="{StaticResource Brush.Category.Investments}"
                            Text="INVEST" />
                        <Border
                            Height="24"
                            Margin="12,0,0,8"
                            Padding="12,0"
                            Background="{StaticResource Brush.Background.Surface}"
                            BorderBrush="{StaticResource Brush.Border.Subtle}"
                            BorderThickness="2"
                            CornerRadius="4">
                            <TextBlock
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                FontFamily="{StaticResource Light}"
                                Foreground="{StaticResource Brush.Text.Secondary}">
                                <Run Text="{Binding InvestAllocationPercentage, StringFormat={}{0}%}" />
                                <Run Text="alloc" />
                            </TextBlock>
                        </Border>
                    </StackPanel>

                    <TextBlock Margin="0,0,0,-8">
                        <Run
                            FontFamily="{StaticResource Bold}"
                            FontSize="24"
                            Foreground="{StaticResource Brush.Text.Primary}"
                            Text="{Binding InvestSpent, Converter={StaticResource MoneyAmountToCanonicalConverter}}" />
                        <Run
                            FontFamily="{StaticResource Regular}"
                            FontSize="16"
                            Foreground="{StaticResource Brush.Text.Secondary}"
                            Text="/" />
                        <Run
                            FontFamily="{StaticResource Regular}"
                            FontSize="16"
                            Foreground="{StaticResource Brush.Text.Secondary}"
                            Text="{Binding InvestAvailable, Converter={StaticResource MoneyAmountToCanonicalConverter}}" />
                    </TextBlock>

                    <TextBlock
                        Margin="0,10,0,0"
                        FontFamily="{StaticResource Light}"
                        FontSize="12"
                        Foreground="{StaticResource Brush.Text.Muted}">
                        <Run Text="{Binding InvestRemaining, Converter={StaticResource MoneyAmountToCanonicalConverter}}" />
                        <Run Text="remaining" />
                    </TextBlock>
                </StackPanel>
            </Grid>
        </Grid>
    </Border>
</UserControl>
