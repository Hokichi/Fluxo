<UserControl
    x:Class="Fluxo.Views.Shell.Main.Sections.SavingGoalsPanel"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:customControls="clr-namespace:Fluxo.Resources.CustomControls;assembly=Fluxo.Resources">
    <UserControl.Resources>
        <Style
            x:Key="SavingGoalActionBalloonButtonStyle"
            BasedOn="{StaticResource ToolbarActionBalloonButtonStyle}"
            TargetType="{x:Type customControls:BalloonButton}">
            <Setter Property="Height" Value="24" />
            <Setter Property="ButtonSize" Value="24" />
            <Setter Property="IconSize" Value="11" />
        </Style>

        <DataTemplate x:Key="SavingGoalTemplate">
            <Border Margin="0,0,0,8" Padding="4,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="8" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="8" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="10" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <Grid Width="44" Height="44">
                            <Canvas
                                Width="56"
                                Height="56"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center">
                                <Ellipse
                                    Canvas.Left="4"
                                    Canvas.Top="4"
                                    Width="48"
                                    Height="48"
                                    Stroke="{StaticResource Brush.Background.Surface}"
                                    StrokeThickness="6" />
                                <Path
                                    Canvas.Left="6"
                                    Canvas.Top="6"
                                    Data="{Binding AnimatedProgressRatio, RelativeSource={RelativeSource AncestorType={x:Type UserControl}}, Converter={StaticResource ProgressToArcGeometryConverter}, ConverterParameter=44}"
                                    Stroke="{Binding AnimatedProgressRatio, RelativeSource={RelativeSource AncestorType={x:Type UserControl}}, Converter={StaticResource GoalProgressToBrushConverter}}"
                                    StrokeEndLineCap="Round"
                                    StrokeLineJoin="Round"
                                    StrokeStartLineCap="Round"
                                    StrokeThickness="6" />
                            </Canvas>

                            <TextBlock
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                FontFamily="{StaticResource Bold}"
                                FontSize="10"
                                Foreground="{Binding AnimatedProgressRatio, RelativeSource={RelativeSource AncestorType={x:Type UserControl}}, Converter={StaticResource GoalProgressToBrushConverter}}"
                                Text="{Binding AnimatedProgressRatio, RelativeSource={RelativeSource AncestorType={x:Type UserControl}}, StringFormat={}{0:0%}}" />
                        </Grid>

                        <StackPanel Grid.Column="2" VerticalAlignment="Center">
                            <TextBlock
                                FontFamily="{StaticResource Bold}"
                                FontSize="16"
                                Foreground="{StaticResource Brush.Text.Primary}"
                                Text="{Binding Name}"
                                TextTrimming="CharacterEllipsis" />

                            <TextBlock
                                Margin="0,6,0,0"
                                FontSize="13"
                                Foreground="{StaticResource Brush.Text.Secondary}">
                                <Run
                                    FontFamily="{StaticResource Black}"
                                    Foreground="{Binding AnimatedProgressRatio, RelativeSource={RelativeSource AncestorType={x:Type UserControl}}, Converter={StaticResource GoalProgressToBrushConverter}}"
                                    Text="{Binding CurrentAmount, Converter={StaticResource NumberWithCommasConverter}}" />
                                <Run FontFamily="{StaticResource Light}" Text="/" />
                                <Run FontFamily="{StaticResource Light}" Text="{Binding TargetAmount, Converter={StaticResource NumberWithCommasConverter}}" />
                            </TextBlock>
                        </StackPanel>
                    </Grid>

                    <Border
                        Grid.Column="2"
                        Padding="8"
                        Background="{StaticResource Brush.Background.Surface}"
                        BorderBrush="{StaticResource Brush.Border.Subtle}"
                        BorderThickness="1"
                        CornerRadius="8">
                        <StackPanel>
                            <TextBlock
                                FontFamily="{StaticResource Medium}"
                                FontSize="10"
                                Foreground="{StaticResource Brush.Text.Muted}"
                                Text="Amount Left"
                                TextWrapping="Wrap" />
                            <TextBlock
                                Margin="0,4,0,0"
                                FontFamily="{StaticResource Bold}"
                                FontSize="12"
                                Foreground="{StaticResource Brush.Text.Primary}"
                                Text="{Binding AmountLeftText}"
                                TextTrimming="CharacterEllipsis" />
                        </StackPanel>
                    </Border>

                    <Border
                        Grid.Column="4"
                        Padding="8"
                        Background="{StaticResource Brush.Background.Surface}"
                        BorderBrush="{StaticResource Brush.Border.Subtle}"
                        BorderThickness="1"
                        CornerRadius="8">
                        <StackPanel>
                            <TextBlock
                                FontFamily="{StaticResource Medium}"
                                FontSize="10"
                                Foreground="{StaticResource Brush.Text.Muted}"
                                Text="Weekly Average"
                                TextWrapping="Wrap" />
                            <TextBlock
                                Margin="0,4,0,0"
                                FontFamily="{StaticResource Bold}"
                                FontSize="12"
                                Foreground="{StaticResource Brush.Text.Primary}"
                                Text="{Binding WeeklyAverageText}"
                                TextTrimming="CharacterEllipsis" />
                        </StackPanel>
                    </Border>

                    <Border
                        Grid.Column="6"
                        Padding="8"
                        Background="{StaticResource Brush.Background.Surface}"
                        BorderBrush="{StaticResource Brush.Border.Subtle}"
                        BorderThickness="1"
                        CornerRadius="8">
                        <StackPanel>
                            <TextBlock
                                FontFamily="{StaticResource Medium}"
                                FontSize="10"
                                Foreground="{StaticResource Brush.Text.Muted}"
                                Text="Estimated Deadline"
                                TextWrapping="Wrap" />
                            <TextBlock
                                Margin="0,4,0,0"
                                FontFamily="{StaticResource Bold}"
                                FontSize="12"
                                Foreground="{StaticResource Brush.Text.Primary}"
                                Text="{Binding EstimatedDeadlineText}"
                                TextTrimming="CharacterEllipsis" />
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>
        </DataTemplate>
    </UserControl.Resources>

    <Border Style="{StaticResource DashboardPanelStyle}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="12" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock
                    VerticalAlignment="Center"
                    FontFamily="{StaticResource Bold}"
                    FontSize="13"
                    Foreground="{StaticResource Brush.Text.Primary}"
                    Text="Saving Goals" />

                <StackPanel
                    Grid.Column="1"
                    VerticalAlignment="Center"
                    Orientation="Horizontal">
                    <customControls:BalloonButton
                        ButtonIcon="{StaticResource Pen}"
                        ButtonText="Edit Goal"
                        Click="OnEditSavingGoalClick"
                        ShouldExpand="True"
                        Style="{StaticResource SavingGoalActionBalloonButtonStyle}"
                        ToolTip="Edit Goal" />

                    <customControls:BalloonButton
                        ButtonIcon="{StaticResource TrackChanges}"
                        ButtonText="Add Funds"
                        Click="OnAddGoalFundsClick"
                        ShouldExpand="True"
                        Style="{StaticResource SavingGoalActionBalloonButtonStyle}"
                        ToolTip="Update Funds" />

                    <Border
                        Width="1"
                        Margin="8,2,0,2"
                        Background="{StaticResource Brush.Text.Muted}"
                        SnapsToDevicePixels="True" />

                    <customControls:BalloonButton
                        ButtonIcon="{StaticResource PlusSolid}"
                        ButtonText="Add New Goal"
                        Click="OnAddSavingGoalClick"
                        ShouldExpand="True"
                        Style="{StaticResource SavingGoalActionBalloonButtonStyle}"
                        ToolTip="Add Saving Goal" />
                </StackPanel>
            </Grid>

            <TextBlock
                Grid.Row="2"
                VerticalAlignment="Center"
                FontFamily="{StaticResource Medium}"
                FontSize="11"
                Foreground="{StaticResource Brush.Text.Muted}"
                Text="Add a saving goal to track progress here."
                TextAlignment="Center"
                TextWrapping="Wrap"
                Visibility="{Binding HasSavingGoals, Converter={StaticResource BoolToVisibilityInvertedConverter}}" />

            <Grid Grid.Row="2" Visibility="{Binding HasSavingGoals, Converter={StaticResource BoolToVisibilityConverter}}">
                <Grid
                    x:Name="CarouselViewport"
                    VerticalAlignment="Center"
                    Background="Transparent"
                    LostMouseCapture="OnCarouselViewportLostMouseCapture"
                    PreviewMouseLeftButtonDown="OnCarouselViewportPreviewMouseLeftButtonDown"
                    PreviewMouseLeftButtonUp="OnCarouselViewportPreviewMouseLeftButtonUp"
                    PreviewMouseMove="OnCarouselViewportPreviewMouseMove">

                    <ContentControl x:Name="CurrentGoalPresenter" ContentTemplate="{StaticResource SavingGoalTemplate}" />

                    <ContentControl
                        x:Name="IncomingGoalPresenter"
                        ContentTemplate="{StaticResource SavingGoalTemplate}"
                        IsHitTestVisible="False"
                        Visibility="Collapsed" />
                </Grid>
            </Grid>

            <Grid
                Grid.Row="3"
                Margin="0,8,0,0"
                HorizontalAlignment="Stretch">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <customControls:BalloonButton
                    Grid.Column="0"
                    ButtonIcon="{StaticResource AngleRight}"
                    Click="OnNavigatePreviousClick"
                    RenderTransformOrigin="0.5,0.5"
                    Style="{StaticResource SavingGoalActionBalloonButtonStyle}"
                    ToolTip="Previous Goal"
                    Visibility="{Binding HasMultipleSavingGoals, Converter={StaticResource BoolToVisibilityConverter}}">
                    <customControls:BalloonButton.RenderTransform>
                        <ScaleTransform ScaleX="-1" />
                    </customControls:BalloonButton.RenderTransform>
                </customControls:BalloonButton>

                <customControls:StepNavigatorControl
                    Grid.Column="1"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    CurrentStep="{Binding CurrentStepNumber}"
                    PaginationCount="10"
                    ShouldIndicateProgress="False"
                    ShouldPaginate="True"
                    StepCount="{Binding GoalStepCount}"
                    Visibility="{Binding HasMultipleSavingGoals, Converter={StaticResource BoolToVisibilityConverter}}" />

                <customControls:BalloonButton
                    Grid.Column="2"
                    ButtonIcon="{StaticResource AngleRight}"
                    Click="OnNavigateNextClick"
                    Style="{StaticResource SavingGoalActionBalloonButtonStyle}"
                    ToolTip="Next Goal"
                    Visibility="{Binding HasMultipleSavingGoals, Converter={StaticResource BoolToVisibilityConverter}}" />
            </Grid>
        </Grid>
    </Border>
</UserControl>



