<UserControl
    x:Class="Fluxo.Views.Shell.Main.Sections.BudgetAllocationPanel"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:components="clr-namespace:Fluxo.Views.Components">
    <UserControl.Resources>
        <ItemsPanelTemplate x:Key="BudgetAllocationTagItemsPanelTemplate">
            <StackPanel Orientation="Horizontal" />
        </ItemsPanelTemplate>

        <ItemsPanelTemplate x:Key="BudgetAllocationPopupTagItemsPanelTemplate">
            <WrapPanel />
        </ItemsPanelTemplate>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel
            Grid.Row="1"
            Margin="0,0,0,16"
            Orientation="Horizontal">
            <Grid Margin="16,0,0,0" VerticalAlignment="Center">
                <Border
                    x:Name="AllTagUnselected"
                    Height="24"
                    Padding="12,0"
                    Background="{StaticResource Brush.Background.Surface}"
                    BorderBrush="{StaticResource Brush.Border.Subtle}"
                    BorderThickness="1"
                    CornerRadius="12"
                    Cursor="Hand">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Visibility" Value="Visible" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding SelectedTag}" Value="{x:Null}">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <Border.InputBindings>
                        <MouseBinding Command="{Binding ClearSelectedTagCommand}" MouseAction="LeftClick" />
                    </Border.InputBindings>
                    <TextBlock
                        VerticalAlignment="Center"
                        FontFamily="{StaticResource Bold}"
                        Foreground="{StaticResource Brush.Text.Primary}"
                        Text="All" />
                </Border>

                <Border
                    x:Name="AllTagSelected"
                    Height="24"
                    Padding="12,0"
                    Background="{StaticResource Brush.Mint}"
                    BorderThickness="1"
                    CornerRadius="12"
                    Cursor="Hand">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding SelectedTag}" Value="{x:Null}">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <Border.InputBindings>
                        <MouseBinding Command="{Binding ClearSelectedTagCommand}" MouseAction="LeftClick" />
                    </Border.InputBindings>
                    <TextBlock
                        VerticalAlignment="Center"
                        FontFamily="{StaticResource Bold}"
                        Foreground="{StaticResource Brush.Background.Surface}"
                        Text="All" />
                </Border>
            </Grid>

            <ListView
                Margin="0,12,0,0"
                VerticalAlignment="Center"
                Background="Transparent"
                BorderThickness="0"
                ItemContainerStyle="{StaticResource ListViewItemStyle}"
                ItemTemplate="{StaticResource Tags}"
                ItemsPanel="{StaticResource BudgetAllocationTagItemsPanelTemplate}"
                ItemsSource="{Binding Tags}"
                PreviewMouseLeftButtonDown="OnTagListPreviewMouseLeftButtonDown"
                ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                SelectedItem="{Binding SelectedVisibleTag}" />

            <ToggleButton
                x:Name="MoreTagsButton"
                Margin="16,0,0,0"
                VerticalAlignment="Center"
                Content="More"
                Style="{StaticResource TagToggleButtonStyle}"
                Tag="{Binding IsSelectedTagInOtherTags}"
                Visibility="{Binding HasOtherTags, Converter={StaticResource BoolToVisibilityConverter}}" />

            <Popup
                AllowsTransparency="True"
                DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}"
                IsOpen="{Binding IsChecked, ElementName=MoreTagsButton, Mode=TwoWay}"
                Placement="Bottom"
                PlacementTarget="{Binding ElementName=MoreTagsButton}"
                PopupAnimation="Fade"
                StaysOpen="False"
                VerticalOffset="8">
                <Border
                    Padding="12"
                    Background="{StaticResource Brush.Background.Elevated}"
                    BorderBrush="{StaticResource Brush.Border.Subtle}"
                    BorderThickness="1"
                    CornerRadius="16">
                    <Grid MaxWidth="320">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="8" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <TextBlock
                            FontFamily="{StaticResource Bold}"
                            FontSize="12"
                            Foreground="{StaticResource Brush.Text.Primary}"
                            Text="More tags" />

                        <ScrollViewer
                            Grid.Row="2"
                            MaxHeight="240"
                            HorizontalScrollBarVisibility="Disabled"
                            VerticalScrollBarVisibility="Auto">
                            <ListView
                                Background="Transparent"
                                BorderThickness="0"
                                ItemContainerStyle="{StaticResource PopupTagListViewItemStyle}"
                                ItemTemplate="{StaticResource PopupTags}"
                                ItemsPanel="{StaticResource BudgetAllocationPopupTagItemsPanelTemplate}"
                                ItemsSource="{Binding OtherTags}"
                                PreviewMouseLeftButtonDown="OnTagListPreviewMouseLeftButtonDown"
                                ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                ScrollViewer.VerticalScrollBarVisibility="Disabled"
                                SelectedItem="{Binding SelectedOtherTag}"
                                SelectionChanged="OnMoreTagsSelectionChanged" />
                        </ScrollViewer>
                    </Grid>
                </Border>
            </Popup>
        </StackPanel>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition />
                <ColumnDefinition Width="16" />
                <ColumnDefinition />
                <ColumnDefinition Width="16" />
                <ColumnDefinition />
            </Grid.ColumnDefinitions>

            <components:ExpensesList
                Title="NEEDS"
                Allocation="{Binding NeedsAllocationPercentage}"
                DeleteCommand="{Binding DeleteExpenseLogCommand}"
                DotColor="{StaticResource Brush.Category.Needs}"
                HasMoreItems="{Binding NeedsHasMoreItems}"
                IsListEmpty="{Binding IsNeedsEmpty}"
                IsLoading="{Binding IsNeedsLoading}"
                ItemsSource="{Binding Needs}"
                LoadMoreCommand="{Binding LoadMoreNeedsCommand}"
                Percentage="{Binding NeedsPercentage}"
                RemainingAmount="{Binding NeedsRemaining}"
                SpentAmount="{Binding NeedsSpent}"
                TotalAmount="{Binding NeedsAvailable}" />

            <components:ExpensesList
                Title="WANTS"
                Grid.Column="2"
                Allocation="{Binding WantsAllocationPercentage}"
                DeleteCommand="{Binding DeleteExpenseLogCommand}"
                DotColor="{StaticResource Brush.Category.Wants}"
                HasMoreItems="{Binding WantsHasMoreItems}"
                IsListEmpty="{Binding IsWantsEmpty}"
                IsLoading="{Binding IsWantsLoading}"
                ItemsSource="{Binding Wants}"
                LoadMoreCommand="{Binding LoadMoreWantsCommand}"
                Percentage="{Binding WantsPercentage}"
                RemainingAmount="{Binding WantsRemaining}"
                SpentAmount="{Binding WantsSpent}"
                TotalAmount="{Binding WantsAvailable}" />

            <components:ExpensesList
                Title="INVEST"
                Grid.Column="4"
                Allocation="{Binding InvestAllocationPercentage}"
                DeleteCommand="{Binding DeleteExpenseLogCommand}"
                DotColor="{StaticResource Brush.Category.Investments}"
                HasMoreItems="{Binding InvestHasMoreItems}"
                IsListEmpty="{Binding IsInvestEmpty}"
                IsLoading="{Binding IsInvestLoading}"
                ItemsSource="{Binding Invest}"
                LoadMoreCommand="{Binding LoadMoreInvestCommand}"
                Percentage="{Binding InvestPercentage}"
                RemainingAmount="{Binding InvestRemaining}"
                SpentAmount="{Binding InvestSpent}"
                TotalAmount="{Binding InvestAvailable}" />
        </Grid>
    </Grid>
</UserControl>
