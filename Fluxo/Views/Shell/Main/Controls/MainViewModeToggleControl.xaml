<UserControl
    x:Class="Fluxo.Views.Shell.Main.Controls.MainViewModeToggleControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:enums="clr-namespace:Fluxo.Core.Enums;assembly=Fluxo.Core"
    xmlns:viewModels="clr-namespace:Fluxo.ViewModels.Shell">
    <StackPanel>
        <Border
            Height="32"
            Padding="4"
            Background="{StaticResource Brush.Background.Surface}"
            BorderBrush="{StaticResource Brush.Border.Subtle}"
            BorderThickness="1"
            CornerRadius="14">
            <StackPanel Orientation="Horizontal">
                <Button
                    Command="{Binding SetSelectedMainContentViewCommand}"
                    CommandParameter="{x:Static enums:MainContentViewMode.Daily}"
                    Content="Day"
                    Style="{StaticResource MainContentViewToggleButtonStyle}"
                    Tag="{Binding IsDailyViewSelected}" />
                <Button
                    Margin="4,0,0,0"
                    Command="{Binding SetSelectedMainContentViewCommand}"
                    CommandParameter="{x:Static enums:MainContentViewMode.Weekly}"
                    Content="Week"
                    Style="{StaticResource MainContentViewToggleButtonStyle}"
                    Tag="{Binding IsWeeklyViewSelected}" />
                <Button
                    Margin="4,0,0,0"
                    Command="{Binding SetSelectedMainContentViewCommand}"
                    CommandParameter="{x:Static enums:MainContentViewMode.Monthly}"
                    Content="Month"
                    Style="{StaticResource MainContentViewToggleButtonStyle}"
                    Tag="{Binding IsMonthlyViewSelected}" />
                <Button
                    Margin="4,0,0,0"
                    Command="{Binding SetSelectedMainContentViewCommand}"
                    CommandParameter="{x:Static enums:MainContentViewMode.AllTime}"
                    Content="All-time"
                    Style="{StaticResource MainContentViewToggleButtonStyle}"
                    Tag="{Binding IsAllTimeViewSelected}" />
            </StackPanel>
        </Border>

        <Button
            Margin="0,4,0,0"
            HorizontalAlignment="Center"
            Command="{Binding MoveToCurrentPeriodCommand}"
            Content="{Binding MoveToCurrentLabel}"
            Cursor="Hand"
            Style="{StaticResource MoveToCurrentPeriodButtonStyle}" />
    </StackPanel>
</UserControl>