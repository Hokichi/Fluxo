<UserControl
    x:Class="Fluxo.Views.Shell.Main.Controls.DaySpinnerControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:icons="http://metro.mahapps.com/winfx/xaml/iconpacks"
    xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework">
    <UserControl.Resources>
        <ItemsPanelTemplate x:Key="DaySpinnerItemsPanelTemplate">
            <StackPanel Orientation="Horizontal" />
        </ItemsPanelTemplate>
    </UserControl.Resources>

    <Grid Visibility="{Binding IsSpinnerVisible, Converter={StaticResource BoolToVisibilityConverter}}">
        <Grid.Style>
            <Style TargetType="Grid">
                <Style.Triggers>
                    <DataTrigger Binding="{Binding IsSpinnerVisible}" Value="False">
                        <Setter Property="Visibility" Value="Collapsed" />
                    </DataTrigger>
                </Style.Triggers>
            </Style>
        </Grid.Style>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="40" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="40" />
        </Grid.ColumnDefinitions>

        <Button
            HorizontalAlignment="Left"
            VerticalAlignment="Center"
            shell:WindowChrome.IsHitTestVisibleInChrome="True"
            Command="{Binding NavigateSpinnerBackCommand}"
            Style="{StaticResource SpinnerArrowButtonStyle}">
            <icons:PackIconUnicons
                Height="12"
                Kind="AngleLeft"
                Style="{StaticResource SpinnerArrowIconStyle}" />
        </Button>

        <ListView
            Grid.Column="1"
            HorizontalAlignment="Center"
            shell:WindowChrome.IsHitTestVisibleInChrome="True"
            Background="Transparent"
            BorderBrush="Transparent"
            BorderThickness="0"
            ItemContainerStyle="{StaticResource DaysOfWeekStyle}"
            ItemsPanel="{StaticResource DaySpinnerItemsPanelTemplate}"
            ItemsSource="{Binding DaysOfWeek}"
            SelectedItem="{Binding SelectedDay, Mode=TwoWay}" />

        <Button
            Grid.Column="2"
            HorizontalAlignment="Right"
            VerticalAlignment="Center"
            shell:WindowChrome.IsHitTestVisibleInChrome="True"
            Command="{Binding NavigateSpinnerForwardCommand}"
            IsEnabled="{Binding CanNavigateForward}"
            Style="{StaticResource SpinnerArrowButtonStyle}">
            <icons:PackIconUnicons
                Height="12"
                Kind="AngleRight"
                Style="{StaticResource SpinnerArrowIconStyle}" />
        </Button>
    </Grid>
</UserControl>
