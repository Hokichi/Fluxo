<UserControl
    x:Class="Fluxo.Views.Shell.Main.Controls.DaySpinnerControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:components="clr-namespace:Fluxo.Resources.Components;assembly=Fluxo.Resources"
    xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework">
    <UserControl.Resources>
        <ItemsPanelTemplate x:Key="DaySpinnerItemsPanelTemplate">
            <StackPanel Orientation="Horizontal" />
        </ItemsPanelTemplate>

        <Style x:Key="TransparentDaySpinnerListViewStyle" TargetType="ListView">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListView">
                        <Border
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}">
                            <ScrollViewer
                                Padding="{TemplateBinding Padding}"
                                Focusable="False">
                                <ItemsPresenter />
                            </ScrollViewer>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Background" Value="Transparent" />
                    <Setter Property="BorderBrush" Value="Transparent" />
                </Trigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <Grid
        Background="Transparent"
        Visibility="{Binding IsSpinnerVisible, Converter={StaticResource BoolToVisibilityConverter}}">
        <Grid.Style>
            <Style TargetType="Grid">
                <Style.Triggers>
                    <DataTrigger Binding="{Binding IsSpinnerVisible}" Value="False">
                        <Setter Property="Visibility" Value="Collapsed" />
                    </DataTrigger>
                    <DataTrigger Binding="{Binding IsEnabled, RelativeSource={RelativeSource AncestorType=UserControl}}" Value="False">
                        <Setter Property="Opacity" Value="0.4" />
                    </DataTrigger>
                </Style.Triggers>
            </Style>
        </Grid.Style>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="40" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="40" />
        </Grid.ColumnDefinitions>

        <Button
            HorizontalAlignment="Left"
            VerticalAlignment="Center"
            shell:WindowChrome.IsHitTestVisibleInChrome="True"
            Click="OnNavigateSpinnerBackClick"
            Style="{StaticResource SpinnerArrowButtonStyle}">
            <components:Icon
                Width="12"
                Height="12"
                Path="{StaticResource AngleLeft}"
                Style="{StaticResource SpinnerArrowIconStyle}" />
        </Button>

        <ListView
            x:Name="SpinnerListView"
            Grid.Column="1"
            HorizontalAlignment="Center"
            shell:WindowChrome.IsHitTestVisibleInChrome="True"
            Background="Transparent"
            BorderBrush="Transparent"
            BorderThickness="0"
            ItemContainerStyle="{StaticResource DaysOfWeekStyle}"
            ItemsPanel="{StaticResource DaySpinnerItemsPanelTemplate}"
            ItemsSource="{Binding DaysOfWeek}"
            SelectedItem="{Binding SelectedDay, Mode=OneWay}"
            SelectionChanged="OnSelectedDayChanged"
            Style="{StaticResource TransparentDaySpinnerListViewStyle}" />

        <Button
            Grid.Column="2"
            HorizontalAlignment="Right"
            VerticalAlignment="Center"
            shell:WindowChrome.IsHitTestVisibleInChrome="True"
            Click="OnNavigateSpinnerForwardClick"
            IsEnabled="{Binding CanNavigateForward}"
            Style="{StaticResource SpinnerArrowButtonStyle}">
            <components:Icon
                Width="12"
                Height="12"
                Path="{StaticResource AngleRight}"
                Style="{StaticResource SpinnerArrowIconStyle}" />
        </Button>
    </Grid>
</UserControl>

