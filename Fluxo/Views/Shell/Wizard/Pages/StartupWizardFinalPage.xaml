<UserControl
    x:Class="Fluxo.Views.Shell.Wizard.Pages.StartupWizardFinalPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:components="clr-namespace:Fluxo.Views.Components">
    <Border Style="{StaticResource PanelStyle}">
        <Grid>
            <StackPanel
                x:Name="PageContent"
                HorizontalAlignment="Center"
                VerticalAlignment="Center">
                <Border
                    Width="84"
                    Height="84"
                    HorizontalAlignment="Center"
                    Background="{StaticResource Brush.Background.Surface}"
                    BorderBrush="{StaticResource Brush.Border.Subtle}"
                    BorderThickness="1"
                    CornerRadius="42">
                    <Image
                        Margin="20"
                        Source="/Fluxo;component/Resources/fluxo.ico"
                        Stretch="Uniform" />
                </Border>
                <TextBlock
                    Margin="0,18,0,0"
                    HorizontalAlignment="Center"
                    FontFamily="{StaticResource Bold}"
                    FontSize="28"
                    Foreground="{StaticResource Brush.Text.Primary}">
                    <Run Text="Welcome to " />
                    <Run Text="flux" />
                    <Run Foreground="{StaticResource Brush.Mint}" Text="o" />
                    <Run Text=", " />
                    <Run Text="{Binding ResolvedUsername, Mode=OneWay}" />
                </TextBlock>
                <TextBlock
                    Margin="0,12,0,0"
                    HorizontalAlignment="Center"
                    FontFamily="{StaticResource Medium}"
                    FontSize="12"
                    Foreground="{StaticResource Brush.Text.Secondary}"
                    Text="Your dashboard, goals, and reminders are ready to go."
                    TextAlignment="Center" />
                <Button
                    Margin="0,28,0,0"
                    HorizontalAlignment="Center"
                    Click="OnFinishClick"
                    Style="{StaticResource WizardCircleActionButtonStyle}">
                    <components:Icon
                        Width="16"
                        Height="16"
                        Color="{StaticResource Brush.Background.Surface}"
                        Path="{StaticResource StartupWizardFinalPage.RocketSolid}" />
                </Button>
            </StackPanel>
        </Grid>
    </Border>
</UserControl>

