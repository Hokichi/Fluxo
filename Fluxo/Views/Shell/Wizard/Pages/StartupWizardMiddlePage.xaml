<UserControl
    x:Class="Fluxo.Views.Shell.Wizard.Pages.QuickSetupWizardMiddlePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:components="clr-namespace:Fluxo.Views.Components"
    xmlns:steps="clr-namespace:Fluxo.Views.Shell.Wizard.Pages.Steps">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="200" />
            <ColumnDefinition Width="20" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!--  Sidebar  -->
        <Border Style="{StaticResource PanelStyle}">
            <StackPanel>
                <TextBlock
                    FontFamily="{StaticResource Bold}"
                    FontSize="14"
                    Foreground="{StaticResource Brush.Text.Primary}"
                    Text="Setup Steps" />
                <TextBlock
                    Margin="0,6,0,16"
                    FontFamily="{StaticResource Medium}"
                    FontSize="11"
                    Foreground="{StaticResource Brush.Text.Muted}"
                    Text="{Binding StepCounterText}" />

                <!--  Step 1  -->
                <Border>
                    <Border.Style>
                        <Style BasedOn="{StaticResource SidebarStepStyle}" TargetType="Border">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsStep2Active}" Value="True">
                                    <Setter Property="Background" Value="{StaticResource Brush.Background.Hovered}" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <Grid>
                        <Border
                            x:Name="Step1Stripe"
                            Width="4"
                            HorizontalAlignment="Left"
                            Background="{StaticResource Brush.Mint}"
                            CornerRadius="2"
                            Opacity="0" />
                        <StackPanel
                            Margin="14,0,0,0"
                            VerticalAlignment="Center"
                            Orientation="Horizontal">
                            <components:Icon
                                Width="12"
                                Height="12"
                                Path="{StaticResource BookDollar}"
                                Color="{Binding Foreground, ElementName=Step1Label}" />
                            <TextBlock
                                x:Name="Step1Label"
                                Margin="10,0,0,0"
                                FontFamily="{StaticResource Bold}"
                                FontSize="12"
                                Foreground="{StaticResource Brush.Text.Secondary}"
                                Text="Spending Sources">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="{StaticResource Brush.Text.Secondary}" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsStep2Active}" Value="True">
                                                <Setter Property="Foreground" Value="{StaticResource Brush.Text.Primary}" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding IsStep3Active}" Value="True">
                                                <Setter Property="Foreground" Value="{StaticResource Brush.Text.Muted}" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding IsStep4Active}" Value="True">
                                                <Setter Property="Foreground" Value="{StaticResource Brush.Text.Muted}" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding IsStep5Active}" Value="True">
                                                <Setter Property="Foreground" Value="{StaticResource Brush.Text.Muted}" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding IsStep6Active}" Value="True">
                                                <Setter Property="Foreground" Value="{StaticResource Brush.Text.Muted}" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding IsStep7Active}" Value="True">
                                                <Setter Property="Foreground" Value="{StaticResource Brush.Text.Muted}" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </StackPanel>
                    </Grid>
                </Border>

                <!--  Step 2  -->
                <Border Visibility="{Binding HasSpendingSources, Converter={StaticResource BoolToVisibilityConverter}}">
                    <Border.Style>
                        <Style BasedOn="{StaticResource SidebarStepStyle}" TargetType="Border">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsStep3Active}" Value="True">
                                    <Setter Property="Background" Value="{StaticResource Brush.Background.Hovered}" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <Grid>
                        <Border
                            x:Name="Step2Stripe"
                            Width="4"
                            HorizontalAlignment="Left"
                            Background="{StaticResource Brush.Mint}"
                            CornerRadius="2"
                            Opacity="0" />
                        <StackPanel
                            Margin="14,0,0,0"
                            VerticalAlignment="Center"
                            Orientation="Horizontal">
                            <components:Icon
                                Width="12"
                                Height="12"
                                Path="{StaticResource InvoiceLight}"
                                Color="{Binding Foreground, ElementName=Step2Label}" />
                            <TextBlock
                                x:Name="Step2Label"
                                Margin="10,0,0,0"
                                FontFamily="{StaticResource Bold}"
                                FontSize="12"
                                Foreground="{StaticResource Brush.Text.Secondary}"
                                Text="Fixed Expenses">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="{StaticResource Brush.Text.Secondary}" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsStep3Active}" Value="True">
                                                <Setter Property="Foreground" Value="{StaticResource Brush.Text.Primary}" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding IsStep4Active}" Value="True">
                                                <Setter Property="Foreground" Value="{StaticResource Brush.Text.Muted}" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding IsStep5Active}" Value="True">
                                                <Setter Property="Foreground" Value="{StaticResource Brush.Text.Muted}" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding IsStep6Active}" Value="True">
                                                <Setter Property="Foreground" Value="{StaticResource Brush.Text.Muted}" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding IsStep7Active}" Value="True">
                                                <Setter Property="Foreground" Value="{StaticResource Brush.Text.Muted}" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </StackPanel>
                    </Grid>
                </Border>

                <!--  Step 3  -->
                <Border Visibility="{Binding HasSpendingSources, Converter={StaticResource BoolToVisibilityConverter}}">
                    <Border.Style>
                        <Style BasedOn="{StaticResource SidebarStepStyle}" TargetType="Border">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsStep4Active}" Value="True">
                                    <Setter Property="Background" Value="{StaticResource Brush.Background.Hovered}" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <Grid>
                        <Border
                            x:Name="Step3Stripe"
                            Width="4"
                            HorizontalAlignment="Left"
                            Background="{StaticResource Brush.Mint}"
                            CornerRadius="2"
                            Opacity="0" />
                        <StackPanel
                            Margin="14,0,0,0"
                            VerticalAlignment="Center"
                            Orientation="Horizontal">
                            <components:Icon
                                Width="12"
                                Height="12"
                                Path="{StaticResource BullseyeSolid}"
                                Color="{Binding Foreground, ElementName=Step3Label}" />
                            <TextBlock
                                x:Name="Step3Label"
                                Margin="10,0,0,0"
                                FontFamily="{StaticResource Bold}"
                                FontSize="12"
                                Foreground="{StaticResource Brush.Text.Secondary}"
                                Text="Savings Goals">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="{StaticResource Brush.Text.Secondary}" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsStep4Active}" Value="True">
                                                <Setter Property="Foreground" Value="{StaticResource Brush.Text.Primary}" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding IsStep5Active}" Value="True">
                                                <Setter Property="Foreground" Value="{StaticResource Brush.Text.Muted}" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding IsStep6Active}" Value="True">
                                                <Setter Property="Foreground" Value="{StaticResource Brush.Text.Muted}" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding IsStep7Active}" Value="True">
                                                <Setter Property="Foreground" Value="{StaticResource Brush.Text.Muted}" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </StackPanel>
                    </Grid>
                </Border>

                <!--  Step 4  -->
                <Border>
                    <Border.Style>
                        <Style BasedOn="{StaticResource SidebarStepStyle}" TargetType="Border">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsStep5Active}" Value="True">
                                    <Setter Property="Background" Value="{StaticResource Brush.Background.Hovered}" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <Grid>
                        <Border
                            x:Name="Step4Stripe"
                            Width="4"
                            HorizontalAlignment="Left"
                            Background="{StaticResource Brush.Mint}"
                            CornerRadius="2"
                            Opacity="0" />
                        <StackPanel
                            Margin="14,0,0,0"
                            VerticalAlignment="Center"
                            Orientation="Horizontal">
                            <components:Icon
                                Width="12"
                                Height="12"
                                Path="{StaticResource AccountBalanceWalletRound}"
                                Color="{Binding Foreground, ElementName=Step4Label}" />
                            <TextBlock
                                x:Name="Step4Label"
                                Margin="10,0,0,0"
                                FontFamily="{StaticResource Bold}"
                                FontSize="12"
                                Foreground="{StaticResource Brush.Text.Secondary}"
                                Text="Budget Allocation">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="{StaticResource Brush.Text.Secondary}" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsStep5Active}" Value="True">
                                                <Setter Property="Foreground" Value="{StaticResource Brush.Text.Primary}" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding IsStep6Active}" Value="True">
                                                <Setter Property="Foreground" Value="{StaticResource Brush.Text.Muted}" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding IsStep7Active}" Value="True">
                                                <Setter Property="Foreground" Value="{StaticResource Brush.Text.Muted}" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </StackPanel>
                    </Grid>
                </Border>

                <!--  Step 5  -->
                <Border>
                    <Border.Style>
                        <Style BasedOn="{StaticResource SidebarStepStyle}" TargetType="Border">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsStep6Active}" Value="True">
                                    <Setter Property="Background" Value="{StaticResource Brush.Background.Hovered}" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <Grid>
                        <Border
                            x:Name="Step5Stripe"
                            Width="4"
                            HorizontalAlignment="Left"
                            Background="{StaticResource Brush.Mint}"
                            CornerRadius="2"
                            Opacity="0" />
                        <StackPanel
                            Margin="14,0,0,0"
                            VerticalAlignment="Center"
                            Orientation="Horizontal">
                            <components:Icon
                                Width="12"
                                Height="12"
                                Path="{StaticResource RegularBell}"
                                Color="{Binding Foreground, ElementName=Step5Label}" />
                            <TextBlock
                                x:Name="Step5Label"
                                Margin="10,0,0,0"
                                FontFamily="{StaticResource Bold}"
                                FontSize="12"
                                Foreground="{StaticResource Brush.Text.Secondary}"
                                Text="Preferences">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="{StaticResource Brush.Text.Secondary}" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsStep6Active}" Value="True">
                                                <Setter Property="Foreground" Value="{StaticResource Brush.Text.Primary}" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding IsStep7Active}" Value="True">
                                                <Setter Property="Foreground" Value="{StaticResource Brush.Text.Muted}" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </StackPanel>
                    </Grid>
                </Border>

                <!--  Step 6  -->
                <Border>
                    <Border.Style>
                        <Style BasedOn="{StaticResource SidebarStepStyle}" TargetType="Border">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsStep7Active}" Value="True">
                                    <Setter Property="Background" Value="{StaticResource Brush.Background.Hovered}" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <Grid>
                        <Border
                            x:Name="Step6Stripe"
                            Width="4"
                            HorizontalAlignment="Left"
                            Background="{StaticResource Brush.Mint}"
                            CornerRadius="2"
                            Opacity="0" />
                        <StackPanel
                            Margin="14,0,0,0"
                            VerticalAlignment="Center"
                            Orientation="Horizontal">
                            <components:Icon
                                Width="12"
                                Height="12"
                                Path="{StaticResource InvoiceLight}"
                                Color="{Binding Foreground, ElementName=Step6Label}" />
                            <TextBlock
                                x:Name="Step6Label"
                                Margin="10,0,0,0"
                                FontFamily="{StaticResource Bold}"
                                FontSize="12"
                                Foreground="{StaticResource Brush.Text.Secondary}"
                                Text="Summary">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="{StaticResource Brush.Text.Secondary}" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsStep7Active}" Value="True">
                                                <Setter Property="Foreground" Value="{StaticResource Brush.Text.Primary}" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </StackPanel>
                    </Grid>
                </Border>
            </StackPanel>
        </Border>

        <!--  Content Area  -->
        <Border
            x:Name="ContentColumn"
            Grid.Column="2"
            Style="{StaticResource PanelStyle}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Grid x:Name="StepContent" Grid.RowSpan="3">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <StackPanel>
                        <TextBlock
                            FontFamily="{StaticResource Bold}"
                            FontSize="22"
                            Foreground="{StaticResource Brush.Text.Primary}"
                            Text="{Binding CurrentStepTitle}" />
                        <TextBlock
                            Margin="0,8,0,0"
                            FontFamily="{StaticResource Medium}"
                            Foreground="{StaticResource Brush.Text.Secondary}"
                            Text="{Binding CurrentStepDescription}"
                            TextWrapping="Wrap" />
                    </StackPanel>

                    <!--  Sticky Add Buttons  -->
                    <StackPanel Grid.Row="1" Margin="0,22,0,0">
                        <Button
                            Click="OnAddSpendingSourceClick"
                            Style="{StaticResource AddTileButtonStyle}"
                            Visibility="{Binding IsStep2Active, Converter={StaticResource BoolToVisibilityConverter}}" />
                        <Button
                            Click="OnAddFixedExpenseClick"
                            Style="{StaticResource AddTileButtonStyle}"
                            Visibility="{Binding IsStep3Active, Converter={StaticResource BoolToVisibilityConverter}}" />
                        <Button
                            Click="OnAddSavingGoalClick"
                            Style="{StaticResource AddTileButtonStyle}"
                            Visibility="{Binding IsStep4Active, Converter={StaticResource BoolToVisibilityConverter}}" />
                    </StackPanel>
                    <ScrollViewer
                        Grid.Row="2"
                        Margin="0,12,0,0"
                        VerticalScrollBarVisibility="Auto">
                        <Grid>
                            <steps:SpendingSources DataContext="{Binding SpendingSources}" />
                            <steps:FixedExpenses DataContext="{Binding FixedExpenses}" />
                            <steps:SavingGoals DataContext="{Binding SavingGoals}" />
                            <steps:BudgetAllocation DataContext="{Binding BudgetAllocation}" />
                            <steps:Notification DataContext="{Binding Notification}" />
                            <steps:Summary DataContext="{Binding Summary}" />
                        </Grid>
                    </ScrollViewer>
                </Grid>

                <Grid Grid.Row="3" Margin="0,16,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Button
                        HorizontalAlignment="Left"
                        Click="OnBackClick"
                        Style="{StaticResource ActionButtonStyle}"
                        Visibility="{Binding IsStep2Active, Converter={StaticResource BoolToVisibilityInvertedConverter}}">
                        <StackPanel VerticalAlignment="Center" Orientation="Horizontal">
                            <components:Icon
                                Width="12"
                                Height="12"
                                VerticalAlignment="Center"
                                Color="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                Path="{StaticResource AngleLeft}" />
                            <TextBlock
                                Margin="6,0,0,0"
                                VerticalAlignment="Center"
                                Text="Back" />
                        </StackPanel>
                    </Button>

                    <customControls:StepNavigatorControl
                        Grid.Column="1"
                        VerticalAlignment="Center"
                        CurrentStep="{Binding MiddleCurrentStep}"
                        StepCount="{Binding MiddleStepCount}" />

                    <Button
                        Grid.Column="2"
                        HorizontalAlignment="Right"
                        Click="OnNextClick"
                        IsEnabled="{Binding IsNextEnabled}">
                        <Button.Style>
                            <Style BasedOn="{StaticResource ActionButtonStyle}" TargetType="Button">
                                <Setter Property="Background" Value="{StaticResource Brush.Mint}" />
                                <Setter Property="BorderBrush" Value="{StaticResource Brush.Mint}" />
                                <Setter Property="Foreground" Value="{StaticResource Brush.Background.Surface}" />
                                <Style.Triggers>
                                    <Trigger Property="IsEnabled" Value="False">
                                        <Setter Property="Opacity" Value="0.4" />
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                        <StackPanel VerticalAlignment="Center" Orientation="Horizontal">
                            <TextBlock
                                Margin="0,0,6,0"
                                VerticalAlignment="Center"
                                Text="Next" />
                            <components:Icon
                                Width="12"
                                Height="12"
                                VerticalAlignment="Center"
                                Color="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                Path="{StaticResource AngleRight}" />
                        </StackPanel>
                    </Button>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</UserControl>