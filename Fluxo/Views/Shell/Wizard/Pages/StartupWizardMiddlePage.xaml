<UserControl
    x:Class="Fluxo.Views.Shell.Wizard.Pages.StartupWizardMiddlePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:steps="clr-namespace:Fluxo.Views.Shell.Wizard.Pages.Steps">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="200" />
            <ColumnDefinition Width="20" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!--  Sidebar  -->
        <Border Style="{StaticResource PanelStyle}">
            <StackPanel>
                <TextBlock
                    FontFamily="{StaticResource Bold}"
                    FontSize="14"
                    Foreground="{StaticResource Brush.Text.Primary}"
                    Text="Setup Steps" />
                <TextBlock
                    Margin="0,6,0,16"
                    FontFamily="{StaticResource Medium}"
                    FontSize="11"
                    Foreground="{StaticResource Brush.Text.Muted}"
                    Text="{Binding StepCounterText}" />

                <!--  Step 1  -->
                <Border Style="{StaticResource Step1SidebarStepStyle}">
                    <Grid>
                        <Border
                            x:Name="Step1Stripe"
                            Width="4"
                            HorizontalAlignment="Left"
                            Background="{StaticResource Brush.Mint}"
                            CornerRadius="2"
                            Opacity="0" />
                        <StackPanel
                            Margin="14,0,0,0"
                            VerticalAlignment="Center"
                            Orientation="Horizontal">
                            <Viewbox
                                Width="12"
                                Height="12"
                                Margin="0,0,0,-12">
                                <Path Data="{StaticResource BookDollar}" Fill="{StaticResource Brush.Text.Secondary}" />
                            </Viewbox>
                            <TextBlock
                                Margin="10,0,0,0"
                                FontFamily="{StaticResource Bold}"
                                FontSize="12"
                                Foreground="{StaticResource Brush.Text.Secondary}"
                                Text="Spending Sources" />
                        </StackPanel>
                    </Grid>
                </Border>

                <!--  Step 2  -->
                <Border Style="{StaticResource Step2SidebarStepStyle}" Visibility="{Binding HasSpendingSources, Converter={StaticResource BoolToVisibilityConverter}}">
                    <Grid>
                        <Border
                            x:Name="Step2Stripe"
                            Width="4"
                            HorizontalAlignment="Left"
                            Background="{StaticResource Brush.Mint}"
                            CornerRadius="2"
                            Opacity="0" />
                        <StackPanel
                            Margin="14,0,0,0"
                            VerticalAlignment="Center"
                            Orientation="Horizontal">
                            <Viewbox Width="12" Height="12">
                                <Path Data="{StaticResource InvoiceLight}" Fill="{StaticResource Brush.Text.Secondary}" />
                            </Viewbox>
                            <TextBlock
                                Margin="10,0,0,0"
                                FontFamily="{StaticResource Bold}"
                                FontSize="12"
                                Foreground="{StaticResource Brush.Text.Secondary}"
                                Text="Fixed Expenses" />
                        </StackPanel>
                    </Grid>
                </Border>

                <!--  Step 3  -->
                <Border Style="{StaticResource Step3SidebarStepStyle}" Visibility="{Binding HasSpendingSources, Converter={StaticResource BoolToVisibilityConverter}}">
                    <Grid>
                        <Border
                            x:Name="Step3Stripe"
                            Width="4"
                            HorizontalAlignment="Left"
                            Background="{StaticResource Brush.Mint}"
                            CornerRadius="2"
                            Opacity="0" />
                        <StackPanel
                            Margin="14,0,0,0"
                            VerticalAlignment="Center"
                            Orientation="Horizontal">
                            <Viewbox Width="12" Height="12">
                                <Path Data="{StaticResource BullseyeSolid}" Fill="{StaticResource Brush.Text.Secondary}" />
                            </Viewbox>
                            <TextBlock
                                Margin="10,0,0,0"
                                FontFamily="{StaticResource Bold}"
                                FontSize="12"
                                Foreground="{StaticResource Brush.Text.Secondary}"
                                Text="Savings Goals" />
                        </StackPanel>
                    </Grid>
                </Border>

                <!--  Step 4  -->
                <Border Style="{StaticResource Step4SidebarStepStyle}">
                    <Grid>
                        <Border
                            x:Name="Step4Stripe"
                            Width="4"
                            HorizontalAlignment="Left"
                            Background="{StaticResource Brush.Mint}"
                            CornerRadius="2"
                            Opacity="0" />
                        <StackPanel
                            Margin="14,0,0,0"
                            VerticalAlignment="Center"
                            Orientation="Horizontal">
                            <Viewbox Width="12" Height="12">
                                <Path Data="{StaticResource AccountBalanceWallet}" Fill="{StaticResource Brush.Text.Secondary}" />
                            </Viewbox>
                            <TextBlock
                                Margin="10,0,0,0"
                                FontFamily="{StaticResource Bold}"
                                FontSize="12"
                                Foreground="{StaticResource Brush.Text.Secondary}"
                                Text="Budget Allocation" />
                        </StackPanel>
                    </Grid>
                </Border>

                <!--  Step 5  -->
                <Border Style="{StaticResource Step5SidebarStepStyle}">
                    <Grid>
                        <Border
                            x:Name="Step5Stripe"
                            Width="4"
                            HorizontalAlignment="Left"
                            Background="{StaticResource Brush.Mint}"
                            CornerRadius="2"
                            Opacity="0" />
                        <StackPanel
                            Margin="14,0,0,0"
                            VerticalAlignment="Center"
                            Orientation="Horizontal">
                            <Viewbox Width="12" Height="12">
                                <Path Data="{StaticResource RegularBell}" Fill="{StaticResource Brush.Text.Secondary}" />
                            </Viewbox>
                            <TextBlock
                                Margin="10,0,0,0"
                                FontFamily="{StaticResource Bold}"
                                FontSize="12"
                                Foreground="{StaticResource Brush.Text.Secondary}"
                                Text="Notifications" />
                        </StackPanel>
                    </Grid>
                </Border>

                <!--  Step 6  -->
                <Border Style="{StaticResource Step6SidebarStepStyle}">
                    <Grid>
                        <Border
                            x:Name="Step6Stripe"
                            Width="4"
                            HorizontalAlignment="Left"
                            Background="{StaticResource Brush.Mint}"
                            CornerRadius="2"
                            Opacity="0" />
                        <StackPanel
                            Margin="14,0,0,0"
                            VerticalAlignment="Center"
                            Orientation="Horizontal">
                            <Viewbox Width="12" Height="12">
                                <Path Data="{StaticResource InvoiceLight}" Fill="{StaticResource Brush.Text.Secondary}" />
                            </Viewbox>
                            <TextBlock
                                Margin="10,0,0,0"
                                FontFamily="{StaticResource Bold}"
                                FontSize="12"
                                Foreground="{StaticResource Brush.Text.Secondary}"
                                Text="Summary" />
                        </StackPanel>
                    </Grid>
                </Border>
            </StackPanel>
        </Border>

        <!--  Content Area  -->
        <Border
            x:Name="ContentColumn"
            Grid.Column="2"
            Style="{StaticResource PanelStyle}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <StackPanel>
                    <TextBlock
                        FontFamily="{StaticResource Bold}"
                        FontSize="22"
                        Foreground="{StaticResource Brush.Text.Primary}"
                        Text="{Binding CurrentStepTitle}" />
                    <TextBlock
                        Margin="0,8,0,0"
                        FontFamily="{StaticResource Medium}"
                        Foreground="{StaticResource Brush.Text.Secondary}"
                        Text="{Binding CurrentStepDescription}"
                        TextWrapping="Wrap" />
                </StackPanel>

                <!--  Sticky Add Buttons  -->
                <StackPanel Grid.Row="1" Margin="0,22,0,0">
                    <Button
                        Click="OnAddSpendingSourceClick"
                        Style="{StaticResource AddTileButtonStyle}"
                        Visibility="{Binding IsStep2Active, Converter={StaticResource BoolToVisibilityConverter}}" />
                    <Button
                        Click="OnAddFixedExpenseClick"
                        Style="{StaticResource AddTileButtonStyle}"
                        Visibility="{Binding IsStep3Active, Converter={StaticResource BoolToVisibilityConverter}}" />
                    <Button
                        Click="OnAddSavingGoalClick"
                        Style="{StaticResource AddTileButtonStyle}"
                        Visibility="{Binding IsStep4Active, Converter={StaticResource BoolToVisibilityConverter}}" />
                </StackPanel>
                <ScrollViewer
                    Grid.Row="2"
                    Margin="0,12,0,0"
                    VerticalScrollBarVisibility="Auto">
                    <Grid>
                        <steps:StartupWizardStep2Page />
                        <steps:StartupWizardStep3Page />
                        <steps:StartupWizardStep4Page />
                        <steps:StartupWizardStep5Page />
                        <steps:StartupWizardStep6Page />
                        <steps:StartupWizardStep7Page />
                    </Grid>
                </ScrollViewer>
            </Grid>
        </Border>
    </Grid>
</UserControl>
