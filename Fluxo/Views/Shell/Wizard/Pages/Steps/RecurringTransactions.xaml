<UserControl
    x:Class="Fluxo.Views.Shell.Wizard.Pages.Steps.RecurringTransactions"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"

    xmlns:customControls="clr-namespace:Fluxo.Resources.CustomControls;assembly=Fluxo.Resources"
xmlns:primitives="clr-namespace:System.Windows.Controls.Primitives;assembly=PresentationFramework">
    <UserControl.Resources>
        <ItemsPanelTemplate x:Key="WizardRecurringTransactionsItemsPanelTemplate">
            <primitives:UniformGrid Columns="2" />
        </ItemsPanelTemplate>

        <Style x:Key="WizardRecurringTransactionsItemContainerStyle" TargetType="ContentPresenter">
            <Setter Property="Margin" Value="0,0,12,12" />
        </Style>

        <DataTemplate x:Key="WizardRecurringTransactionsItemTemplate">
            <Border Style="{StaticResource CardBorderStyle}">
                <Grid>
                    <StackPanel
                        HorizontalAlignment="Right"
                        VerticalAlignment="Bottom"
                        Orientation="Horizontal">
                        <customControls:BalloonButton Click="OnEditRecurringTransactionClick" Style="{StaticResource EditButton}"
                            DefaultBackground="{StaticResource Brush.BalloonButton.Background.Surface}"
                            HoveredBackground="{StaticResource Brush.BalloonButton.Background.Surface.Hovered}" />
                        <customControls:BalloonButton Click="OnDeleteRecurringTransactionClick" Style="{StaticResource DeleteButton}"
                            DefaultBackground="{StaticResource Brush.BalloonButton.Background.Destructive}"
                            HoveredBackground="{StaticResource Brush.BalloonButton.Background.Destructive.Hovered}" />
                    </StackPanel>
                    <StackPanel Margin="0,4,0,0">
                        <TextBlock
                            FontFamily="{StaticResource Bold}"
                            FontSize="15"
                            Foreground="{StaticResource Brush.Text.Primary}"
                            Text="{Binding Name}" />
                        <TextBlock
                            Margin="0,8,0,0"
                            FontFamily="{StaticResource Medium}"
                            Foreground="{StaticResource Brush.Text.Secondary}">
                            <Run Text="{Binding CategoryLabel}" />
                            <Run Text=" &#183; " />
                            <Run Text="{Binding AccountName}" />
                        </TextBlock>
                        <TextBlock
                            Margin="0,12,0,0"
                            FontFamily="{StaticResource Bold}"
                            Foreground="{StaticResource Brush.Warning}"
                            Text="{Binding Amount, Converter={StaticResource NumberWithCommasConverter}}"
                            ToolTip="{Binding Amount, Converter={StaticResource MoneyFullDisplayConverter}}" />
                        <TextBlock
                            Margin="0,8,0,0"
                            FontFamily="{StaticResource Medium}"
                            Foreground="{StaticResource Brush.Text.Secondary}"
                            Text="{Binding DueDateDisplay}" />
                    </StackPanel>
                </Grid>
            </Border>
        </DataTemplate>
    </UserControl.Resources>

    <!--  Step 3: Recurring Transactions  -->
    <StackPanel Visibility="{Binding IsStep3Active, Converter={StaticResource BoolToVisibilityConverter}}">
        <ItemsControl
            ItemContainerStyle="{StaticResource WizardRecurringTransactionsItemContainerStyle}"
            ItemTemplate="{StaticResource WizardRecurringTransactionsItemTemplate}"
            ItemsPanel="{StaticResource WizardRecurringTransactionsItemsPanelTemplate}"
            ItemsSource="{Binding RecurringTransactions}" />
    </StackPanel>
</UserControl>




