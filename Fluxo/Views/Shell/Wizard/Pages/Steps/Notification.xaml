<UserControl
    x:Class="Fluxo.Views.Shell.Wizard.Pages.Steps.Notification"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:coreEnums="clr-namespace:Fluxo.Core.Enums;assembly=Fluxo.Core"
    xmlns:primitives="clr-namespace:System.Windows.Controls.Primitives;assembly=PresentationFramework">
    <UserControl.Resources>
        <DataTemplate x:Key="WizardNotificationSettingItemTemplate">
            <Border Margin="0,0,0,12" Style="{StaticResource CardStyle}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock
                            FontFamily="{StaticResource Bold}"
                            Foreground="{StaticResource Brush.Text.Primary}"
                            Text="{Binding Title}" />
                        <TextBlock
                            Margin="0,6,0,0"
                            FontFamily="{StaticResource Medium}"
                            Foreground="{StaticResource Brush.Text.Secondary}"
                            Text="{Binding Description}"
                            TextWrapping="Wrap" />
                    </StackPanel>
                    <ToggleButton
                        Grid.Column="1"
                        VerticalAlignment="Center"
                        IsChecked="{Binding IsEnabled, Mode=TwoWay}"
                        Style="{StaticResource ToggleSwitchStyle}" />
                </Grid>
            </Border>
        </DataTemplate>
    </UserControl.Resources>

    <!--  Step 6: Notifications  -->
    <StackPanel Visibility="{Binding IsStep6Active, Converter={StaticResource BoolToVisibilityConverter}}">
        <Border Margin="0,0,0,12" Style="{StaticResource CardStyle}">
            <StackPanel>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock
                            FontFamily="{StaticResource Bold}"
                            Foreground="{StaticResource Brush.Text.Primary}"
                            Text="Run with Windows" />
                        <StackPanel Margin="0,6,0,0" Orientation="Horizontal">
                            <TextBlock
                                FontFamily="{StaticResource Medium}"
                                Foreground="{StaticResource Brush.Text.Secondary}"
                                TextWrapping="Wrap">
                                <Run Text="Start " />
                            </TextBlock>
                            <TextBlock
                                FontFamily="{StaticResource Bold}"
                                Foreground="{StaticResource Brush.Text.Secondary}"
                                Text="flux" />
                            <TextBlock
                                FontFamily="{StaticResource Bold}"
                                Foreground="{StaticResource Brush.Mint.Muted}"
                                Text="o" />
                            <TextBlock
                                FontFamily="{StaticResource Medium}"
                                Foreground="{StaticResource Brush.Text.Secondary}"
                                TextWrapping="Wrap">
                                <Run Text=" in the system tray when Windows signs in." />
                            </TextBlock>
                        </StackPanel>
                    </StackPanel>
                    <ToggleButton
                        Grid.Column="1"
                        VerticalAlignment="Center"
                        IsChecked="{Binding ShouldRunAtStartup, Mode=TwoWay}"
                        Style="{StaticResource ToggleSwitchStyle}" />
                </Grid>
                <Grid Margin="0,12,0,0" VerticalAlignment="Center">
                    <StackPanel VerticalAlignment="Center" Orientation="Horizontal">
                        <TextBlock
                            FontFamily="{StaticResource Bold}"
                            Foreground="{StaticResource Brush.Text.Primary}"
                            Text="When closing " />
                        <TextBlock
                            FontFamily="{StaticResource Bold}"
                            Foreground="{StaticResource Brush.Text.Primary}"
                            Text="flux" />
                        <TextBlock
                            FontFamily="{StaticResource Bold}"
                            Foreground="{StaticResource Brush.Mint}"
                            Text="o" />
                    </StackPanel>
                    <Border
                        Height="32"
                        Padding="4"
                        HorizontalAlignment="Right"
                        Background="{StaticResource Brush.Background.Surface}"
                        BorderBrush="{StaticResource Brush.Border.Subtle}"
                        BorderThickness="1"
                        CornerRadius="14">
                        <StackPanel Orientation="Horizontal">
                            <Button
                                Width="120"
                                Command="{Binding SetCloseBehaviorCommand}"
                                CommandParameter="{x:Static coreEnums:AppCloseBehavior.MinimizeToTray}"
                                Content="Minimize to tray"
                                Style="{StaticResource MainContentViewToggleButtonStyle}"
                                Tag="{Binding IsMinimizeToTrayCloseBehaviorSelected}" />
                            <Button
                                Width="120"
                                Margin="4,0,0,0"
                                Command="{Binding SetCloseBehaviorCommand}"
                                CommandParameter="{x:Static coreEnums:AppCloseBehavior.Exit}"
                                Content="Exit"
                                Style="{StaticResource MainContentViewToggleButtonStyle}"
                                Tag="{Binding IsExitCloseBehaviorSelected}" />
                        </StackPanel>
                    </Border>
                </Grid>
            </StackPanel>
        </Border>

        <ItemsControl ItemTemplate="{StaticResource WizardNotificationSettingItemTemplate}" ItemsSource="{Binding NotificationSettings}" />
    </StackPanel>

</UserControl>
