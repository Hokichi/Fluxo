<UserControl
    x:Class="Fluxo.Views.Shell.Wizard.Pages.Steps.Notification"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:coreEnums="clr-namespace:Fluxo.Core.Enums;assembly=Fluxo.Core"
    xmlns:primitives="clr-namespace:System.Windows.Controls.Primitives;assembly=PresentationFramework">
    <UserControl.Resources>
        <DataTemplate x:Key="WizardNotificationSettingItemTemplate">
            <Border Margin="0,0,0,12" Style="{StaticResource CardStyle}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock
                            FontFamily="{StaticResource Bold}"
                            Foreground="{StaticResource Brush.Text.Primary}"
                            Text="{Binding Title}" />
                        <TextBlock
                            Margin="0,6,0,0"
                            FontFamily="{StaticResource Medium}"
                            Foreground="{StaticResource Brush.Text.Secondary}"
                            Text="{Binding Description}"
                            TextWrapping="Wrap" />
                    </StackPanel>
                    <ToggleButton
                        Grid.Column="1"
                        VerticalAlignment="Center"
                        IsChecked="{Binding IsEnabled, Mode=TwoWay}"
                        Style="{StaticResource ToggleSwitchStyle}" />
                </Grid>
            </Border>
        </DataTemplate>
    </UserControl.Resources>

    <!--  Step 6: Notifications  -->
    <StackPanel Visibility="{Binding IsStep6Active, Converter={StaticResource BoolToVisibilityConverter}}">
        <Border Margin="0,0,0,12" Style="{StaticResource CardStyle}">
            <StackPanel>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock
                            FontFamily="{StaticResource Bold}"
                            Foreground="{StaticResource Brush.Text.Primary}"
                            Text="Run with Windows" />
                        <TextBlock
                            Margin="0,6,0,0"
                            FontFamily="{StaticResource Medium}"
                            Foreground="{StaticResource Brush.Text.Secondary}"
                            Text="Start fluxo in the system tray when Windows signs in."
                            TextWrapping="Wrap" />
                    </StackPanel>
                    <ToggleButton
                        Grid.Column="1"
                        VerticalAlignment="Center"
                        IsChecked="{Binding ShouldRunAtStartup, Mode=TwoWay}"
                        Style="{StaticResource ToggleSwitchStyle}" />
                </Grid>
                <StackPanel Margin="0,14,0,0">
                    <TextBlock
                        FontFamily="{StaticResource Bold}"
                        Foreground="{StaticResource Brush.Text.Primary}"
                        Text="When closing fluxo" />
                    <ComboBox
                        Margin="0,8,0,0"
                        SelectedValue="{Binding CloseBehavior, Mode=TwoWay}"
                        SelectedValuePath="Tag"
                        Style="{StaticResource FluxoComboBoxStyle}">
                        <ComboBoxItem Tag="{x:Static coreEnums:AppCloseBehavior.MinimizeToTray}">Minimize to tray</ComboBoxItem>
                        <ComboBoxItem Tag="{x:Static coreEnums:AppCloseBehavior.Exit}">Exit</ComboBoxItem>
                    </ComboBox>
                </StackPanel>
            </StackPanel>
        </Border>

        <ItemsControl
            ItemTemplate="{StaticResource WizardNotificationSettingItemTemplate}"
            ItemsSource="{Binding NotificationSettings}" />
    </StackPanel>

</UserControl>
