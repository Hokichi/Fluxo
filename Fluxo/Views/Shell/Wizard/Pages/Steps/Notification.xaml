<UserControl
    x:Class="Fluxo.Views.Shell.Wizard.Pages.Steps.Notification"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:primitives="clr-namespace:System.Windows.Controls.Primitives;assembly=PresentationFramework">
    <UserControl.Resources>
        <DataTemplate x:Key="WizardNotificationSettingItemTemplate">
            <Border Margin="0,0,0,12" Style="{StaticResource CardStyle}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock
                            FontFamily="{StaticResource Bold}"
                            Foreground="{StaticResource Brush.Text.Primary}"
                            Text="{Binding Title}" />
                        <TextBlock
                            Margin="0,6,0,0"
                            FontFamily="{StaticResource Medium}"
                            Foreground="{StaticResource Brush.Text.Secondary}"
                            Text="{Binding Description}"
                            TextWrapping="Wrap" />
                    </StackPanel>
                    <ToggleButton
                        Grid.Column="1"
                        VerticalAlignment="Center"
                        IsChecked="{Binding IsEnabled, Mode=TwoWay}"
                        Style="{StaticResource ToggleSwitchStyle}" />
                </Grid>
            </Border>
        </DataTemplate>
    </UserControl.Resources>

    <!--  Step 6: Notifications  -->
    <ItemsControl
        ItemTemplate="{StaticResource WizardNotificationSettingItemTemplate}"
        ItemsSource="{Binding NotificationSettings}"
        Visibility="{Binding IsStep6Active, Converter={StaticResource BoolToVisibilityConverter}}" />

</UserControl>
