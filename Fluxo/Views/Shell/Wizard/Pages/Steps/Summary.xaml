<UserControl
    x:Class="Fluxo.Views.Shell.Wizard.Pages.Steps.Summary"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:primitives="clr-namespace:System.Windows.Controls.Primitives;assembly=PresentationFramework">
    <!--  Step 8: Report Summary  -->
    <StackPanel Visibility="{Binding IsStep8Active, Converter={StaticResource BoolToVisibilityConverter}}">
        <!--  Profile  -->
        <Border Style="{StaticResource CardBorderStyle}">
            <StackPanel>
                <TextBlock
                    FontFamily="{StaticResource Medium}"
                    FontSize="11"
                    Foreground="{StaticResource Brush.Text.Muted}"
                    Text="Username" />
                <TextBlock
                    Margin="0,4,0,0"
                    FontFamily="{StaticResource Bold}"
                    Foreground="{StaticResource Brush.Text.Primary}"
                    Text="{Binding ReportUsernameText}" />
            </StackPanel>
        </Border>

        <!--  Accounts / Recurring Transactions / Savings Goals  -->
        <Grid Margin="0,12,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="12" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="12" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource CardBorderStyle}">
                <StackPanel HorizontalAlignment="Center">
                    <TextBlock
                        HorizontalAlignment="Center"
                        FontFamily="{StaticResource Bold}"
                        FontSize="22"
                        Foreground="{StaticResource Brush.Mint}"
                        Text="{Binding ReportAccountCount}" />
                    <TextBlock
                        Margin="0,4,0,0"
                        HorizontalAlignment="Center"
                        FontFamily="{StaticResource Medium}"
                        FontSize="11"
                        Foreground="{StaticResource Brush.Text.Secondary}"
                        Text="Accounts" />
                    <TextBlock
                        Margin="0,4,0,0"
                        HorizontalAlignment="Center"
                        FontFamily="{StaticResource Medium}"
                        FontSize="11"
                        Foreground="{StaticResource Brush.Text.Muted}"
                        Text="{Binding ReportTotalBalanceText}"
                        ToolTip="{Binding ReportTotalBalanceTooltipText}" />
                </StackPanel>
            </Border>

            <Border Grid.Column="2" Style="{StaticResource CardBorderStyle}">
                <StackPanel HorizontalAlignment="Center">
                    <TextBlock
                        HorizontalAlignment="Center"
                        FontFamily="{StaticResource Bold}"
                        FontSize="22"
                        Foreground="{StaticResource Brush.Warning}"
                        Text="{Binding ReportFixedExpenseCount}" />
                    <TextBlock
                        Margin="0,4,0,0"
                        HorizontalAlignment="Center"
                        FontFamily="{StaticResource Medium}"
                        FontSize="11"
                        Foreground="{StaticResource Brush.Text.Secondary}"
                        Text="Recurring Transactions" />
                    <TextBlock
                        Margin="0,4,0,0"
                        HorizontalAlignment="Center"
                        FontFamily="{StaticResource Medium}"
                        FontSize="11"
                        Foreground="{StaticResource Brush.Text.Muted}"
                        Text="{Binding ReportTotalFixedExpenseText}"
                        ToolTip="{Binding ReportTotalFixedExpenseTooltipText}" />
                </StackPanel>
            </Border>

            <Border Grid.Column="4" Style="{StaticResource CardBorderStyle}">
                <StackPanel HorizontalAlignment="Center">
                    <TextBlock
                        HorizontalAlignment="Center"
                        FontFamily="{StaticResource Bold}"
                        FontSize="22"
                        Foreground="{StaticResource Brush.Mint}"
                        Text="{Binding ReportSavingGoalCount}" />
                    <TextBlock
                        Margin="0,4,0,0"
                        HorizontalAlignment="Center"
                        FontFamily="{StaticResource Medium}"
                        FontSize="11"
                        Foreground="{StaticResource Brush.Text.Secondary}"
                        Text="Savings Goals" />
                </StackPanel>
            </Border>
        </Grid>

        <!--  Budget Allocation  -->
        <Border Margin="0,12,0,0" Style="{StaticResource CardBorderStyle}">
            <StackPanel>
                <TextBlock
                    FontFamily="{StaticResource Medium}"
                    FontSize="11"
                    Foreground="{StaticResource Brush.Text.Muted}"
                    Text="Budget Allocation" />
                <TextBlock
                    Margin="0,4,0,0"
                    FontFamily="{StaticResource Bold}"
                    Foreground="{StaticResource Brush.Text.Primary}"
                    Text="{Binding ReportBudgetAllocationText}" />
            </StackPanel>
        </Border>

        <!--  Notifications  -->
        <Border Margin="0,12,0,0" Style="{StaticResource CardBorderStyle}">
            <StackPanel>
                <TextBlock
                    FontFamily="{StaticResource Medium}"
                    FontSize="11"
                    Foreground="{StaticResource Brush.Text.Muted}"
                    Text="Notifications Enabled" />
                <TextBlock
                    Margin="0,4,0,0"
                    FontFamily="{StaticResource Bold}"
                    Foreground="{StaticResource Brush.Text.Primary}">
                    <Run Text="{Binding ReportNotificationsEnabledCount, Mode=OneWay}" />
                    <Run Text=" of 7" />
                </TextBlock>
            </StackPanel>
        </Border>
    </StackPanel>
</UserControl>
