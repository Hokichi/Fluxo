<UserControl
    x:Class="Fluxo.Views.Shell.Wizard.Pages.Steps.SavingGoals"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"

    xmlns:customControls="clr-namespace:Fluxo.Resources.CustomControls;assembly=Fluxo.Resources"
xmlns:primitives="clr-namespace:System.Windows.Controls.Primitives;assembly=PresentationFramework">
    <UserControl.Resources>
        <ItemsPanelTemplate x:Key="WizardSavingGoalsItemsPanelTemplate">
            <primitives:UniformGrid Columns="2" />
        </ItemsPanelTemplate>

        <Style x:Key="WizardSavingGoalsItemContainerStyle" TargetType="ContentPresenter">
            <Setter Property="Margin" Value="0,0,12,12" />
        </Style>

        <DataTemplate x:Key="WizardSavingGoalsItemTemplate">
            <Border Style="{StaticResource CardBorderStyle}">
                <Grid>
                    <StackPanel
                        HorizontalAlignment="Right"
                        VerticalAlignment="Bottom"
                        Orientation="Horizontal">
                        <customControls:BalloonButton Click="OnEditSavingGoalClick" Style="{StaticResource EditButton}"
                            DefaultBackground="{StaticResource Brush.BalloonButton.Background.Surface}"
                            HoveredBackground="{StaticResource Brush.BalloonButton.Background.Surface.Hovered}" />
                        <customControls:BalloonButton Click="OnDeleteSavingGoalClick" Style="{StaticResource DeleteButton}"
                            DefaultBackground="{StaticResource Brush.BalloonButton.Background.Destructive}"
                            HoveredBackground="{StaticResource Brush.BalloonButton.Background.Destructive.Hovered}" />
                    </StackPanel>
                    <StackPanel Margin="0,4,0,0">
                        <TextBlock
                            FontFamily="{StaticResource Bold}"
                            FontSize="15"
                            Foreground="{StaticResource Brush.Text.Primary}"
                            Text="{Binding Name}" />
                        <TextBlock
                            Margin="0,8,0,0"
                            FontFamily="{StaticResource Medium}"
                            Foreground="{StaticResource Brush.Text.Secondary}"
                            Text="{Binding SavingEndDate, StringFormat=Target {0:MMM d, yyyy}}" />
                        <TextBlock
                            Margin="0,12,0,0"
                            FontFamily="{StaticResource Bold}"
                            Foreground="{StaticResource Brush.Mint}">
                            <TextBlock.ToolTip>
                                <MultiBinding StringFormat="{}{0}/{1}">
                                    <Binding Converter="{StaticResource MoneyFullDisplayConverter}" Path="CurrentAmount" />
                                    <Binding Converter="{StaticResource MoneyFullDisplayConverter}" Path="TargetAmount" />
                                </MultiBinding>
                            </TextBlock.ToolTip>
                            <Run Text="{Binding CurrentAmount, Converter={StaticResource NumberWithCommasConverter}}" />
                            <Run Text=" / " />
                            <Run Text="{Binding TargetAmount, Converter={StaticResource NumberWithCommasConverter}}" />
                        </TextBlock>
                    </StackPanel>
                </Grid>
            </Border>
        </DataTemplate>
    </UserControl.Resources>

    <!--  Step 4: Savings Goals  -->
    <StackPanel Visibility="{Binding IsStep4Active, Converter={StaticResource BoolToVisibilityConverter}}">
        <ItemsControl
            ItemContainerStyle="{StaticResource WizardSavingGoalsItemContainerStyle}"
            ItemTemplate="{StaticResource WizardSavingGoalsItemTemplate}"
            ItemsPanel="{StaticResource WizardSavingGoalsItemsPanelTemplate}"
            ItemsSource="{Binding SavingGoals}" />
    </StackPanel>
</UserControl>




