<UserControl
    x:Class="Fluxo.Views.Shell.Wizard.Pages.Steps.StartupWizardStep5Page"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:c="clr-namespace:Fluxo.Resources.CustomControls"
    xmlns:primitives="clr-namespace:System.Windows.Controls.Primitives;assembly=PresentationFramework">
                                <!--  Step 5: Budget Allocation  -->
                                <StackPanel Visibility="{Binding IsStep5Active, Converter={StaticResource BoolToVisibilityConverter}}">
                                    <Border Style="{StaticResource CardStyle}">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                            </Grid.RowDefinitions>
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <TextBlock
                                                    FontFamily="{StaticResource Bold}"
                                                    FontSize="14"
                                                    Foreground="{StaticResource Brush.Text.Primary}"
                                                    Text="Needs" />
                                                <StackPanel Grid.Column="1" Orientation="Horizontal">
                                                    <Button
                                                        Click="OnAllocationAdjustButtonClick"
                                                        Content="-"
                                                        MouseLeave="OnAllocationAdjustButtonMouseLeave"
                                                        PreviewMouseLeftButtonDown="OnAllocationAdjustButtonMouseDown"
                                                        PreviewMouseLeftButtonUp="OnAllocationAdjustButtonMouseUp"
                                                        Style="{StaticResource StepperButtonStyle}"
                                                        Tag="Needs:-1" />
                                                    <TextBlock
                                                        Width="56"
                                                        VerticalAlignment="Center"
                                                        FontFamily="{StaticResource Bold}"
                                                        Foreground="{StaticResource Brush.Text.Primary}"
                                                        Text="{Binding NeedsAllocationPercentage, StringFormat={}{0}%}"
                                                        TextAlignment="Center" />
                                                    <Button
                                                        Click="OnAllocationAdjustButtonClick"
                                                        Content="+"
                                                        MouseLeave="OnAllocationAdjustButtonMouseLeave"
                                                        PreviewMouseLeftButtonDown="OnAllocationAdjustButtonMouseDown"
                                                        PreviewMouseLeftButtonUp="OnAllocationAdjustButtonMouseUp"
                                                        Style="{StaticResource StepperButtonStyle}"
                                                        Tag="Needs:+1" />
                                                </StackPanel>
                                            </Grid>
                                            <Slider
                                                Grid.Row="1"
                                                Margin="0,8,0,0"
                                                IsSnapToTickEnabled="True"
                                                Maximum="100"
                                                Minimum="0"
                                                Style="{StaticResource BudgetSliderStyle}"
                                                TickFrequency="1"
                                                Value="{Binding NeedsAllocationPercentage, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                            <TextBlock
                                                Grid.Row="2"
                                                HorizontalAlignment="Right"
                                                FontFamily="{StaticResource Medium}"
                                                Foreground="{StaticResource Brush.Text.Secondary}"
                                                Text="{Binding NeedsAllocationAmountText, Converter={StaticResource MoneyDisplayConverter}}"
                                                ToolTip="{Binding NeedsAllocationAmountText, Converter={StaticResource MoneyFullDisplayConverter}}" />
                                        </Grid>
                                    </Border>
                                    <Border Margin="0,12,0,0" Style="{StaticResource CardStyle}">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                            </Grid.RowDefinitions>
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <TextBlock
                                                    FontFamily="{StaticResource Bold}"
                                                    FontSize="14"
                                                    Foreground="{StaticResource Brush.Text.Primary}"
                                                    Text="Wants" />
                                                <StackPanel Grid.Column="1" Orientation="Horizontal">
                                                    <Button
                                                        Click="OnAllocationAdjustButtonClick"
                                                        Content="-"
                                                        MouseLeave="OnAllocationAdjustButtonMouseLeave"
                                                        PreviewMouseLeftButtonDown="OnAllocationAdjustButtonMouseDown"
                                                        PreviewMouseLeftButtonUp="OnAllocationAdjustButtonMouseUp"
                                                        Style="{StaticResource StepperButtonStyle}"
                                                        Tag="Wants:-1" />
                                                    <TextBlock
                                                        Width="56"
                                                        VerticalAlignment="Center"
                                                        FontFamily="{StaticResource Bold}"
                                                        Foreground="{StaticResource Brush.Text.Primary}"
                                                        Text="{Binding WantsAllocationPercentage, StringFormat={}{0}%}"
                                                        TextAlignment="Center" />
                                                    <Button
                                                        Click="OnAllocationAdjustButtonClick"
                                                        Content="+"
                                                        MouseLeave="OnAllocationAdjustButtonMouseLeave"
                                                        PreviewMouseLeftButtonDown="OnAllocationAdjustButtonMouseDown"
                                                        PreviewMouseLeftButtonUp="OnAllocationAdjustButtonMouseUp"
                                                        Style="{StaticResource StepperButtonStyle}"
                                                        Tag="Wants:+1" />
                                                </StackPanel>
                                            </Grid>
                                            <Slider
                                                Grid.Row="1"
                                                Margin="0,8,0,0"
                                                IsSnapToTickEnabled="True"
                                                Maximum="100"
                                                Minimum="0"
                                                Style="{StaticResource BudgetSliderStyle}"
                                                TickFrequency="1"
                                                Value="{Binding WantsAllocationPercentage, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                            <TextBlock
                                                Grid.Row="2"
                                                HorizontalAlignment="Right"
                                                FontFamily="{StaticResource Medium}"
                                                Foreground="{StaticResource Brush.Text.Secondary}"
                                                Text="{Binding WantsAllocationAmountText, Converter={StaticResource MoneyDisplayConverter}}"
                                                ToolTip="{Binding WantsAllocationAmountText, Converter={StaticResource MoneyFullDisplayConverter}}" />
                                        </Grid>
                                    </Border>
                                    <Border Margin="0,12,0,0" Style="{StaticResource CardStyle}">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                            </Grid.RowDefinitions>
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <TextBlock
                                                    FontFamily="{StaticResource Bold}"
                                                    FontSize="14"
                                                    Foreground="{StaticResource Brush.Text.Primary}"
                                                    Text="Invest" />
                                                <StackPanel Grid.Column="1" Orientation="Horizontal">
                                                    <Button
                                                        Click="OnAllocationAdjustButtonClick"
                                                        Content="-"
                                                        MouseLeave="OnAllocationAdjustButtonMouseLeave"
                                                        PreviewMouseLeftButtonDown="OnAllocationAdjustButtonMouseDown"
                                                        PreviewMouseLeftButtonUp="OnAllocationAdjustButtonMouseUp"
                                                        Style="{StaticResource StepperButtonStyle}"
                                                        Tag="Invest:-1" />
                                                    <TextBlock
                                                        Width="56"
                                                        VerticalAlignment="Center"
                                                        FontFamily="{StaticResource Bold}"
                                                        Foreground="{StaticResource Brush.Text.Primary}"
                                                        Text="{Binding InvestAllocationPercentage, StringFormat={}{0}%}"
                                                        TextAlignment="Center" />
                                                    <Button
                                                        Click="OnAllocationAdjustButtonClick"
                                                        Content="+"
                                                        MouseLeave="OnAllocationAdjustButtonMouseLeave"
                                                        PreviewMouseLeftButtonDown="OnAllocationAdjustButtonMouseDown"
                                                        PreviewMouseLeftButtonUp="OnAllocationAdjustButtonMouseUp"
                                                        Style="{StaticResource StepperButtonStyle}"
                                                        Tag="Invest:+1" />
                                                </StackPanel>
                                            </Grid>
                                            <Slider
                                                Grid.Row="1"
                                                Margin="0,8,0,0"
                                                IsSnapToTickEnabled="True"
                                                Maximum="100"
                                                Minimum="0"
                                                Style="{StaticResource BudgetSliderStyle}"
                                                TickFrequency="1"
                                                Value="{Binding InvestAllocationPercentage, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                            <TextBlock
                                                Grid.Row="2"
                                                HorizontalAlignment="Right"
                                                FontFamily="{StaticResource Medium}"
                                                Foreground="{StaticResource Brush.Text.Secondary}"
                                                Text="{Binding InvestAllocationAmountText, Converter={StaticResource MoneyDisplayConverter}}"
                                                ToolTip="{Binding InvestAllocationAmountText, Converter={StaticResource MoneyFullDisplayConverter}}" />
                                        </Grid>
                                    </Border>

                                    <TextBlock
                                        Margin="0,12,0,0"
                                        FontFamily="{StaticResource Bold}"
                                        Foreground="{StaticResource Brush.Danger}"
                                        Text="{Binding BudgetAllocationErrorMessage}"
                                        Visibility="{Binding HasBudgetAllocationError, Converter={StaticResource BoolToVisibilityConverter}}" />
                                </StackPanel>

</UserControl>
