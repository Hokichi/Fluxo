<UserControl
    x:Class="Fluxo.Views.Shell.Wizard.Pages.Steps.Accounts"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:customControls="clr-namespace:Fluxo.Resources.CustomControls;assembly=Fluxo.Resources"
    xmlns:primitives="clr-namespace:System.Windows.Controls.Primitives;assembly=PresentationFramework">
    <UserControl.Resources>
        <ItemsPanelTemplate x:Key="WizardAccountsItemsPanelTemplate">
            <primitives:UniformGrid Columns="2" />
        </ItemsPanelTemplate>

        <Style x:Key="WizardAccountsItemContainerStyle" TargetType="ContentPresenter">
            <Setter Property="Margin" Value="0,0,12,12" />
        </Style>

        <DataTemplate x:Key="WizardAccountsItemTemplate">
            <Border Style="{StaticResource CardStyle}">
                <Grid>
                    <StackPanel
                        HorizontalAlignment="Right"
                        VerticalAlignment="Bottom"
                        Orientation="Horizontal">
                        <customControls:BalloonButton Click="OnEditAccountClick" Style="{StaticResource EditButton}" />
                        <customControls:BalloonButton Click="OnDeleteAccountClick" Style="{StaticResource DeleteButton}" />
                    </StackPanel>
                    <StackPanel Margin="0,4,0,0">
                        <TextBlock
                            FontFamily="{StaticResource Bold}"
                            FontSize="15"
                            Foreground="{StaticResource Brush.Text.Primary}"
                            Text="{Binding Name}" />
                        <TextBlock
                            Margin="0,8,0,0"
                            FontFamily="{StaticResource Medium}"
                            Foreground="{StaticResource Brush.Text.Secondary}"
                            Text="{Binding TypeLabel}" />
                        <TextBlock
                            Margin="0,12,0,0"
                            FontFamily="{StaticResource Bold}"
                            Foreground="{StaticResource Brush.Mint}"
                            ToolTip="{Binding PrimaryAmount, Converter={StaticResource MoneyFullDisplayConverter}}">
                            <Run Text="{Binding PrimaryAmountLabel}" />
                            <Run Text=": " />
                            <Run Text="{Binding PrimaryAmount, Converter={StaticResource NumberWithCommasConverter}}" />
                        </TextBlock>
                    </StackPanel>
                </Grid>
            </Border>
        </DataTemplate>
    </UserControl.Resources>

    <!--  Step 2: Accounts  -->
    <StackPanel Visibility="{Binding IsStep2Active, Converter={StaticResource BoolToVisibilityConverter}}">
        <ItemsControl
            ItemContainerStyle="{StaticResource WizardAccountsItemContainerStyle}"
            ItemTemplate="{StaticResource WizardAccountsItemTemplate}"
            ItemsPanel="{StaticResource WizardAccountsItemsPanelTemplate}"
            ItemsSource="{Binding Accounts}" />
    </StackPanel>

</UserControl>




