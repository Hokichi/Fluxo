<UserControl
    x:Class="Fluxo.Views.Shell.Wizard.Pages.Steps.StartupWizardStep7Page"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:c="clr-namespace:Fluxo.Resources.CustomControls"
    xmlns:primitives="clr-namespace:System.Windows.Controls.Primitives;assembly=PresentationFramework">
    <!--  Step 7: Report Summary  -->
    <StackPanel Visibility="{Binding IsStep7Active, Converter={StaticResource BoolToVisibilityConverter}}">
        <!--  Profile  -->
        <Border Style="{StaticResource CardStyle}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock
                        FontFamily="{StaticResource Medium}"
                        FontSize="11"
                        Foreground="{StaticResource Brush.Text.Muted}"
                        Text="Username" />
                    <TextBlock
                        Margin="0,4,0,0"
                        FontFamily="{StaticResource Bold}"
                        Foreground="{StaticResource Brush.Text.Primary}"
                        Text="{Binding ReportUsernameText}" />
                </StackPanel>
                <StackPanel Grid.Column="1">
                    <TextBlock
                        FontFamily="{StaticResource Medium}"
                        FontSize="11"
                        Foreground="{StaticResource Brush.Text.Muted}"
                        Text="Salary" />
                    <TextBlock
                        Margin="0,4,0,0"
                        FontFamily="{StaticResource Bold}"
                        Foreground="{StaticResource Brush.Text.Primary}"
                        Text="{Binding ReportSalaryText}"
                        ToolTip="{Binding ReportSalaryTooltipText}" />
                </StackPanel>
            </Grid>
        </Border>

        <!--  Spending Sources / Fixed Expenses / Savings Goals  -->
        <Grid Margin="0,12,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="12" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="12" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource CardStyle}">
                <StackPanel HorizontalAlignment="Center">
                    <TextBlock
                        HorizontalAlignment="Center"
                        FontFamily="{StaticResource Bold}"
                        FontSize="22"
                        Foreground="{StaticResource Brush.Mint}"
                        Text="{Binding ReportSpendingSourceCount}" />
                    <TextBlock
                        Margin="0,4,0,0"
                        HorizontalAlignment="Center"
                        FontFamily="{StaticResource Medium}"
                        FontSize="11"
                        Foreground="{StaticResource Brush.Text.Secondary}"
                        Text="Spending Sources" />
                    <TextBlock
                        Margin="0,4,0,0"
                        HorizontalAlignment="Center"
                        FontFamily="{StaticResource Medium}"
                        FontSize="11"
                        Foreground="{StaticResource Brush.Text.Muted}"
                        Text="{Binding ReportTotalBalanceText}"
                        ToolTip="{Binding ReportTotalBalanceTooltipText}" />
                </StackPanel>
            </Border>

            <Border Grid.Column="2" Style="{StaticResource CardStyle}">
                <StackPanel HorizontalAlignment="Center">
                    <TextBlock
                        HorizontalAlignment="Center"
                        FontFamily="{StaticResource Bold}"
                        FontSize="22"
                        Foreground="{StaticResource Brush.Warning}"
                        Text="{Binding ReportFixedExpenseCount}" />
                    <TextBlock
                        Margin="0,4,0,0"
                        HorizontalAlignment="Center"
                        FontFamily="{StaticResource Medium}"
                        FontSize="11"
                        Foreground="{StaticResource Brush.Text.Secondary}"
                        Text="Fixed Expenses" />
                    <TextBlock
                        Margin="0,4,0,0"
                        HorizontalAlignment="Center"
                        FontFamily="{StaticResource Medium}"
                        FontSize="11"
                        Foreground="{StaticResource Brush.Text.Muted}"
                        Text="{Binding ReportTotalFixedExpenseText}"
                        ToolTip="{Binding ReportTotalFixedExpenseTooltipText}" />
                </StackPanel>
            </Border>

            <Border Grid.Column="4" Style="{StaticResource CardStyle}">
                <StackPanel HorizontalAlignment="Center">
                    <TextBlock
                        HorizontalAlignment="Center"
                        FontFamily="{StaticResource Bold}"
                        FontSize="22"
                        Foreground="{StaticResource Brush.Mint}"
                        Text="{Binding ReportSavingGoalCount}" />
                    <TextBlock
                        Margin="0,4,0,0"
                        HorizontalAlignment="Center"
                        FontFamily="{StaticResource Medium}"
                        FontSize="11"
                        Foreground="{StaticResource Brush.Text.Secondary}"
                        Text="Savings Goals" />
                </StackPanel>
            </Border>
        </Grid>

        <!--  Budget Allocation  -->
        <Border Margin="0,12,0,0" Style="{StaticResource CardStyle}">
            <StackPanel>
                <TextBlock
                    FontFamily="{StaticResource Medium}"
                    FontSize="11"
                    Foreground="{StaticResource Brush.Text.Muted}"
                    Text="Budget Allocation" />
                <TextBlock
                    Margin="0,4,0,0"
                    FontFamily="{StaticResource Bold}"
                    Foreground="{StaticResource Brush.Text.Primary}"
                    Text="{Binding ReportBudgetAllocationText}" />
            </StackPanel>
        </Border>

        <!--  Notifications  -->
        <Border Margin="0,12,0,0" Style="{StaticResource CardStyle}">
            <StackPanel>
                <TextBlock
                    FontFamily="{StaticResource Medium}"
                    FontSize="11"
                    Foreground="{StaticResource Brush.Text.Muted}"
                    Text="Notifications Enabled" />
                <TextBlock
                    Margin="0,4,0,0"
                    FontFamily="{StaticResource Bold}"
                    Foreground="{StaticResource Brush.Text.Primary}">
                    <Run Text="{Binding ReportNotificationsEnabledCount, Mode=OneWay}" />
                    <Run Text=" of 5" />
                </TextBlock>
            </StackPanel>
        </Border>
    </StackPanel>
</UserControl>
