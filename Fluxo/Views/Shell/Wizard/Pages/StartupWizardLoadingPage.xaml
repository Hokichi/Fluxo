<UserControl
    x:Class="Fluxo.Views.Shell.Wizard.Pages.QuickSetupWizardLoadingPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:components="clr-namespace:Fluxo.Resources.Components;assembly=Fluxo.Resources">
    <Border Style="{StaticResource PanelStyle}">
        <Grid>
            <StackPanel
                x:Name="PageContent"
                HorizontalAlignment="Center"
                VerticalAlignment="Center">
                <Border
                    Width="84"
                    Height="84"
                    HorizontalAlignment="Center"
                    Background="{StaticResource Brush.Background.Surface}"
                    BorderBrush="{StaticResource Brush.Border.Subtle}"
                    BorderThickness="1"
                    CornerRadius="42">
                    <Image
                        Margin="20"
                        Source="/Fluxo.Resources;component/Resources/fluxo.ico"
                        Stretch="Uniform" />
                </Border>
                <TextBlock
                    Margin="0,24,0,0"
                    HorizontalAlignment="Center"
                    FontFamily="{StaticResource Bold}"
                    FontSize="28"
                    Foreground="{StaticResource Brush.Text.Primary}"
                    Text="{Binding CurrentStepTitle}" />
                <TextBlock
                    Margin="0,12,0,0"
                    HorizontalAlignment="Center"
                    FontFamily="{StaticResource Medium}"
                    FontSize="13"
                    Foreground="{StaticResource Brush.Text.Secondary}"
                    Text="{Binding CurrentStepDescription}"
                    TextAlignment="Center" />
                <ProgressBar
                    Width="240"
                    Height="8"
                    Margin="0,28,0,0"
                    Foreground="{StaticResource Brush.Mint}"
                    IsIndeterminate="True" />
            </StackPanel>
        </Grid>
    </Border>
</UserControl>
