<UserControl
    x:Class="Fluxo.Views.Shell.Wizard.Pages.QuickSetupWizardLoadingPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:components="clr-namespace:Fluxo.Resources.Components;assembly=Fluxo.Resources"
    xmlns:controls="clr-namespace:Fluxo.Controls;assembly=Fluxo.Resources">
    <Border Padding="0,24" Style="{StaticResource PanelStyle}">
        <Grid>
            <controls:RisingFlowBackground Grid.RowSpan="5" AccentBrush="{DynamicResource Color.Mint}" />

            <StackPanel
                x:Name="PageContent"
                Margin="0,-40,0,0"
                HorizontalAlignment="Center"
                VerticalAlignment="Center">
                <Border
                    Width="84"
                    Height="84"
                    HorizontalAlignment="Center"
                    Background="{StaticResource Brush.Background.Surface}"
                    BorderBrush="{StaticResource Brush.Border.Subtle}"
                    BorderThickness="1"
                    CornerRadius="42">
                    <Image
                        Margin="20"
                        Source="/Fluxo.Resources;component/Resources/fluxo.ico"
                        Stretch="Uniform" />
                </Border>
                <TextBlock
                    Margin="0,24,0,0"
                    HorizontalAlignment="Center"
                    FontFamily="{StaticResource Bold}"
                    FontSize="28"
                    Foreground="{StaticResource Brush.Text.Primary}"
                    Text="{Binding CurrentStepTitle}" />
                <TextBlock
                    Margin="0,12,0,0"
                    HorizontalAlignment="Center"
                    FontFamily="{StaticResource Medium}"
                    FontSize="13"
                    Foreground="{StaticResource Brush.Text.Secondary}"
                    Text="{Binding CurrentStepDescription}"
                    TextAlignment="Center" />
            </StackPanel>

            <controls:FluxoWave
                Height="120"
                Margin="0,200,0,0"
                VerticalAlignment="Bottom"
                ClipToBounds="True" />
        </Grid>
    </Border>
</UserControl>