<customControls:BasePopup
    x:Class="Fluxo.Views.Shell.Wizard.QuickSetupWizard"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    
    xmlns:customControls="clr-namespace:Fluxo.Resources.CustomControls;assembly=Fluxo.Resources"
xmlns:pages="clr-namespace:Fluxo.Views.Shell.Wizard.Pages"
    Title="fluxo Wizard"
    Icon="/Fluxo.Resources;component/fluxo.ico"
    ShowInTaskbar="True">

    <customControls:BasePopup.PopupTitleContent>
        <StackPanel Orientation="Horizontal">
            <TextBlock
                FontFamily="{StaticResource Bold}"
                FontSize="18"
                Foreground="{StaticResource Brush.Text.Primary}"
                Text="Welcome to " />
            <TextBlock
                FontFamily="{StaticResource Bold}"
                FontSize="18"
                Foreground="{StaticResource Brush.Text.Primary}"
                Text="flux" />
            <TextBlock
                FontFamily="{StaticResource Bold}"
                FontSize="18"
                Foreground="{StaticResource Brush.Mint}"
                Text="o" />
        </StackPanel>
    </customControls:BasePopup.PopupTitleContent>

    <customControls:BasePopup.Style>
        <Style BasedOn="{StaticResource {x:Type customControls:BasePopup}}" TargetType="{x:Type customControls:BasePopup}">
            <Setter Property="ShowCloseButton" Value="True" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding DataContext.IsFinalStep, RelativeSource={RelativeSource Self}}" Value="True">
                    <Setter Property="ShowCloseButton" Value="False" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </customControls:BasePopup.Style>

    <customControls:BasePopup.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Fluxo.Resources;component/Resources/Styles/QuickSetupWizardStyle.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </customControls:BasePopup.Resources>

    <Grid
        Width="860"
        Height="560"
        Margin="24,0,24,24">
        <Grid x:Name="ContentContainer">
            <!--  Greeting Page (Step 0)  -->
            <pages:QuickSetupWizardGreetingPage DataContext="{Binding GreetingPage}" Visibility="{Binding DataContext.IsGreetingStep, RelativeSource={RelativeSource AncestorType={x:Type customControls:BasePopup}}, Converter={StaticResource BoolToVisibilityConverter}}" />

            <!--  Preferred Name Page (Step 1)  -->
            <pages:QuickSetupWizardNamePage DataContext="{Binding NamePage}" Visibility="{Binding DataContext.IsNameStep, RelativeSource={RelativeSource AncestorType={x:Type customControls:BasePopup}}, Converter={StaticResource BoolToVisibilityConverter}}" />

            <!--  Middle Steps (2-7): Sidebar + Content  -->
            <pages:QuickSetupWizardMiddlePage
                x:Name="MiddleStepPage"
                DataContext="{Binding MiddlePage}"
                Visibility="{Binding DataContext.IsMiddleStep, RelativeSource={RelativeSource AncestorType={x:Type customControls:BasePopup}}, Converter={StaticResource BoolToVisibilityConverter}}" />

            <!--  Loading Page (Step 8)  -->
            <pages:QuickSetupWizardLoadingPage
                x:Name="LoadingStepPage"
                DataContext="{Binding LoadingPage}"
                Visibility="{Binding DataContext.IsLoadingStep, RelativeSource={RelativeSource AncestorType={x:Type customControls:BasePopup}}, Converter={StaticResource BoolToVisibilityConverter}}" />

            <!--  Welcome Page (Step 9)  -->
            <pages:QuickSetupWizardFinalPage
                x:Name="FinalStepPage"
                DataContext="{Binding FinalPage}"
                Visibility="{Binding DataContext.IsFinalStep, RelativeSource={RelativeSource AncestorType={x:Type customControls:BasePopup}}, Converter={StaticResource BoolToVisibilityConverter}}" />
        </Grid>
    </Grid>
</customControls:BasePopup>




