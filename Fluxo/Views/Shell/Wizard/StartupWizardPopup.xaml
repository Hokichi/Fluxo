<customControls:BasePopup
    x:Class="Fluxo.Views.Shell.Wizard.StartupWizardPopup"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:icons="http://metro.mahapps.com/winfx/xaml/iconpacks"
    xmlns:pages="clr-namespace:Fluxo.Views.Shell.Wizard.Pages"
    xmlns:customControls="clr-namespace:Fluxo.Views.CustomControls"
    PopupTitle="Welcome to Fluxo"
    ShowInTaskbar="True">

    <customControls:BasePopup.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Fluxo;component/Resources/Styles/StartupWizardStyle.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </customControls:BasePopup.Resources>

    <Grid
        Width="860"
        Height="560"
        Margin="24,0,24,24">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid x:Name="ContentContainer">
            <!--  Greeting Page (Step 0)  -->
            <pages:StartupWizardGreetingPage Visibility="{Binding IsGreetingStep, Converter={StaticResource BoolToVisibilityConverter}}" />

            <!--  Preferred Name Page (Step 1)  -->
            <pages:StartupWizardNamePage Visibility="{Binding IsNameStep, Converter={StaticResource BoolToVisibilityConverter}}" />

            <!--  Middle Steps (2-7): Sidebar + Content  -->
            <pages:StartupWizardMiddlePage x:Name="MiddleStepPage" Visibility="{Binding IsMiddleStep, Converter={StaticResource BoolToVisibilityConverter}}" />

            <!--  Loading Page (Step 8)  -->
            <pages:StartupWizardLoadingPage Visibility="{Binding IsLoadingStep, Converter={StaticResource BoolToVisibilityConverter}}" />

            <!--  Welcome Page (Step 9)  -->
            <pages:StartupWizardFinalPage Visibility="{Binding IsFinalStep, Converter={StaticResource BoolToVisibilityConverter}}" />
        </Grid>

        <!--  Navigation Bar  -->
        <Grid
            Grid.Row="1"
            Margin="0,16,0,0"
            Visibility="{Binding IsLoadingStep, Converter={StaticResource BoolToVisibilityInvertedConverter}}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!--  Back Button  -->
            <Button
                HorizontalAlignment="Left"
                Click="OnBackClick"
                Style="{StaticResource ActionButtonStyle}"
                Visibility="{Binding IsGreetingStep, Converter={StaticResource BoolToVisibilityInvertedConverter}}">
                <StackPanel VerticalAlignment="Center" Orientation="Horizontal">
                    <icons:PackIconUnicons
                        Height="12"
                        VerticalAlignment="Center"
                        Kind="AngleLeft" />
                    <TextBlock
                        Margin="6,0,0,0"
                        VerticalAlignment="Center"
                        Text="Back" />
                </StackPanel>
            </Button>

            <!--  Dot Navigator  -->
            <ItemsControl
                Grid.Column="1"
                VerticalAlignment="Center"
                ItemsSource="{Binding StepDots}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel Orientation="Horizontal" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Ellipse
                            Width="8"
                            Height="8"
                            Margin="3,0"
                            Cursor="Hand"
                            MouseLeftButtonDown="OnDotClick"
                            Style="{StaticResource WizardStepDotStyle}" />
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <!--  Next / Open Fluxo  -->
            <StackPanel
                Grid.Column="2"
                HorizontalAlignment="Right"
                Orientation="Horizontal">
                <Button
                    Click="OnNextClick"
                    IsEnabled="{Binding IsNextEnabled}"
                    Style="{StaticResource PrimaryActionButtonStyle}"
                    Visibility="{Binding IsFinalStep, Converter={StaticResource BoolToVisibilityInvertedConverter}}">
                    <StackPanel VerticalAlignment="Center" Orientation="Horizontal">
                        <TextBlock
                            Margin="0,0,6,0"
                            VerticalAlignment="Center"
                            Text="Next" />
                        <icons:PackIconUnicons
                            Height="12"
                            VerticalAlignment="Center"
                            Kind="AngleRight" />
                    </StackPanel>
                </Button>
                <Button
                    Click="OnFinishClick"
                    Content="Open Fluxo"
                    Style="{StaticResource PrimaryActionButtonStyle}"
                    Visibility="{Binding IsFinalStep, Converter={StaticResource BoolToVisibilityConverter}}" />
            </StackPanel>
        </Grid>
    </Grid>
</customControls:BasePopup>
