<Window
    x:Class="Fluxo.Views.Shell.StartupLoaderPopup"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:components="clr-namespace:Fluxo.Resources.Components;assembly=Fluxo.Resources"
    Width="340"
    Height="220"
    AllowsTransparency="True"
    Background="Transparent"
    Icon="/Fluxo.Resources;component/Resources/fluxo.ico"
    ResizeMode="NoResize"
    ShowInTaskbar="True"
    WindowStartupLocation="CenterScreen"
    WindowStyle="None">

    <Grid>

        <Border
            Padding="28"
            Background="{StaticResource Brush.Background.Elevated}"
            BorderBrush="{StaticResource Brush.Border.Subtle}"
            BorderThickness="1"
            CornerRadius="22">
            <StackPanel VerticalAlignment="Center">
                <Border
                    Width="72"
                    Height="72"
                    HorizontalAlignment="Center"
                    Background="{StaticResource Brush.Background.Surface}"
                    BorderBrush="{StaticResource Brush.Border.Subtle}"
                    BorderThickness="1"
                    CornerRadius="36">
                    <Image
                        Margin="18"
                        Source="/Fluxo.Resources;component/Resources/fluxo.ico"
                        Stretch="Uniform" />
                </Border>

                <StackPanel
                    Margin="0,18,0,0"
                    HorizontalAlignment="Center"
                    Orientation="Horizontal">
                    <TextBlock
                        FontFamily="{StaticResource Bold}"
                        FontSize="24"
                        Foreground="{StaticResource Brush.Text.Primary}"
                        Text="flux" />
                    <TextBlock
                        FontFamily="{StaticResource Bold}"
                        FontSize="24"
                        Foreground="{StaticResource Brush.Mint}"
                        Text="o" />
                </StackPanel>
            </StackPanel>
        </Border>

        <components:FluxoWave Margin="0,160,0,0" ClipToBounds="True" />
    </Grid>
</Window>