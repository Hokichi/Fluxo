<Window
    x:Class="Fluxo.Views.Shell.StartupLoaderPopup"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:components="clr-namespace:Fluxo.Views.Components"
    Width="340"
    Height="220"
    AllowsTransparency="True"
    Background="Transparent"
    Icon="/Fluxo;component/Resources/fluxo.ico"
    ResizeMode="NoResize"
    ShowInTaskbar="True"
    WindowStartupLocation="CenterScreen"
    WindowStyle="None">

    <Border
        Padding="28"
        Background="{StaticResource Brush.Background.Elevated}"
        BorderBrush="{StaticResource Brush.Border.Subtle}"
        BorderThickness="1"
        CornerRadius="22">
        <StackPanel VerticalAlignment="Center">
            <Border
                Width="72"
                Height="72"
                HorizontalAlignment="Center"
                Background="{StaticResource Brush.Background.Surface}"
                BorderBrush="{StaticResource Brush.Border.Subtle}"
                BorderThickness="1"
                CornerRadius="36">
                <Image
                    Margin="18"
                    Source="/Fluxo;component/Resources/fluxo.ico"
                    Stretch="Uniform" />
            </Border>

            <StackPanel
                Margin="0,18,0,0"
                HorizontalAlignment="Center"
                Orientation="Horizontal">
                <TextBlock
                    FontFamily="{StaticResource Bold}"
                    FontSize="24"
                    Foreground="{StaticResource Brush.Text.Primary}"
                    Text="flux" />
                <TextBlock
                    FontFamily="{StaticResource Bold}"
                    FontSize="24"
                    Foreground="{StaticResource Brush.Mint}"
                    Text="o" />
            </StackPanel>

            <ProgressBar
                Height="8"
                Margin="0,20,0,0"
                Foreground="{StaticResource Brush.Mint}"
                IsIndeterminate="True" />
        </StackPanel>
    </Border>
</Window>