<Window
    x:Class="Fluxo.Views.Shell.StartupLoaderPopup"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Width="340"
    Height="220"
    AllowsTransparency="True"
    Background="Transparent"
    ResizeMode="NoResize"
    ShowInTaskbar="False"
    WindowStartupLocation="CenterScreen"
    WindowStyle="None">

    <Border
        Padding="28"
        Background="{StaticResource Brush.Background.Elevated}"
        BorderBrush="{StaticResource Brush.Border.Subtle}"
        BorderThickness="1"
        CornerRadius="22">
        <StackPanel VerticalAlignment="Center">
            <Border
                Width="72"
                Height="72"
                HorizontalAlignment="Center"
                Background="{StaticResource Brush.Background.Surface}"
                BorderBrush="{StaticResource Brush.Border.Subtle}"
                BorderThickness="1"
                CornerRadius="36">
                <Viewbox Margin="18" Stretch="Uniform">
                    <Path Data="{StaticResource AccountBalanceWallet}" Fill="{StaticResource Brush.Mint}" />
                </Viewbox>
            </Border>

            <TextBlock
                Margin="0,18,0,0"
                HorizontalAlignment="Center"
                FontFamily="{StaticResource Bold}"
                FontSize="24"
                Foreground="{StaticResource Brush.Text.Primary}"
                Text="Fluxo" />

            <ProgressBar
                Height="8"
                Margin="0,20,0,0"
                IsIndeterminate="True"
                Foreground="{StaticResource Brush.Mint}" />
        </StackPanel>
    </Border>
</Window>
