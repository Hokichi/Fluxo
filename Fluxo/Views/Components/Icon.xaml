<UserControl
    x:Class="Fluxo.Views.Components.Icon"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    x:Name="Root">
    <Rectangle Fill="{Binding Color, ElementName=Root}">
        <Rectangle.OpacityMask>
            <DrawingBrush Drawing="{Binding MaskDrawing, ElementName=Root}" Stretch="Uniform" />
        </Rectangle.OpacityMask>
    </Rectangle>
</UserControl>