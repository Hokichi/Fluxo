<UserControl
    x:Class="Fluxo.Views.Components.IncomeSource"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:components="clr-namespace:Fluxo.Views.Components"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Width="240"
    Visibility="{Binding ShowOnUI, Converter={StaticResource BoolToVisibilityConverter}}"
    mc:Ignorable="d">
    <UserControl.Resources>
        <Style x:Key="IncomeSourceAccentStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource Brush.Income.Checking.Cash}" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding SpendingSourceType}" Value="Checking">
                    <Setter Property="Background" Value="{StaticResource Brush.Income.Checking.Cash}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding SpendingSourceType}" Value="Cash">
                    <Setter Property="Background" Value="{StaticResource Brush.Income.Checking.Cash}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding SpendingSourceType}" Value="Credit">
                    <Setter Property="Background" Value="{StaticResource Brush.Income.Credit.BNPL}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding SpendingSourceType}" Value="BNPL">
                    <Setter Property="Background" Value="{StaticResource Brush.Income.Credit.BNPL}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding SpendingSourceType}" Value="Saving">
                    <Setter Property="Background" Value="{StaticResource Brush.Income.Saving}" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="BankIconStyle" TargetType="components:Icon">
            <Setter Property="Visibility" Value="Collapsed" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding SpendingSourceType}" Value="Checking">
                    <Setter Property="Visibility" Value="Visible" />
                </DataTrigger>
                <DataTrigger Binding="{Binding SpendingSourceType}" Value="Cash">
                    <Setter Property="Visibility" Value="Visible" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="CreditCardIconStyle" TargetType="components:Icon">
            <Setter Property="Visibility" Value="Collapsed" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding SpendingSourceType}" Value="Credit">
                    <Setter Property="Visibility" Value="Visible" />
                </DataTrigger>
                <DataTrigger Binding="{Binding SpendingSourceType}" Value="BNPL">
                    <Setter Property="Visibility" Value="Visible" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="PiggyBankIconStyle" TargetType="components:Icon">
            <Setter Property="Visibility" Value="Collapsed" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding SpendingSourceType}" Value="Saving">
                    <Setter Property="Visibility" Value="Visible" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="CheckingCashDetailsStyle" TargetType="StackPanel">
            <Setter Property="Visibility" Value="Collapsed" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding SpendingSourceType}" Value="Checking">
                    <Setter Property="Visibility" Value="Visible" />
                </DataTrigger>
                <DataTrigger Binding="{Binding SpendingSourceType}" Value="Cash">
                    <Setter Property="Visibility" Value="Visible" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="CreditDetailsStyle" TargetType="StackPanel">
            <Setter Property="Visibility" Value="Collapsed" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding SpendingSourceType}" Value="Credit">
                    <Setter Property="Visibility" Value="Visible" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Border
            x:Name="SourceCard"
            BorderThickness="1"
            CornerRadius="16"
            MouseLeftButtonDown="OnRootMouseLeftButtonDown"
            PreviewMouseRightButtonUp="OnRootPreviewMouseRightButtonUp">
            <Border.Background>
                <SolidColorBrush Color="{StaticResource Color.Background.Surface}" />
            </Border.Background>
            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="BorderBrush" Value="{StaticResource Brush.Border.Subtle}" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsSelected}" Value="True">
                            <Setter Property="BorderBrush" Value="{StaticResource Brush.Mint}" />
                        </DataTrigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Trigger.EnterActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <ColorAnimation
                                            Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)"
                                            To="{StaticResource Color.Background.Elevated}"
                                            Duration="0:0:0.2" />
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.EnterActions>
                            <Trigger.ExitActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <ColorAnimation
                                            Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)"
                                            To="{StaticResource Color.Background.Surface}"
                                            Duration="0:0:0.2" />
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.ExitActions>
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>

            <StackPanel Margin="12" IsHitTestVisible="False">
                <StackPanel Orientation="Horizontal">
                    <Border
                        x:Name="AccentBorder"
                        Width="20"
                        Height="20"
                        CornerRadius="16"
                        Style="{StaticResource IncomeSourceAccentStyle}">
                        <Grid>
                            <components:Icon
                                Margin="6"
                                Path="{StaticResource IncomeSource.Bank}"
                                Style="{StaticResource BankIconStyle}"
                                Color="{Binding Background, ElementName=AccentBorder, Converter={StaticResource BrushToLighterBrushConverter}}" />
                            <components:Icon
                                Margin="6"
                                Path="{StaticResource IncomeSource.CreditCardAlt}"
                                Style="{StaticResource CreditCardIconStyle}"
                                Color="{Binding Background, ElementName=AccentBorder, Converter={StaticResource BrushToLighterBrushConverter}}" />
                            <components:Icon
                                Margin="6"
                                Path="{StaticResource IncomeSource.PiggyBank}"
                                Style="{StaticResource PiggyBankIconStyle}"
                                Color="{Binding Background, ElementName=AccentBorder, Converter={StaticResource BrushToLighterBrushConverter}}" />
                        </Grid>
                    </Border>

                    <TextBlock
                        Margin="8,0,0,0"
                        VerticalAlignment="Center"
                        FontFamily="{StaticResource Medium}"
                        FontSize="13"
                        Foreground="{StaticResource Brush.Text.Muted}"
                        Text="{Binding Name}" />
                </StackPanel>

                <TextBlock
                    Margin="0,8,0,0"
                    VerticalAlignment="Center"
                    FontFamily="{StaticResource Bold}"
                    FontSize="20"
                    Foreground="{StaticResource Brush.Text.Primary}"
                    Text="{Binding SpentAmount, Converter={StaticResource NumberWithCommasConverter}}"
                    ToolTip="{Binding SpentAmount, Converter={StaticResource MoneyFullDisplayConverter}}" />
            </StackPanel>
        </Border>

        <Popup
            x:Name="SourceActionsPopup"
            AllowsTransparency="True"
            IsOpen="False"
            Placement="Bottom"
            PlacementTarget="{Binding ElementName=SourceCard}"
            PopupAnimation="Fade"
            StaysOpen="False"
            VerticalOffset="8">
            <Border
                Width="220"
                Padding="8"
                Background="{StaticResource Brush.Background.Elevated}"
                BorderBrush="{StaticResource Brush.Border.Subtle}"
                BorderThickness="1"
                CornerRadius="18">
                <StackPanel>
                    <Button Click="OnViewActionClick" Style="{StaticResource HeaderMenuActionButtonStyle}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="16" />
                                <ColumnDefinition Width="12" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <components:Icon
                                Width="14"
                                Height="14"
                                Path="{StaticResource IncomeSource.Eye}"
                                Color="{StaticResource Brush.Info}" />
                            <TextBlock
                                Grid.Column="2"
                                VerticalAlignment="Center"
                                FontFamily="{StaticResource Bold}"
                                Foreground="{StaticResource Brush.Text.Primary}"
                                Text="View" />
                        </Grid>
                    </Button>

                    <Button Click="OnDeleteActionClick" Style="{StaticResource HeaderMenuActionButtonStyle}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="16" />
                                <ColumnDefinition Width="12" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <components:Icon
                                Width="14"
                                Height="14"
                                Path="{StaticResource IncomeSource.CircleMinusSolid}"
                                Color="{StaticResource Brush.Danger}" />
                            <TextBlock
                                Grid.Column="2"
                                VerticalAlignment="Center"
                                FontFamily="{StaticResource Bold}"
                                Foreground="{StaticResource Brush.Text.Primary}"
                                Text="Delete" />
                        </Grid>
                    </Button>

                    <Button Click="OnHideActionClick" Style="{StaticResource HeaderMenuActionButtonStyle}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="16" />
                                <ColumnDefinition Width="12" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <components:Icon
                                Width="14"
                                Height="14"
                                Path="{StaticResource IncomeSource.EyeOff}"
                                Color="{StaticResource Brush.Warning}" />
                            <TextBlock
                                Grid.Column="2"
                                VerticalAlignment="Center"
                                FontFamily="{StaticResource Bold}"
                                Foreground="{StaticResource Brush.Text.Primary}"
                                Text="Hide" />
                        </Grid>
                    </Button>

                    <Button
                        Click="OnDisableActionClick"
                        IsEnabled="{Binding IsEnabled}"
                        Style="{StaticResource HeaderMenuActionButtonStyle}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="16" />
                                <ColumnDefinition Width="12" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <components:Icon
                                Width="14"
                                Height="14"
                                Path="{StaticResource IncomeSource.LightningSlashFill}"
                                Color="{StaticResource Brush.Warning}" />
                            <TextBlock
                                Grid.Column="2"
                                VerticalAlignment="Center"
                                FontFamily="{StaticResource Bold}"
                                Foreground="{StaticResource Brush.Text.Primary}"
                                Text="Disable" />
                        </Grid>
                    </Button>

                    <Button
                        Click="OnTransferActionClick"
                        IsEnabled="{Binding CanTransfer}"
                        Style="{StaticResource HeaderMenuActionButtonStyle}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="16" />
                                <ColumnDefinition Width="12" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <components:Icon
                                Width="14"
                                Height="14"
                                Path="{StaticResource IncomeSource.Exchange}"
                                Color="{StaticResource Brush.Mint}" />
                            <TextBlock
                                Grid.Column="2"
                                VerticalAlignment="Center"
                                FontFamily="{StaticResource Bold}"
                                Foreground="{StaticResource Brush.Text.Primary}"
                                Text="Transfer" />
                        </Grid>
                    </Button>
                </StackPanel>
            </Border>
        </Popup>
    </Grid>
</UserControl>