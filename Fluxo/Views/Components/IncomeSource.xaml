<UserControl
    x:Class="Fluxo.Views.Components.IncomeSource"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Width="240"
    Height="100"
    Visibility="{Binding ShowOnUI, Converter={StaticResource BoolToVisibilityConverter}}"
    mc:Ignorable="d">
    <UserControl.Resources>
        <Style x:Key="RoundedProgressBarStyle" TargetType="ProgressBar">
            <Setter Property="Background" Value="{StaticResource Brush.Text.Secondary}" />
            <Setter Property="Foreground" Value="{StaticResource Brush.Income.Credit.BNPL}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ProgressBar">
                        <Border
                            x:Name="BackgroundBorder"
                            Background="{TemplateBinding Background}"
                            SnapsToDevicePixels="True">
                            <Border.CornerRadius>
                                <MultiBinding Converter="{StaticResource CornerRadiusConverter}">
                                    <Binding Path="Width" RelativeSource="{RelativeSource TemplatedParent}" />
                                    <Binding Path="Height" RelativeSource="{RelativeSource TemplatedParent}" />
                                </MultiBinding>
                            </Border.CornerRadius>
                            <Grid x:Name="PART_Track">
                                <Border
                                    x:Name="PART_Indicator"
                                    HorizontalAlignment="Left"
                                    Background="{TemplateBinding Foreground}"
                                    CornerRadius="{Binding ElementName=BackgroundBorder, Path=CornerRadius}" />
                            </Grid>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="IncomeSourceAccentStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource Brush.Income.Checking.Cash}" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding SpendingSourceType}" Value="Checking">
                    <Setter Property="Background" Value="{StaticResource Brush.Income.Checking.Cash}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding SpendingSourceType}" Value="Cash">
                    <Setter Property="Background" Value="{StaticResource Brush.Income.Checking.Cash}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding SpendingSourceType}" Value="Credit">
                    <Setter Property="Background" Value="{StaticResource Brush.Income.Credit.BNPL}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding SpendingSourceType}" Value="BNPL">
                    <Setter Property="Background" Value="{StaticResource Brush.Income.Credit.BNPL}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding SpendingSourceType}" Value="Saving">
                    <Setter Property="Background" Value="{StaticResource Brush.Income.Saving}" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="BankIconStyle" TargetType="Rectangle">
            <Setter Property="Visibility" Value="Collapsed" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding SpendingSourceType}" Value="Checking">
                    <Setter Property="Visibility" Value="Visible" />
                </DataTrigger>
                <DataTrigger Binding="{Binding SpendingSourceType}" Value="Cash">
                    <Setter Property="Visibility" Value="Visible" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="CreditCardIconStyle" TargetType="Rectangle">
            <Setter Property="Visibility" Value="Collapsed" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding SpendingSourceType}" Value="Credit">
                    <Setter Property="Visibility" Value="Visible" />
                </DataTrigger>
                <DataTrigger Binding="{Binding SpendingSourceType}" Value="BNPL">
                    <Setter Property="Visibility" Value="Visible" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="PiggyBankIconStyle" TargetType="Rectangle">
            <Setter Property="Visibility" Value="Collapsed" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding SpendingSourceType}" Value="Saving">
                    <Setter Property="Visibility" Value="Visible" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="CheckingCashDetailsStyle" TargetType="StackPanel">
            <Setter Property="Visibility" Value="Collapsed" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding SpendingSourceType}" Value="Checking">
                    <Setter Property="Visibility" Value="Visible" />
                </DataTrigger>
                <DataTrigger Binding="{Binding SpendingSourceType}" Value="Cash">
                    <Setter Property="Visibility" Value="Visible" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="CreditDetailsStyle" TargetType="StackPanel">
            <Setter Property="Visibility" Value="Collapsed" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding SpendingSourceType}" Value="Credit">
                    <Setter Property="Visibility" Value="Visible" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>
    <Border
        BorderBrush="{StaticResource Brush.Border.Subtle}"
        BorderThickness="1"
        CornerRadius="16">
        <Border.Background>
            <SolidColorBrush Color="{StaticResource Color.Background.Surface}" />
        </Border.Background>
        <Border.Style>
            <Style TargetType="Border">
                <Style.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Trigger.EnterActions>
                            <BeginStoryboard>
                                <Storyboard>
                                    <ColorAnimation
                                        Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)"
                                        To="{StaticResource Color.Background.Elevated}"
                                        Duration="0:0:0.2" />
                                </Storyboard>
                            </BeginStoryboard>
                        </Trigger.EnterActions>
                        <Trigger.ExitActions>
                            <BeginStoryboard>
                                <Storyboard>
                                    <ColorAnimation
                                        Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)"
                                        To="{StaticResource Color.Background.Surface}"
                                        Duration="0:0:0.2" />
                                </Storyboard>
                            </BeginStoryboard>
                        </Trigger.ExitActions>
                    </Trigger>
                </Style.Triggers>
            </Style>
        </Border.Style>
        <StackPanel Margin="12" IsHitTestVisible="False">
            <StackPanel Orientation="Horizontal">
                <Border
                    x:Name="AccentBorder"
                    Width="20"
                    Height="20"
                    CornerRadius="16"
                    Style="{StaticResource IncomeSourceAccentStyle}">
                    <Grid>
                        <Rectangle
                            Margin="6"
                            Fill="{Binding Background, ElementName=AccentBorder, Converter={StaticResource BrushToLighterBrushConverter}}"
                            Style="{StaticResource BankIconStyle}">
                            <Rectangle.OpacityMask>
                                <DrawingBrush Stretch="Uniform">
                                    <DrawingBrush.Drawing>
                                        <GeometryDrawing Geometry="{StaticResource Bank}">
                                            <GeometryDrawing.Brush>
                                                <SolidColorBrush Color="Black" />
                                            </GeometryDrawing.Brush>
                                        </GeometryDrawing>
                                    </DrawingBrush.Drawing>
                                </DrawingBrush>
                            </Rectangle.OpacityMask>
                        </Rectangle>
                        <Rectangle
                            Margin="6"
                            Fill="{Binding Background, ElementName=AccentBorder, Converter={StaticResource BrushToLighterBrushConverter}}"
                            Style="{StaticResource CreditCardIconStyle}">
                            <Rectangle.OpacityMask>
                                <DrawingBrush Stretch="Uniform">
                                    <DrawingBrush.Drawing>
                                        <GeometryDrawing Geometry="{StaticResource CreditCardAlt}">
                                            <GeometryDrawing.Brush>
                                                <SolidColorBrush Color="Black" />
                                            </GeometryDrawing.Brush>
                                        </GeometryDrawing>
                                    </DrawingBrush.Drawing>
                                </DrawingBrush>
                            </Rectangle.OpacityMask>
                        </Rectangle>
                        <Rectangle
                            Margin="6"
                            Fill="{Binding Background, ElementName=AccentBorder, Converter={StaticResource BrushToLighterBrushConverter}}"
                            Style="{StaticResource PiggyBankIconStyle}">
                            <Rectangle.OpacityMask>
                                <DrawingBrush Stretch="Uniform">
                                    <DrawingBrush.Drawing>
                                        <GeometryDrawing Geometry="{StaticResource PiggyBank}">
                                            <GeometryDrawing.Brush>
                                                <SolidColorBrush Color="Black" />
                                            </GeometryDrawing.Brush>
                                        </GeometryDrawing>
                                    </DrawingBrush.Drawing>
                                </DrawingBrush>
                            </Rectangle.OpacityMask>
                        </Rectangle>
                    </Grid>
                </Border>
                <TextBlock
                    Margin="8,0,0,0"
                    VerticalAlignment="Center"
                    FontFamily="{StaticResource Medium}"
                    FontSize="13"
                    Foreground="{StaticResource Brush.Text.Muted}"
                    Text="{Binding Name}" />
            </StackPanel>

            <TextBlock
                Margin="0,8,0,0"
                VerticalAlignment="Center"
                FontFamily="{StaticResource Bold}"
                FontSize="20"
                Foreground="{StaticResource Brush.Text.Primary}"
                Text="{Binding SpentAmount, Converter={StaticResource NumberWithCommasConverter}, StringFormat={}${0}}" />

            <Grid Margin="0,8,0,0">
                <StackPanel Orientation="Horizontal" Style="{StaticResource CheckingCashDetailsStyle}">
                    <TextBlock
                        FontFamily="{StaticResource Bold}"
                        Foreground="{StaticResource Brush.Success}"
                        Text="↓" />
                    <TextBlock
                        Margin="4,0,0,0"
                        FontFamily="{StaticResource Medium}"
                        Foreground="{StaticResource Brush.Success}"
                        Text="{Binding MoneyIn, Converter={StaticResource NumberWithCommasConverter}, StringFormat={}${0} In}" />
                    <Border
                        Width="1"
                        Height="12"
                        Margin="6,0,4,0"
                        Background="{StaticResource Brush.Text.Muted}" />
                    <TextBlock
                        FontFamily="{StaticResource Bold}"
                        Foreground="{StaticResource Brush.Danger}"
                        Text="↑" />
                    <TextBlock
                        Margin="4,0,0,0"
                        FontFamily="{StaticResource Medium}"
                        Foreground="{StaticResource Brush.Danger}"
                        Text="{Binding MoneyOut, Converter={StaticResource NumberWithCommasConverter}, StringFormat={}${0} Out}" />
                </StackPanel>

                <StackPanel Orientation="Horizontal" Style="{StaticResource CreditDetailsStyle}">
                    <TextBlock
                        VerticalAlignment="Center"
                        FontFamily="{StaticResource Medium}"
                        FontSize="10"
                        Foreground="{StaticResource Brush.Text.Secondary}"
                        Text="Spent:" />

                    <ProgressBar
                        Width="80"
                        Height="3"
                        Margin="5,3,0,0"
                        VerticalAlignment="Center"
                        Maximum="{Binding AccountLimit}"
                        Style="{StaticResource RoundedProgressBarStyle}"
                        Value="{Binding SpentAmount}" />

                    <TextBlock
                        Margin="5,1,0,0"
                        VerticalAlignment="Center"
                        FontFamily="{StaticResource Medium}"
                        FontSize="10"
                        Foreground="{StaticResource Brush.Text.Secondary}">
                        <Run Text="{Binding SpentAmount, Converter={StaticResource NumberWithCommasConverter}}" />
                        <Run Text="/" />
                        <Run Text="{Binding AccountLimit, Converter={StaticResource NumberWithCommasConverter}}" />
                    </TextBlock>
                </StackPanel>
            </Grid>
        </StackPanel>
    </Border>
</UserControl>