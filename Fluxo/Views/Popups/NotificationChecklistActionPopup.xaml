<customControls:BasePopup
    x:Class="Fluxo.Views.Popups.NotificationChecklistActionPopup"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:customControls="clr-namespace:Fluxo.Resources.CustomControls;assembly=Fluxo.Resources"
    PopupTitle="Review Notification Actions">
    <customControls:BasePopup.Resources>
        <DataTemplate x:Key="NotificationChecklistTagItemTemplate">
            <StackPanel Orientation="Horizontal">
                <Ellipse
                    Width="10"
                    Height="10"
                    VerticalAlignment="Center"
                    Fill="{Binding HexCode}" />
                <TextBlock
                    Margin="8,0,0,0"
                    VerticalAlignment="Center"
                    Text="{Binding Name}" />
            </StackPanel>
        </DataTemplate>

        <Style
            x:Key="NotificationChecklistTagsComboBoxStyle"
            BasedOn="{StaticResource FluxoComboBoxStyle}"
            TargetType="ComboBox">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid SnapsToDevicePixels="True">
                            <ToggleButton
                                x:Name="ToggleButton"
                                Height="{Binding Height, RelativeSource={RelativeSource AncestorType=ComboBox}}"
                                HorizontalAlignment="Stretch"
                                Background="{Binding Background, RelativeSource={RelativeSource TemplatedParent}}"
                                BorderBrush="{Binding BorderBrush, RelativeSource={RelativeSource TemplatedParent}}"
                                BorderThickness="{Binding BorderThickness, RelativeSource={RelativeSource TemplatedParent}}"
                                ClickMode="Press"
                                Focusable="False"
                                Foreground="{Binding Foreground, RelativeSource={RelativeSource TemplatedParent}}"
                                IsChecked="{Binding IsDropDownOpen, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border
                                            Padding="10,0,12,0"
                                            Background="{TemplateBinding Background}"
                                            BorderBrush="{TemplateBinding BorderBrush}"
                                            BorderThickness="{TemplateBinding BorderThickness}"
                                            CornerRadius="8">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>

                                                <ContentPresenter
                                                    HorizontalAlignment="{Binding HorizontalContentAlignment, RelativeSource={RelativeSource AncestorType=ComboBox}}"
                                                    VerticalAlignment="Center"
                                                    Content="{Binding SelectionBoxItem, RelativeSource={RelativeSource AncestorType=ComboBox}}"
                                                    ContentTemplate="{Binding ItemTemplate, RelativeSource={RelativeSource AncestorType=ComboBox}}"
                                                    ContentTemplateSelector="{Binding ItemTemplateSelector, RelativeSource={RelativeSource AncestorType=ComboBox}}"
                                                    RecognizesAccessKey="True"
                                                    SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}"
                                                    TextElement.FontFamily="{Binding FontFamily, RelativeSource={RelativeSource AncestorType=ComboBox}}"
                                                    TextElement.FontSize="{Binding FontSize, RelativeSource={RelativeSource AncestorType=ComboBox}}"
                                                    TextElement.Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=ComboBox}}" />

                                                <Path
                                                    x:Name="DropDownChevron"
                                                    Grid.Column="1"
                                                    Width="8"
                                                    Height="8"
                                                    VerticalAlignment="Center"
                                                    Data="{StaticResource AngleDown}"
                                                    Fill="{StaticResource Brush.Text.Muted}"
                                                    RenderTransformOrigin="0.5,0.5"
                                                    Stretch="Uniform" />
                                            </Grid>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsChecked" Value="True">
                                                <Setter TargetName="DropDownChevron" Property="RenderTransform">
                                                    <Setter.Value>
                                                        <RotateTransform Angle="180" />
                                                    </Setter.Value>
                                                </Setter>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>

                            <Popup
                                x:Name="PART_Popup"
                                AllowsTransparency="True"
                                Focusable="False"
                                HorizontalOffset="0"
                                IsOpen="{Binding IsDropDownOpen, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}"
                                Placement="Bottom"
                                PlacementTarget="{Binding RelativeSource={RelativeSource TemplatedParent}}"
                                PopupAnimation="Fade"
                                VerticalOffset="8">
                                <Border
                                    x:Name="DropDownBorder"
                                    MinWidth="{Binding ActualWidth, RelativeSource={RelativeSource TemplatedParent}}"
                                    Background="{StaticResource Brush.Background.Surface}"
                                    BorderBrush="{StaticResource Brush.Border.Subtle}"
                                    BorderThickness="1"
                                    CornerRadius="8">
                                    <Grid Margin="4">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="1" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>

                                        <Button
                                            Grid.Row="0"
                                            Height="30"
                                            Margin="2"
                                            Click="OnAddTagClick"
                                            Content="+ Add Tag"
                                            Style="{StaticResource ActionTextButtonStyle}" />
                                        <Border
                                            Grid.Row="1"
                                            Margin="4,4"
                                            Background="{StaticResource Brush.Border.Subtle}" />
                                        <customControls:FadingScrollViewer
                                            Grid.Row="2"
                                            MaxHeight="{TemplateBinding MaxDropDownHeight}"
                                            CanContentScroll="False"
                                            HorizontalScrollBarVisibility="Disabled"
                                            VerticalScrollBarVisibility="Hidden">
                                            <ItemsPresenter KeyboardNavigation.DirectionalNavigation="Contained" />
                                        </customControls:FadingScrollViewer>
                                    </Grid>
                                </Border>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsKeyboardFocusWithin" Value="True">
                                <Setter Property="BorderBrush" Value="{StaticResource Brush.Mint}" />
                            </Trigger>
                            <Trigger Property="Validation.HasError" Value="True">
                                <Setter Property="BorderBrush" Value="{StaticResource Brush.Danger}" />
                            </Trigger>
                            <Trigger Property="HasItems" Value="False">
                                <Setter TargetName="DropDownBorder" Property="MinHeight" Value="0" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <DataTemplate x:Key="NotificationChecklistItemTemplate">
            <Grid Margin="0,4,0,8">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock
                        Margin="0,10,12,0"
                        VerticalAlignment="Center"
                        FontFamily="{StaticResource Medium}"
                        Foreground="{StaticResource Brush.Text.Primary}"
                        Text="{Binding Label}" />

                    <customControls:SegmentedToggleGroup Margin="0,8,0,0">
                        <customControls:SegmentedToggleOption Content="Ignore" IsSelected="{Binding IsIgnoreSelected, Mode=TwoWay}" />
                        <customControls:SegmentedToggleOption Content="Paid" IsSelected="{Binding IsPaidSelected, Mode=TwoWay}" />
                        <customControls:SegmentedToggleOption Content="Process" IsSelected="{Binding IsProcessSelected, Mode=TwoWay}" />
                    </customControls:SegmentedToggleGroup>
                </StackPanel>

                <Grid
                    Grid.Row="1"
                    Grid.ColumnSpan="2"
                    Margin="0,8,0,0"
                    Visibility="{Binding ShowRecurringFields, Converter={StaticResource BoolToVisibilityConverter}}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="12" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="12" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <customControls:MoneyTextBox
                        Grid.Column="0"
                        Style="{StaticResource RoundedMoneyTextInputStyle}"
                        Text="{Binding Amount, UpdateSourceTrigger=PropertyChanged, Converter={StaticResource MoneyAmountToCanonicalConverter}}" />
                    <ComboBox
                        Grid.Column="2"
                        DisplayMemberPath="Name"
                        ItemsSource="{Binding AvailableSources}"
                        SelectedValue="{Binding SelectedSourceId, Mode=TwoWay}"
                        SelectedValuePath="Id"
                        Style="{StaticResource FluxoComboBoxStyle}" />
                    <ComboBox
                        Grid.Column="4"
                        ItemTemplate="{StaticResource NotificationChecklistTagItemTemplate}"
                        ItemsSource="{Binding AvailableTags}"
                        SelectedValue="{Binding SelectedTagId, Mode=TwoWay}"
                        SelectedValuePath="Id"
                        Style="{StaticResource NotificationChecklistTagsComboBoxStyle}"
                        Visibility="{Binding IsRecurringExpense, Converter={StaticResource BoolToVisibilityConverter}}" />
                    <ComboBox
                        Grid.Column="4"
                        DisplayMemberPath="Name"
                        ItemsSource="{Binding AvailableGoals}"
                        SelectedValue="{Binding SelectedGoalId, Mode=TwoWay}"
                        SelectedValuePath="Id"
                        Style="{StaticResource FluxoComboBoxStyle}"
                        Visibility="{Binding IsRecurringGoalUpdate, Converter={StaticResource BoolToVisibilityConverter}}" />
                </Grid>
            </Grid>
        </DataTemplate>
    </customControls:BasePopup.Resources>

    <Grid
        Width="600"
        MaxHeight="780"
        Margin="24,0,24,24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="12" />
            <RowDefinition Height="*" />
            <RowDefinition Height="16" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock
            Grid.Row="0"
            FontFamily="{StaticResource Medium}"
            Foreground="{StaticResource Brush.Text.Secondary}"
            Text="Choose Ignore, Paid, or Process for each notification" />

        <Border
            Grid.Row="2"
            Padding="12,0"
            Background="{StaticResource Brush.Background.Elevated}"
            BorderBrush="{StaticResource Brush.Border.Subtle}"
            BorderThickness="1"
            CornerRadius="12">
            <customControls:FadingScrollViewer VerticalScrollBarVisibility="Hidden">
                <ItemsControl ItemTemplate="{StaticResource NotificationChecklistItemTemplate}" ItemsSource="{Binding Items}" />
            </customControls:FadingScrollViewer>
        </Border>

        <Button
            Grid.Row="4"
            Height="36"
            Click="OnProceedClick"
            Content="Proceed"
            IsEnabled="{Binding CanProceed}"
            Style="{StaticResource ActionTextButtonStyle}" />
    </Grid>
</customControls:BasePopup>
