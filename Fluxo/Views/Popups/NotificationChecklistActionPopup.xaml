<customControls:BasePopup
    x:Class="Fluxo.Views.Popups.NotificationChecklistActionPopup"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    
    xmlns:customControls="clr-namespace:Fluxo.Resources.CustomControls;assembly=Fluxo.Resources"
Width="500"
    PopupTitle="Review Notification Actions">
    <customControls:BasePopup.Resources>
        <DataTemplate x:Key="NotificationChecklistItemTemplate">
            <Grid Margin="0,4,0,8">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock
                    Grid.Row="0"
                    Grid.Column="0"
                    Margin="0,10,12,0"
                    VerticalAlignment="Center"
                    FontFamily="{StaticResource Medium}"
                    Foreground="{StaticResource Brush.Text.Primary}"
                    Text="{Binding Label}" />

                <Border
                    Grid.Row="0"
                    Grid.Column="1"
                    Padding="4"
                    Background="{StaticResource Brush.Background.Surface}"
                    BorderBrush="{StaticResource Brush.Border.Subtle}"
                    BorderThickness="1"
                    CornerRadius="14">
                    <StackPanel Orientation="Horizontal">
                        <RadioButton
                            Content="Ignore"
                            IsChecked="{Binding IsIgnoreSelected, Mode=TwoWay}"
                            MinWidth="0"
                            Style="{StaticResource SegmentedToggleOptionStyle}" />
                        <RadioButton
                            Margin="4,0,0,0"
                            Content="Paid"
                            IsChecked="{Binding IsPaidSelected, Mode=TwoWay}"
                            MinWidth="0"
                            Style="{StaticResource SegmentedToggleOptionStyle}" />
                        <RadioButton
                            Margin="4,0,0,0"
                            Content="Process"
                            IsChecked="{Binding IsProcessSelected, Mode=TwoWay}"
                            MinWidth="0"
                            Style="{StaticResource SegmentedToggleOptionStyle}" />
                    </StackPanel>
                </Border>

                <Grid
                    Grid.Row="1"
                    Grid.ColumnSpan="2"
                    Margin="0,8,0,0"
                    IsEnabled="{Binding AreRecurringFieldsEnabled}"
                    Visibility="{Binding IsRecurringTransaction, Converter={StaticResource BoolToVisibilityConverter}}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="12" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="12" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <customControls:MoneyTextBox
                        Grid.Column="0"
                        Style="{StaticResource RoundedMoneyTextInputStyle}"
                        Text="{Binding Amount, UpdateSourceTrigger=PropertyChanged, Converter={StaticResource MoneyAmountToCanonicalConverter}}" />
                    <ComboBox
                        Grid.Column="2"
                        DisplayMemberPath="Name"
                        ItemsSource="{Binding AvailableSources}"
                        SelectedValue="{Binding SelectedSourceId, Mode=TwoWay}"
                        SelectedValuePath="Id"
                        Style="{StaticResource FluxoComboBoxStyle}" />
                    <ComboBox
                        Grid.Column="4"
                        DisplayMemberPath="Name"
                        ItemsSource="{Binding AvailableTags}"
                        SelectedValue="{Binding SelectedTagId, Mode=TwoWay}"
                        SelectedValuePath="Id"
                        Style="{StaticResource FluxoComboBoxStyle}"
                        Visibility="{Binding IsRecurringExpense, Converter={StaticResource BoolToVisibilityConverter}}" />
                    <ComboBox
                        Grid.Column="4"
                        DisplayMemberPath="Name"
                        ItemsSource="{Binding AvailableGoals}"
                        SelectedValue="{Binding SelectedGoalId, Mode=TwoWay}"
                        SelectedValuePath="Id"
                        Style="{StaticResource FluxoComboBoxStyle}"
                        Visibility="{Binding IsRecurringGoalUpdate, Converter={StaticResource BoolToVisibilityConverter}}" />
                </Grid>
            </Grid>
        </DataTemplate>
    </customControls:BasePopup.Resources>

    <Grid Margin="24,0,24,24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="12" />
            <RowDefinition Height="*" />
            <RowDefinition Height="16" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock
            FontFamily="{StaticResource Bold}"
            FontSize="14"
            Foreground="{StaticResource Brush.Text.Primary}"
            Text="Choose Ignore, Paid, or Process for each notification" />

        <Border
            Grid.Row="2"
            Padding="12"
            Background="{StaticResource Brush.Background.Elevated}"
            BorderBrush="{StaticResource Brush.Border.Subtle}"
            BorderThickness="1"
            CornerRadius="12">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <ItemsControl ItemTemplate="{StaticResource NotificationChecklistItemTemplate}" ItemsSource="{Binding Items}" />
            </ScrollViewer>
        </Border>

        <Button
            Grid.Row="4"
            Height="36"
            Command="{Binding ProceedCommand}"
            Content="Proceed"
            Style="{StaticResource ActionTextButtonStyle}" />
    </Grid>
</customControls:BasePopup>



