<c:BasePopup
    x:Class="Fluxo.Views.Popups.SpendingSourceDetailPopup"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:c="clr-namespace:Fluxo.Resources.CustomControls"
    xmlns:components="clr-namespace:Fluxo.Views.Components"
    x:Name="Root"
    Width="1080"
    MaxHeight="800"
    PopupTitle="Income Detail">

    <c:BasePopup.Resources>
        <Style x:Key="PanelStyle" TargetType="Border">
            <Setter Property="Padding" Value="18" />
            <Setter Property="Background" Value="{StaticResource Brush.Background.Surface}" />
            <Setter Property="BorderBrush" Value="{StaticResource Brush.Border.Subtle}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="18" />
        </Style>

        <Style x:Key="LeftSideLabelStyle" TargetType="TextBlock">
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="FontFamily" Value="{StaticResource Bold}" />
            <Setter Property="Foreground" Value="{StaticResource Brush.Text.Primary}" />
        </Style>

        <Style x:Key="InlineHeaderTextBoxBaseStyle" TargetType="TextBox">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="CaretBrush" Value="{StaticResource Brush.Text.Primary}" />
            <Setter Property="Foreground" Value="{StaticResource Brush.Text.Primary}" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <ScrollViewer x:Name="PART_ContentHost" Margin="0" />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style
            x:Key="InlineHeaderNameTextBoxStyle"
            BasedOn="{StaticResource InlineHeaderTextBoxBaseStyle}"
            TargetType="TextBox">
            <Setter Property="FontFamily" Value="{StaticResource Bold}" />
            <Setter Property="FontSize" Value="22" />
            <Setter Property="MinWidth" Value="24" />
        </Style>

        <Style
            x:Key="InlineHeaderAmountTextBoxStyle"
            BasedOn="{StaticResource InlineHeaderTextBoxBaseStyle}"
            TargetType="TextBox">
            <Setter Property="FontFamily" Value="{StaticResource Bold}" />
            <Setter Property="FontSize" Value="26" />
            <Setter Property="MinWidth" Value="24" />
            <Setter Property="HorizontalContentAlignment" Value="Right" />
            <Setter Property="TextAlignment" Value="Right" />
        </Style>

        <Style
            x:Key="InlineDetailValueTextBoxStyle"
            BasedOn="{StaticResource InlineHeaderTextBoxBaseStyle}"
            TargetType="TextBox">
            <Setter Property="FontFamily" Value="{StaticResource Medium}" />
            <Setter Property="Foreground" Value="{StaticResource Brush.Text.Secondary}" />
            <Setter Property="HorizontalContentAlignment" Value="Right" />
            <Setter Property="TextAlignment" Value="Right" />
            <Setter Property="MinWidth" Value="24" />
        </Style>
    </c:BasePopup.Resources>

    <Grid MaxHeight="600" Margin="24,0,24,24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="16" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Style="{StaticResource PanelStyle}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="16" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <Border
                    Width="56"
                    Height="56"
                    Background="{StaticResource Brush.Background.Hover}"
                    CornerRadius="28">
                    <Viewbox Margin="14">
                        <Path
                            Data="{StaticResource Bank}"
                            Fill="{StaticResource Brush.Mint}"
                            Stretch="Uniform" />
                    </Viewbox>
                </Border>

                <StackPanel Grid.Column="2" VerticalAlignment="Center">
                    <TextBlock
                        FontFamily="{StaticResource Medium}"
                        FontSize="11"
                        Foreground="{StaticResource Brush.Text.Muted}"
                        Text="{Binding SpendingSourceType}" />
                    <TextBlock
                        FontFamily="{StaticResource Bold}"
                        FontSize="22"
                        Foreground="{StaticResource Brush.Text.Primary}"
                        Cursor="IBeam"
                        MouseLeftButtonDown="OnHeaderNameTextMouseLeftButtonDown"
                        Text="{Binding NameText}"
                        Visibility="{Binding IsEditing, Converter={StaticResource BoolToVisibilityInvertedConverter}}" />
                    <TextBox
                        x:Name="NameTextBox"
                        Style="{StaticResource InlineHeaderNameTextBoxStyle}"
                        Text="{Binding NameText, UpdateSourceTrigger=PropertyChanged}"
                        Visibility="{Binding IsEditing, Converter={StaticResource BoolToVisibilityConverter}}" />
                </StackPanel>

                <StackPanel Grid.Column="3" VerticalAlignment="Center">
                    <TextBlock
                        HorizontalAlignment="Right"
                        FontFamily="{StaticResource Medium}"
                        FontSize="10"
                        Foreground="{StaticResource Brush.Text.Muted}"
                        Text="{Binding PrimaryAmountLabel}" />
                    <TextBlock
                        Margin="0,6,0,0"
                        HorizontalAlignment="Right"
                        FontFamily="{StaticResource Bold}"
                        FontSize="26"
                        Foreground="{StaticResource Brush.Text.Primary}"
                        Cursor="IBeam"
                        MouseLeftButtonDown="OnHeaderAmountTextMouseLeftButtonDown"
                        Visibility="{Binding IsEditing, Converter={StaticResource BoolToVisibilityInvertedConverter}}">
                        <Run Text="$" />
                        <Run Text="{Binding DisplayPrimaryAmount, Mode=OneWay, Converter={StaticResource NumberWithCommasConverter}}" />
                    </TextBlock>
                    <StackPanel
                        Margin="0,6,0,0"
                        HorizontalAlignment="Right"
                        Orientation="Horizontal"
                        Visibility="{Binding IsEditing, Converter={StaticResource BoolToVisibilityConverter}}">
                        <TextBlock
                            FontFamily="{StaticResource Bold}"
                            FontSize="26"
                            Foreground="{StaticResource Brush.Text.Primary}"
                            Text="$" />
                        <c:MoneyTextBox
                            x:Name="PrimaryAmountTextBox"
                            Style="{StaticResource InlineHeaderAmountTextBoxStyle}"
                            Text="{Binding PrimaryAmountText, UpdateSourceTrigger=PropertyChanged}" />
                    </StackPanel>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="320" />
                <ColumnDefinition Width="16" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Style="{StaticResource PanelStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="16" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="16" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Button
                        Content="Generate Report"
                        IsEnabled="False"
                        Style="{StaticResource PopupTextButtonStyle}" />

                    <StackPanel Grid.Row="2">
                        <Grid Margin="0,0,0,10" Visibility="{Binding IsCashOrChecking, Converter={StaticResource BoolToVisibilityConverter}}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Style="{StaticResource LeftSideLabelStyle}" Text="Inflow" />
                            <TextBlock
                                Grid.Column="1"
                                FontFamily="{StaticResource Medium}"
                                Foreground="{StaticResource Brush.Text.Secondary}">
                                <Run Text="$" />
                                <Run Text="{Binding MoneyIn, Converter={StaticResource NumberWithCommasConverter}}" />
                            </TextBlock>
                        </Grid>
                        <Grid Margin="0,0,0,10" Visibility="{Binding IsCashOrChecking, Converter={StaticResource BoolToVisibilityConverter}}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Style="{StaticResource LeftSideLabelStyle}" Text="Outflow" />
                            <TextBlock
                                Grid.Column="1"
                                FontFamily="{StaticResource Medium}"
                                Foreground="{StaticResource Brush.Text.Secondary}">
                                <Run Text="$" />
                                <Run Text="{Binding MoneyOut, Converter={StaticResource NumberWithCommasConverter}}" />
                            </TextBlock>
                        </Grid>
                        <Grid Margin="0,0,0,10" Visibility="{Binding IsCredit, Converter={StaticResource BoolToVisibilityConverter}}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Style="{StaticResource LeftSideLabelStyle}" Text="Spent" />
                            <TextBlock
                                Grid.Column="1"
                                FontFamily="{StaticResource Medium}"
                                Foreground="{StaticResource Brush.Text.Secondary}"
                                Cursor="IBeam"
                                MouseLeftButtonDown="OnCreditSpentTextMouseLeftButtonDown"
                                Visibility="{Binding IsEditing, Converter={StaticResource BoolToVisibilityInvertedConverter}}">
                                <Run Text="$" /><Run Text="{Binding SpentAmountText}" />
                            </TextBlock>
                            <c:MoneyTextBox
                                x:Name="CreditSpentAmountTextBox"
                                Grid.Column="1"
                                Style="{StaticResource InlineDetailValueTextBoxStyle}"
                                Text="{Binding SpentAmountText, UpdateSourceTrigger=PropertyChanged}"
                                Visibility="{Binding IsEditing, Converter={StaticResource BoolToVisibilityConverter}}" />
                        </Grid>
                        <Grid Margin="0,0,0,10" Visibility="{Binding IsCredit, Converter={StaticResource BoolToVisibilityConverter}}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Style="{StaticResource LeftSideLabelStyle}" Text="Limit" />
                            <TextBlock
                                Grid.Column="1"
                                FontFamily="{StaticResource Medium}"
                                Foreground="{StaticResource Brush.Text.Secondary}"
                                Cursor="IBeam"
                                MouseLeftButtonDown="OnCreditLimitTextMouseLeftButtonDown"
                                Visibility="{Binding IsEditing, Converter={StaticResource BoolToVisibilityInvertedConverter}}">
                                <Run Text="$" /><Run Text="{Binding AccountLimitText}" />
                            </TextBlock>
                            <c:MoneyTextBox
                                x:Name="CreditLimitTextBox"
                                Grid.Column="1"
                                Style="{StaticResource InlineDetailValueTextBoxStyle}"
                                Text="{Binding AccountLimitText, UpdateSourceTrigger=PropertyChanged}"
                                Visibility="{Binding IsEditing, Converter={StaticResource BoolToVisibilityConverter}}" />
                        </Grid>
                        <Grid Margin="0,0,0,10" Visibility="{Binding IsCredit, Converter={StaticResource BoolToVisibilityConverter}}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Style="{StaticResource LeftSideLabelStyle}" Text="Due Date" />
                            <TextBlock
                                Grid.Column="1"
                                FontFamily="{StaticResource Medium}"
                                Foreground="{StaticResource Brush.Text.Secondary}"
                                Text="{Binding DueDate, StringFormat={}{0:MMM d, yyyy}}"
                                Visibility="{Binding IsEditing, Converter={StaticResource BoolToVisibilityInvertedConverter}}" />
                            <components:DateSelector
                                Grid.Column="1"
                                SelectedDate="{Binding DueDate, Mode=TwoWay}"
                                Visibility="{Binding IsEditing, Converter={StaticResource BoolToVisibilityConverter}}" />
                        </Grid>
                        <Grid Margin="0,0,0,10" Visibility="{Binding IsBnpl, Converter={StaticResource BoolToVisibilityConverter}}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Style="{StaticResource LeftSideLabelStyle}" Text="Spend" />
                            <TextBlock
                                Grid.Column="1"
                                FontFamily="{StaticResource Medium}"
                                Foreground="{StaticResource Brush.Text.Secondary}"
                                Cursor="IBeam"
                                MouseLeftButtonDown="OnBnplSpentTextMouseLeftButtonDown"
                                Visibility="{Binding IsEditing, Converter={StaticResource BoolToVisibilityInvertedConverter}}">
                                <Run Text="$" /><Run Text="{Binding SpentAmountText}" />
                            </TextBlock>
                            <c:MoneyTextBox
                                x:Name="BnplSpentAmountTextBox"
                                Grid.Column="1"
                                Style="{StaticResource InlineDetailValueTextBoxStyle}"
                                Text="{Binding SpentAmountText, UpdateSourceTrigger=PropertyChanged}"
                                Visibility="{Binding IsEditing, Converter={StaticResource BoolToVisibilityConverter}}" />
                        </Grid>
                        <Grid Margin="0,0,0,10" Visibility="{Binding IsBnpl, Converter={StaticResource BoolToVisibilityConverter}}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Style="{StaticResource LeftSideLabelStyle}" Text="Due Date" />
                            <TextBlock
                                Grid.Column="1"
                                FontFamily="{StaticResource Medium}"
                                Foreground="{StaticResource Brush.Text.Secondary}"
                                Text="{Binding DueDate, StringFormat={}{0:MMM d, yyyy}}"
                                Visibility="{Binding IsEditing, Converter={StaticResource BoolToVisibilityInvertedConverter}}" />
                            <components:DateSelector
                                Grid.Column="1"
                                SelectedDate="{Binding DueDate, Mode=TwoWay}"
                                Visibility="{Binding IsEditing, Converter={StaticResource BoolToVisibilityConverter}}" />
                        </Grid>
                        <Grid Margin="0,0,0,10" Visibility="{Binding IsSaving, Converter={StaticResource BoolToVisibilityConverter}}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Style="{StaticResource LeftSideLabelStyle}" Text="Balance" />
                            <TextBlock
                                Grid.Column="1"
                                FontFamily="{StaticResource Medium}"
                                Foreground="{StaticResource Brush.Text.Secondary}">
                                <Run Text="$" />
                                <Run Text="{Binding DisplayPrimaryAmount, Mode=OneWay, Converter={StaticResource NumberWithCommasConverter}}" />
                            </TextBlock>
                        </Grid>
                        <Grid Margin="0,0,0,10" Visibility="{Binding IsSaving, Converter={StaticResource BoolToVisibilityConverter}}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Style="{StaticResource LeftSideLabelStyle}" Text="APY" />
                            <TextBlock
                                Grid.Column="1"
                                FontFamily="{StaticResource Medium}"
                                Foreground="{StaticResource Brush.Text.Secondary}"
                                Cursor="IBeam"
                                MouseLeftButtonDown="OnSavingApyTextMouseLeftButtonDown"
                                Text="{Binding ApyText, StringFormat={}{0}%}"
                                Visibility="{Binding IsEditing, Converter={StaticResource BoolToVisibilityInvertedConverter}}" />
                            <c:MoneyTextBox
                                x:Name="SavingApyTextBox"
                                Grid.Column="1"
                                Style="{StaticResource InlineDetailValueTextBoxStyle}"
                                Text="{Binding ApyText, UpdateSourceTrigger=PropertyChanged}"
                                Visibility="{Binding IsEditing, Converter={StaticResource BoolToVisibilityConverter}}" />
                        </Grid>
                    </StackPanel>

                    <UniformGrid
                        Grid.Row="5"
                        Width="Auto"
                        Height="Auto"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Bottom"
                        Columns="3"
                        Rows="2">
                        <c:BalloonButton Click="OnDisableButtonClick" Style="{StaticResource DisableActionButtonStyle}" />
                        <c:BalloonButton
                            Click="OnEditButtonClick"
                            ToolTip="{Binding EditButtonLabel}">
                            <c:BalloonButton.Style>
                                <Style BasedOn="{StaticResource DetailActionBalloonButtonStyle}" TargetType="{x:Type c:BalloonButton}">
                                    <Setter Property="ButtonIcon" Value="{StaticResource Pen}" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsEditing}" Value="True">
                                            <Setter Property="ButtonIcon" Value="{StaticResource ContentSave}" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </c:BalloonButton.Style>
                        </c:BalloonButton>
                        <c:BalloonButton
                            ButtonIcon="{StaticResource Exchange}"
                            Click="OnTransferButtonClick"
                            HoveredBackground="{StaticResource Brush.Mint}"
                            IsEnabled="{Binding CanTransfer}"
                            Style="{StaticResource DetailActionBalloonButtonStyle}"
                            ToolTip="Transfer funds" />
                        <c:BalloonButton
                            Click="OnHideOrUnhideButtonClick"
                            IsEnabled="{Binding CanHideOrUnhide}"
                            Style="{StaticResource HideActionButtonStyle}" />
                        <c:BalloonButton
                            ButtonIcon="{StaticResource SourceSwitch}"
                            Click="OnBackToSourcesButtonClick"
                            HoveredBackground="{StaticResource Brush.Primary.Hover}"
                            Style="{StaticResource DetailActionBalloonButtonStyle}"
                            ToolTip="Back to sources" />
                        <c:BalloonButton
                            ButtonIcon="{StaticResource CircleMinusSolid}"
                            Click="OnDeleteButtonClick"
                            HoveredBackground="{StaticResource Brush.Danger}"
                            IsEnabled="{Binding CanDelete}"
                            Style="{StaticResource DetailActionBalloonButtonStyle}"
                            ToolTip="Delete source" />
                    </UniformGrid>
                </Grid>
            </Border>

            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="2*" />
                    <RowDefinition Height="16" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Border Style="{StaticResource PanelStyle}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="12" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <TextBlock
                            FontFamily="{StaticResource Bold}"
                            FontSize="14"
                            Foreground="{StaticResource Brush.Text.Primary}"
                            Text="Recent Activity" />
                        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
                            <ItemsControl ItemsSource="{Binding RecentActivities}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border
                                            Margin="0,0,0,10"
                                            Padding="12"
                                            Background="{StaticResource Brush.Background.Hover}"
                                            BorderBrush="{StaticResource Brush.Border.Subtle}"
                                            BorderThickness="1"
                                            CornerRadius="14">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <StackPanel>
                                                    <TextBlock
                                                        FontFamily="{StaticResource Bold}"
                                                        FontSize="12"
                                                        Foreground="{StaticResource Brush.Text.Primary}"
                                                        Text="{Binding Title}" />
                                                    <TextBlock
                                                        Margin="0,4,0,0"
                                                        FontFamily="{StaticResource Medium}"
                                                        FontSize="10"
                                                        Foreground="{StaticResource Brush.Text.Secondary}"
                                                        Text="{Binding Detail}"
                                                        TextWrapping="Wrap" />
                                                    <TextBlock
                                                        Margin="0,6,0,0"
                                                        FontFamily="{StaticResource Medium}"
                                                        FontSize="9"
                                                        Foreground="{StaticResource Brush.Text.Muted}"
                                                        Text="{Binding Date, StringFormat={}{0:MMM d, yyyy}}" />
                                                </StackPanel>
                                                <TextBlock
                                                    Grid.Column="1"
                                                    VerticalAlignment="Center"
                                                    FontFamily="{StaticResource Bold}"
                                                    FontSize="12">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Foreground" Value="{StaticResource Brush.Success}" />
                                                            <Setter Property="Text" Value="{Binding Amount, StringFormat=+${0:N2}}" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsExpense}" Value="True">
                                                                    <Setter Property="Foreground" Value="{StaticResource Brush.Danger}" />
                                                                    <Setter Property="Text" Value="{Binding Amount, StringFormat=-${0:N2}}" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Grid>
                </Border>

                <Border Grid.Row="2" Style="{StaticResource PanelStyle}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="12" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <TextBlock
                            FontFamily="{StaticResource Bold}"
                            FontSize="14"
                            Foreground="{StaticResource Brush.Text.Primary}"
                            Text="Trends" />
                        <c:FadingScrollViewer Grid.Row="2">
                            <ItemsControl ItemsSource="{Binding Trends}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="0,0,0,10">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="52" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="12" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock
                                                VerticalAlignment="Center"
                                                FontFamily="{StaticResource Bold}"
                                                FontSize="11"
                                                Foreground="{StaticResource Brush.Text.Primary}"
                                                Text="{Binding Label}" />
                                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                <ProgressBar
                                                    Height="5"
                                                    Maximum="{Binding ElementName=Root, Path=DataContext.TrendMaximum}"
                                                    Style="{StaticResource RoundedProgressBarStyle}"
                                                    Value="{Binding IncomeAmount}" />
                                                <ProgressBar
                                                    Height="5"
                                                    Margin="0,8,0,0"
                                                    Foreground="{StaticResource Brush.Danger}"
                                                    Maximum="{Binding ElementName=Root, Path=DataContext.TrendMaximum}"
                                                    Style="{StaticResource RoundedProgressBarStyle}"
                                                    Value="{Binding ExpenseAmount}" />
                                            </StackPanel>
                                            <StackPanel Grid.Column="3">
                                                <TextBlock
                                                    HorizontalAlignment="Right"
                                                    FontFamily="{StaticResource Medium}"
                                                    FontSize="10"
                                                    Foreground="{StaticResource Brush.Success}"
                                                    Text="{Binding IncomeAmount, StringFormat=+${0:N0}}" />
                                                <TextBlock
                                                    Margin="0,6,0,0"
                                                    HorizontalAlignment="Right"
                                                    FontFamily="{StaticResource Medium}"
                                                    FontSize="10"
                                                    Foreground="{StaticResource Brush.Danger}"
                                                    Text="{Binding ExpenseAmount, StringFormat=-${0:N0}}" />
                                            </StackPanel>
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </c:FadingScrollViewer>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</c:BasePopup>


