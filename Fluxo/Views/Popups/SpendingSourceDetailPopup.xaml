<customControls:BasePopup
    x:Class="Fluxo.Views.Popups.SpendingSourceDetailPopup"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:components="clr-namespace:Fluxo.Views.Components"
    xmlns:customControls="clr-namespace:Fluxo.Views.CustomControls"
    x:Name="Root"
    Width="1080"
    MaxHeight="800"
    PopupTitle="Income Detail">

    <customControls:BasePopup.Resources>
        <Style x:Key="PanelStyle" TargetType="Border">
            <Setter Property="Padding" Value="18" />
            <Setter Property="Background" Value="{StaticResource Brush.Background.Surface}" />
            <Setter Property="BorderBrush" Value="{StaticResource Brush.Border.Subtle}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="18" />
        </Style>

        <Style x:Key="LeftSideLabelStyle" TargetType="TextBlock">
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="FontFamily" Value="{StaticResource Bold}" />
            <Setter Property="Foreground" Value="{StaticResource Brush.Text.Primary}" />
        </Style>

        <Style x:Key="InlineHeaderTextBoxBaseStyle" TargetType="TextBox">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="CaretBrush" Value="{StaticResource Brush.Text.Primary}" />
            <Setter Property="Foreground" Value="{StaticResource Brush.Text.Primary}" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <ScrollViewer x:Name="PART_ContentHost" Margin="0" />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style
            x:Key="InlineDetailValueTextBoxStyle"
            BasedOn="{StaticResource InlineHeaderTextBoxBaseStyle}"
            TargetType="TextBox">
            <Setter Property="FontFamily" Value="{StaticResource Medium}" />
            <Setter Property="Foreground" Value="{StaticResource Brush.Text.Secondary}" />
            <Setter Property="HorizontalContentAlignment" Value="Right" />
            <Setter Property="TextAlignment" Value="Right" />
            <Setter Property="MinWidth" Value="24" />
        </Style>

        <DataTemplate x:Key="SpendingSourceRecentActivityItemTemplate">
            <Border
                Margin="0,0,0,10"
                Padding="12"
                Background="{StaticResource Brush.Background.Hover}"
                BorderBrush="{StaticResource Brush.Border.Subtle}"
                BorderThickness="1"
                CornerRadius="14">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock
                            FontFamily="{StaticResource Bold}"
                            FontSize="12"
                            Foreground="{StaticResource Brush.Text.Primary}"
                            Text="{Binding Title}" />
                        <TextBlock
                            Margin="0,4,0,0"
                            FontFamily="{StaticResource Medium}"
                            FontSize="10"
                            Foreground="{StaticResource Brush.Text.Secondary}"
                            Text="{Binding Detail}"
                            TextWrapping="Wrap" />
                        <TextBlock
                            Margin="0,6,0,0"
                            FontFamily="{StaticResource Medium}"
                            FontSize="9"
                            Foreground="{StaticResource Brush.Text.Muted}"
                            Text="{Binding Date, StringFormat={}{0:MMM d, yyyy}}" />
                    </StackPanel>
                    <TextBlock
                        Grid.Column="1"
                        VerticalAlignment="Center"
                        FontFamily="{StaticResource Bold}"
                        FontSize="12">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Foreground" Value="{StaticResource Brush.Success}" />
                                <Setter Property="Text" Value="{Binding Amount, Converter={StaticResource NumberWithCommasConverter}, StringFormat=+{0}}" />
                                <Setter Property="ToolTip" Value="{Binding Amount, Converter={StaticResource MoneyFullDisplayConverter}, StringFormat=+{0}}" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsExpense}" Value="True">
                                        <Setter Property="Foreground" Value="{StaticResource Brush.Danger}" />
                                        <Setter Property="Text" Value="{Binding Amount, Converter={StaticResource NumberWithCommasConverter}, StringFormat=-{0}}" />
                                        <Setter Property="ToolTip" Value="{Binding Amount, Converter={StaticResource MoneyFullDisplayConverter}, StringFormat=-{0}}" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </Grid>
            </Border>
        </DataTemplate>

        <DataTemplate x:Key="SpendingSourceTrendItemTemplate">
            <Grid Margin="0,0,0,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="52" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="12" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock
                    VerticalAlignment="Center"
                    FontFamily="{StaticResource Bold}"
                    FontSize="11"
                    Foreground="{StaticResource Brush.Text.Primary}"
                    Text="{Binding Label}" />
                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                    <ProgressBar
                        Height="5"
                        Maximum="{Binding ElementName=Root, Path=DataContext.TrendMaximum}"
                        Style="{StaticResource RoundedProgressBarStyle}"
                        Value="{Binding IncomeAmount, Mode=OneWay}" />
                    <ProgressBar
                        Height="5"
                        Margin="0,8,0,0"
                        Foreground="{StaticResource Brush.Danger}"
                        Maximum="{Binding ElementName=Root, Path=DataContext.TrendMaximum}"
                        Style="{StaticResource RoundedProgressBarStyle}"
                        Value="{Binding ExpenseAmount, Mode=OneWay}" />
                </StackPanel>
                <StackPanel Grid.Column="3">
                    <TextBlock
                        HorizontalAlignment="Right"
                        FontFamily="{StaticResource Medium}"
                        FontSize="10"
                        Foreground="{StaticResource Brush.Success}"
                        Text="{Binding IncomeAmount, Converter={StaticResource NumberWithCommasConverter}, StringFormat=+{0}}"
                        ToolTip="{Binding IncomeAmount, Converter={StaticResource MoneyFullDisplayConverter}, StringFormat=+{0}}" />
                    <TextBlock
                        Margin="0,6,0,0"
                        HorizontalAlignment="Right"
                        FontFamily="{StaticResource Medium}"
                        FontSize="10"
                        Foreground="{StaticResource Brush.Danger}"
                        Text="{Binding ExpenseAmount, Converter={StaticResource NumberWithCommasConverter}, StringFormat=-{0}}"
                        ToolTip="{Binding ExpenseAmount, Converter={StaticResource MoneyFullDisplayConverter}, StringFormat=-{0}}" />
                </StackPanel>
            </Grid>
        </DataTemplate>
    </customControls:BasePopup.Resources>

    <Grid MaxHeight="600" Margin="24,0,24,24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="16" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Style="{StaticResource PanelStyle}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="16" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <Border
                    Width="56"
                    Height="56"
                    Background="{StaticResource Brush.Background.Hover}"
                    CornerRadius="28">
                    <components:Icon Margin="14" Path="{StaticResource SpendingSourceDetailPopup.Bank}" Color="{StaticResource Brush.Mint}" />
                </Border>

                <StackPanel Grid.Column="2" VerticalAlignment="Center">
                    <TextBlock
                        FontFamily="{StaticResource Medium}"
                        FontSize="11"
                        Foreground="{StaticResource Brush.Text.Muted}"
                        Text="{Binding SpendingSourceType}" />
                    <TextBlock
                        FontFamily="{StaticResource Bold}"
                        FontSize="22"
                        Foreground="{StaticResource Brush.Text.Primary}"
                        Cursor="IBeam"
                        MouseLeftButtonDown="OnHeaderNameTextMouseLeftButtonDown"
                        Text="{Binding NameText}"
                        Visibility="{Binding IsEditing, Converter={StaticResource BoolToVisibilityInvertedConverter}}" />
                    <TextBox
                        x:Name="NameTextBox"
                        MinWidth="24"
                        FontFamily="{StaticResource Bold}"
                        FontSize="22"
                        Style="{StaticResource InlineHeaderTextBoxBaseStyle}"
                        Text="{Binding NameText, UpdateSourceTrigger=PropertyChanged}"
                        Visibility="{Binding IsEditing, Converter={StaticResource BoolToVisibilityConverter}}" />
                </StackPanel>

                <StackPanel Grid.Column="3" VerticalAlignment="Center">
                    <TextBlock
                        HorizontalAlignment="Right"
                        FontFamily="{StaticResource Medium}"
                        FontSize="10"
                        Foreground="{StaticResource Brush.Text.Muted}"
                        Text="{Binding PrimaryAmountLabel}" />
                    <TextBlock
                        Margin="0,6,0,0"
                        HorizontalAlignment="Right"
                        FontFamily="{StaticResource Bold}"
                        FontSize="26"
                        Foreground="{StaticResource Brush.Text.Primary}"
                        Cursor="IBeam"
                        MouseLeftButtonDown="OnHeaderAmountTextMouseLeftButtonDown"
                        ToolTip="{Binding DisplayPrimaryAmount, Mode=OneWay, Converter={StaticResource MoneyFullDisplayConverter}}"
                        Visibility="{Binding IsEditing, Converter={StaticResource BoolToVisibilityInvertedConverter}}">
                        <Run Text="{Binding DisplayPrimaryAmount, Mode=OneWay, Converter={StaticResource NumberWithCommasConverter}}" />
                    </TextBlock>
                    <StackPanel
                        Margin="0,6,0,0"
                        HorizontalAlignment="Right"
                        Orientation="Horizontal"
                        Visibility="{Binding IsEditing, Converter={StaticResource BoolToVisibilityConverter}}">
                        <customControls:MoneyTextBox
                            x:Name="PrimaryAmountTextBox"
                            MinWidth="24"
                            FontFamily="{StaticResource Bold}"
                            FontSize="26"
                            HorizontalContentAlignment="Right"
                            Style="{StaticResource InlineHeaderTextBoxBaseStyle}"
                            TextAlignment="Right"
                            Text="{Binding PrimaryAmountText, UpdateSourceTrigger=PropertyChanged, Converter={StaticResource MoneyAmountToCanonicalConverter}}" />
                    </StackPanel>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="320" />
                <ColumnDefinition Width="16" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Style="{StaticResource PanelStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="16" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="16" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Button
                        Content="Generate Report"
                        IsEnabled="False"
                        Style="{StaticResource PopupTextButtonStyle}" />

                    <StackPanel Grid.Row="2">
                        <Grid Margin="0,0,0,10" Visibility="{Binding IsCashOrChecking, Converter={StaticResource BoolToVisibilityConverter}}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Style="{StaticResource LeftSideLabelStyle}" Text="Inflow" />
                            <TextBlock
                                Grid.Column="1"
                                FontFamily="{StaticResource Medium}"
                                Foreground="{StaticResource Brush.Text.Secondary}"
                                ToolTip="{Binding MoneyIn, Converter={StaticResource MoneyFullDisplayConverter}}">
                                <Run Text="{Binding MoneyIn, Converter={StaticResource NumberWithCommasConverter}}" />
                            </TextBlock>
                        </Grid>
                        <Grid Margin="0,0,0,10" Visibility="{Binding IsCashOrChecking, Converter={StaticResource BoolToVisibilityConverter}}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Style="{StaticResource LeftSideLabelStyle}" Text="Outflow" />
                            <TextBlock
                                Grid.Column="1"
                                FontFamily="{StaticResource Medium}"
                                Foreground="{StaticResource Brush.Text.Secondary}"
                                ToolTip="{Binding MoneyOut, Converter={StaticResource MoneyFullDisplayConverter}}">
                                <Run Text="{Binding MoneyOut, Converter={StaticResource NumberWithCommasConverter}}" />
                            </TextBlock>
                        </Grid>
                        <Grid Margin="0,0,0,10" Visibility="{Binding IsCredit, Converter={StaticResource BoolToVisibilityConverter}}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Style="{StaticResource LeftSideLabelStyle}" Text="Spent" />
                            <TextBlock
                                Grid.Column="1"
                                FontFamily="{StaticResource Medium}"
                                Foreground="{StaticResource Brush.Text.Secondary}"
                                Cursor="IBeam"
                                MouseLeftButtonDown="OnCreditSpentTextMouseLeftButtonDown"
                                ToolTip="{Binding SpentAmountText, Converter={StaticResource MoneyFullDisplayConverter}}"
                                Visibility="{Binding IsEditing, Converter={StaticResource BoolToVisibilityInvertedConverter}}">
                                <Run Text="{Binding SpentAmountText, Converter={StaticResource MoneyDisplayConverter}}" />
                            </TextBlock>
                            <customControls:MoneyTextBox
                                x:Name="CreditSpentAmountTextBox"
                                Grid.Column="1"
                                Style="{StaticResource InlineDetailValueTextBoxStyle}"
                                Text="{Binding SpentAmountText, UpdateSourceTrigger=PropertyChanged, Converter={StaticResource MoneyAmountToCanonicalConverter}}"
                                Visibility="{Binding IsEditing, Converter={StaticResource BoolToVisibilityConverter}}" />
                        </Grid>
                        <Grid Margin="0,0,0,10" Visibility="{Binding IsCredit, Converter={StaticResource BoolToVisibilityConverter}}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Style="{StaticResource LeftSideLabelStyle}" Text="Limit" />
                            <TextBlock
                                Grid.Column="1"
                                FontFamily="{StaticResource Medium}"
                                Foreground="{StaticResource Brush.Text.Secondary}"
                                Cursor="IBeam"
                                MouseLeftButtonDown="OnCreditLimitTextMouseLeftButtonDown"
                                ToolTip="{Binding AccountLimitText, Converter={StaticResource MoneyFullDisplayConverter}}"
                                Visibility="{Binding IsEditing, Converter={StaticResource BoolToVisibilityInvertedConverter}}">
                                <Run Text="{Binding AccountLimitText, Converter={StaticResource MoneyDisplayConverter}}" />
                            </TextBlock>
                            <customControls:MoneyTextBox
                                x:Name="CreditLimitTextBox"
                                Grid.Column="1"
                                Style="{StaticResource InlineDetailValueTextBoxStyle}"
                                Text="{Binding AccountLimitText, UpdateSourceTrigger=PropertyChanged, Converter={StaticResource MoneyAmountToCanonicalConverter}}"
                                Visibility="{Binding IsEditing, Converter={StaticResource BoolToVisibilityConverter}}" />
                        </Grid>
                        <Grid Margin="0,0,0,10" Visibility="{Binding IsCredit, Converter={StaticResource BoolToVisibilityConverter}}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Style="{StaticResource LeftSideLabelStyle}" Text="Due Date" />
                            <TextBlock
                                Grid.Column="1"
                                FontFamily="{StaticResource Medium}"
                                Foreground="{StaticResource Brush.Text.Secondary}"
                                Text="{Binding MonthlyDueDateDisplay}"
                                Visibility="{Binding IsEditing, Converter={StaticResource BoolToVisibilityInvertedConverter}}" />
                            <TextBox
                                x:Name="CreditMonthlyDueDateTextBox"
                                Grid.Column="1"
                                Width="64"
                                HorizontalAlignment="Right"
                                MaxLength="2"
                                PreviewKeyDown="OnMonthlyDueDatePreviewKeyDown"
                                PreviewTextInput="OnMonthlyDueDatePreviewTextInput"
                                Style="{StaticResource InlineDetailValueTextBoxStyle}"
                                Text="{Binding MonthlyDueDateText, UpdateSourceTrigger=PropertyChanged}"
                                ToolTip="Enter a day between 1 and 28"
                                Visibility="{Binding IsEditing, Converter={StaticResource BoolToVisibilityConverter}}"
                                DataObject.Pasting="OnMonthlyDueDatePasting" />
                        </Grid>
                        <Grid Margin="0,0,0,10" Visibility="{Binding IsCredit, Converter={StaticResource BoolToVisibilityConverter}}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Style="{StaticResource LeftSideLabelStyle}" Text="Deduct Source" />
                            <TextBlock
                                Grid.Column="1"
                                FontFamily="{StaticResource Medium}"
                                Foreground="{StaticResource Brush.Text.Secondary}"
                                Text="{Binding DeductSourceDisplay}"
                                Visibility="{Binding IsEditing, Converter={StaticResource BoolToVisibilityInvertedConverter}}" />
                            <ComboBox
                                Grid.Column="1"
                                Width="160"
                                DisplayMemberPath="Name"
                                ItemsSource="{Binding DeductSources}"
                                SelectedValue="{Binding SelectedDeductSource, Mode=TwoWay}"
                                SelectedValuePath="Id"
                                Style="{StaticResource FluxoComboBoxStyle}"
                                Visibility="{Binding IsEditing, Converter={StaticResource BoolToVisibilityConverter}}" />
                        </Grid>
                        <Grid Margin="0,0,0,10" Visibility="{Binding IsBnpl, Converter={StaticResource BoolToVisibilityConverter}}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Style="{StaticResource LeftSideLabelStyle}" Text="Spend" />
                            <TextBlock
                                Grid.Column="1"
                                FontFamily="{StaticResource Medium}"
                                Foreground="{StaticResource Brush.Text.Secondary}"
                                Cursor="IBeam"
                                MouseLeftButtonDown="OnBnplSpentTextMouseLeftButtonDown"
                                ToolTip="{Binding SpentAmountText, Converter={StaticResource MoneyFullDisplayConverter}}"
                                Visibility="{Binding IsEditing, Converter={StaticResource BoolToVisibilityInvertedConverter}}">
                                <Run Text="{Binding SpentAmountText, Converter={StaticResource MoneyDisplayConverter}}" />
                            </TextBlock>
                            <customControls:MoneyTextBox
                                x:Name="BnplSpentAmountTextBox"
                                Grid.Column="1"
                                Style="{StaticResource InlineDetailValueTextBoxStyle}"
                                Text="{Binding SpentAmountText, UpdateSourceTrigger=PropertyChanged, Converter={StaticResource MoneyAmountToCanonicalConverter}}"
                                Visibility="{Binding IsEditing, Converter={StaticResource BoolToVisibilityConverter}}" />
                        </Grid>
                        <Grid Margin="0,0,0,10" Visibility="{Binding IsBnpl, Converter={StaticResource BoolToVisibilityConverter}}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Style="{StaticResource LeftSideLabelStyle}" Text="Due Date" />
                            <TextBlock
                                Grid.Column="1"
                                FontFamily="{StaticResource Medium}"
                                Foreground="{StaticResource Brush.Text.Secondary}"
                                Text="{Binding MonthlyDueDateDisplay}"
                                Visibility="{Binding IsEditing, Converter={StaticResource BoolToVisibilityInvertedConverter}}" />
                            <TextBox
                                x:Name="BnplMonthlyDueDateTextBox"
                                Grid.Column="1"
                                Width="64"
                                HorizontalAlignment="Right"
                                MaxLength="2"
                                PreviewKeyDown="OnMonthlyDueDatePreviewKeyDown"
                                PreviewTextInput="OnMonthlyDueDatePreviewTextInput"
                                Style="{StaticResource InlineDetailValueTextBoxStyle}"
                                Text="{Binding MonthlyDueDateText, UpdateSourceTrigger=PropertyChanged}"
                                ToolTip="Enter a day between 1 and 28"
                                Visibility="{Binding IsEditing, Converter={StaticResource BoolToVisibilityConverter}}"
                                DataObject.Pasting="OnMonthlyDueDatePasting" />
                        </Grid>
                        <Grid Margin="0,0,0,10" Visibility="{Binding IsBnpl, Converter={StaticResource BoolToVisibilityConverter}}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Style="{StaticResource LeftSideLabelStyle}" Text="Deduct Source" />
                            <TextBlock
                                Grid.Column="1"
                                FontFamily="{StaticResource Medium}"
                                Foreground="{StaticResource Brush.Text.Secondary}"
                                Text="{Binding DeductSourceDisplay}"
                                Visibility="{Binding IsEditing, Converter={StaticResource BoolToVisibilityInvertedConverter}}" />
                            <ComboBox
                                Grid.Column="1"
                                Width="160"
                                DisplayMemberPath="Name"
                                ItemsSource="{Binding DeductSources}"
                                SelectedValue="{Binding SelectedDeductSource, Mode=TwoWay}"
                                SelectedValuePath="Id"
                                Style="{StaticResource FluxoComboBoxStyle}"
                                Visibility="{Binding IsEditing, Converter={StaticResource BoolToVisibilityConverter}}" />
                        </Grid>
                        <Grid Margin="0,0,0,10" Visibility="{Binding IsSaving, Converter={StaticResource BoolToVisibilityConverter}}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Style="{StaticResource LeftSideLabelStyle}" Text="Balance" />
                            <TextBlock
                                Grid.Column="1"
                                FontFamily="{StaticResource Medium}"
                                Foreground="{StaticResource Brush.Text.Secondary}"
                                ToolTip="{Binding DisplayPrimaryAmount, Mode=OneWay, Converter={StaticResource MoneyFullDisplayConverter}}">
                                <Run Text="{Binding DisplayPrimaryAmount, Mode=OneWay, Converter={StaticResource NumberWithCommasConverter}}" />
                            </TextBlock>
                        </Grid>
                        <Grid Margin="0,0,0,10" Visibility="{Binding IsSaving, Converter={StaticResource BoolToVisibilityConverter}}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Style="{StaticResource LeftSideLabelStyle}" Text="APY" />
                            <TextBlock
                                Grid.Column="1"
                                FontFamily="{StaticResource Medium}"
                                Foreground="{StaticResource Brush.Text.Secondary}"
                                Cursor="IBeam"
                                MouseLeftButtonDown="OnSavingApyTextMouseLeftButtonDown"
                                Text="{Binding ApyText, StringFormat={}{0}%}"
                                Visibility="{Binding IsEditing, Converter={StaticResource BoolToVisibilityInvertedConverter}}" />
                            <customControls:MoneyTextBox
                                x:Name="SavingApyTextBox"
                                Grid.Column="1"
                                Style="{StaticResource InlineDetailValueTextBoxStyle}"
                                Text="{Binding ApyText, UpdateSourceTrigger=PropertyChanged, Converter={StaticResource MoneyAmountToCanonicalConverter}}"
                                Visibility="{Binding IsEditing, Converter={StaticResource BoolToVisibilityConverter}}" />
                        </Grid>
                    </StackPanel>

                    <UniformGrid
                        Grid.Row="5"
                        Width="Auto"
                        Height="Auto"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Bottom"
                        Columns="3"
                        Rows="2">
                        <customControls:BalloonButton Click="OnDisableButtonClick">
                            <customControls:BalloonButton.Style>
                                <Style BasedOn="{StaticResource DetailActionBalloonButtonStyle}" TargetType="{x:Type customControls:BalloonButton}">
                                    <Setter Property="ButtonIcon" Value="{StaticResource ButtonStyles.LightningSlashFill}" />
                                    <Setter Property="HoveredBackground" Value="{StaticResource Brush.Warning}" />
                                    <Setter Property="ToolTip" Value="Disable source" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsEnabled}" Value="False">
                                            <Setter Property="ButtonIcon" Value="{StaticResource ButtonStyles.LightningFill}" />
                                            <Setter Property="ToolTip" Value="Enable source" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </customControls:BalloonButton.Style>
                        </customControls:BalloonButton>
                        <customControls:BalloonButton
                            Click="OnEditButtonClick"
                            ToolTip="{Binding EditButtonLabel}">
                            <customControls:BalloonButton.Style>
                                <Style BasedOn="{StaticResource DetailActionBalloonButtonStyle}" TargetType="{x:Type customControls:BalloonButton}">
                                    <Setter Property="ButtonIcon" Value="{StaticResource SpendingSourceDetailPopup.Pen}" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsEditing}" Value="True">
                                            <Setter Property="ButtonIcon" Value="{StaticResource SpendingSourceDetailPopup.ContentSave}" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </customControls:BalloonButton.Style>
                        </customControls:BalloonButton>
                        <customControls:BalloonButton
                            ButtonIcon="{StaticResource SpendingSourceDetailPopup.Exchange}"
                            Click="OnTransferButtonClick"
                            HoveredBackground="{StaticResource Brush.Mint}"
                            IsEnabled="{Binding CanTransfer}"
                            Style="{StaticResource DetailActionBalloonButtonStyle}"
                            ToolTip="Transfer funds" />
                        <customControls:BalloonButton
                            Click="OnHideOrUnhideButtonClick"
                            IsEnabled="{Binding CanHideOrUnhide}">
                            <customControls:BalloonButton.Style>
                                <Style BasedOn="{StaticResource DetailActionBalloonButtonStyle}" TargetType="{x:Type customControls:BalloonButton}">
                                    <Setter Property="ButtonIcon" Value="{StaticResource ButtonStyles.EyeOff}" />
                                    <Setter Property="HoveredBackground" Value="{StaticResource Brush.Primary.Hover}" />
                                    <Setter Property="ToolTip" Value="Hide source" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsHidden}" Value="True">
                                            <Setter Property="ButtonIcon" Value="{StaticResource ButtonStyles.Eye}" />
                                            <Setter Property="ToolTip" Value="Unhide source" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </customControls:BalloonButton.Style>
                        </customControls:BalloonButton>
                        <customControls:BalloonButton
                            ButtonIcon="{StaticResource SpendingSourceDetailPopup.SourceSwitch}"
                            Click="OnBackToSourcesButtonClick"
                            HoveredBackground="{StaticResource Brush.Primary.Hover}"
                            Style="{StaticResource DetailActionBalloonButtonStyle}"
                            ToolTip="Back to sources" />
                        <customControls:BalloonButton
                            ButtonIcon="{StaticResource SpendingSourceDetailPopup.CircleMinusSolid}"
                            Click="OnDeleteButtonClick"
                            HoveredBackground="{StaticResource Brush.Danger}"
                            IsEnabled="{Binding CanDelete}"
                            Style="{StaticResource DetailActionBalloonButtonStyle}"
                            ToolTip="Delete source" />
                    </UniformGrid>
                </Grid>
            </Border>

            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="2*" />
                    <RowDefinition Height="16" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Border Style="{StaticResource PanelStyle}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="12" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <TextBlock
                            FontFamily="{StaticResource Bold}"
                            FontSize="14"
                            Foreground="{StaticResource Brush.Text.Primary}"
                            Text="Recent Activity" />
                        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
                            <ItemsControl
                                ItemTemplate="{StaticResource SpendingSourceRecentActivityItemTemplate}"
                                ItemsSource="{Binding RecentActivities}" />
                        </ScrollViewer>
                    </Grid>
                </Border>

                <Border Grid.Row="2" Style="{StaticResource PanelStyle}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="12" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <TextBlock
                            FontFamily="{StaticResource Bold}"
                            FontSize="14"
                            Foreground="{StaticResource Brush.Text.Primary}"
                            Text="Trends" />
                        <customControls:FadingScrollViewer Grid.Row="2">
                            <ItemsControl ItemTemplate="{StaticResource SpendingSourceTrendItemTemplate}" ItemsSource="{Binding Trends}" />
                        </customControls:FadingScrollViewer>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</customControls:BasePopup>



