<customControls:BasePopup
    x:Class="Fluxo.Views.Popups.TransactionDetailPopup"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:components="clr-namespace:Fluxo.Resources.Components;assembly=Fluxo.Resources"
    xmlns:customControls="clr-namespace:Fluxo.Resources.CustomControls;assembly=Fluxo.Resources"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    IsSplitButtonChecked="{Binding IsSplitMode, Mode=TwoWay}"
    PopupTitle="Transaction Detail"
    ShowCloneButton="True"
    ShowDeleteButton="True"
    ShowEditButton="True"
    ShowSplitButton="{Binding ShowSplitButton, Mode=OneWay}"
    mc:Ignorable="d">

    <customControls:BasePopup.Resources>
        <Style x:Key="SectionLabelStyle" TargetType="TextBlock">
            <Setter Property="Margin" Value="0,0,0,8" />
            <Setter Property="FontFamily" Value="{DynamicResource Bold}" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="Foreground" Value="{DynamicResource Brush.Text.Muted}" />
        </Style>

        <Style x:Key="FieldHeaderGridStyle" TargetType="Grid">
            <Setter Property="Margin" Value="0,0,0,8" />
        </Style>

        <Style x:Key="FieldValidationHintStyle" TargetType="TextBlock">
            <Setter Property="HorizontalAlignment" Value="Right" />
            <Setter Property="FontFamily" Value="{DynamicResource Bold}" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="Foreground" Value="{DynamicResource Brush.Danger}" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
        </Style>

        <Style x:Key="PopupFieldBorderStyle" TargetType="Border">
            <Setter Property="Padding" Value="12" />
            <Setter Property="Background" Value="{DynamicResource Brush.Background.Elevated}" />
            <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border.Subtle}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="12" />
        </Style>

        <Style x:Key="PopupTagListBoxStyle" TargetType="ListBox">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled" />
            <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Disabled" />
        </Style>

        <Style x:Key="PopupTagListBoxItemStyle" TargetType="ListBoxItem">
            <Setter Property="Margin" Value="0,0,8,0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <ContentPresenter />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style
            x:Key="PopupOtherTagListBoxItemStyle"
            BasedOn="{StaticResource PopupTagListBoxItemStyle}"
            TargetType="ListBoxItem">
            <Setter Property="Margin" Value="0,0,8,8" />
        </Style>

        <DataTemplate x:Key="PopupTagTemplate">
            <ToggleButton
                Content="{Binding Name}"
                IsChecked="{Binding RelativeSource={RelativeSource AncestorType=ListBoxItem}, Path=IsSelected}"
                Style="{StaticResource PopupTagItemToggleStyle}" />
        </DataTemplate>

        <ItemsPanelTemplate x:Key="PopupVisibleTagsItemsPanelTemplate">
            <StackPanel Orientation="Horizontal" />
        </ItemsPanelTemplate>

        <ItemsPanelTemplate x:Key="PopupOverflowTagsItemsPanelTemplate">
            <WrapPanel />
        </ItemsPanelTemplate>

        <Style x:Key="SplitRowTagPopupListBoxStyle" TargetType="ListBox">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled" />
            <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Auto" />
            <Setter Property="MaxHeight" Value="220" />
        </Style>

        <Style x:Key="SplitRowTagPopupItemStyle" TargetType="ListBoxItem">
            <Setter Property="Margin" Value="0,0,0,8" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <ContentPresenter />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SplitParentAmountHighlightBorderStyle" TargetType="Border">
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="CornerRadius" Value="12" />
            <Style.Triggers>
                <MultiDataTrigger>
                    <MultiDataTrigger.Conditions>
                        <Condition Binding="{Binding IsSplitMode}" Value="True" />
                        <Condition Binding="{Binding HasNegativeSplitRemainder}" Value="True" />
                    </MultiDataTrigger.Conditions>
                    <Setter Property="BorderBrush" Value="{DynamicResource Brush.Danger}" />
                    <Setter Property="BorderThickness" Value="1" />
                </MultiDataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="SplitRowTagToggleStyle" TargetType="ToggleButton">
            <Setter Property="Height" Value="28" />
            <Setter Property="Padding" Value="12,0" />
            <Setter Property="Background" Value="{DynamicResource Brush.Background.Surface}" />
            <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border.Subtle}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Foreground" Value="{DynamicResource Brush.Text.Primary}" />
            <Setter Property="FontFamily" Value="{DynamicResource Bold}" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border
                            Padding="{TemplateBinding Padding}"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="14">
                            <StackPanel Orientation="Horizontal">
                                <Ellipse
                                    x:Name="ColorDot"
                                    Width="6"
                                    Height="6"
                                    VerticalAlignment="Center"
                                    Fill="{Binding RelativeSource={RelativeSource AncestorType=ToggleButton}, Path=Tag}" />
                                <TextBlock
                                    Margin="6,0,0,0"
                                    VerticalAlignment="Center"
                                    FontFamily="{TemplateBinding FontFamily}"
                                    FontSize="{TemplateBinding FontSize}"
                                    Text="{TemplateBinding Content}"
                                    TextTrimming="CharacterEllipsis">
                                    <TextBlock.Foreground>
                                        <MultiBinding Converter="{StaticResource ForegroundForBackgroundBrushConverter}">
                                            <Binding Path="Background" RelativeSource="{RelativeSource TemplatedParent}" />
                                            <Binding Path="Foreground" RelativeSource="{RelativeSource TemplatedParent}" />
                                        </MultiBinding>
                                    </TextBlock.Foreground>
                                </TextBlock>
                            </StackPanel>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource Brush.Background.Hover}" />
                </Trigger>
                <Trigger Property="IsChecked" Value="True">
                    <Setter Property="Background" Value="{Binding RelativeSource={RelativeSource Self}, Path=Tag}" />
                    <Setter Property="BorderThickness" Value="0" />
                    <Setter Property="Foreground" Value="{DynamicResource Brush.Background.Surface}" />
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Opacity" Value="0.4" />
                    <Setter Property="Cursor" Value="Arrow" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <DataTemplate x:Key="ChildTransactionItemTemplate">
            <Border
                Margin="0,0,0,10"
                Padding="10"
                Background="{DynamicResource Brush.Background.Surface}"
                BorderBrush="{DynamicResource Brush.Border.Subtle}"
                BorderThickness="1"
                CornerRadius="8">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock
                            FontFamily="{DynamicResource Bold}"
                            FontSize="12"
                            Foreground="{DynamicResource Brush.Text.Primary}"
                            Text="{Binding Name}"
                            TextTrimming="CharacterEllipsis" />
                        <TextBlock
                            Grid.Column="1"
                            Margin="8,0,0,0"
                            FontFamily="{DynamicResource Bold}"
                            FontSize="12"
                            Foreground="{DynamicResource Brush.Danger}"
                            Text="{Binding Amount, StringFormat={}{0:#,##0}}" />
                    </Grid>

                    <TextBlock
                        Grid.Row="1"
                        Margin="0,6,0,0"
                        FontFamily="{DynamicResource Medium}"
                        FontSize="11"
                        Foreground="{DynamicResource Brush.Text.Muted}"
                        Text="{Binding OccurredOn, StringFormat={}{0:MMM d, yyyy}}" />

                    <StackPanel
                        Grid.Row="2"
                        Margin="0,8,0,0"
                        Orientation="Horizontal">
                        <Border
                            MaxWidth="96"
                            Padding="8,2"
                            Background="{Binding TagHexCode}"
                            CornerRadius="8">
                            <TextBlock
                                FontFamily="{DynamicResource Bold}"
                                FontSize="10"
                                Text="{Binding TagName}"
                                TextTrimming="CharacterEllipsis">
                                <TextBlock.Foreground>
                                    <Binding
                                        Converter="{StaticResource ForegroundForBackgroundBrushConverter}"
                                        ConverterParameter="{StaticResource Brush.Text.Primary}"
                                        Path="Background"
                                        RelativeSource="{RelativeSource AncestorType=Border}" />
                                </TextBlock.Foreground>
                            </TextBlock>
                        </Border>
                        <TextBlock
                            Margin="8,2,0,0"
                            FontFamily="{DynamicResource Medium}"
                            FontSize="10"
                            Foreground="{DynamicResource Brush.Text.Muted}"
                            Text="{Binding CategoryLabel}" />
                    </StackPanel>
                    <Path
                        Grid.Row="2"
                        Width="13"
                        Height="13"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Bottom"
                        Data="{StaticResource CreditCardMinusSolid}"
                        Fill="{DynamicResource Brush.Info}"
                        Stretch="Uniform"
                        ToolTip="Lend"
                        Visibility="{Binding IsIoU, Converter={StaticResource BoolToVisibilityConverter}}" />
                </Grid>
            </Border>
        </DataTemplate>
    </customControls:BasePopup.Resources>

    <Border Padding="20,4,20,20">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <StackPanel
                x:Name="NormalTransactionNamePinPanel"
                Grid.Row="0"
                Width="640"
                Visibility="{Binding ShowNormalTransactionFields, Converter={StaticResource BoolToVisibilityConverter}}">
                <Grid Style="{StaticResource FieldHeaderGridStyle}">
                    <TextBlock
                        Margin="0"
                        Style="{StaticResource SectionLabelStyle}"
                        Text="Name" />
                </Grid>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="8" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="8" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBox
                        x:Name="TransactionNameTextBox"
                        IsReadOnly="{Binding AreFieldsReadOnly}"
                        Style="{StaticResource RoundedTextInputStyle}"
                        Text="{Binding NameText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                    <customControls:BalloonCheckBox
                        Grid.Column="2"
                        ButtonSize="38"
                        CornerRadius="12"
                        DefaultBackground="{StaticResource Brush.BalloonButton.Background.Surface}"
                        HoveredBackground="{StaticResource Brush.BalloonButton.Background.Surface.Hovered}"
                        IconSize="14"
                        IsChecked="{Binding IsExcludedFromBudget, Mode=TwoWay}"
                        IsEnabled="{Binding CanEditFields}"
                        ToolTip="Exclude from budget"
                        UncheckedIcon="{StaticResource CreditCardOff}"
                        UncheckedText="Exclude" />
                    <customControls:BalloonCheckBox
                        x:Name="TransactionPinButton"
                        Grid.Column="4"
                        ButtonSize="38"
                        CheckedBackground="{StaticResource Brush.BalloonButton.Background.Surface}"
                        CornerRadius="12"
                        DefaultBackground="{StaticResource Brush.BalloonButton.Background.Surface}"
                        HoveredBackground="{StaticResource Brush.BalloonButton.Background.Surface.Hovered}"
                        IconSize="14"
                        IsChecked="{Binding IsPinned, Mode=TwoWay}"
                        IsEnabled="{Binding CanEditFields}"
                        ToolTip="Pin transaction"
                        UncheckedIcon="{StaticResource Pin}"
                        UncheckedText="Pinned" />
                </Grid>
                <Grid Margin="0,12,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <customControls:BalloonRadioButton
                        CheckedBackground="{StaticResource Brush.Mint}"
                        CornerRadius="8"
                        DefaultBackground="{StaticResource Brush.BalloonButton.Background.Neutral}"
                        GroupName="TransactionDetailMode"
                        HoveredBackground="{StaticResource Brush.BalloonButton.Background.Neutral.Hovered}"
                        IconSize="14"
                        IsChecked="{Binding IsRegularMode, Mode=TwoWay}"
                        IsEnabled="{Binding CanEditFields}"
                        ShouldShowText="True"
                        UncheckedIcon="{StaticResource CreditCardAlt}"
                        UncheckedText="Regular" />
                    <customControls:BalloonRadioButton
                        Grid.Column="1"
                        Margin="8,0,0,0"
                        CheckedBackground="{StaticResource Brush.Mint}"
                        CornerRadius="8"
                        DefaultBackground="{StaticResource Brush.BalloonButton.Background.Neutral}"
                        GroupName="TransactionDetailMode"
                        HoveredBackground="{StaticResource Brush.BalloonButton.Background.Neutral.Hovered}"
                        IconSize="14"
                        IsChecked="{Binding IsUnpostedIoUMode, Mode=TwoWay}"
                        IsEnabled="{Binding CanEditFields}"
                        ShouldShowText="True"
                        UncheckedIcon="{StaticResource CreditCardMinusSolid}"
                        UncheckedText="Unposted Debt/IoU" />
                    <customControls:BalloonRadioButton
                        Grid.Column="2"
                        Margin="8,0,0,0"
                        CheckedBackground="{StaticResource Brush.Mint}"
                        CornerRadius="8"
                        DefaultBackground="{StaticResource Brush.BalloonButton.Background.Neutral}"
                        GroupName="TransactionDetailMode"
                        HoveredBackground="{StaticResource Brush.BalloonButton.Background.Neutral.Hovered}"
                        IconSize="14"
                        IsChecked="{Binding IsPostedIoUMode, Mode=TwoWay}"
                        IsEnabled="{Binding CanEditFields}"
                        ShouldShowText="True"
                        UncheckedIcon="{StaticResource CreditCardMinusSolid}"
                        UncheckedText="Posted Debt/IoU" />
                </Grid>
                <TextBlock
                    Margin="0,8,0,0"
                    FontFamily="{StaticResource Medium}"
                    FontSize="11"
                    Foreground="{StaticResource Brush.Text.Secondary}"
                    Text="{Binding TransactionModeDescription, Mode=OneWay}"
                    TextWrapping="Wrap" />
            </StackPanel>

            <StackPanel
                x:Name="SplitTransactionAmountPanel"
                Grid.Row="0"
                Visibility="{Binding IsSplitMode, Converter={StaticResource BoolToVisibilityConverter}}">
                <Grid Style="{StaticResource FieldHeaderGridStyle}">
                    <TextBlock
                        Margin="0"
                        Style="{StaticResource SectionLabelStyle}"
                        Text="Amount" />
                    <TextBlock
                        Style="{StaticResource FieldValidationHintStyle}"
                        Text="Split amounts exceed the original transaction amount."
                        Visibility="{Binding HasNegativeSplitRemainder, Converter={StaticResource BoolToVisibilityConverter}}" />
                </Grid>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="16" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <Border Style="{StaticResource SplitParentAmountHighlightBorderStyle}">
                        <customControls:MoneyTextBox
                            x:Name="SplitTransactionAmountTextBox"
                            IsReadOnly="{Binding AreFieldsReadOnly}"
                            Style="{StaticResource RoundedMoneyTextInputStyle}"
                            Text="{Binding AmountText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, Converter={StaticResource MoneyAmountToCanonicalConverter}}" />
                    </Border>

                    <customControls:BalloonCheckBox
                        Grid.Column="2"
                        ButtonSize="36"
                        CheckedBackground="{StaticResource Brush.BalloonButton.Background.ConfirmSave}"
                        CheckedIcon="{StaticResource CallSplit}"
                        CheckedText="Split Equally"
                        CornerRadius="8"
                        DefaultBackground="{StaticResource Brush.BalloonButton.Background.Neutral}"
                        HoveredBackground="{StaticResource Brush.BalloonButton.Background.Neutral.Hovered}"
                        IconSize="12"
                        ShouldExpand="True"
                        UncheckedIcon="{StaticResource CallSplit}"
                        UncheckedText="Split Equally" />
                </Grid>
            </StackPanel>

            <Grid Grid.Row="1" Margin="0,16,0,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Grid
                    x:Name="NormalTransactionNameDatePanel"
                    Grid.Row="0"
                    Visibility="{Binding ShowNormalTransactionFields, Converter={StaticResource BoolToVisibilityConverter}}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="8" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <TextBlock Style="{StaticResource SectionLabelStyle}" Text="Amount" />
                        <Border Style="{StaticResource SplitParentAmountHighlightBorderStyle}">
                            <customControls:MoneyTextBox
                                x:Name="TransactionAmountTextBox"
                                IsReadOnly="{Binding AreFieldsReadOnly}"
                                Style="{StaticResource RoundedMoneyTextInputStyle}"
                                Text="{Binding AmountText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, Converter={StaticResource MoneyAmountToCanonicalConverter}}" />
                        </Border>
                    </StackPanel>

                    <StackPanel Grid.Column="2">
                        <TextBlock Style="{StaticResource SectionLabelStyle}" Text="Date" />
                        <components:DateSelector x:Name="TransactionTransactionDateSelector" SelectedDate="{Binding SelectedDate, Mode=TwoWay}" />
                    </StackPanel>
                </Grid>

                <Grid
                    x:Name="NormalTransactionCategorySourcePanel"
                    Grid.Row="1"
                    Margin="0,16,0,0"
                    Visibility="{Binding ShowNormalTransactionFields, Converter={StaticResource BoolToVisibilityConverter}}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="16" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Visibility="{Binding ShowCategoryField, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                        <TextBlock Style="{StaticResource SectionLabelStyle}" Text="Category" />
                        <ComboBox
                            x:Name="TransactionCategoryComboBox"
                            DisplayMemberPath="Label"
                            IsEnabled="{Binding IsCategoryEnabled}"
                            ItemsSource="{Binding ExpenseCategories}"
                            SelectedValue="{Binding SelectedExpenseCategory, Mode=TwoWay}"
                            SelectedValuePath="Value"
                            Style="{StaticResource FluxoComboBoxStyle}" />
                    </StackPanel>

                    <StackPanel>
                        <StackPanel.Style>
                            <Style TargetType="StackPanel">
                                <Setter Property="Grid.Column" Value="2" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding ShouldExpandAccountField, Mode=OneWay}" Value="True">
                                        <Setter Property="Grid.Column" Value="0" />
                                        <Setter Property="Grid.ColumnSpan" Value="3" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </StackPanel.Style>
                        <TextBlock Style="{StaticResource SectionLabelStyle}" Text="Account" />
                        <ComboBox
                            x:Name="TransactionAccountComboBox"
                            DisplayMemberPath="Name"
                            ItemsSource="{Binding AccountsView}"
                            SelectedItem="{Binding SelectedAccount, Mode=TwoWay}"
                            Style="{StaticResource FluxoComboBoxStyle}">
                            <ComboBox.GroupStyle>
                                <GroupStyle HeaderTemplate="{StaticResource AccountComboGroupHeaderTemplate}" />
                            </ComboBox.GroupStyle>
                        </ComboBox>
                    </StackPanel>
                </Grid>

                <StackPanel
                    x:Name="NormalTagsPanel"
                    Grid.Row="2"
                    Margin="0,16,0,0"
                    Visibility="{Binding ShowNormalTransactionFields, Converter={StaticResource BoolToVisibilityConverter}}">
                    <TextBlock Style="{StaticResource SectionLabelStyle}" Text="Tags" />
                    <DockPanel x:Name="TagsDockPanel" LastChildFill="False">
                        <Button
                            x:Name="AddTagButton"
                            Margin="0,0,8,0"
                            Click="OnAddTagClick"
                            Content="+ Add Tag"
                            DockPanel.Dock="Left"
                            Style="{StaticResource PopupTagButtonStyle}"
                            Visibility="{Binding CanEditFields, Converter={StaticResource BoolToVisibilityConverter}}" />

                        <ListBox
                            x:Name="VisibleTagsListBox"
                            DockPanel.Dock="Left"
                            IsHitTestVisible="{Binding CanEditFields}"
                            ItemContainerStyle="{StaticResource PopupTagListBoxItemStyle}"
                            ItemTemplate="{StaticResource PopupTagTemplate}"
                            ItemsPanel="{StaticResource PopupVisibleTagsItemsPanelTemplate}"
                            ItemsSource="{Binding VisibleTags}"
                            SelectedItem="{Binding SelectedTag, Mode=TwoWay}"
                            SelectionChanged="OnTagSelectionChanged"
                            Style="{StaticResource PopupTagListBoxStyle}" />

                        <ToggleButton
                            x:Name="MoreTagsButton"
                            Margin="4,0,0,0"
                            Checked="OnMoreTagsButtonChecked"
                            Content="More"
                            IsChecked="{Binding IsMoreTagsOpen, Mode=TwoWay}"
                            MouseEnter="OnMoreTagsHoverChanged"
                            MouseLeave="OnMoreTagsHoverChanged"
                            Style="{StaticResource PopupTagToggleStyle}"
                            Unchecked="OnMoreTagsButtonUnchecked"
                            Visibility="{Binding HasMoreTags, Converter={StaticResource BoolToVisibilityConverter}}" />
                    </DockPanel>

                    <Popup
                        x:Name="MoreTagsPopup"
                        AllowsTransparency="True"
                        Closed="OnMoreTagsPopupClosed"
                        Placement="Bottom"
                        PlacementTarget="{Binding ElementName=MoreTagsButton}"
                        PopupAnimation="Fade"
                        StaysOpen="True"
                        VerticalOffset="8">
                        <Border
                            x:Name="MoreTagsPopupContent"
                            MaxWidth="360"
                            Padding="12"
                            Background="{DynamicResource Brush.Background.Elevated}"
                            BorderBrush="{DynamicResource Brush.Border.Subtle}"
                            BorderThickness="1"
                            CornerRadius="16"
                            MouseEnter="OnMoreTagsHoverChanged"
                            MouseLeave="OnMoreTagsHoverChanged">
                            <StackPanel>
                                <TextBlock
                                    Margin="0,0,0,10"
                                    FontFamily="{DynamicResource Bold}"
                                    FontSize="12"
                                    Foreground="{DynamicResource Brush.Text.Primary}"
                                    Text="More Tags" />
                                <ListBox
                                    x:Name="MoreTagsListBox"
                                    IsHitTestVisible="{Binding CanEditFields}"
                                    ItemContainerStyle="{StaticResource PopupOtherTagListBoxItemStyle}"
                                    ItemTemplate="{StaticResource PopupTagTemplate}"
                                    ItemsPanel="{StaticResource PopupOverflowTagsItemsPanelTemplate}"
                                    ItemsSource="{Binding OverflowTags}"
                                    SelectedItem="{Binding SelectedTag, Mode=TwoWay}"
                                    SelectionChanged="OnTagSelectionChanged"
                                    Style="{StaticResource PopupTagListBoxStyle}" />
                            </StackPanel>
                        </Border>
                    </Popup>
                </StackPanel>

                <Border
                    x:Name="SplitRowsPanel"
                    Grid.Row="3"
                    MinWidth="800"
                    Margin="0,16,0,0"
                    Padding="12"
                    Background="{DynamicResource Brush.Background.Surface}"
                    BorderBrush="{DynamicResource Brush.Border.Subtle}"
                    BorderThickness="1"
                    CornerRadius="12"
                    Visibility="{Binding IsSplitMode, Converter={StaticResource BoolToVisibilityConverter}}">
                    <StackPanel Grid.IsSharedSizeScope="True">
                        <Button
                            Click="OnAddSplitRowClick"
                            Content="Add Sub-transaction"
                            Style="{StaticResource PopupTagButtonStyle}" />

                        <Border
                            Height="0.5"
                            Margin="4,16"
                            Background="{StaticResource Brush.Text.Muted}"
                            Opacity="0.5"
                            SnapsToDevicePixels="True" />

                        <customControls:FadingScrollViewer
                            MaxHeight="330"
                            Margin="0"
                            HorizontalScrollBarVisibility="Auto">
                            <ItemsControl x:Name="SplitRowsItemsControl" ItemsSource="{Binding SplitRows}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel>
                                            <Grid Margin="0,12">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="240" />
                                                    <ColumnDefinition Width="160" />
                                                    <ColumnDefinition Width="Auto" SharedSizeGroup="SplitCategory" />
                                                    <ColumnDefinition Width="200" />
                                                </Grid.ColumnDefinitions>

                                                <TextBox
                                                    Grid.Column="0"
                                                    Margin="0,0,8,0"
                                                    Style="{StaticResource RoundedTextInputStyle}"
                                                    Text="{Binding NameText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                                                <Grid Grid.Column="1" Margin="0,0,8,0">
                                                    <customControls:MoneyTextBox Style="{StaticResource RoundedMoneyTextInputStyle}" Text="{Binding AmountText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, Converter={StaticResource MoneyAmountToCanonicalConverter}}" />
                                                    <Border
                                                        BorderBrush="{DynamicResource Brush.Danger}"
                                                        BorderThickness="1"
                                                        CornerRadius="8"
                                                        IsHitTestVisible="False"
                                                        Visibility="{Binding IsCausingNegativeRemainder, Converter={StaticResource BoolToVisibilityConverter}}" />
                                                </Grid>

                                                <ComboBox
                                                    Grid.Column="2"
                                                    Width="100"
                                                    Margin="0,0,8,0"
                                                    DisplayMemberPath="Label"
                                                    ItemsSource="{Binding DataContext.ExpenseCategories, RelativeSource={RelativeSource AncestorType=customControls:BasePopup}}"
                                                    SelectedValue="{Binding SelectedExpenseCategory, Mode=TwoWay}"
                                                    SelectedValuePath="Value"
                                                    Style="{StaticResource FluxoComboBoxStyle}"
                                                    Visibility="{Binding DataContext.IsExcludedFromBudget, RelativeSource={RelativeSource AncestorType=customControls:BasePopup}, Mode=OneWay, Converter={StaticResource BoolToVisibilityInvertedConverter}}" />

                                                <Grid Grid.Column="3" Margin="0,0,8,0">
                                                    <ToggleButton
                                                        x:Name="SplitRowTagToggleButton"
                                                        Content="{Binding TagDisplayName}"
                                                        IsChecked="{Binding IsTagPopupOpen, Mode=TwoWay}"
                                                        Style="{StaticResource SplitRowTagToggleStyle}"
                                                        Tag="{Binding SelectedTag.HexCode}" />

                                                    <Popup
                                                        AllowsTransparency="True"
                                                        IsOpen="{Binding IsTagPopupOpen, Mode=TwoWay}"
                                                        Placement="Bottom"
                                                        PlacementTarget="{Binding ElementName=SplitRowTagToggleButton}"
                                                        PopupAnimation="Fade"
                                                        StaysOpen="False"
                                                        VerticalOffset="8">
                                                        <Border
                                                            MaxWidth="280"
                                                            Padding="12"
                                                            Background="{DynamicResource Brush.Background.Elevated}"
                                                            BorderBrush="{DynamicResource Brush.Border.Subtle}"
                                                            BorderThickness="1"
                                                            CornerRadius="12">
                                                            <ListBox
                                                                ItemContainerStyle="{StaticResource SplitRowTagPopupItemStyle}"
                                                                ItemTemplate="{StaticResource PopupTagTemplate}"
                                                                ItemsSource="{Binding DataContext.AllSplitTags, RelativeSource={RelativeSource AncestorType=customControls:BasePopup}}"
                                                                SelectedItem="{Binding SelectedTag, Mode=TwoWay}"
                                                                Style="{StaticResource SplitRowTagPopupListBoxStyle}" />
                                                        </Border>
                                                    </Popup>
                                                </Grid>
                                            </Grid>

                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>

                                                <customControls:BalloonRadioButton
                                                    Grid.Column="0"
                                                    CheckedBackground="{StaticResource Brush.Success}"
                                                    CornerRadius="8"
                                                    DefaultBackground="{StaticResource Brush.BalloonButton.Background.Neutral}"
                                                    GroupName="AddTransactionMode"
                                                    HoveredBackground="{StaticResource Brush.BalloonButton.Background.Neutral.Hovered}"
                                                    IconSize="14"
                                                    IsChecked="{Binding IsRegularMode, Mode=TwoWay}"
                                                    IsEnabled="{Binding CanToggleRecurring}"
                                                    ShouldShowText="True"
                                                    UncheckedIcon="{StaticResource CreditCardAlt}"
                                                    UncheckedText="Regular" />
                                                <customControls:BalloonRadioButton
                                                    Grid.Column="1"
                                                    Margin="8,0,0,0"
                                                    CheckedBackground="{StaticResource Brush.Success}"
                                                    CornerRadius="8"
                                                    DefaultBackground="{StaticResource Brush.BalloonButton.Background.Neutral}"
                                                    GroupName="AddTransactionMode"
                                                    HoveredBackground="{StaticResource Brush.BalloonButton.Background.Neutral.Hovered}"
                                                    IconSize="14"
                                                    IsChecked="{Binding IsUnpostedIoUMode, Mode=TwoWay}"
                                                    IsEnabled="{Binding CanUseIoU}"
                                                    ShouldShowText="True"
                                                    UncheckedIcon="{StaticResource CreditCardMinusSolid}"
                                                    UncheckedText="Unposted IoU" />
                                                <customControls:BalloonRadioButton
                                                    Grid.Column="2"
                                                    Margin="8,0,0,0"
                                                    CheckedBackground="{StaticResource Brush.Success}"
                                                    CornerRadius="8"
                                                    DefaultBackground="{StaticResource Brush.BalloonButton.Background.Neutral}"
                                                    GroupName="AddTransactionMode"
                                                    HoveredBackground="{StaticResource Brush.BalloonButton.Background.Neutral.Hovered}"
                                                    IconSize="14"
                                                    IsChecked="{Binding IsPostedIoUMode, Mode=TwoWay}"
                                                    IsEnabled="{Binding CanUseIoU}"
                                                    ShouldShowText="True"
                                                    UncheckedIcon="{StaticResource CreditCardMinusSolid}"
                                                    UncheckedText="Posted IoU" />

                                                <Border
                                                    Grid.Column="3"
                                                    Width="1"
                                                    Background="{StaticResource Brush.Border.Default}"
                                                    SnapsToDevicePixels="True" />

                                                <customControls:BalloonCheckBox
                                                    Grid.Column="4"
                                                    Margin="16,0,0,0"
                                                    ButtonIcon="{StaticResource Delete}"
                                                    ButtonSize="32"
                                                    ButtonText="Delete"
                                                    CheckedIcon="{StaticResource ArrowsOutLineVertical}"
                                                    CheckedText="Modify"
                                                    CornerRadius="8"
                                                    DefaultBackground="{StaticResource Brush.BalloonButton.Background.NavInfo}"
                                                    HoveredBackground="{StaticResource Brush.BalloonButton.Background.NavInfo.Hovered}"
                                                    IconSize="12"
                                                    ShouldShowText="True"
                                                    UncheckedIcon="{StaticResource ArrowsOutLineVertical}"
                                                    UncheckedText="Modify" />

                                                <customControls:BalloonCheckBox
                                                    Grid.Column="5"
                                                    Margin="16,0,0,0"
                                                    ButtonIcon="{StaticResource Delete}"
                                                    ButtonSize="32"
                                                    ButtonText="Delete"
                                                    CheckedIcon="{StaticResource ArrowsOutLineVertical}"
                                                    CheckedText="Split"
                                                    CornerRadius="8"
                                                    DefaultBackground="{StaticResource Brush.BalloonButton.Background.ConfirmSave}"
                                                    HoveredBackground="{StaticResource Brush.BalloonButton.Background.ConfirmSave.Hovered}"
                                                    IconSize="12"
                                                    ShouldShowText="True"
                                                    UncheckedIcon="{StaticResource ArrowsOutLineVertical}"
                                                    UncheckedText="Split" />

                                                <customControls:BalloonButton
                                                    Grid.Column="6"
                                                    Margin="16,0,0,0"
                                                    ButtonIcon="{StaticResource Delete}"
                                                    ButtonSize="32"
                                                    ButtonText="Delete"
                                                    Click="OnRemoveSplitRowClick"
                                                    DefaultBackground="{StaticResource Brush.BalloonButton.Background.Destructive}"
                                                    HoveredBackground="{StaticResource Brush.BalloonButton.Background.Destructive.Hovered}"
                                                    ShouldShowText="True"
                                                    Style="{StaticResource ToolbarActionBalloonButtonStyle}" />
                                            </Grid>
                                        </StackPanel>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </customControls:FadingScrollViewer>
                    </StackPanel>
                </Border>
            </Grid>

            <StackPanel
                x:Name="NormalTransactionNotePanel"
                Grid.Row="2"
                Margin="0,16,0,0"
                Visibility="{Binding ShowNormalTransactionFields, Converter={StaticResource BoolToVisibilityConverter}}">
                <TextBlock Style="{StaticResource SectionLabelStyle}" Text="Note" />
                <Border Style="{StaticResource PopupFieldBorderStyle}">
                    <RichTextBox
                        x:Name="NoteRichTextBox"
                        MinHeight="120"
                        Background="Transparent"
                        BorderThickness="0"
                        CaretBrush="{DynamicResource Brush.Text.Primary}"
                        FontFamily="{DynamicResource Regular}"
                        FontSize="13"
                        Foreground="{DynamicResource Brush.Text.Primary}"
                        IsReadOnly="{Binding AreFieldsReadOnly}"
                        TextChanged="OnNoteTextChanged"
                        VerticalScrollBarVisibility="Auto" />
                </Border>
            </StackPanel>

            <Border
                Grid.Row="0"
                Grid.RowSpan="3"
                Background="Transparent"
                Visibility="{Binding CanEditFields, Converter={StaticResource BoolToVisibilityInvertedConverter}}" />

            <Border
                Grid.Row="0"
                Grid.RowSpan="3"
                Grid.Column="2"
                Margin="16,0,0,0"
                Padding="12"
                Background="{DynamicResource Brush.Background.Elevated}"
                BorderBrush="{DynamicResource Brush.Border.Subtle}"
                BorderThickness="1"
                CornerRadius="8"
                Visibility="{Binding ShowChildTransactions, Converter={StaticResource BoolToVisibilityConverter}}">
                <StackPanel>
                    <TextBlock
                        FontFamily="{DynamicResource Bold}"
                        FontSize="12"
                        Foreground="{DynamicResource Brush.Text.Primary}"
                        Text="Sub-transactions" />
                    <ScrollViewer
                        Width="260"
                        MaxHeight="520"
                        Margin="0,12,0,0"
                        HorizontalScrollBarVisibility="Disabled"
                        VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemTemplate="{StaticResource ChildTransactionItemTemplate}" ItemsSource="{Binding ChildTransactions}" />
                    </ScrollViewer>
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</customControls:BasePopup>