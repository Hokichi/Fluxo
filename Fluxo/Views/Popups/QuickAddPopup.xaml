<customControls:BasePopup
    x:Class="Fluxo.Views.Popups.QuickAddPopup"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:components="clr-namespace:Fluxo.Resources.Components;assembly=Fluxo.Resources"
    xmlns:customControls="clr-namespace:Fluxo.Resources.CustomControls;assembly=Fluxo.Resources"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    PopupTitle="Quick Access"
    mc:Ignorable="d">

    <customControls:BasePopup.Resources>
        <Style x:Key="QuickAddTileButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Width" Value="236" />
            <Setter Property="Height" Value="112" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="VerticalContentAlignment" Value="Stretch" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border
                            x:Name="TileBorder"
                            Padding="{TemplateBinding Padding}"
                            Background="{DynamicResource Brush.Background.Surface}"
                            BorderBrush="{DynamicResource Brush.Border.Subtle}"
                            BorderThickness="1"
                            CornerRadius="16"
                            SnapsToDevicePixels="True">
                            <ContentPresenter
                                x:Name="TileContent"
                                HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                RenderTransformOrigin="0.5,0.5">
                                <ContentPresenter.RenderTransform>
                                    <ScaleTransform ScaleX="1" ScaleY="1" />
                                </ContentPresenter.RenderTransform>
                            </ContentPresenter>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="TileBorder" Property="Background" Value="{DynamicResource Brush.Background.Hover}" />
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation
                                                Storyboard.TargetName="TileContent"
                                                Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)"
                                                To="1.02"
                                                Duration="0:0:0.14">
                                                <DoubleAnimation.EasingFunction>
                                                    <CubicEase EasingMode="EaseOut" />
                                                </DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                            <DoubleAnimation
                                                Storyboard.TargetName="TileContent"
                                                Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                                                To="1.02"
                                                Duration="0:0:0.14">
                                                <DoubleAnimation.EasingFunction>
                                                    <CubicEase EasingMode="EaseOut" />
                                                </DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation
                                                Storyboard.TargetName="TileContent"
                                                Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)"
                                                To="1"
                                                Duration="0:0:0.14">
                                                <DoubleAnimation.EasingFunction>
                                                    <CubicEase EasingMode="EaseOut" />
                                                </DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                            <DoubleAnimation
                                                Storyboard.TargetName="TileContent"
                                                Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                                                To="1"
                                                Duration="0:0:0.14">
                                                <DoubleAnimation.EasingFunction>
                                                    <CubicEase EasingMode="EaseOut" />
                                                </DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="TileBorder" Property="Opacity" Value="0.4" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style
            x:Key="LockedDisabledQuickAddTileButtonStyle"
            BasedOn="{StaticResource QuickAddTileButtonStyle}"
            TargetType="Button">
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsSufficientFundsActionGateLocked}" Value="True">
                    <Setter Property="IsEnabled" Value="False" />
                    <Setter Property="Cursor" Value="Arrow" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </customControls:BasePopup.Resources>

    <customControls:SpacedUniformGrid
        Width="760"
        Height="508"
        Margin="40,6,40,24"
        HorizontalAlignment="Center"
        Columns="3"
        HorizontalGap="16"
        VerticalGap="16">
        <Button
            x:Name="NewAccountQuickAddButton"
            Click="OnNewAccountClick"
            Style="{StaticResource QuickAddTileButtonStyle}">
            <StackPanel VerticalAlignment="Center">
                <components:Icon
                    Width="24"
                    Height="24"
                    HorizontalAlignment="Center"
                    Path="{StaticResource Bank}"
                    Color="{DynamicResource Brush.Mint}" />
                <TextBlock
                    Margin="0,12,0,0"
                    HorizontalAlignment="Center"
                    FontFamily="{DynamicResource Bold}"
                    FontSize="13"
                    Foreground="{DynamicResource Brush.Text.Primary}"
                    Text="New Account"
                    TextAlignment="Center" />
                <TextBlock
                    Margin="0,8,0,0"
                    HorizontalAlignment="Center"
                    FontFamily="{DynamicResource Medium}"
                    FontSize="11"
                    Foreground="{DynamicResource Brush.Text.Secondary}"
                    Text="Add a new account or wallet."
                    TextAlignment="Center"
                    TextWrapping="Wrap" />
            </StackPanel>
        </Button>

        <Button
            x:Name="NewTransactionQuickAddButton"
            Click="OnNewTransactionClick"
            Style="{StaticResource LockedDisabledQuickAddTileButtonStyle}">
            <StackPanel VerticalAlignment="Center">
                <components:Icon
                    Width="24"
                    Height="24"
                    HorizontalAlignment="Center"
                    Path="{StaticResource InvoiceLight}"
                    Color="{DynamicResource Brush.Mint}" />
                <TextBlock
                    Margin="0,12,0,0"
                    HorizontalAlignment="Center"
                    FontFamily="{DynamicResource Bold}"
                    FontSize="13"
                    Foreground="{DynamicResource Brush.Text.Primary}"
                    Text="New Transaction"
                    TextAlignment="Center" />
                <TextBlock
                    Margin="0,8,0,0"
                    HorizontalAlignment="Center"
                    FontFamily="{DynamicResource Medium}"
                    FontSize="11"
                    Foreground="{DynamicResource Brush.Text.Secondary}"
                    Text="Add income or expense quickly."
                    TextAlignment="Center"
                    TextWrapping="Wrap" />
            </StackPanel>
        </Button>

        <Button
            x:Name="NewSavingGoalQuickAddButton"
            Click="OnNewSavingGoalClick"
            Style="{StaticResource LockedDisabledQuickAddTileButtonStyle}">
            <StackPanel VerticalAlignment="Center">
                <components:Icon
                    Width="24"
                    Height="24"
                    HorizontalAlignment="Center"
                    Path="{StaticResource BullseyeSolid}"
                    Color="{DynamicResource Brush.Mint}" />
                <TextBlock
                    Margin="0,12,0,0"
                    HorizontalAlignment="Center"
                    FontFamily="{DynamicResource Bold}"
                    FontSize="13"
                    Foreground="{DynamicResource Brush.Text.Primary}"
                    Text="New Saving Goal"
                    TextAlignment="Center" />
                <TextBlock
                    Margin="0,8,0,0"
                    HorizontalAlignment="Center"
                    FontFamily="{DynamicResource Medium}"
                    FontSize="11"
                    Foreground="{DynamicResource Brush.Text.Secondary}"
                    Text="Set a target and track progress."
                    TextAlignment="Center"
                    TextWrapping="Wrap" />
            </StackPanel>
        </Button>

        <Button
            x:Name="RunSetupWizardQuickAddButton"
            Click="OnRunSetupWizardClick"
            Style="{StaticResource QuickAddTileButtonStyle}">
            <StackPanel VerticalAlignment="Center">
                <components:Icon
                    Width="24"
                    Height="24"
                    HorizontalAlignment="Center"
                    Path="{StaticResource RocketSolid}"
                    Color="{DynamicResource Brush.Mint}" />
                <TextBlock
                    Margin="0,12,0,0"
                    HorizontalAlignment="Center"
                    FontFamily="{DynamicResource Bold}"
                    FontSize="13"
                    Foreground="{DynamicResource Brush.Text.Primary}"
                    Text="Run Setup Wizard"
                    TextAlignment="Center" />
                <TextBlock
                    Margin="0,8,0,0"
                    HorizontalAlignment="Center"
                    FontFamily="{DynamicResource Medium}"
                    FontSize="11"
                    Foreground="{DynamicResource Brush.Text.Secondary}"
                    Text="Revisit guided setup."
                    TextAlignment="Center"
                    TextWrapping="Wrap" />
            </StackPanel>
        </Button>

        <Button
            x:Name="CheckForUpdatesQuickAddButton"
            Click="OnCheckForUpdatesClick"
            Style="{StaticResource QuickAddTileButtonStyle}">
            <StackPanel VerticalAlignment="Center">
                <components:Icon
                    Width="24"
                    Height="24"
                    HorizontalAlignment="Center"
                    Path="{StaticResource UpdateOutline}"
                    Color="{DynamicResource Brush.Mint}" />
                <TextBlock
                    Margin="0,12,0,0"
                    HorizontalAlignment="Center"
                    FontFamily="{DynamicResource Bold}"
                    FontSize="13"
                    Foreground="{DynamicResource Brush.Text.Primary}"
                    Text="Check for updates"
                    TextAlignment="Center" />
                <TextBlock
                    Margin="0,8,0,0"
                    HorizontalAlignment="Center"
                    FontFamily="{DynamicResource Medium}"
                    FontSize="11"
                    Foreground="{DynamicResource Brush.Text.Secondary}"
                    Text="Look for a newer version."
                    TextAlignment="Center"
                    TextWrapping="Wrap" />
            </StackPanel>
        </Button>

        <Button
            x:Name="NewRecurringTransactionQuickAddButton"
            Click="OnNewRecurringTransactionClick"
            Style="{StaticResource LockedDisabledQuickAddTileButtonStyle}">
            <StackPanel VerticalAlignment="Center">
                <components:Icon
                    Width="24"
                    Height="24"
                    HorizontalAlignment="Center"
                    Path="{StaticResource Calendar}"
                    Color="{DynamicResource Brush.Mint}" />
                <TextBlock
                    Margin="0,12,0,0"
                    HorizontalAlignment="Center"
                    FontFamily="{DynamicResource Bold}"
                    FontSize="13"
                    Foreground="{DynamicResource Brush.Text.Primary}"
                    Text="New Recurring Transaction"
                    TextAlignment="Center" />
                <TextBlock
                    Margin="0,8,0,0"
                    HorizontalAlignment="Center"
                    FontFamily="{DynamicResource Medium}"
                    FontSize="11"
                    Foreground="{DynamicResource Brush.Text.Secondary}"
                    Text="Schedule repeating money flow."
                    TextAlignment="Center"
                    TextWrapping="Wrap" />
            </StackPanel>
        </Button>

        <Button
            x:Name="ViewAccountsQuickAddButton"
            Click="OnViewAccountsClick"
            Style="{StaticResource QuickAddTileButtonStyle}">
            <StackPanel VerticalAlignment="Center">
                <components:Icon
                    Width="24"
                    Height="24"
                    HorizontalAlignment="Center"
                    Path="{StaticResource Bank}"
                    Color="{DynamicResource Brush.Mint}" />
                <TextBlock
                    Margin="0,12,0,0"
                    HorizontalAlignment="Center"
                    FontFamily="{DynamicResource Bold}"
                    FontSize="13"
                    Foreground="{DynamicResource Brush.Text.Primary}"
                    Text="View Accounts"
                    TextAlignment="Center" />
                <TextBlock
                    Margin="0,8,0,0"
                    HorizontalAlignment="Center"
                    FontFamily="{DynamicResource Medium}"
                    FontSize="11"
                    Foreground="{DynamicResource Brush.Text.Secondary}"
                    Text="Review accounts and wallets."
                    TextAlignment="Center"
                    TextWrapping="Wrap" />
            </StackPanel>
        </Button>

        <Button
            x:Name="PlanningReportQuickAddButton"
            Click="OnPlanningReportClick"
            Style="{StaticResource LockedDisabledQuickAddTileButtonStyle}">
