<c:BasePopup
    x:Class="Fluxo.Views.Popups.QuickAddPopup"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:c="clr-namespace:Fluxo.Resources.CustomControls"
    xmlns:components="clr-namespace:Fluxo.Views.Components"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    PopupTitle="Add New Transaction"
    ShowSaveAndCreateNewButton="True"
    ShowSaveButton="True"
    mc:Ignorable="d">

    <c:BasePopup.Resources>
        <Style x:Key="SectionLabelStyle" TargetType="TextBlock">
            <Setter Property="Margin" Value="0,0,0,8" />
            <Setter Property="FontFamily" Value="{DynamicResource Bold}" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="Foreground" Value="{DynamicResource Brush.Text.Muted}" />
        </Style>

        

        <Style x:Key="PopupFieldBorderStyle" TargetType="Border">
            <Setter Property="Padding" Value="12,10" />
            <Setter Property="Background" Value="{DynamicResource Brush.Background.Surface}" />
            <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border.Subtle}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="12" />
        </Style>

        <Style
            x:Key="PopupComboBoxStyle"
            BasedOn="{StaticResource FluxoComboBoxStyle}"
            TargetType="ComboBox">
            <Setter Property="MinHeight" Value="16" />
        </Style>

        <Style x:Key="PopupTagListBoxStyle" TargetType="ListBox">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled" />
            <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Disabled" />
        </Style>

        <Style x:Key="PopupTagListBoxItemStyle" TargetType="ListBoxItem">
            <Setter Property="Margin" Value="0,0,8,0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <ContentPresenter />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style
            x:Key="PopupOtherTagListBoxItemStyle"
            BasedOn="{StaticResource PopupTagListBoxItemStyle}"
            TargetType="ListBoxItem">
            <Setter Property="Margin" Value="0,0,8,8" />
        </Style>

        

        <DataTemplate x:Key="PopupTagTemplate">
            <ToggleButton
                Content="{Binding Name}"
                IsChecked="{Binding RelativeSource={RelativeSource AncestorType=ListBoxItem}, Path=IsSelected}"
                Style="{StaticResource PopupTagToggleStyle}" />
        </DataTemplate>
    </c:BasePopup.Resources>

    <Border Padding="20,4,20,20">
        <Grid Width="560">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0">
                <Border
                    Height="32"
                    Padding="4"
                    HorizontalAlignment="Center"
                    Background="{DynamicResource Brush.Background.Surface}"
                    BorderBrush="{DynamicResource Brush.Border.Subtle}"
                    BorderThickness="1"
                    CornerRadius="14">
                    <StackPanel Orientation="Horizontal">
                        <RadioButton
                            x:Name="ExpenseRadioButton"
                            Content="Expense"
                            GroupName="TransactionType"
                            IsChecked="{Binding IsExpense, Mode=TwoWay}"
                            Style="{StaticResource SegmentedToggleOptionStyle}" />
                        <RadioButton
                            x:Name="IncomeRadioButton"
                            Margin="4,0,0,0"
                            Content="Income"
                            GroupName="TransactionType"
                            IsChecked="{Binding IsIncome, Mode=TwoWay}"
                            Style="{StaticResource SegmentedToggleOptionStyle}" />
                    </StackPanel>
                </Border>
            </StackPanel>

            <Grid Grid.Row="1" Margin="0,16,0,0">
                <StackPanel Visibility="{Binding IsExpense, Converter={StaticResource BoolToVisibilityConverter}}">
                    <StackPanel>
                        <TextBlock Style="{StaticResource SectionLabelStyle}" Text="Amount" />
                        <Border Style="{StaticResource PopupFieldBorderStyle}">
                            <Grid>
                                <c:MoneyTextBox
                                    x:Name="ExpenseAmountTextBox"
                                    Style="{StaticResource PopupTextBoxStyle}"
                                    Text="{Binding AmountText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                <TextBlock
                                    Margin="0,1,0,0"
                                    VerticalAlignment="Center"
                                    FontFamily="{DynamicResource Medium}"
                                    FontSize="12"
                                    Foreground="{DynamicResource Brush.Text.Muted}"
                                    IsHitTestVisible="False"
                                    Text="0">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Text, ElementName=ExpenseAmountTextBox}"
                                                             Value="">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Text, ElementName=ExpenseAmountTextBox}"
                                                             Value="{x:Null}">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </Grid>
                        </Border>
                    </StackPanel>

                    <Grid Margin="0,16,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="16" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <TextBlock Style="{StaticResource SectionLabelStyle}" Text="Name" />
                            <Border Style="{StaticResource PopupFieldBorderStyle}">
                                <TextBox
                                    x:Name="ExpenseNameTextBox"
                                    Style="{StaticResource PopupTextBoxStyle}"
                                    Text="{Binding NameText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            </Border>
                        </StackPanel>

                        <StackPanel Grid.Column="2">
                            <TextBlock Style="{StaticResource SectionLabelStyle}" Text="Date" />
                            <components:DateSelector x:Name="ExpenseTransactionDateSelector"
                                                     SelectedDate="{Binding SelectedDate, Mode=TwoWay}" />
                        </StackPanel>
                    </Grid>

                    <Grid Margin="0,16,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="16" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <TextBlock Style="{StaticResource SectionLabelStyle}" Text="Category" />
                            <Border Style="{StaticResource PopupFieldBorderStyle}">
                                <ComboBox
                                    x:Name="ExpenseCategoryComboBox"
                                    DisplayMemberPath="Label"
                                    ItemsSource="{Binding ExpenseCategories}"
                                    SelectedValue="{Binding SelectedExpenseCategory, Mode=TwoWay}"
                                    SelectedValuePath="Value"
                                    Style="{StaticResource PopupComboBoxStyle}" />
                            </Border>
                        </StackPanel>

                        <StackPanel Grid.Column="2">
                            <TextBlock Style="{StaticResource SectionLabelStyle}" Text="Spending Source" />
                            <Border Style="{StaticResource PopupFieldBorderStyle}">
                                <ComboBox
                                    x:Name="ExpenseSpendingSourceComboBox"
                                    DisplayMemberPath="Name"
                                    ItemsSource="{Binding SpendingSources}"
                                    SelectedItem="{Binding SelectedSpendingSource, Mode=TwoWay}"
                                    Style="{StaticResource PopupComboBoxStyle}" />
                            </Border>
                        </StackPanel>
                    </Grid>
                </StackPanel>

                <StackPanel Visibility="{Binding IsIncome, Converter={StaticResource BoolToVisibilityConverter}}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="16" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <TextBlock Style="{StaticResource SectionLabelStyle}" Text="Name" />
                            <Border Style="{StaticResource PopupFieldBorderStyle}">
                                <TextBox
                                    x:Name="IncomeNameTextBox"
                                    Style="{StaticResource PopupTextBoxStyle}"
                                    Text="{Binding NameText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            </Border>
                        </StackPanel>

                        <StackPanel Grid.Column="2">
                            <TextBlock Style="{StaticResource SectionLabelStyle}" Text="Amount" />
                            <Border Style="{StaticResource PopupFieldBorderStyle}">
                                <Grid>
                                    <c:MoneyTextBox
                                        x:Name="IncomeAmountTextBox"
                                        Style="{StaticResource PopupTextBoxStyle}"
                                        Text="{Binding AmountText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                    <TextBlock
                                        Margin="0,1,0,0"
                                        VerticalAlignment="Center"
                                        FontFamily="{DynamicResource Medium}"
                                        FontSize="12"
                                        Foreground="{DynamicResource Brush.Text.Muted}"
                                        IsHitTestVisible="False"
                                        Text="0">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                                <Style.Triggers>
                                                    <DataTrigger
                                                        Binding="{Binding Text, ElementName=IncomeAmountTextBox}"
                                                        Value="">
                                                        <Setter Property="Visibility" Value="Visible" />
                                                    </DataTrigger>
                                                    <DataTrigger
                                                        Binding="{Binding Text, ElementName=IncomeAmountTextBox}"
                                                        Value="{x:Null}">
                                                        <Setter Property="Visibility" Value="Visible" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </Grid>
                            </Border>
                        </StackPanel>
                    </Grid>

                    <Grid Margin="0,16,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="16" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <TextBlock Style="{StaticResource SectionLabelStyle}" Text="Spending Source" />
                            <Border Style="{StaticResource PopupFieldBorderStyle}">
                                <ComboBox
                                    x:Name="IncomeSpendingSourceComboBox"
                                    DisplayMemberPath="Name"
                                    ItemsSource="{Binding SpendingSources}"
                                    SelectedItem="{Binding SelectedSpendingSource, Mode=TwoWay}"
                                    Style="{StaticResource PopupComboBoxStyle}" />
                            </Border>
                        </StackPanel>

                        <StackPanel Grid.Column="2">
                            <TextBlock Style="{StaticResource SectionLabelStyle}" Text="Date" />
                            <components:DateSelector x:Name="IncomeTransactionDateSelector"
                                                     SelectedDate="{Binding SelectedDate, Mode=TwoWay}" />
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Grid>

            <StackPanel
                x:Name="TagsPanel"
                Grid.Row="2"
                Margin="0,16,0,0"
                Visibility="{Binding IsExpense, Converter={StaticResource BoolToVisibilityConverter}}">
                <TextBlock Style="{StaticResource SectionLabelStyle}" Text="Tags" />
                <DockPanel LastChildFill="False">
                    <ListBox
                        x:Name="VisibleTagsListBox"
                        DockPanel.Dock="Left"
                        ItemContainerStyle="{StaticResource PopupTagListBoxItemStyle}"
                        ItemTemplate="{StaticResource PopupTagTemplate}"
                        ItemsSource="{Binding VisibleTags}"
                        SelectedItem="{Binding SelectedTag, Mode=TwoWay}"
                        Style="{StaticResource PopupTagListBoxStyle}">
                        <ListBox.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Horizontal" />
                            </ItemsPanelTemplate>
                        </ListBox.ItemsPanel>
                    </ListBox>

                    <ToggleButton
                        x:Name="MoreTagsButton"
                        Margin="4,0,0,0"
                        Content="More Tags"
                        IsChecked="{Binding IsMoreTagsOpen, Mode=TwoWay}"
                        Style="{StaticResource PopupTagToggleStyle}"
                        Visibility="{Binding HasMoreTags, Converter={StaticResource BoolToVisibilityConverter}}" />
                </DockPanel>

                <Popup
                    AllowsTransparency="True"
                    IsOpen="{Binding IsMoreTagsOpen, Mode=TwoWay}"
                    Placement="Bottom"
                    PlacementTarget="{Binding ElementName=MoreTagsButton}"
                    PopupAnimation="Fade"
                    StaysOpen="False"
                    VerticalOffset="8">
                    <Border
                        MaxWidth="360"
                        Padding="12"
                        Background="{DynamicResource Brush.Background.Elevated}"
                        BorderBrush="{DynamicResource Brush.Border.Subtle}"
                        BorderThickness="1"
                        CornerRadius="16">
                        <StackPanel>
                            <TextBlock
                                Margin="0,0,0,10"
                                FontFamily="{DynamicResource Bold}"
                                FontSize="12"
                                Foreground="{DynamicResource Brush.Text.Primary}"
                                Text="More Tags" />
                            <ListBox
                                x:Name="MoreTagsListBox"
                                ItemContainerStyle="{StaticResource PopupOtherTagListBoxItemStyle}"
                                ItemTemplate="{StaticResource PopupTagTemplate}"
                                ItemsSource="{Binding OverflowTags}"
                                SelectedItem="{Binding SelectedTag, Mode=TwoWay}"
                                Style="{StaticResource PopupTagListBoxStyle}">
                                <ListBox.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel />
                                    </ItemsPanelTemplate>
                                </ListBox.ItemsPanel>
                            </ListBox>
                        </StackPanel>
                    </Border>
                </Popup>
            </StackPanel>

            <StackPanel Grid.Row="3" Margin="0,16,0,0">
                <TextBlock Style="{StaticResource SectionLabelStyle}" Text="Note" />
                <Border Style="{StaticResource PopupFieldBorderStyle}">
                    <RichTextBox
                        x:Name="NoteRichTextBox"
                        MinHeight="120"
                        Background="Transparent"
                        BorderThickness="0"
                        CaretBrush="{DynamicResource Brush.Text.Primary}"
                        FontFamily="{DynamicResource Regular}"
                        FontSize="13"
                        Foreground="{DynamicResource Brush.Text.Primary}"
                        TextChanged="OnNoteTextChanged"
                        VerticalScrollBarVisibility="Auto" />
                </Border>
            </StackPanel>
        </Grid>
    </Border>
</c:BasePopup>

