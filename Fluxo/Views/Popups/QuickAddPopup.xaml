                    Text="Project balances and budget."
                    TextAlignment="Center"
                    TextWrapping="Wrap" />
            </StackPanel>
        </Button>

        <Button
            x:Name="OpenSettingsQuickAddButton"
            Click="OnOpenSettingsClick"
            Style="{StaticResource QuickAddTileButtonStyle}">
            <StackPanel VerticalAlignment="Center">
                <components:Icon
                    Width="24"
                    Height="24"
                    HorizontalAlignment="Center"
                    Path="{StaticResource Cog}"
                    Color="{DynamicResource Brush.Mint}" />
                <TextBlock
                    Margin="0,12,0,0"
                    HorizontalAlignment="Center"
                    FontFamily="{DynamicResource Bold}"
                    FontSize="13"
                    Foreground="{DynamicResource Brush.Text.Primary}"
                    Text="Open Settings"
                    TextAlignment="Center" />
                <TextBlock
                    Margin="0,8,0,0"
                    HorizontalAlignment="Center"
                    FontFamily="{DynamicResource Medium}"
                    FontSize="11"
                    Foreground="{DynamicResource Brush.Text.Secondary}"
                    Text="Adjust app preferences."
                    TextAlignment="Center"
                    TextWrapping="Wrap" />
            </StackPanel>
        </Button>
    </customControls:SpacedUniformGrid>
</customControls:BasePopup>
