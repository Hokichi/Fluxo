<c:BasePopup
    x:Class="Fluxo.Views.Popups.SpendingSourcesListPopup"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x='http://schemas.microsoft.com/winfx/2006/xaml'
    xmlns:components='clr-namespace:Fluxo.Views.Components'
    xmlns:c="clr-namespace:Fluxo.Resources.CustomControls"
    PopupTitle="Spending Sources">

    <c:BasePopup.Resources>
        <Style x:Key="AccentStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource Brush.Income.Checking.Cash}" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding SpendingSourceType}" Value="Credit">
                    <Setter Property="Background" Value="{StaticResource Brush.Income.Credit.BNPL}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding SpendingSourceType}" Value="BNPL">
                    <Setter Property="Background" Value="{StaticResource Brush.Income.Credit.BNPL}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding SpendingSourceType}" Value="Saving">
                    <Setter Property="Background" Value="{StaticResource Brush.Income.Saving}" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="BankIconStyle" TargetType="Rectangle">
            <Setter Property="Visibility" Value="Collapsed" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding SpendingSourceType}" Value="Checking">
                    <Setter Property="Visibility" Value="Visible" />
                </DataTrigger>
                <DataTrigger Binding="{Binding SpendingSourceType}" Value="Cash">
                    <Setter Property="Visibility" Value="Visible" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="CreditIconStyle" TargetType="Rectangle">
            <Setter Property="Visibility" Value="Collapsed" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding SpendingSourceType}" Value="Credit">
                    <Setter Property="Visibility" Value="Visible" />
                </DataTrigger>
                <DataTrigger Binding="{Binding SpendingSourceType}" Value="BNPL">
                    <Setter Property="Visibility" Value="Visible" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="SavingIconStyle" TargetType="Rectangle">
            <Setter Property="Visibility" Value="Collapsed" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding SpendingSourceType}" Value="Saving">
                    <Setter Property="Visibility" Value="Visible" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </c:BasePopup.Resources>

    <Grid
        Width="400"
        Height="336"
        Margin="24,0,24,24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="12" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TextBlock
            FontFamily="{StaticResource Medium}"
            FontSize="12"
            Foreground="{StaticResource Brush.Text.Secondary}"
            Text="Open any spending source to inspect or edit it." />

        <Border
            Grid.Row="2"
            Background="{StaticResource Brush.Background.Surface}"
            BorderBrush="{StaticResource Brush.Border.Subtle}"
            BorderThickness="1"
            CornerRadius="18">
            <c:FadingScrollViewer Margin="0,12,0,-12" VerticalScrollBarVisibility="Auto">
                <ItemsControl x:Name="SourcesList">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Button
                                Margin="12,12,12,0"
                                Click="OnSourceClick"
                                Style="{StaticResource SourceButtonStyle}">
                                <Grid>
                                    <Grid.Style>
                                        <Style TargetType="Grid">
                                            <Setter Property="Opacity" Value="1" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsDisabled}" Value="True">
                                                    <Setter Property="Opacity" Value="0.55" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Grid.Style>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="12" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <Border
                                        x:Name="AccentBorder"
                                        Width="36"
                                        Height="36"
                                        VerticalAlignment="Center"
                                        CornerRadius="18"
                                        Style="{StaticResource AccentStyle}">
                                        <Grid>
                                            <Rectangle
                                                Margin="10"
                                                Fill="{Binding Background, ElementName=AccentBorder, Converter={StaticResource BrushToLighterBrushConverter}}"
                                                Style="{StaticResource BankIconStyle}">
                                                <Rectangle.OpacityMask>
                                                    <DrawingBrush Stretch="Uniform">
                                                        <DrawingBrush.Drawing>
                                                            <GeometryDrawing Geometry="{StaticResource SpendingSourcesListPopup.Bank}">
                                                                <GeometryDrawing.Brush>
                                                                    <SolidColorBrush Color="Black" />
                                                                </GeometryDrawing.Brush>
                                                            </GeometryDrawing>
                                                        </DrawingBrush.Drawing>
                                                    </DrawingBrush>
                                                </Rectangle.OpacityMask>
                                            </Rectangle>
                                            <Rectangle
                                                Margin="10"
                                                Fill="{Binding Background, ElementName=AccentBorder, Converter={StaticResource BrushToLighterBrushConverter}}"
                                                Style="{StaticResource CreditIconStyle}">
                                                <Rectangle.OpacityMask>
                                                    <DrawingBrush Stretch="Uniform">
                                                        <DrawingBrush.Drawing>
                                                            <GeometryDrawing Geometry="{StaticResource SpendingSourcesListPopup.CreditCardAlt}">
                                                                <GeometryDrawing.Brush>
                                                                    <SolidColorBrush Color="Black" />
                                                                </GeometryDrawing.Brush>
                                                            </GeometryDrawing>
                                                        </DrawingBrush.Drawing>
                                                    </DrawingBrush>
                                                </Rectangle.OpacityMask>
                                            </Rectangle>
                                            <Rectangle
                                                Margin="10"
                                                Fill="{Binding Background, ElementName=AccentBorder, Converter={StaticResource BrushToLighterBrushConverter}}"
                                                Style="{StaticResource SavingIconStyle}">
                                                <Rectangle.OpacityMask>
                                                    <DrawingBrush Stretch="Uniform">
                                                        <DrawingBrush.Drawing>
                                                            <GeometryDrawing Geometry="{StaticResource SpendingSourcesListPopup.PiggyBank}">
                                                                <GeometryDrawing.Brush>
                                                                    <SolidColorBrush Color="Black" />
                                                                </GeometryDrawing.Brush>
                                                            </GeometryDrawing>
                                                        </DrawingBrush.Drawing>
                                                    </DrawingBrush>
                                                </Rectangle.OpacityMask>
                                            </Rectangle>
                                        </Grid>
                                    </Border>

                                    <StackPanel Grid.Column="2" VerticalAlignment="Center">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock
                                                FontFamily="{StaticResource Bold}"
                                                FontSize="13"
                                                Foreground="{StaticResource Brush.Text.Primary}"
                                                Text="{Binding Name}" />
                                            <Border
                                                Width="12"
                                                Height="12"
                                                Margin="8,0,0,0"
                                                Visibility="{Binding IsDisabled, Converter={StaticResource BoolToVisibilityConverter}}">
                                                <components:Icon Path='{StaticResource SpendingSourcesListPopup.LightningSlashFill}' Color='{StaticResource Brush.Danger}' />
                                            </Border>
                                            <Border
                                                Width="12"
                                                Height="12"
                                                Margin="8,0,0,0"
                                                Visibility="{Binding ShowOnUI, Converter={StaticResource BoolToVisibilityInvertedConverter}}">
                                                <components:Icon Path='{StaticResource SpendingSourcesListPopup.EyeOff}' Color='{StaticResource Brush.Warning}' />
                                            </Border>
                                        </StackPanel>
                                        <TextBlock
                                            Margin="0,6,0,0"
                                            FontFamily="{StaticResource Medium}"
                                            FontSize="11"
                                            Foreground="{StaticResource Brush.Text.Secondary}"
                                            Text="{Binding TypeDisplayName}" />
                                    </StackPanel>

                                    <StackPanel Grid.Column="3" VerticalAlignment="Center">
                                        <TextBlock
                                            HorizontalAlignment="Right"
                                            FontFamily="{StaticResource Bold}"
                                            FontSize="12"
                                            Foreground="{StaticResource Brush.Text.Primary}"
                                            ToolTip="{Binding PrimaryAmount, Mode=OneWay, Converter={StaticResource MoneyFullDisplayConverter}}">
                                            <Run Text="{Binding PrimaryAmount, Mode=OneWay, Converter={StaticResource NumberWithCommasConverter}}" />
                                        </TextBlock>
                                        <TextBlock
                                            Margin="0,6,0,0"
                                            HorizontalAlignment="Right"
                                            FontFamily="{StaticResource Medium}"
                                            FontSize="10"
                                            Foreground="{StaticResource Brush.Text.Muted}"
                                            Text="{Binding PrimaryAmountLabel}" />
                                    </StackPanel>
                                </Grid>
                            </Button>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </c:FadingScrollViewer>
        </Border>
    </Grid>
</c:BasePopup>
