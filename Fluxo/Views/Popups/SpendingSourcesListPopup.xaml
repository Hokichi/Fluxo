<customControls:BasePopup
    x:Class="Fluxo.Views.Popups.SpendingSourcesListPopup"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:components="clr-namespace:Fluxo.Views.Components"
    PopupTitle="Spending Sources">

    <customControls:BasePopup.Resources>
        <Style x:Key="AccentStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource Brush.Income.Checking.Cash}" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding SpendingSourceType}" Value="Credit">
                    <Setter Property="Background" Value="{StaticResource Brush.Income.Credit.BNPL}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding SpendingSourceType}" Value="BNPL">
                    <Setter Property="Background" Value="{StaticResource Brush.Income.Credit.BNPL}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding SpendingSourceType}" Value="Saving">
                    <Setter Property="Background" Value="{StaticResource Brush.Income.Saving}" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="BankIconStyle" TargetType="components:Icon">
            <Setter Property="Visibility" Value="Collapsed" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding SpendingSourceType}" Value="Checking">
                    <Setter Property="Visibility" Value="Visible" />
                </DataTrigger>
                <DataTrigger Binding="{Binding SpendingSourceType}" Value="Cash">
                    <Setter Property="Visibility" Value="Visible" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="CreditIconStyle" TargetType="components:Icon">
            <Setter Property="Visibility" Value="Collapsed" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding SpendingSourceType}" Value="Credit">
                    <Setter Property="Visibility" Value="Visible" />
                </DataTrigger>
                <DataTrigger Binding="{Binding SpendingSourceType}" Value="BNPL">
                    <Setter Property="Visibility" Value="Visible" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <DataTemplate x:Key="SpendingSourcesListItemTemplate">
            <Button
                Margin="12,12,12,0"
                Click="OnSourceClick"
                Style="{StaticResource SourceButtonStyle}">
                <Grid>
                    <Grid.Style>
                        <Style TargetType="Grid">
                            <Setter Property="Opacity" Value="1" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsDisabled}" Value="True">
                                    <Setter Property="Opacity" Value="0.55" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Grid.Style>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="12" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <Border
                        x:Name="AccentBorder"
                        Width="36"
                        Height="36"
                        VerticalAlignment="Center"
                        CornerRadius="18"
                        Style="{StaticResource AccentStyle}">
                        <Grid>
                            <components:Icon
                                Margin="10"
                                Color="{Binding Background, ElementName=AccentBorder, Converter={StaticResource BrushToLighterBrushConverter}}"
                                Path="{StaticResource Bank}"
                                Style="{StaticResource BankIconStyle}" />
                            <components:Icon
                                Margin="10"
                                Color="{Binding Background, ElementName=AccentBorder, Converter={StaticResource BrushToLighterBrushConverter}}"
                                Path="{StaticResource CreditCardAlt}"
                                Style="{StaticResource CreditIconStyle}" />
                            <components:Icon
                                Margin="10"
                                Color="{Binding Background, ElementName=AccentBorder, Converter={StaticResource BrushToLighterBrushConverter}}"
                                Path="{StaticResource PiggyBank}">
                                <components:Icon.Style>
                                    <Style TargetType="components:Icon">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding SpendingSourceType}" Value="Saving">
                                                <Setter Property="Visibility" Value="Visible" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </components:Icon.Style>
                            </components:Icon>
                        </Grid>
                    </Border>

                    <StackPanel Grid.Column="2" VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock
                                FontFamily="{StaticResource Bold}"
                                FontSize="13"
                                Foreground="{StaticResource Brush.Text.Primary}"
                                Text="{Binding Name}" />
                            <Border
                                Width="12"
                                Height="12"
                                Margin="8,0,0,0"
                                Visibility="{Binding IsDisabled, Converter={StaticResource BoolToVisibilityConverter}}">
                                <components:Icon Path="{StaticResource LightningSlashFill}" Color="{StaticResource Brush.Danger}" />
                            </Border>
                            <Border
                                Width="12"
                                Height="12"
                                Margin="8,0,0,0"
                                Visibility="{Binding ShowOnUI, Converter={StaticResource BoolToVisibilityInvertedConverter}}">
                                <components:Icon Path="{StaticResource EyeOff}" Color="{StaticResource Brush.Warning}" />
                            </Border>
                        </StackPanel>
                        <TextBlock
                            Margin="0,6,0,0"
                            FontFamily="{StaticResource Medium}"
                            FontSize="11"
                            Foreground="{StaticResource Brush.Text.Secondary}"
                            Text="{Binding TypeDisplayName}" />
                    </StackPanel>

                    <StackPanel Grid.Column="3" VerticalAlignment="Center">
                        <TextBlock
                            HorizontalAlignment="Right"
                            FontFamily="{StaticResource Bold}"
                            FontSize="12"
                            Foreground="{StaticResource Brush.Text.Primary}"
                            ToolTip="{Binding PrimaryAmount, Mode=OneWay, Converter={StaticResource MoneyFullDisplayConverter}}">
                            <Run Text="{Binding PrimaryAmount, Mode=OneWay, Converter={StaticResource NumberWithCommasConverter}}" />
                        </TextBlock>
                        <TextBlock
                            Margin="0,6,0,0"
                            HorizontalAlignment="Right"
                            FontFamily="{StaticResource Medium}"
                            FontSize="10"
                            Foreground="{StaticResource Brush.Text.Muted}"
                            Text="{Binding PrimaryAmountLabel}" />
                    </StackPanel>
                </Grid>
            </Button>
        </DataTemplate>
    </customControls:BasePopup.Resources>

    <Grid
        Width="400"
        Height="336"
        Margin="24,0,24,24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="12" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TextBlock
            FontFamily="{StaticResource Medium}"
            FontSize="12"
            Foreground="{StaticResource Brush.Text.Secondary}"
            Text="Open any spending source to inspect or edit it." />

        <Border
            Grid.Row="2"
            Background="{StaticResource Brush.Background.Surface}"
            BorderBrush="{StaticResource Brush.Border.Subtle}"
            BorderThickness="1"
            CornerRadius="18">
            <customControls:FadingScrollViewer Margin="0,12,0,-12" VerticalScrollBarVisibility="Auto">
                <ItemsControl x:Name="SourcesList" ItemTemplate="{StaticResource SpendingSourcesListItemTemplate}" />
            </customControls:FadingScrollViewer>
        </Border>
    </Grid>
</customControls:BasePopup>
