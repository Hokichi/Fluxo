<customControls:BasePopup
    x:Class="Fluxo.Views.Popups.AddFixedExpensePopup"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:customControls="clr-namespace:Fluxo.Views.CustomControls"
    IsSaveButtonEnabled="{Binding CanSave}"
    PopupTitle="{Binding PopupTitle}"
    ShowSaveButton="True">

    <customControls:BasePopup.Resources>
        <Style x:Key="PanelStyle" TargetType="Border">
            <Setter Property="Padding" Value="18" />
            <Setter Property="Background" Value="{StaticResource Brush.Background.Elevated}" />
            <Setter Property="BorderBrush" Value="{StaticResource Brush.Border.Subtle}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="18" />
        </Style>
        <Style x:Key="FieldLabelStyle" TargetType="TextBlock">
            <Setter Property="Margin" Value="0,0,0,8" />
            <Setter Property="FontFamily" Value="{StaticResource Bold}" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Foreground" Value="{StaticResource Brush.Text.Primary}" />
        </Style>
        <DataTemplate x:Key="TagOptionTemplate">
            <StackPanel Orientation="Horizontal">
                <Ellipse
                    x:Name="TagDot"
                    Width="6"
                    Height="6"
                    VerticalAlignment="Center"
                    Fill="{Binding Tag.HexCode, FallbackValue=Transparent, TargetNullValue=Transparent}" />
                <TextBlock
                    Margin="6,0,0,0"
                    VerticalAlignment="Center"
                    FontFamily="{StaticResource Bold}"
                    Foreground="{StaticResource Brush.Text.Primary}"
                    Text="{Binding Label}" />
            </StackPanel>
            <DataTemplate.Triggers>
                <DataTrigger Binding="{Binding IsAddTagAction}" Value="True">
                    <Setter TargetName="TagDot" Property="Visibility" Value="Collapsed" />
                    <Setter TargetName="TagDot" Property="Width" Value="0" />
                    <Setter TargetName="TagDot" Property="Height" Value="0" />
                </DataTrigger>
            </DataTemplate.Triggers>
        </DataTemplate>

    </customControls:BasePopup.Resources>

    <Grid Width="480" Margin="24,0,24,24">
        <Border Style="{StaticResource PanelStyle}">
            <StackPanel>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="16" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <StackPanel>
                        <TextBlock Style="{StaticResource FieldLabelStyle}" Text="Expense Name" />
                        <TextBox
                            x:Name="NameTextBox"
                            Style="{StaticResource RoundedTextInputStyle}"
                            Text="{Binding NameText, UpdateSourceTrigger=PropertyChanged}" />

                        <TextBlock
                            Margin="0,14,0,8"
                            Style="{StaticResource FieldLabelStyle}"
                            Text="Amount" />
                        <customControls:MoneyTextBox Style="{StaticResource RoundedMoneyTextInputStyle}" Text="{Binding AmountText, UpdateSourceTrigger=PropertyChanged, Converter={StaticResource MoneyAmountToCanonicalConverter}}" />

                        <TextBlock
                            Margin="0,14,0,8"
                            Style="{StaticResource FieldLabelStyle}"
                            Text="Category" />
                        <ComboBox
                            DisplayMemberPath="Label"
                            ItemsSource="{Binding Categories}"
                            SelectedValue="{Binding SelectedCategory, Mode=TwoWay}"
                            SelectedValuePath="Value"
                            Style="{StaticResource FluxoComboBoxStyle}" />
                    </StackPanel>

                    <StackPanel Grid.Column="2">
                        <TextBlock Style="{StaticResource FieldLabelStyle}" Text="Spending Source" />
                        <ComboBox
                            DisplayMemberPath="Name"
                            ItemsSource="{Binding SpendingSourcesView}"
                            SelectedItem="{Binding SelectedSpendingSource, Mode=TwoWay}"
                            Style="{StaticResource FluxoComboBoxStyle}">
                            <ComboBox.GroupStyle>
                                <GroupStyle HeaderTemplate="{StaticResource SpendingSourceComboGroupHeaderTemplate}" />
                            </ComboBox.GroupStyle>
                        </ComboBox>

                        <TextBlock
                            Margin="0,14,0,8"
                            Style="{StaticResource FieldLabelStyle}"
                            Text="Recurring Date" />
                        <TextBox
                            x:Name="RecurringDateTextBox"
                            DataObject.Pasting="OnRecurringDatePasting"
                            MaxLength="2"
                            PreviewKeyDown="OnRecurringDatePreviewKeyDown"
                            PreviewTextInput="OnRecurringDatePreviewTextInput"
                            Style="{StaticResource RoundedTextInputStyle}"
                            Text="{Binding RecurringDateText, UpdateSourceTrigger=PropertyChanged}"
                            ToolTip="Enter a day between 1 and 28" />

                        <TextBlock
                            Margin="0,14,0,8"
                            Style="{StaticResource FieldLabelStyle}"
                            Text="Tag" />
                        <ComboBox
                            x:Name="TagComboBox"
                            ItemTemplate="{StaticResource TagOptionTemplate}"
                            ItemsSource="{Binding TagOptions}"
                            SelectedItem="{Binding SelectedTagOption, Mode=TwoWay}"
                            SelectionChanged="OnTagSelectionChanged"
                            Style="{StaticResource FluxoComboBoxStyle}" />
                    </StackPanel>
                </Grid>
            </StackPanel>
        </Border>
    </Grid>
</customControls:BasePopup>


