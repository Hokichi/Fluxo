<c:BasePopup
    x:Class="Fluxo.Views.Popups.AddFixedExpensePopup"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:c="clr-namespace:Fluxo.Resources.CustomControls"
    xmlns:components="clr-namespace:Fluxo.Views.Components"
    Width="620"
    IsSaveButtonEnabled="{Binding CanSave}"
    PopupTitle="Add Fixed Expense"
    ShowSaveButton="True">

    <c:BasePopup.Resources>
        <Style x:Key="PanelStyle" TargetType="Border">
            <Setter Property="Padding" Value="18" />
            <Setter Property="Background" Value="{StaticResource Brush.Background.Elevated}" />
            <Setter Property="BorderBrush" Value="{StaticResource Brush.Border.Subtle}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="18" />
        </Style>
        <Style x:Key="FieldLabelStyle" TargetType="TextBlock">
            <Setter Property="Margin" Value="0,0,0,8" />
            <Setter Property="FontFamily" Value="{StaticResource Bold}" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Foreground" Value="{StaticResource Brush.Text.Primary}" />
        </Style>

    </c:BasePopup.Resources>

    <Grid Margin="24,0,24,24">
        <Border Style="{StaticResource PanelStyle}">
            <StackPanel>
                <TextBlock
                    FontFamily="{StaticResource Bold}"
                    FontSize="16"
                    Foreground="{StaticResource Brush.Text.Primary}"
                    Text="Add Fixed Expense" />
                <TextBlock
                    Margin="0,8,0,18"
                    FontFamily="{StaticResource Medium}"
                    FontSize="11"
                    Foreground="{StaticResource Brush.Text.Secondary}"
                    Text="Add a recurring expense for rent, subscriptions, bills, and similar commitments." />

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="16" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <StackPanel>
                        <TextBlock Style="{StaticResource FieldLabelStyle}" Text="Expense Name" />
                        <TextBox
                            x:Name="NameTextBox"
                            Style="{StaticResource PopupSurfaceTextBoxStyle}"
                            Text="{Binding NameText, UpdateSourceTrigger=PropertyChanged}" />

                        <TextBlock
                            Margin="0,14,0,8"
                            Style="{StaticResource FieldLabelStyle}"
                            Text="Amount" />
                        <c:MoneyTextBox Style="{StaticResource PopupSurfaceTextBoxStyle}" Text="{Binding AmountText, UpdateSourceTrigger=PropertyChanged}" />

                        <TextBlock
                            Margin="0,14,0,8"
                            Style="{StaticResource FieldLabelStyle}"
                            Text="Category" />
                        <Border
                            Padding="8,4"
                            Background="{StaticResource Brush.Background.Surface}"
                            BorderBrush="{StaticResource Brush.Border.Subtle}"
                            BorderThickness="1"
                            CornerRadius="12">
                            <ComboBox
                                DisplayMemberPath="Label"
                                ItemsSource="{Binding Categories}"
                                SelectedValue="{Binding SelectedCategory, Mode=TwoWay}"
                                SelectedValuePath="Value"
                                Style="{StaticResource FluxoComboBoxStyle}" />
                        </Border>

                        <CheckBox
                            Margin="0,16,0,0"
                            Content="Active"
                            IsChecked="{Binding IsActive, Mode=TwoWay}"
                            Style="{StaticResource ItemCheckBoxStyle}" />
                    </StackPanel>

                    <StackPanel Grid.Column="2">
                        <TextBlock Style="{StaticResource FieldLabelStyle}" Text="Spending Source" />
                        <Border
                            Padding="8,4"
                            Background="{StaticResource Brush.Background.Surface}"
                            BorderBrush="{StaticResource Brush.Border.Subtle}"
                            BorderThickness="1"
                            CornerRadius="12">
                            <ComboBox
                                DisplayMemberPath="Name"
                                ItemsSource="{Binding SpendingSources}"
                                SelectedItem="{Binding SelectedSpendingSource, Mode=TwoWay}"
                                Style="{StaticResource FluxoComboBoxStyle}" />
                        </Border>

                        <TextBlock
                            Margin="0,14,0,8"
                            Style="{StaticResource FieldLabelStyle}"
                            Text="Recurring Date" />
                        <components:DateSelector SelectedDate="{Binding DueDate, Mode=TwoWay}" />

                        <TextBlock
                            Margin="0,14,0,8"
                            Style="{StaticResource FieldLabelStyle}"
                            Text="Tag" />
                        <TextBox Style="{StaticResource PopupSurfaceTextBoxStyle}" Text="{Binding TagNameText, UpdateSourceTrigger=PropertyChanged}" />
                    </StackPanel>
                </Grid>
            </StackPanel>
        </Border>
    </Grid>
</c:BasePopup>


