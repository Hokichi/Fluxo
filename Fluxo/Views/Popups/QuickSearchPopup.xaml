<c:BasePopup
    x:Class="Fluxo.Views.Popups.QuickSearchPopup"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:c="clr-namespace:Fluxo.Resources.CustomControls"
    PopupTitle="Quick Search">

    <c:BasePopup.Resources>
        <Style x:Key="SearchTextBoxStyle" TargetType="TextBox">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{DynamicResource Brush.Text.Primary}" />
            <Setter Property="CaretBrush" Value="{DynamicResource Brush.Text.Primary}" />
            <Setter Property="FontFamily" Value="{DynamicResource Regular}" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <ScrollViewer x:Name="PART_ContentHost" Margin="0" />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SearchResultItemStyle" TargetType="Border">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="CornerRadius" Value="12" />
            <Setter Property="Padding" Value="12,10" />
            <Setter Property="Cursor" Value="Hand" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource Brush.Background.Hover}" />
                </Trigger>
            </Style.Triggers>
        </Style>
    </c:BasePopup.Resources>

    <Grid Width="450">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!--  Search Bar  -->
        <Border
            Grid.Row="0"
            Margin="16"
            Padding="12,10"
            Background="{DynamicResource Brush.Background.Surface}"
            BorderBrush="{DynamicResource Brush.Border.Subtle}"
            BorderThickness="1"
            CornerRadius="12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Path
                    Width="14"
                    Height="14"
                    VerticalAlignment="Center"
                    Data="{DynamicResource MagnifyingGlass}"
                    Fill="{DynamicResource Brush.Text.Muted}"
                    Stretch="Uniform" />

                <TextBox
                    x:Name="SearchBox"
                    Grid.Column="1"
                    Margin="10,0,0,0"
                    Style="{StaticResource SearchTextBoxStyle}"
                    TextChanged="OnSearchTextChanged" />
            </Grid>
        </Border>

        <!--  Search Results  -->
        <Border
            x:Name="ResultsBorder"
            Grid.Row="1"
            Margin="16,0,16,16"
            Visibility="Collapsed">
            <Grid>
                <TextBlock
                    x:Name="NoResultsText"
                    Padding="12,10"
                    HorizontalAlignment="Center"
                    FontFamily="{DynamicResource Medium}"
                    FontSize="14"
                    Foreground="{DynamicResource Brush.Text.Muted}"
                    Text="No expense found"
                    Visibility="Collapsed" />
                <ItemsControl x:Name="ResultsList">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border MouseLeftButtonUp="OnResultItemClick" Style="{StaticResource SearchResultItemStyle}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Margin="0,0,8,0">
                                        <TextBlock
                                            FontFamily="{DynamicResource Bold}"
                                            FontSize="13"
                                            Foreground="{DynamicResource Brush.Text.Primary}"
                                            Text="{Binding Expense.Name}"
                                            TextTrimming="CharacterEllipsis"
                                            TextWrapping="NoWrap" />
                                        <StackPanel Margin="0,6,0,0" Orientation="Horizontal">
                                            <TextBlock
                                                FontFamily="{DynamicResource Regular}"
                                                FontSize="10"
                                                Foreground="{DynamicResource Brush.Text.Muted}"
                                                Text="{Binding DeductedOn, Converter={StaticResource DateTimeToRelativeDateConverter}}" />

                                            <Border
                                                Margin="8,0,0,0"
                                                Padding="5,2"
                                                VerticalAlignment="Center"
                                                Background="{Binding Expense.ExpenseTag.HexCode}">
                                                <Border.CornerRadius>
                                                    <MultiBinding Converter="{StaticResource CornerRadiusConverter}">
                                                        <Binding Path="ActualWidth" RelativeSource="{RelativeSource Self}" />
                                                        <Binding Path="ActualHeight" RelativeSource="{RelativeSource Self}" />
                                                    </MultiBinding>
                                                </Border.CornerRadius>
                                                <TextBlock
                                                    VerticalAlignment="Center"
                                                    FontFamily="{DynamicResource Medium}"
                                                    FontSize="10"
                                                    Foreground="{Binding Expense.ExpenseTag.HexCode, Converter={StaticResource BrushToLighterBrushConverter}}"
                                                    Text="{Binding Expense.ExpenseTag.Name}" />
                                            </Border>
                                        </StackPanel>
                                    </StackPanel>

                                    <StackPanel
                                        Grid.Column="1"
                                        HorizontalAlignment="Right"
                                        VerticalAlignment="Center">
                                        <TextBlock
                                            HorizontalAlignment="Right"
                                            FontFamily="{DynamicResource Bold}"
                                            FontSize="13"
                                            Foreground="{DynamicResource Brush.Text.Primary}"
                                            Text="{Binding Amount, Converter={StaticResource NumberWithCommasConverter}, StringFormat={}${0}}" />
                                        <TextBlock
                                            MaxWidth="120"
                                            Margin="0,6,0,0"
                                            HorizontalAlignment="Right"
                                            FontFamily="{DynamicResource Regular}"
                                            FontSize="10"
                                            Foreground="{DynamicResource Brush.Text.Muted}"
                                            Text="{Binding SpendingSource.Name}"
                                            TextTrimming="CharacterEllipsis"
                                            TextWrapping="NoWrap" />
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </Grid>
        </Border>
    </Grid>
</c:BasePopup>