<customControls:BasePopup
    x:Class="Fluxo.Views.Popups.AnalyticsPopup"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:components="clr-namespace:Fluxo.Views.Components"
    xmlns:customControls="clr-namespace:Fluxo.Views.CustomControls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.WPF;assembly=LiveChartsCore.SkiaSharpView.WPF"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="clr-namespace:Fluxo.ViewModels.Popups"
    Width="1360"
    Height="900"
    MinWidth="1200"
    MinHeight="760"
    PopupTitle="Analytics"
    d:DataContext="{d:DesignInstance Type=vm:AnalyticsVM}"
    mc:Ignorable="d">

    <customControls:BasePopup.Resources>
        <Style x:Key="AnalyticsCardStyle" TargetType="Border">
            <Setter Property="Padding" Value="16" />
            <Setter Property="Background" Value="{StaticResource Brush.Background.Surface}" />
            <Setter Property="BorderBrush" Value="{StaticResource Brush.Border.Subtle}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="14" />
        </Style>

        <Style x:Key="AnalyticsCardLabelStyle" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="{StaticResource Bold}" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="Foreground" Value="{StaticResource Brush.Text.Muted}" />
        </Style>
    </customControls:BasePopup.Resources>

    <Grid Margin="24,0,24,24">
        <Border
            Padding="18"
            Background="{StaticResource Brush.Background.Elevated}"
            BorderBrush="{StaticResource Brush.Border.Subtle}"
            BorderThickness="1"
            CornerRadius="18">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="360" />
                        <RowDefinition Height="300" />
                    </Grid.RowDefinitions>

                    <!-- First row: date selectors -->
                    <StackPanel
                        Orientation="Horizontal"
                        VerticalAlignment="Center">
                        <TextBlock
                            Margin="0,0,8,0"
                            VerticalAlignment="Center"
                            FontFamily="{StaticResource Medium}"
                            Foreground="{StaticResource Brush.Text.Secondary}"
                            Text="From" />
                        <components:DateSelector SelectedDate="{Binding StartDate, Mode=TwoWay}" />

                        <TextBlock
                            Margin="16,0,8,0"
                            VerticalAlignment="Center"
                            FontFamily="{StaticResource Medium}"
                            Foreground="{StaticResource Brush.Text.Secondary}"
                            Text="To" />
                        <components:DateSelector SelectedDate="{Binding EndDate, Mode=TwoWay}" />
                    </StackPanel>

                    <!-- Second row: summary cards -->
                    <Grid Grid.Row="1" Margin="0,14,0,14">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="10" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="10" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <Border Style="{StaticResource AnalyticsCardStyle}">
                            <StackPanel>
                                <TextBlock Style="{StaticResource AnalyticsCardLabelStyle}" Text="TOTAL INCOME" />
                                <TextBlock
                                    Margin="0,6,0,0"
                                    FontFamily="{StaticResource Bold}"
                                    FontSize="26"
                                    Foreground="{StaticResource Brush.Mint}"
                                    Text="{Binding TotalIncomeText}" />
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="2" Style="{StaticResource AnalyticsCardStyle}">
                            <StackPanel>
                                <TextBlock Style="{StaticResource AnalyticsCardLabelStyle}" Text="TOTAL EXPENSE" />
                                <TextBlock
                                    Margin="0,6,0,0"
                                    FontFamily="{StaticResource Bold}"
                                    FontSize="26"
                                    Foreground="{StaticResource Brush.Danger}"
                                    Text="{Binding TotalExpenseText}" />
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="4" Style="{StaticResource AnalyticsCardStyle}">
                            <StackPanel>
                                <TextBlock Style="{StaticResource AnalyticsCardLabelStyle}" Text="NET VALUE" />
                                <TextBlock
                                    Margin="0,6,0,0"
                                    FontFamily="{StaticResource Bold}"
                                    FontSize="26"
                                    Foreground="{StaticResource Brush.Info}"
                                    Text="{Binding NetValueText}" />
                            </StackPanel>
                        </Border>
                    </Grid>

                    <!-- Third row: trend chart + donut -->
                    <Grid Grid.Row="2" Margin="0,0,0,14">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2.2*" />
                            <ColumnDefinition Width="10" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <Border Style="{StaticResource AnalyticsCardStyle}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="180" />
                                    </Grid.ColumnDefinitions>

                                    <TextBlock
                                        VerticalAlignment="Center"
                                        FontFamily="{StaticResource Bold}"
                                        FontSize="14"
                                        Foreground="{StaticResource Brush.Text.Primary}"
                                        Text="Period Trend" />

                                    <ComboBox
                                        Grid.Column="1"
                                        DisplayMemberPath="."
                                        ItemsSource="{Binding TrendModes}"
                                        SelectedItem="{Binding SelectedTrendMode, Mode=TwoWay}"
                                        Style="{StaticResource FluxoComboBoxStyle}" />
                                </Grid>

                                <lvc:CartesianChart
                                    Grid.Row="1"
                                    Margin="0,12,0,0"
                                    Series="{Binding TrendSeries}"
                                    XAxes="{Binding TrendXAxes}"
                                    YAxes="{Binding TrendYAxes}" />
                            </Grid>
                        </Border>

                        <Border Grid.Column="2" Style="{StaticResource AnalyticsCardStyle}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>

                                <TextBlock
                                    FontFamily="{StaticResource Bold}"
                                    FontSize="14"
                                    Foreground="{StaticResource Brush.Text.Primary}"
                                    Text="Needs / Wants / Invest Ratio" />

                                <lvc:PieChart
                                    Grid.Row="1"
                                    Margin="0,12,0,0"
                                    InitialRotation="-90"
                                    Series="{Binding RatioSeries}" />
                            </Grid>
                        </Border>
                    </Grid>

                    <!-- Fourth row: top tags + goals -->
                    <Grid Grid.Row="3">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="10" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <Border Style="{StaticResource AnalyticsCardStyle}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>

                                <TextBlock
                                    FontFamily="{StaticResource Bold}"
                                    FontSize="14"
                                    Foreground="{StaticResource Brush.Text.Primary}"
                                    Text="Top Spending Tags" />

                                <lvc:CartesianChart
                                    Grid.Row="1"
                                    Margin="0,12,0,0"
                                    Series="{Binding TagSeries}"
                                    XAxes="{Binding TagXAxes}"
                                    YAxes="{Binding TagYAxes}" />
                            </Grid>
                        </Border>

                        <Border Grid.Column="2" Style="{StaticResource AnalyticsCardStyle}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>

                                <TextBlock
                                    FontFamily="{StaticResource Bold}"
                                    FontSize="14"
                                    Foreground="{StaticResource Brush.Text.Primary}"
                                    Text="Goals Created In Period" />

                                <ScrollViewer Grid.Row="1" Margin="0,12,0,0" VerticalScrollBarVisibility="Auto">
                                    <ItemsControl ItemsSource="{Binding GoalsCreatedInPeriod}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border
                                                    Margin="0,0,0,10"
                                                    Padding="10"
                                                    Background="{StaticResource Brush.Background.Hover}"
                                                    BorderBrush="{StaticResource Brush.Border.Subtle}"
                                                    BorderThickness="1"
                                                    CornerRadius="10">
                                                    <StackPanel>
                                                        <Grid>
                                                            <TextBlock
                                                                FontFamily="{StaticResource Bold}"
                                                                Foreground="{StaticResource Brush.Text.Primary}"
                                                                Text="{Binding Name}" />
                                                            <TextBlock
                                                                HorizontalAlignment="Right"
                                                                FontFamily="{StaticResource Medium}"
                                                                Foreground="{StaticResource Brush.Text.Secondary}"
                                                                Text="{Binding ProgressPercent, StringFormat={}{0:F0}%}" />
                                                        </Grid>

                                                        <ProgressBar
                                                            Height="8"
                                                            Margin="0,6,0,6"
                                                            Maximum="100"
                                                            Value="{Binding ProgressPercent}" />

                                                        <TextBlock
                                                            FontFamily="{StaticResource Medium}"
                                                            FontSize="11"
                                                            Foreground="{StaticResource Brush.Text.Secondary}">
                                                            <Run Text="{Binding CurrentAmount, StringFormat={}{0:N0}}" />
                                                            <Run Text=" / " />
                                                            <Run Text="{Binding TargetAmount, StringFormat={}{0:N0}}" />
                                                            <Run Text=" - Created " />
                                                            <Run Text="{Binding CreatedOn, StringFormat={}{0:dd MMM yyyy}}" />
                                                        </TextBlock>
                                                    </StackPanel>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>
                            </Grid>
                        </Border>
                    </Grid>
                </Grid>
            </ScrollViewer>
        </Border>
    </Grid>
</customControls:BasePopup>
