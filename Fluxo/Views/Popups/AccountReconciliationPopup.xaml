<customControls:BasePopup
    x:Class="Fluxo.Views.Popups.AccountReconciliationPopup"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:customControls="clr-namespace:Fluxo.Resources.CustomControls;assembly=Fluxo.Resources"
    Width="600"
    Height="340"
    IsSaveButtonEnabled="{Binding CanSave}"
    PopupTitle="Account Reconciliation"
    Mode="SaveDiscard">

    <customControls:BasePopup.Resources>
        <Style x:Key="FieldLabelStyle" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="{StaticResource Bold}" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="Foreground" Value="{StaticResource Brush.Text.Primary}" />
        </Style>
    </customControls:BasePopup.Resources>

    <Grid Width="400" Margin="24,0,24,24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="12" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="18" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="12" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="12" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TextBlock
            Style="{StaticResource FieldLabelStyle}"
            Text="{Binding NewAmountLabel, Mode=OneWay}" />
        <customControls:MoneyTextBox
            x:Name="AmountTextBox"
            Grid.Row="2"
            Style="{StaticResource RoundedMoneyTextInputStyle}"
            Text="{Binding AmountText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, Converter={StaticResource MoneyAmountToCanonicalConverter}}" />

        <TextBlock
            Grid.Row="4"
            Style="{StaticResource FieldLabelStyle}"
            Text="Account" />
        <ComboBox
            Grid.Row="6"
            DisplayMemberPath="Name"
            ItemsSource="{Binding AccountsView}"
            SelectedItem="{Binding SelectedAccount, Mode=TwoWay}"
            Style="{StaticResource FluxoComboBoxStyle}">
            <ComboBox.GroupStyle>
                <GroupStyle HeaderTemplate="{StaticResource AccountComboGroupHeaderTemplate}" />
            </ComboBox.GroupStyle>
        </ComboBox>

        <TextBlock Grid.Row="8" Style="{StaticResource FieldLabelStyle}">
            <Run Text="{Binding CurrentAmountLabel, Mode=OneWay}" />
            <Run Text=": " />
            <Run Text="{Binding CurrentAmount, Mode=OneWay, Converter={StaticResource MoneyAmountToCanonicalConverter}}" />
        </TextBlock>
    </Grid>
</customControls:BasePopup>
