<customControls:BasePopup
    x:Class="Fluxo.Views.Popups.IoUAccountSelectionPopup"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:customControls="clr-namespace:Fluxo.Resources.CustomControls;assembly=Fluxo.Resources"
    Width="460"
    PopupTitle="Select Account"
    Mode="SaveDiscard">

    <StackPanel Margin="24,0,24,24">
        <TextBlock
            Margin="0,0,0,8"
            FontFamily="{StaticResource Bold}"
            Foreground="{StaticResource Brush.Text.Primary}"
            Text="Account" />
        <ComboBox
            x:Name="AccountComboBox"
            DisplayMemberPath="Name"
            Style="{StaticResource FluxoComboBoxStyle}" />
    </StackPanel>
</customControls:BasePopup>
