<c:BasePopup
    x:Class="Fluxo.Views.Popups.AddTagPopup"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x='http://schemas.microsoft.com/winfx/2006/xaml'
    xmlns:components='clr-namespace:Fluxo.Views.Components'
    xmlns:c="clr-namespace:Fluxo.Resources.CustomControls"
    Width="520"
    PopupTitle="Add New Tag"
    ShowSaveButton="True">

    <c:BasePopup.Resources>
        <Style x:Key="PanelStyle" TargetType="Border">
            <Setter Property="Padding" Value="18" />
            <Setter Property="Background" Value="{StaticResource Brush.Background.Elevated}" />
            <Setter Property="BorderBrush" Value="{StaticResource Brush.Border.Subtle}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="18" />
        </Style>
        <Style x:Key="FieldLabelStyle" TargetType="TextBlock">
            <Setter Property="Margin" Value="0,0,0,8" />
            <Setter Property="FontFamily" Value="{StaticResource Bold}" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Foreground" Value="{StaticResource Brush.Text.Primary}" />
        </Style>
        
        <Style x:Key="ColorSelectorListBoxStyle" TargetType="ListBox">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled" />
            <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Disabled" />
            <Setter Property="ItemContainerStyle">
                <Setter.Value>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="Margin" Value="0,0,10,10" />
                        <Setter Property="Padding" Value="0" />
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ListBoxItem">
                                    <Border
                                        x:Name="ColorChip"
                                        Width="30"
                                        Height="30"
                                        Background="{Binding HexCode}"
                                        BorderBrush="{StaticResource Brush.Border.Subtle}"
                                        BorderThickness="1"
                                        CornerRadius="15">
                                        <components:Icon Margin='8' x:Name='TickPath' Path='{StaticResource AddTagPopup.Check}' Color='{StaticResource Brush.Background.Surface}' Opacity='0' />
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="ColorChip" Property="BorderBrush" Value="{StaticResource Brush.Text.Primary}" />
                                        </Trigger>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter TargetName="ColorChip" Property="BorderBrush" Value="{StaticResource Brush.Text.Primary}" />
                                            <Setter TargetName="ColorChip" Property="BorderThickness" Value="2" />
                                            <Setter TargetName="TickPath" Property="Opacity" Value="1" />
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </Setter.Value>
            </Setter>
            <Setter Property="ItemsPanel">
                <Setter.Value>
                    <ItemsPanelTemplate>
                        <WrapPanel />
                    </ItemsPanelTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        
    </c:BasePopup.Resources>

    <Grid Margin="24,0,24,24">
        <Border Style="{StaticResource PanelStyle}">
            <StackPanel>
                <TextBlock
                    FontFamily="{StaticResource Bold}"
                    FontSize="16"
                    Foreground="{StaticResource Brush.Text.Primary}"
                    Text="Create Tag" />
                <TextBlock
                    Margin="0,8,0,18"
                    FontFamily="{StaticResource Medium}"
                    FontSize="11"
                    Foreground="{StaticResource Brush.Text.Secondary}"
                    Text="Choose a color and set a label for the tag." />

                <TextBlock Style="{StaticResource FieldLabelStyle}" Text="Tag Name" />
                <TextBox
                    x:Name="TagNameTextBox"
                    Style="{StaticResource RoundedTextInputStyle}"
                    Text="{Binding NameText, UpdateSourceTrigger=PropertyChanged}" />

                <TextBlock
                    Margin="0,14,0,8"
                    Style="{StaticResource FieldLabelStyle}"
                    Text="Color" />
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <ListBox
                        Grid.Column="0"
                        ItemsSource="{Binding ColorOptions}"
                        SelectedValue="{Binding SelectedColorHex, Mode=TwoWay}"
                        SelectedValuePath="HexCode"
                        Style="{StaticResource ColorSelectorListBoxStyle}" />
                    <Button
                        Grid.Column="1"
                        VerticalAlignment="Top"
                        Click="OnAddCustomColorClick"
                        Style="{StaticResource CustomColorButtonStyle}"
                        ToolTip="Custom color" />
                </Grid>
            </StackPanel>
        </Border>
    </Grid>
</c:BasePopup>



