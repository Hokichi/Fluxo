<c:BasePopup
    x:Class="Fluxo.Views.Popups.AddSpendingSourcePopup"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:c="clr-namespace:Fluxo.Resources.CustomControls"
    xmlns:components="clr-namespace:Fluxo.Views.Components"
    Width="620"
    PopupTitle="Add New Income Source"
    ShowSaveButton="True">

    <c:BasePopup.Resources>
        <Style x:Key="PanelStyle" TargetType="Border">
            <Setter Property="Padding" Value="18" />
            <Setter Property="Background" Value="{StaticResource Brush.Background.Elevated}" />
            <Setter Property="BorderBrush" Value="{StaticResource Brush.Border.Subtle}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="18" />
        </Style>
        <Style x:Key="FieldLabelStyle" TargetType="TextBlock">
            <Setter Property="Margin" Value="0,0,0,8" />
            <Setter Property="FontFamily" Value="{StaticResource Bold}" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Foreground" Value="{StaticResource Brush.Text.Primary}" />
        </Style>
        <Style
            x:Key="FieldTextBoxStyle"
            BasedOn="{StaticResource PopupTextInputStyle}"
            TargetType="TextBox">
            <Setter Property="Background" Value="{StaticResource Brush.Background.Surface}" />
            <Setter Property="BorderBrush" Value="{StaticResource Brush.Border.Subtle}" />
        </Style>
        <Style x:Key="SelectorToggleStyle" TargetType="CheckBox">
            <Setter Property="Margin" Value="0,0,16,0" />
            <Setter Property="Foreground" Value="{StaticResource Brush.Text.Primary}" />
            <Setter Property="FontFamily" Value="{StaticResource Medium}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <StackPanel Orientation="Horizontal">
                            <Border
                                x:Name="TickBox"
                                Width="18"
                                Height="18"
                                Margin="0,0,8,0"
                                Background="{StaticResource Brush.Background.Surface}"
                                BorderBrush="{StaticResource Brush.Border.Subtle}"
                                BorderThickness="1"
                                CornerRadius="9">
                                <Viewbox Margin="4" Stretch="Uniform">
                                    <Path
                                        x:Name="TickPath"
                                        Data="{StaticResource Check}"
                                        Fill="{StaticResource Brush.Background.Surface}"
                                        Stretch="Uniform" />
                                </Viewbox>
                            </Border>
                            <ContentPresenter VerticalAlignment="Center" />
                        </StackPanel>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="TickBox" Property="Background" Value="{StaticResource Brush.Mint}" />
                                <Setter TargetName="TickBox" Property="BorderBrush" Value="{StaticResource Brush.Mint}" />
                                <Setter TargetName="TickPath" Property="Fill" Value="{StaticResource Brush.Background.Surface}" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="TickBox" Property="Background" Value="{StaticResource Brush.Background.Hover}" />
                            </Trigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsMouseOver" Value="True" />
                                    <Condition Property="IsChecked" Value="True" />
                                </MultiTrigger.Conditions>
                                <Setter TargetName="TickBox" Property="Background" Value="{StaticResource Brush.Mint.Muted}" />
                                <Setter TargetName="TickBox" Property="BorderBrush" Value="{StaticResource Brush.Mint.Muted}" />
                            </MultiTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </c:BasePopup.Resources>

    <Grid Margin="24,0,24,24">
        <Border Style="{StaticResource PanelStyle}">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <TextBlock
                        FontFamily="{StaticResource Bold}"
                        FontSize="16"
                        Foreground="{StaticResource Brush.Text.Primary}"
                        Text="Add New Income Source" />
                    <TextBlock
                        Margin="0,8,0,18"
                        FontFamily="{StaticResource Medium}"
                        FontSize="11"
                        Foreground="{StaticResource Brush.Text.Secondary}"
                        Text="Set up a new source for checking, cash, credit, BNPL, or savings." />

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="16" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <StackPanel>
                            <TextBlock Style="{StaticResource FieldLabelStyle}" Text="Source Name" />
                            <TextBox
                                x:Name="NameTextBox"
                                Style="{StaticResource FieldTextBoxStyle}"
                                Text="{Binding NameText, UpdateSourceTrigger=PropertyChanged}" />

                            <TextBlock
                                Margin="0,14,0,8"
                                Style="{StaticResource FieldLabelStyle}"
                                Text="Source Type" />
                            <Border
                                Padding="8,4"
                                Background="{StaticResource Brush.Background.Surface}"
                                BorderBrush="{StaticResource Brush.Border.Subtle}"
                                BorderThickness="1"
                                CornerRadius="12">
                                <ComboBox
                                    DisplayMemberPath="Label"
                                    ItemsSource="{Binding SpendingSourceTypes}"
                                    SelectedValue="{Binding SelectedSpendingSourceType, Mode=TwoWay}"
                                    SelectedValuePath="Value"
                                    Style="{StaticResource FluxoComboBoxStyle}" />
                            </Border>
                        </StackPanel>

                        <StackPanel Grid.Column="2">
                            <StackPanel Visibility="{Binding IsCreditLike, Converter={StaticResource BoolToVisibilityConverter}}">
                                <TextBlock Style="{StaticResource FieldLabelStyle}" Text="Current Spent" />
                                <TextBox
                                    PreviewTextInput="OnAmountTextBoxPreviewTextInput"
                                    Style="{StaticResource FieldTextBoxStyle}"
                                    Text="{Binding SpentAmountText, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>

                            <StackPanel Margin="0,14,0,0" Visibility="{Binding IsCredit, Converter={StaticResource BoolToVisibilityConverter}}">
                                <TextBlock Style="{StaticResource FieldLabelStyle}" Text="Account Limit" />
                                <TextBox
                                    PreviewTextInput="OnAmountTextBoxPreviewTextInput"
                                    Style="{StaticResource FieldTextBoxStyle}"
                                    Text="{Binding AccountLimitText, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>

                            <StackPanel Margin="0,14,0,0" Visibility="{Binding IsCreditLike, Converter={StaticResource BoolToVisibilityConverter}}">
                                <TextBlock Style="{StaticResource FieldLabelStyle}" Text="Due Date" />
                                <components:DateSelector SelectedDate="{Binding DueDate, Mode=TwoWay}" />
                            </StackPanel>

                            <StackPanel Margin="0,0,0,0" Visibility="{Binding IsSaving, Converter={StaticResource BoolToVisibilityConverter}}">
                                <TextBlock Style="{StaticResource FieldLabelStyle}" Text="APY (%)" />
                                <TextBox
                                    PreviewTextInput="OnAmountTextBoxPreviewTextInput"
                                    Style="{StaticResource FieldTextBoxStyle}"
                                    Text="{Binding ApyText, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>
                        </StackPanel>
                    </Grid>

                    <StackPanel Margin="0,16,0,0" Orientation="Horizontal">
                        <CheckBox
                            Content="Show on dashboard"
                            IsChecked="{Binding ShowOnUI, Mode=TwoWay}"
                            Style="{StaticResource SelectorToggleStyle}" />
                        <CheckBox
                            Content="Enabled"
                            IsChecked="{Binding IsEnabled, Mode=TwoWay}"
                            Style="{StaticResource SelectorToggleStyle}" />
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>
        </Border>
    </Grid>
</c:BasePopup>