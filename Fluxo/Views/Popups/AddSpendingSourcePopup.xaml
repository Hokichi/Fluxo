<c:BasePopup
    x:Class="Fluxo.Views.Popups.AddSpendingSourcePopup"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x='http://schemas.microsoft.com/winfx/2006/xaml'
    xmlns:c="clr-namespace:Fluxo.Resources.CustomControls"
    Width="620"
    IsSaveButtonEnabled="{Binding CanSave}"
    PopupTitle="Add New Income Source"
    ShowSaveButton="True">

    <c:BasePopup.Resources>
        <Style x:Key="PanelStyle" TargetType="Border">
            <Setter Property="Padding" Value="18" />
            <Setter Property="Background" Value="{StaticResource Brush.Background.Elevated}" />
            <Setter Property="BorderBrush" Value="{StaticResource Brush.Border.Subtle}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="18" />
        </Style>
        <Style x:Key="FieldLabelStyle" TargetType="TextBlock">
            <Setter Property="Margin" Value="0,0,0,8" />
            <Setter Property="FontFamily" Value="{StaticResource Bold}" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Foreground" Value="{StaticResource Brush.Text.Primary}" />
        </Style>
    </c:BasePopup.Resources>

    <Grid Margin="24,0,24,24">
        <Border Style="{StaticResource PanelStyle}">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <TextBlock
                        FontFamily="{StaticResource Bold}"
                        FontSize="16"
                        Foreground="{StaticResource Brush.Text.Primary}"
                        Text="Add New Income Source" />
                    <TextBlock
                        Margin="0,8,0,18"
                        FontFamily="{StaticResource Medium}"
                        FontSize="11"
                        Foreground="{StaticResource Brush.Text.Secondary}"
                        Text="Set up a new source for checking, cash, credit, BNPL, or savings." />

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="16" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <StackPanel>
                            <TextBlock Style="{StaticResource FieldLabelStyle}" Text="Source Name" />
                            <TextBox
                                x:Name="NameTextBox"
                                Style="{StaticResource RoundedTextInputStyle}"
                                Text="{Binding NameText, UpdateSourceTrigger=PropertyChanged}" />

                            <TextBlock
                                Margin="0,14,0,8"
                                Style="{StaticResource FieldLabelStyle}"
                                Text="Source Type" />
                            <ComboBox
                                DisplayMemberPath="Label"
                                ItemsSource="{Binding SpendingSourceTypes}"
                                SelectedValue="{Binding SelectedSpendingSourceType, Mode=TwoWay}"
                                SelectedValuePath="Value"
                                Style="{StaticResource FluxoComboBoxStyle}" />
                        </StackPanel>

                        <StackPanel Grid.Column="2">
                            <StackPanel Visibility="{Binding IsCashLike, Converter={StaticResource BoolToVisibilityConverter}}">
                                <TextBlock Style="{StaticResource FieldLabelStyle}" Text="Current Amount" />
                                <c:MoneyTextBox Style="{StaticResource RoundedTextInputStyle}" Text="{Binding PrimaryAmountText, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>

                            <StackPanel Visibility="{Binding IsCreditLike, Converter={StaticResource BoolToVisibilityConverter}}">
                                <TextBlock Style="{StaticResource FieldLabelStyle}" Text="Current Spent" />
                                <c:MoneyTextBox Style="{StaticResource RoundedTextInputStyle}" Text="{Binding SpentAmountText, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>

                            <StackPanel Margin="0,14,0,0" Visibility="{Binding IsCredit, Converter={StaticResource BoolToVisibilityConverter}}">
                                <TextBlock Style="{StaticResource FieldLabelStyle}" Text="Account Limit" />
                                <c:MoneyTextBox Style="{StaticResource RoundedTextInputStyle}" Text="{Binding AccountLimitText, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>

                            <StackPanel Margin="0,14,0,0" Visibility="{Binding IsCreditLike, Converter={StaticResource BoolToVisibilityConverter}}">
                                <TextBlock Style="{StaticResource FieldLabelStyle}" Text="Due Date" />
                                <TextBox
                                    x:Name="MonthlyDueDateTextBox"
                                    DataObject.Pasting="OnMonthlyDueDatePasting"
                                    MaxLength="2"
                                    PreviewKeyDown="OnMonthlyDueDatePreviewKeyDown"
                                    PreviewTextInput="OnMonthlyDueDatePreviewTextInput"
                                    Style="{StaticResource RoundedTextInputStyle}"
                                    Text="{Binding MonthlyDueDateText, UpdateSourceTrigger=PropertyChanged}"
                                    ToolTip="Enter a day between 1 and 28" />
                            </StackPanel>

                            <StackPanel Margin="0,14,0,0" Visibility="{Binding IsCreditLike, Converter={StaticResource BoolToVisibilityConverter}}">
                                <TextBlock Style="{StaticResource FieldLabelStyle}" Text="Deduct Source" />
                                <ComboBox
                                    DisplayMemberPath="Name"
                                    ItemsSource="{Binding DeductSources}"
                                    SelectedValue="{Binding SelectedDeductSource, Mode=TwoWay}"
                                    SelectedValuePath="Id"
                                    Style="{StaticResource FluxoComboBoxStyle}" />
                            </StackPanel>

                            <StackPanel Visibility="{Binding IsSaving, Converter={StaticResource BoolToVisibilityConverter}}">
                                <TextBlock Style="{StaticResource FieldLabelStyle}" Text="APY (%)" />
                                <c:MoneyTextBox Style="{StaticResource RoundedTextInputStyle}" Text="{Binding ApyText, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>
                        </StackPanel>
                    </Grid>

                    <StackPanel Margin="0,16,0,0" Orientation="Horizontal">
                        <CheckBox
                            Content="Show on dashboard"
                            IsChecked="{Binding ShowOnUI, Mode=TwoWay}"
                            Margin="0,0,16,0"
                            Style="{StaticResource ItemCheckBoxWithContentStyle}" />
                        <CheckBox
                            Content="Enabled"
                            IsChecked="{Binding IsEnabled, Mode=TwoWay}"
                            Style="{StaticResource ItemCheckBoxWithContentStyle}" />
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>
        </Border>
    </Grid>
</c:BasePopup>



