<customControls:BasePopup
    x:Class="Fluxo.Views.Popups.Planning.PlanningReportPopup"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:customControls="clr-namespace:Fluxo.Views.CustomControls"
    xmlns:local="clr-namespace:Fluxo.Views.Popups.Planning"
    Width="820"
    MaxHeight="720"
    PopupTitle="Planning Report">

    <customControls:BasePopup.Resources>
        <Style x:Key="PanelStyle" TargetType="Border">
            <Setter Property="Padding" Value="18" />
            <Setter Property="Background" Value="{StaticResource Brush.Background.Elevated}" />
            <Setter Property="BorderBrush" Value="{StaticResource Brush.Border.Subtle}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="18" />
        </Style>

        <Style x:Key="RowCardStyle" TargetType="Border">
            <Setter Property="Padding" Value="12" />
            <Setter Property="Margin" Value="0,0,0,10" />
            <Setter Property="Background" Value="{StaticResource Brush.Background.Surface}" />
            <Setter Property="BorderBrush" Value="{StaticResource Brush.Border.Subtle}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="14" />
        </Style>

        <Style x:Key="FieldLabelStyle" TargetType="TextBlock">
            <Setter Property="Margin" Value="0,0,0,8" />
            <Setter Property="FontFamily" Value="{StaticResource Bold}" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Foreground" Value="{StaticResource Brush.Text.Primary}" />
        </Style>

        <Style x:Key="SubtleTextStyle" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="{StaticResource Medium}" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="Foreground" Value="{StaticResource Brush.Text.Secondary}" />
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>
    </customControls:BasePopup.Resources>

    <Grid Margin="24,0,24,24">
        <Border Style="{StaticResource PanelStyle}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <StackPanel>
                    <TextBlock FontFamily="{StaticResource Bold}" FontSize="18" Foreground="{StaticResource Brush.Text.Primary}" Text="Planning Report" />
                    <TextBlock Margin="0,8,0,0" Style="{StaticResource SubtleTextStyle}" Text="Review and adjust the in-memory planning entries. These edits are not persisted." />
                </StackPanel>

                <Border Grid.Row="1" Margin="0,18,0,18" Padding="14" Background="{StaticResource Brush.Background.Surface}" BorderBrush="{StaticResource Brush.Border.Subtle}" BorderThickness="1" CornerRadius="14">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <StackPanel>
                            <TextBlock Style="{StaticResource FieldLabelStyle}" Text="Needs" />
                            <TextBlock FontFamily="{StaticResource Bold}" FontSize="16" Foreground="{StaticResource Brush.Text.Primary}" Text="{Binding NeedsPercent, StringFormat={}{0}%}" />
                        </StackPanel>
                        <StackPanel Grid.Column="1">
                            <TextBlock Style="{StaticResource FieldLabelStyle}" Text="Wants" />
                            <TextBlock FontFamily="{StaticResource Bold}" FontSize="16" Foreground="{StaticResource Brush.Text.Primary}" Text="{Binding WantsPercent, StringFormat={}{0}%}" />
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Style="{StaticResource FieldLabelStyle}" Text="Invest" />
                            <TextBlock FontFamily="{StaticResource Bold}" FontSize="16" Foreground="{StaticResource Brush.Text.Primary}" Text="{Binding InvestPercent, StringFormat={}{0}%}" />
                        </StackPanel>
                    </Grid>
                </Border>

                <ScrollViewer Grid.Row="2" MaxHeight="470" VerticalScrollBarVisibility="Auto">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="18" />
                            <ColumnDefinition Width="1.35*" />
                        </Grid.ColumnDefinitions>

                        <StackPanel>
                            <Grid Margin="0,0,0,12">
                                <TextBlock FontFamily="{StaticResource Bold}" FontSize="16" Foreground="{StaticResource Brush.Text.Primary}" Text="Incomes" />
                                <Button MinWidth="88" Padding="12,7" HorizontalAlignment="Right" Click="OnAddIncomeClick" Content="Add" />
                            </Grid>

                            <ItemsControl ItemsSource="{Binding Incomes}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Style="{StaticResource RowCardStyle}">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="10" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>

                                                <StackPanel>
                                                    <TextBlock Style="{StaticResource FieldLabelStyle}" Text="Amount" />
                                                    <TextBox Style="{StaticResource RoundedTextInputStyle}" Text="{Binding Amount, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                                </StackPanel>

                                                <Button Grid.Column="2" MinWidth="70" Padding="10,7" VerticalAlignment="Bottom" Click="OnRemoveIncomeClick" Content="Remove" />
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>

                        <StackPanel Grid.Column="2">
                            <Grid Margin="0,0,0,12">
                                <TextBlock FontFamily="{StaticResource Bold}" FontSize="16" Foreground="{StaticResource Brush.Text.Primary}" Text="Expenses" />
                                <Button MinWidth="88" Padding="12,7" HorizontalAlignment="Right" Click="OnAddExpenseClick" Content="Add" />
                            </Grid>

                            <ItemsControl ItemsSource="{Binding Expenses}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Style="{StaticResource RowCardStyle}">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="1.35*" />
                                                    <ColumnDefinition Width="10" />
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="10" />
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="10" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>

                                                <StackPanel>
                                                    <TextBlock Style="{StaticResource FieldLabelStyle}" Text="Name" />
                                                    <TextBox Style="{StaticResource RoundedTextInputStyle}" Text="{Binding Name, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                                </StackPanel>

                                                <StackPanel Grid.Column="2">
                                                    <TextBlock Style="{StaticResource FieldLabelStyle}" Text="Amount" />
                                                    <TextBox Style="{StaticResource RoundedTextInputStyle}" Text="{Binding Amount, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                                </StackPanel>

                                                <StackPanel Grid.Column="4">
                                                    <TextBlock Style="{StaticResource FieldLabelStyle}" Text="Allocation" />
                                                    <ComboBox
                                                        DisplayMemberPath="Label"
                                                        ItemsSource="{Binding AllocationCategories, RelativeSource={RelativeSource AncestorType={x:Type local:PlanningReportPopup}}}"
                                                        SelectedValue="{Binding ExpenseCategory, Mode=TwoWay}"
                                                        SelectedValuePath="Value"
                                                        Style="{StaticResource FluxoComboBoxStyle}" />
                                                </StackPanel>

                                                <Button Grid.Column="6" MinWidth="70" Padding="10,7" VerticalAlignment="Bottom" Click="OnRemoveExpenseClick" Content="Remove" />
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Grid>
                </ScrollViewer>
            </Grid>
        </Border>
    </Grid>
</customControls:BasePopup>
