<customControls:BasePopup
    x:Class="Fluxo.Views.Popups.Planning.PlanningReportPopup"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:cons="clr-namespace:Fluxo.Converters"
    xmlns:customControls="clr-namespace:Fluxo.Views.CustomControls"
    xmlns:local="clr-namespace:Fluxo.Views.Popups.Planning"
    Height="760"
    MaxHeight="760"
    PopupTitle="Planning Report">

    <customControls:BasePopup.Resources>
        <cons:SourceSequenceLabelConverter x:Key="SourceSequenceLabelConverter" />

        <Style x:Key="SectionCardStyle" TargetType="Border">
            <Setter Property="Padding" Value="14" />
            <Setter Property="Background" Value="{StaticResource Brush.Background.Surface}" />
            <Setter Property="BorderBrush" Value="{StaticResource Brush.Border.Subtle}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="14" />
        </Style>

        <Style x:Key="TableContainerStyle" TargetType="Border">
            <Setter Property="Padding" Value="12" />
            <Setter Property="Background" Value="{StaticResource Brush.Background.Main}" />
            <Setter Property="BorderBrush" Value="{StaticResource Brush.Border.Subtle}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="14" />
        </Style>

        <Style x:Key="TableRowCardStyle" TargetType="Border">
            <Setter Property="Padding" Value="10" />
            <Setter Property="Margin" Value="0,0,0,8" />
            <Setter Property="Background" Value="{StaticResource Brush.Background.Surface}" />
            <Setter Property="BorderBrush" Value="{StaticResource Brush.Border.Subtle}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="10" />
        </Style>

        <Style x:Key="SummaryLabelStyle" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="{StaticResource Bold}" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="Foreground" Value="{StaticResource Brush.Text.Muted}" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
        </Style>

        <Style x:Key="TableHeaderTextStyle" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="{StaticResource Bold}" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="Foreground" Value="{StaticResource Brush.Text.Muted}" />
            <Setter Property="TextAlignment" Value="Left" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
        </Style>

        <Style
            x:Key="ReportIconBalloonButtonStyle"
            BasedOn="{StaticResource {x:Type customControls:BalloonButton}}"
            TargetType="{x:Type customControls:BalloonButton}">
            <Setter Property="Width" Value="28" />
            <Setter Property="Height" Value="{Binding RelativeSource={RelativeSource Self}, Path=Width}" />
            <Setter Property="CurveHeight" Value="8" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="IconSize" Value="8" />
            <Setter Property="Foreground" Value="{StaticResource Brush.Text.Primary}" />
            <Setter Property="DefaultBackground" Value="{StaticResource Brush.Background.Surface}" />
            <Setter Property="HoveredBackground" Value="{StaticResource Brush.Danger}" />
        </Style>

        <Style x:Key="ReportAddButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="34" />
            <Setter Property="Padding" Value="12,0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="{StaticResource Brush.Border.Subtle}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="FontFamily" Value="{StaticResource Bold}" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Foreground" Value="{StaticResource Brush.Text.Secondary}" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border
                            x:Name="AddRowButtonBorder"
                            Padding="{TemplateBinding Padding}"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="10">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="AddRowButtonBorder" Property="Background" Value="{StaticResource Brush.Background.Hover}" />
                                <Setter Property="Foreground" Value="{StaticResource Brush.Text.Primary}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </customControls:BasePopup.Resources>

    <Grid Width="1280" Margin="24,0,24,24">
        <Border
            Padding="18"
            Background="{StaticResource Brush.Background.Elevated}"
            BorderBrush="{StaticResource Brush.Border.Subtle}"
            BorderThickness="1"
            CornerRadius="18">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="16" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <StackPanel>
                    <TextBlock
                        FontFamily="{StaticResource Bold}"
                        FontSize="18"
                        Foreground="{StaticResource Brush.Text.Primary}"
                        Text="Planning Report" />
                    <TextBlock
                        Margin="0,8,0,0"
                        FontFamily="{StaticResource Medium}"
                        FontSize="11"
                        Foreground="{StaticResource Brush.Text.Secondary}"
                        Text="Review and adjust this planning snapshot. Changes are only in-memory for this report session." />
                </StackPanel>

                <Grid Grid.Row="2">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="16" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="1.1*" />
                            <ColumnDefinition Width="16" />
                            <ColumnDefinition Width="1*" />
                        </Grid.ColumnDefinitions>

                        <Border Style="{StaticResource SectionCardStyle}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>

                                <TextBlock Style="{StaticResource SummaryLabelStyle}" Text="NEEDS / WANTS / INVEST" />

                                <Grid Grid.Row="1" Margin="0,10,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="16" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>

                                    <Grid
                                        Width="180"
                                        Height="180"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center">
                                        <Canvas
                                            Width="164"
                                            Height="164"
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center">
                                            <Ellipse
                                                Width="164"
                                                Height="164"
                                                Stroke="{StaticResource Brush.Background.Hover}"
                                                StrokeThickness="18" />

                                            <Path
                                                Data="{Binding NeedsRatio, Converter={StaticResource ProgressToArcGeometryConverter}, ConverterParameter=164}"
                                                Stroke="{StaticResource Brush.Category.Needs}"
                                                StrokeEndLineCap="Flat"
                                                StrokeStartLineCap="Flat"
                                                StrokeThickness="18" />

                                            <Path
                                                Data="{Binding WantsRatio, Converter={StaticResource ProgressToArcGeometryConverter}, ConverterParameter=164}"
                                                Stroke="{StaticResource Brush.Category.Wants}"
                                                StrokeEndLineCap="Flat"
                                                StrokeStartLineCap="Flat"
                                                StrokeThickness="18">
                                                <Path.RenderTransform>
                                                    <RotateTransform Angle="{Binding WantsArcRotationDegrees}" CenterX="82" CenterY="82" />
                                                </Path.RenderTransform>
                                            </Path>

                                            <Path
                                                Data="{Binding InvestRatio, Converter={StaticResource ProgressToArcGeometryConverter}, ConverterParameter=164}"
                                                Stroke="{StaticResource Brush.Category.Investments}"
                                                StrokeEndLineCap="Flat"
                                                StrokeStartLineCap="Flat"
                                                StrokeThickness="18">
                                                <Path.RenderTransform>
                                                    <RotateTransform Angle="{Binding InvestArcRotationDegrees}" CenterX="82" CenterY="82" />
                                                </Path.RenderTransform>
                                            </Path>
                                        </Canvas>

                                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                            <TextBlock
                                                HorizontalAlignment="Center"
                                                FontFamily="{StaticResource Bold}"
                                                FontSize="12"
                                                Foreground="{StaticResource Brush.Text.Primary}"
                                                Text="ALLOCATION" />
                                            <TextBlock
                                                HorizontalAlignment="Center"
                                                FontFamily="{StaticResource Medium}"
                                                FontSize="10"
                                                Foreground="{StaticResource Brush.Text.Muted}"
                                                Text="100%" />
                                        </StackPanel>
                                    </Grid>

                                    <StackPanel Grid.Column="2" VerticalAlignment="Center">
                                        <StackPanel Margin="0,0,0,10" Orientation="Horizontal">
                                            <Ellipse
                                                Width="8"
                                                Height="8"
                                                VerticalAlignment="Center"
                                                Fill="{StaticResource Brush.Category.Needs}" />
                                            <TextBlock
                                                Margin="8,0,0,0"
                                                VerticalAlignment="Center"
                                                FontFamily="{StaticResource Bold}"
                                                FontSize="12"
                                                Foreground="{StaticResource Brush.Text.Primary}"
                                                Text="Needs" />
                                            <TextBlock
                                                Margin="8,0,0,0"
                                                VerticalAlignment="Center"
                                                FontFamily="{StaticResource Medium}"
                                                FontSize="12"
                                                Foreground="{StaticResource Brush.Text.Secondary}"
                                                Text="{Binding NeedsPercent, StringFormat={}{0}%}" />
                                        </StackPanel>

                                        <StackPanel Margin="0,0,0,10" Orientation="Horizontal">
                                            <Ellipse
                                                Width="8"
                                                Height="8"
                                                VerticalAlignment="Center"
                                                Fill="{StaticResource Brush.Category.Wants}" />
                                            <TextBlock
                                                Margin="8,0,0,0"
                                                VerticalAlignment="Center"
                                                FontFamily="{StaticResource Bold}"
                                                FontSize="12"
                                                Foreground="{StaticResource Brush.Text.Primary}"
                                                Text="Wants" />
                                            <TextBlock
                                                Margin="8,0,0,0"
                                                VerticalAlignment="Center"
                                                FontFamily="{StaticResource Medium}"
                                                FontSize="12"
                                                Foreground="{StaticResource Brush.Text.Secondary}"
                                                Text="{Binding WantsPercent, StringFormat={}{0}%}" />
                                        </StackPanel>

                                        <StackPanel Orientation="Horizontal">
                                            <Ellipse
                                                Width="8"
                                                Height="8"
                                                VerticalAlignment="Center"
                                                Fill="{StaticResource Brush.Category.Investments}" />
                                            <TextBlock
                                                Margin="8,0,0,0"
                                                VerticalAlignment="Center"
                                                FontFamily="{StaticResource Bold}"
                                                FontSize="12"
                                                Foreground="{StaticResource Brush.Text.Primary}"
                                                Text="Invest" />
                                            <TextBlock
                                                Margin="8,0,0,0"
                                                VerticalAlignment="Center"
                                                FontFamily="{StaticResource Medium}"
                                                FontSize="12"
                                                Foreground="{StaticResource Brush.Text.Secondary}"
                                                Text="{Binding InvestPercent, StringFormat={}{0}%}" />
                                        </StackPanel>
                                    </StackPanel>
                                </Grid>
                            </Grid>
                        </Border>

                        <StackPanel Grid.Column="2">
                            <Border Style="{StaticResource SectionCardStyle}">
                                <Grid>
                                    <TextBlock Style="{StaticResource SummaryLabelStyle}" Text="INCOME" />
                                    <TextBlock
                                        HorizontalAlignment="Right"
                                        FontFamily="{StaticResource Bold}"
                                        FontSize="18"
                                        Foreground="{StaticResource Brush.Success}"
                                        Text="{Binding TotalIncome, StringFormat={}{0:N0}}" />
                                </Grid>
                            </Border>

                            <Border Margin="0,10,0,0" Style="{StaticResource SectionCardStyle}">
                                <Grid>
                                    <TextBlock Style="{StaticResource SummaryLabelStyle}" Text="EXPENSES" />
                                    <TextBlock
                                        HorizontalAlignment="Right"
                                        FontFamily="{StaticResource Bold}"
                                        FontSize="18"
                                        Foreground="{StaticResource Brush.Danger}"
                                        Text="{Binding TotalExpenses, StringFormat={}{0:N0}}" />
                                </Grid>
                            </Border>

                            <Border Margin="0,10,0,0" Style="{StaticResource SectionCardStyle}">
                                <Grid>
                                    <TextBlock Style="{StaticResource SummaryLabelStyle}" Text="BALANCE" />
                                    <TextBlock
                                        HorizontalAlignment="Right"
                                        FontFamily="{StaticResource Bold}"
                                        FontSize="18"
                                        Foreground="{StaticResource Brush.Text.Primary}"
                                        Text="{Binding Balance, StringFormat={}{0:N0}}" />
                                </Grid>
                            </Border>
                        </StackPanel>
                    </Grid>

                    <Grid Grid.Row="2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="16" />
                            <ColumnDefinition Width="1.4*" />
                        </Grid.ColumnDefinitions>

                        <StackPanel>
                            <TextBlock
                                FontFamily="{StaticResource Bold}"
                                FontSize="15"
                                Foreground="{StaticResource Brush.Text.Primary}"
                                Text="INCOME" />
                            <TextBlock
                                Margin="0,4,0,12"
                                FontFamily="{StaticResource Medium}"
                                FontSize="11"
                                Foreground="{StaticResource Brush.Text.Secondary}"
                                Text="Edit your income rows directly." />

                            <Border>
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="*" />
                                    </Grid.RowDefinitions>

                                    <Grid Margin="2,0,0,8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="110" />
                                            <ColumnDefinition Width="12" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="36" />
                                        </Grid.ColumnDefinitions>

                                        <TextBlock Style="{StaticResource TableHeaderTextStyle}" Text="SOURCE" />
                                        <TextBlock
                                            Grid.Column="2"
                                            Style="{StaticResource TableHeaderTextStyle}"
                                            Text="AMOUNT" />
                                    </Grid>

                                    <Border
                                        Grid.Row="1"
                                        Height="1"
                                        Margin="0,0,0,10"
                                        Background="{StaticResource Brush.Text.Muted}"
                                        Opacity="0.25" />

                                    <ScrollViewer
                                        Grid.Row="2"
                                        Height="152"
                                        VerticalScrollBarVisibility="Auto">
                                        <ItemsControl AlternationCount="1000" ItemsSource="{Binding Incomes}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Grid Margin="0,0,0,12">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="110" />
                                                            <ColumnDefinition Width="8" />
                                                            <ColumnDefinition Width="*" />
                                                            <ColumnDefinition Width="8" />
                                                            <ColumnDefinition Width="Auto" />
                                                        </Grid.ColumnDefinitions>

                                                        <TextBlock
                                                            VerticalAlignment="Center"
                                                            FontFamily="{StaticResource Bold}"
                                                            FontSize="11"
                                                            Foreground="{StaticResource Brush.Text.Secondary}"
                                                            Text="{Binding RelativeSource={RelativeSource AncestorType=ContentPresenter}, Path=(ItemsControl.AlternationIndex), Converter={StaticResource SourceSequenceLabelConverter}}" />

                                                        <customControls:MoneyTextBox
                                                            Grid.Column="2"
                                                            Style="{StaticResource PopupTextBoxStyle}"
                                                            Text="{Binding Amount, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, Converter={StaticResource MoneyAmountToCanonicalConverter}}" />

                                                        <customControls:BalloonButton
                                                            Grid.Column="4"
                                                            Margin="0,6,0,6"
                                                            VerticalAlignment="Center"
                                                            ButtonIcon="{StaticResource PopupStyles.Close}"
                                                            Click="OnRemoveIncomeClick"
                                                            Style="{StaticResource ReportIconBalloonButtonStyle}" />
                                                    </Grid>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </ScrollViewer>
                                </Grid>
                            </Border>

                            <Button
                                Margin="0,10,0,0"
                                Click="OnAddIncomeClick"
                                Content="Add Income"
                                Style="{StaticResource ReportAddButtonStyle}" />
                        </StackPanel>

                        <StackPanel Grid.Column="2">
                            <TextBlock
                                FontFamily="{StaticResource Bold}"
                                FontSize="15"
                                Foreground="{StaticResource Brush.Text.Primary}"
                                Text="EXPENSES" />
                            <TextBlock
                                Margin="0,4,0,12"
                                FontFamily="{StaticResource Medium}"
                                FontSize="11"
                                Foreground="{StaticResource Brush.Text.Secondary}"
                                Text="Update labels, amounts, and categories." />

                            <Border Style="{StaticResource TableContainerStyle}">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="*" />
                                    </Grid.RowDefinitions>

                                    <Grid Margin="2,0,0,8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="1.7*" />
                                            <ColumnDefinition Width="10" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="10" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="36" />
                                        </Grid.ColumnDefinitions>

                                        <TextBlock Style="{StaticResource TableHeaderTextStyle}" Text="NAME" />
                                        <TextBlock
                                            Grid.Column="2"
                                            Style="{StaticResource TableHeaderTextStyle}"
                                            Text="AMOUNT" />
                                        <TextBlock
                                            Grid.Column="4"
                                            Style="{StaticResource TableHeaderTextStyle}"
                                            Text="ALLOCATION" />
                                    </Grid>

                                    <Border
                                        Grid.Row="1"
                                        Height="1"
                                        Margin="0,0,0,10"
                                        Background="{StaticResource Brush.Text.Muted}"
                                        Opacity="0.25" />

                                    <ScrollViewer
                                        Grid.Row="2"
                                        Height="152"
                                        VerticalScrollBarVisibility="Auto">
                                        <ItemsControl ItemsSource="{Binding Expenses}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Grid Margin="0,0,0,12">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="1.7*" />
                                                            <ColumnDefinition Width="8" />
                                                            <ColumnDefinition Width="*" />
                                                            <ColumnDefinition Width="8" />
                                                            <ColumnDefinition Width="*" />
                                                            <ColumnDefinition Width="8" />
                                                            <ColumnDefinition Width="Auto" />
                                                        </Grid.ColumnDefinitions>

                                                        <TextBox Style="{StaticResource RoundedTextInputStyle}" Text="{Binding Name, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                                                        <customControls:MoneyTextBox
                                                            Grid.Column="2"
                                                            AllowDecimal="False"
                                                            Language="en-US"
                                                            Style="{StaticResource RoundedMoneyTextInputStyle}"
                                                            Text="{Binding Amount, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, Converter={StaticResource MoneyAmountToCanonicalConverter}, ConverterParameter='NoDecimal;Comma'}"
                                                            UseCommaAsGroupSeparator="True" />

                                                        <ComboBox
                                                            Grid.Column="4"
                                                            DisplayMemberPath="Label"
                                                            ItemsSource="{Binding AllocationCategories, RelativeSource={RelativeSource AncestorType={x:Type local:PlanningReportPopup}}}"
                                                            SelectedValue="{Binding ExpenseCategory, Mode=TwoWay}"
                                                            SelectedValuePath="Value"
                                                            Style="{StaticResource FluxoComboBoxStyle}" />

                                                        <customControls:BalloonButton
                                                            Grid.Column="6"
                                                            Margin="0,6,0,6"
                                                            VerticalAlignment="Center"
                                                            ButtonIcon="{StaticResource PopupStyles.Close}"
                                                            Click="OnRemoveExpenseClick"
                                                            Style="{StaticResource ReportIconBalloonButtonStyle}" />
                                                    </Grid>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </ScrollViewer>
                                </Grid>
                            </Border>

                            <Button
                                Margin="0,10,0,0"
                                Click="OnAddExpenseClick"
                                Content="Add Expense"
                                Style="{StaticResource ReportAddButtonStyle}" />
                        </StackPanel>
                    </Grid>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</customControls:BasePopup>
