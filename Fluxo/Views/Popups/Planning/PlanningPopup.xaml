<customControls:BasePopup
    x:Class="Fluxo.Views.Popups.Planning.PlanningPopup"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:customControls="clr-namespace:Fluxo.Views.CustomControls"
    xmlns:local="clr-namespace:Fluxo.Views.Popups.Planning"
    Width="760"
    MaxHeight="720"
    PopupTitle="Planning">

    <customControls:BasePopup.Resources>
        <Style x:Key="PanelStyle" TargetType="Border">
            <Setter Property="Padding" Value="18" />
            <Setter Property="Background" Value="{StaticResource Brush.Background.Elevated}" />
            <Setter Property="BorderBrush" Value="{StaticResource Brush.Border.Subtle}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="18" />
        </Style>

        <Style x:Key="RowCardStyle" TargetType="Border">
            <Setter Property="Padding" Value="12" />
            <Setter Property="Margin" Value="0,0,0,10" />
            <Setter Property="Background" Value="{StaticResource Brush.Background.Surface}" />
            <Setter Property="BorderBrush" Value="{StaticResource Brush.Border.Subtle}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="14" />
        </Style>

        <Style x:Key="FieldLabelStyle" TargetType="TextBlock">
            <Setter Property="Margin" Value="0,0,0,8" />
            <Setter Property="FontFamily" Value="{StaticResource Bold}" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Foreground" Value="{StaticResource Brush.Text.Primary}" />
        </Style>

        <Style x:Key="SubtleTextStyle" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="{StaticResource Medium}" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="Foreground" Value="{StaticResource Brush.Text.Secondary}" />
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>
    </customControls:BasePopup.Resources>

    <Grid Margin="24,0,24,24">
        <Border Style="{StaticResource PanelStyle}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <StackPanel>
                    <TextBlock
                        FontFamily="{StaticResource Bold}"
                        FontSize="18"
                        Foreground="{StaticResource Brush.Text.Primary}"
                        Text="Plan your cash flow" />
                    <TextBlock
                        Margin="0,8,0,0"
                        Style="{StaticResource SubtleTextStyle}"
                        Text="Add expected income, tune the allocation split, then list planned expenses for this cycle." />
                </StackPanel>

                <Grid Grid.Row="1" Margin="0,18,0,18">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="12" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="12" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Border x:Name="IncomesStepBadge" Padding="12,10" CornerRadius="14">
                        <TextBlock x:Name="IncomesStepText" FontFamily="{StaticResource Bold}" FontSize="12" Text="1. Incomes" TextAlignment="Center" />
                    </Border>
                    <Border x:Name="AllocationStepBadge" Grid.Column="2" Padding="12,10" CornerRadius="14">
                        <TextBlock x:Name="AllocationStepText" FontFamily="{StaticResource Bold}" FontSize="12" Text="2. Allocation" TextAlignment="Center" />
                    </Border>
                    <Border x:Name="ExpensesStepBadge" Grid.Column="4" Padding="12,10" CornerRadius="14">
                        <TextBlock x:Name="ExpensesStepText" FontFamily="{StaticResource Bold}" FontSize="12" Text="3. Expenses" TextAlignment="Center" />
                    </Border>
                </Grid>

                <ScrollViewer Grid.Row="2" MaxHeight="470" VerticalScrollBarVisibility="Auto">
                    <Grid>
                        <StackPanel x:Name="IncomesStepPanel">
                            <Grid Margin="0,0,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <StackPanel>
                                    <TextBlock FontFamily="{StaticResource Bold}" FontSize="16" Foreground="{StaticResource Brush.Text.Primary}" Text="Incomes" />
                                    <TextBlock Margin="0,6,0,0" Style="{StaticResource SubtleTextStyle}" Text="Enter each income amount expected for this plan." />
                                </StackPanel>

                                <Button Grid.Column="1" MinWidth="96" Padding="14,8" VerticalAlignment="Top" Click="OnAddIncomeClick" Content="Add Row" />
                            </Grid>

                            <ItemsControl ItemsSource="{Binding Incomes}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Style="{StaticResource RowCardStyle}">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="12" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>

                                                <StackPanel>
                                                    <TextBlock Style="{StaticResource FieldLabelStyle}" Text="Amount" />
                                                    <TextBox Style="{StaticResource RoundedTextInputStyle}" Text="{Binding Amount, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                                </StackPanel>

                                                <Button Grid.Column="2" MinWidth="76" Padding="12,7" VerticalAlignment="Bottom" Click="OnRemoveIncomeClick" Content="Remove" />
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <Border Padding="14" Background="{StaticResource Brush.Background.Surface}" BorderBrush="{StaticResource Brush.Border.Subtle}" BorderThickness="1" CornerRadius="14">
                                <Grid>
                                    <TextBlock FontFamily="{StaticResource Bold}" FontSize="13" Foreground="{StaticResource Brush.Text.Primary}" Text="Total income" />
                                    <TextBlock HorizontalAlignment="Right" FontFamily="{StaticResource Bold}" FontSize="16" Foreground="{StaticResource Brush.Success}" Text="{Binding TotalIncome, StringFormat={}{0:C}}" />
                                </Grid>
                            </Border>
                        </StackPanel>

                        <StackPanel x:Name="AllocationStepPanel" Visibility="Collapsed">
                            <TextBlock FontFamily="{StaticResource Bold}" FontSize="16" Foreground="{StaticResource Brush.Text.Primary}" Text="Allocation" />
                            <TextBlock Margin="0,6,0,16" Style="{StaticResource SubtleTextStyle}" Text="Split income between Needs, Wants, and Invest. The total should equal 100%." />

                            <Border Style="{StaticResource RowCardStyle}">
                                <StackPanel>
                                    <Grid>
                                        <TextBlock FontFamily="{StaticResource Bold}" FontSize="14" Foreground="{StaticResource Brush.Text.Primary}" Text="Needs" />
                                        <TextBlock HorizontalAlignment="Right" FontFamily="{StaticResource Bold}" Foreground="{StaticResource Brush.Text.Primary}" Text="{Binding NeedsPercent, StringFormat={}{0}%}" />
                                    </Grid>
                                    <Slider Margin="0,8,0,0" IsSnapToTickEnabled="True" Maximum="100" Minimum="0" TickFrequency="1" Value="{Binding NeedsPercent, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                </StackPanel>
                            </Border>

                            <Border Style="{StaticResource RowCardStyle}">
                                <StackPanel>
                                    <Grid>
                                        <TextBlock FontFamily="{StaticResource Bold}" FontSize="14" Foreground="{StaticResource Brush.Text.Primary}" Text="Wants" />
                                        <TextBlock HorizontalAlignment="Right" FontFamily="{StaticResource Bold}" Foreground="{StaticResource Brush.Text.Primary}" Text="{Binding WantsPercent, StringFormat={}{0}%}" />
                                    </Grid>
                                    <Slider Margin="0,8,0,0" IsSnapToTickEnabled="True" Maximum="100" Minimum="0" TickFrequency="1" Value="{Binding WantsPercent, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                </StackPanel>
                            </Border>

                            <Border Style="{StaticResource RowCardStyle}">
                                <StackPanel>
                                    <Grid>
                                        <TextBlock FontFamily="{StaticResource Bold}" FontSize="14" Foreground="{StaticResource Brush.Text.Primary}" Text="Invest" />
                                        <TextBlock HorizontalAlignment="Right" FontFamily="{StaticResource Bold}" Foreground="{StaticResource Brush.Text.Primary}" Text="{Binding InvestPercent, StringFormat={}{0}%}" />
                                    </Grid>
                                    <Slider Margin="0,8,0,0" IsSnapToTickEnabled="True" Maximum="100" Minimum="0" TickFrequency="1" Value="{Binding InvestPercent, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                </StackPanel>
                            </Border>

                            <Border Padding="14" Background="{StaticResource Brush.Background.Surface}" BorderBrush="{StaticResource Brush.Border.Subtle}" BorderThickness="1" CornerRadius="14">
                                <StackPanel>
                                    <Grid>
                                        <TextBlock FontFamily="{StaticResource Bold}" FontSize="13" Foreground="{StaticResource Brush.Text.Primary}" Text="Allocation total" />
                                        <TextBlock x:Name="AllocationTotalText" HorizontalAlignment="Right" FontFamily="{StaticResource Bold}" FontSize="16" Foreground="{StaticResource Brush.Text.Primary}" />
                                    </Grid>
                                    <TextBlock x:Name="AllocationValidationHint" Margin="0,8,0,0" FontFamily="{StaticResource Medium}" FontSize="11" Foreground="{StaticResource Brush.Warning}" TextWrapping="Wrap" />
                                </StackPanel>
                            </Border>
                        </StackPanel>

                        <StackPanel x:Name="ExpensesStepPanel" Visibility="Collapsed">
                            <Grid Margin="0,0,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <StackPanel>
                                    <TextBlock FontFamily="{StaticResource Bold}" FontSize="16" Foreground="{StaticResource Brush.Text.Primary}" Text="Expenses" />
                                    <TextBlock Margin="0,6,0,0" Style="{StaticResource SubtleTextStyle}" Text="Name each planned expense, enter the amount, and choose its allocation bucket." />
                                </StackPanel>

                                <Button Grid.Column="1" MinWidth="96" Padding="14,8" VerticalAlignment="Top" Click="OnAddExpenseClick" Content="Add Row" />
                            </Grid>

                            <CheckBox Margin="0,0,0,14" Checked="OnImportFixedExpensesChanged" Content="Import Fixed Expenses" FontFamily="{StaticResource Medium}" Foreground="{StaticResource Brush.Text.Primary}" Unchecked="OnImportFixedExpensesChanged" />

                            <ItemsControl ItemsSource="{Binding Expenses}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Style="{StaticResource RowCardStyle}">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="2*" />
                                                    <ColumnDefinition Width="12" />
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="12" />
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="12" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>

                                                <StackPanel>
                                                    <TextBlock Style="{StaticResource FieldLabelStyle}" Text="Name" />
                                                    <TextBox Style="{StaticResource RoundedTextInputStyle}" Text="{Binding Name, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                                </StackPanel>

                                                <StackPanel Grid.Column="2">
                                                    <TextBlock Style="{StaticResource FieldLabelStyle}" Text="Amount" />
                                                    <TextBox Style="{StaticResource RoundedTextInputStyle}" Text="{Binding Amount, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                                </StackPanel>

                                                <StackPanel Grid.Column="4">
                                                    <TextBlock Style="{StaticResource FieldLabelStyle}" Text="Allocation" />
                                                    <ComboBox
                                                        DisplayMemberPath="Label"
                                                        ItemsSource="{Binding AllocationCategories, RelativeSource={RelativeSource AncestorType={x:Type local:PlanningPopup}}}"
                                                        SelectedValue="{Binding ExpenseCategory, Mode=TwoWay}"
                                                        SelectedValuePath="Value"
                                                        Style="{StaticResource FluxoComboBoxStyle}" />
                                                </StackPanel>

                                                <Button Grid.Column="6" MinWidth="76" Padding="12,7" VerticalAlignment="Bottom" Click="OnRemoveExpenseClick" Content="Remove" />
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Grid>
                </ScrollViewer>

                <Grid Grid.Row="3" Margin="0,18,0,0">
                    <TextBlock x:Name="StepCounterText" VerticalAlignment="Center" Style="{StaticResource SubtleTextStyle}" />
                    <StackPanel HorizontalAlignment="Right" Orientation="Horizontal">
                        <Button x:Name="BackButton" MinWidth="90" Padding="16,9" Click="OnBackClick" Content="Back" />
                        <Button x:Name="NextButton" MinWidth="110" Margin="10,0,0,0" Padding="16,9" Click="OnNextOrFinishClick" />
                    </StackPanel>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</customControls:BasePopup>
