<customControls:BasePopup
    x:Class="Fluxo.Views.Popups.Planning.PlanningPopup"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:customControls="clr-namespace:Fluxo.Views.CustomControls"
    xmlns:local="clr-namespace:Fluxo.Views.Popups.Planning"
    Width="760"
    MaxHeight="720"
    PopupTitle="Planning">

    <customControls:BasePopup.Resources>
        <PathGeometry x:Key="PlanningPopup.AngleLeftPath">M9.17,11.29,13.41,7.05a1,1,0,0,1,1.42,0,1,1,0,0,1,0,1.41L11.29,12l3.54,3.54a1,1,0,0,1,0,1.41,1,1,0,0,1-.71.29,1,1,0,0,1-.71-.29L9.17,12.71A1,1,0,0,1,9.17,11.29Z</PathGeometry>
        <GeometryDrawing
            x:Key="PlanningPopup.AngleLeftIcon"
            Brush="Black"
            Geometry="{StaticResource PlanningPopup.AngleLeftPath}" />
        <GeometryDrawing
            x:Key="PlanningPopup.AngleRightIcon"
            Brush="Black"
            Geometry="{StaticResource AngleRight}" />
        <GeometryDrawing
            x:Key="PlanningPopup.CheckIcon"
            Brush="Black"
            Geometry="{StaticResource Check}" />

        <Style x:Key="PanelStyle" TargetType="Border">
            <Setter Property="Padding" Value="18" />
            <Setter Property="Background" Value="{StaticResource Brush.Background.Elevated}" />
            <Setter Property="BorderBrush" Value="{StaticResource Brush.Border.Subtle}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="18" />
        </Style>

        <Style x:Key="TableContainerStyle" TargetType="Border">
            <Setter Property="Padding" Value="12" />
            <Setter Property="Background" Value="{StaticResource Brush.Background.Main}" />
            <Setter Property="BorderBrush" Value="{StaticResource Brush.Border.Subtle}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="14" />
        </Style>

        <Style x:Key="TableRowCardStyle" TargetType="Border">
            <Setter Property="Padding" Value="10" />
            <Setter Property="Margin" Value="0,0,0,8" />
            <Setter Property="Background" Value="{StaticResource Brush.Background.Surface}" />
            <Setter Property="BorderBrush" Value="{StaticResource Brush.Border.Subtle}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="10" />
        </Style>

        <Style x:Key="FieldLabelStyle" TargetType="TextBlock">
            <Setter Property="Margin" Value="0,0,0,8" />
            <Setter Property="FontFamily" Value="{StaticResource Bold}" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Foreground" Value="{StaticResource Brush.Text.Primary}" />
        </Style>

        <Style x:Key="SubtleTextStyle" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="{StaticResource Medium}" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="Foreground" Value="{StaticResource Brush.Text.Secondary}" />
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>

        <Style x:Key="TableHeaderTextStyle" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="{StaticResource Bold}" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="Foreground" Value="{StaticResource Brush.Text.Muted}" />
            <Setter Property="TextAlignment" Value="Left" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
        </Style>

        <Style x:Key="PlannerIconBalloonButtonStyle" TargetType="{x:Type customControls:BalloonButton}">
            <Setter Property="Width" Value="28" />
            <Setter Property="Height" Value="{Binding RelativeSource={RelativeSource Self}, Path=Width}" />
            <Setter Property="CurveHeight" Value="8" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="IconSize" Value="8" />
            <Setter Property="Foreground" Value="{StaticResource Brush.Text.Primary}" />
            <Setter Property="DefaultBackground" Value="{StaticResource Brush.Background.Surface}" />
            <Setter Property="HoveredBackground" Value="{StaticResource Brush.Background.Hovered}" />
        </Style>

        <Style
            x:Key="PlannerDangerBalloonButtonStyle"
            BasedOn="{StaticResource PlannerIconBalloonButtonStyle}"
            TargetType="{x:Type customControls:BalloonButton}">
            <Setter Property="HoveredBackground" Value="{StaticResource Brush.Danger}" />
        </Style>

        <Style
            x:Key="PlannerNavBackBalloonButtonStyle"
            BasedOn="{StaticResource PlannerIconBalloonButtonStyle}"
            TargetType="{x:Type customControls:BalloonButton}">
            <Setter Property="Width" Value="36" />
            <Setter Property="IconSize" Value="10" />
        </Style>

        <Style
            x:Key="PlannerNavNextBalloonButtonStyle"
            BasedOn="{StaticResource PlannerNavBackBalloonButtonStyle}"
            TargetType="{x:Type customControls:BalloonButton}">
            <Setter Property="Foreground" Value="{StaticResource Brush.Background.Surface}" />
            <Setter Property="DefaultBackground" Value="{StaticResource Brush.Mint}" />
            <Setter Property="HoveredBackground" Value="{StaticResource Brush.Mint.Muted}" />
        </Style>

        <Style x:Key="PlannerAddRowButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="34" />
            <Setter Property="Padding" Value="12,0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="{StaticResource Brush.Border.Subtle}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="FontFamily" Value="{StaticResource Bold}" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Foreground" Value="{StaticResource Brush.Text.Secondary}" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border
                            x:Name="AddRowButtonBorder"
                            Padding="{TemplateBinding Padding}"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="10">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="AddRowButtonBorder" Property="Background" Value="{StaticResource Brush.Background.Hover}" />
                                <Setter Property="Foreground" Value="{StaticResource Brush.Text.Primary}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="AddRowButtonBorder" Property="Opacity" Value="0.45" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </customControls:BasePopup.Resources>

    <Grid Margin="24,0,24,24">
        <Border Style="{StaticResource PanelStyle}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <StackPanel>
                    <TextBlock
                        FontFamily="{StaticResource Bold}"
                        FontSize="18"
                        Foreground="{StaticResource Brush.Text.Primary}"
                        Text="Plan your cash flow" />
                    <TextBlock
                        Margin="0,8,0,0"
                        Style="{StaticResource SubtleTextStyle}"
                        Text="Add expected income, tune the allocation split, then list planned expenses for this cycle." />
                </StackPanel>

                <ScrollViewer Grid.Row="1" Margin="0,18,0,0" MaxHeight="470" VerticalScrollBarVisibility="Auto">
                    <Grid>
                        <StackPanel x:Name="IncomesStepPanel">
                            <TextBlock FontFamily="{StaticResource Bold}" FontSize="16" Foreground="{StaticResource Brush.Text.Primary}" Text="Incomes" />
                            <TextBlock Margin="0,6,0,16" Style="{StaticResource SubtleTextStyle}" Text="Enter each income amount expected for this plan." />

                            <Border Style="{StaticResource TableContainerStyle}">
                                <ItemsControl ItemsSource="{Binding Incomes}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Style="{StaticResource TableRowCardStyle}">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="8" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>

                                                    <customControls:MoneyTextBox
                                                        Style="{StaticResource RoundedTextInputStyle}"
                                                        Text="{Binding Amount, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                                                    <customControls:BalloonButton
                                                        Grid.Column="2"
                                                        Margin="0,6,0,6"
                                                        VerticalAlignment="Center"
                                                        ButtonIcon="{StaticResource PopupStyles.Close}"
                                                        Click="OnRemoveIncomeClick"
                                                        Style="{StaticResource PlannerDangerBalloonButtonStyle}" />
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </Border>

                            <Button
                                Margin="0,10,0,0"
                                Click="OnAddIncomeClick"
                                Content="Add Income"
                                Style="{StaticResource PlannerAddRowButtonStyle}" />

                            <Border Margin="0,12,0,0" Padding="14" Background="{StaticResource Brush.Background.Surface}" BorderBrush="{StaticResource Brush.Border.Subtle}" BorderThickness="1" CornerRadius="14">
                                <Grid>
                                    <TextBlock FontFamily="{StaticResource Bold}" FontSize="13" Foreground="{StaticResource Brush.Text.Primary}" Text="Total income" />
                                    <TextBlock HorizontalAlignment="Right" FontFamily="{StaticResource Bold}" FontSize="16" Foreground="{StaticResource Brush.Success}" Text="{Binding TotalIncome, StringFormat={}{0:C}}" />
                                </Grid>
                            </Border>
                        </StackPanel>

                        <StackPanel x:Name="AllocationStepPanel" Visibility="Collapsed">
                            <TextBlock FontFamily="{StaticResource Bold}" FontSize="16" Foreground="{StaticResource Brush.Text.Primary}" Text="Allocation" />
                            <TextBlock Margin="0,6,0,16" Style="{StaticResource SubtleTextStyle}" Text="Split income between Needs, Wants, and Invest. The total should equal 100%." />

                            <Border Style="{StaticResource TableRowCardStyle}">
                                <StackPanel>
                                    <Grid>
                                        <TextBlock FontFamily="{StaticResource Bold}" FontSize="14" Foreground="{StaticResource Brush.Text.Primary}" Text="Needs" />
                                        <TextBlock HorizontalAlignment="Right" FontFamily="{StaticResource Bold}" Foreground="{StaticResource Brush.Text.Primary}" Text="{Binding NeedsPercent, StringFormat={}{0}%}" />
                                    </Grid>
                                    <Slider Margin="0,8,0,0" IsSnapToTickEnabled="True" Maximum="100" Minimum="0" Style="{StaticResource BudgetSliderStyle}" TickFrequency="1" Value="{Binding NeedsPercent, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                </StackPanel>
                            </Border>

                            <Border Style="{StaticResource TableRowCardStyle}">
                                <StackPanel>
                                    <Grid>
                                        <TextBlock FontFamily="{StaticResource Bold}" FontSize="14" Foreground="{StaticResource Brush.Text.Primary}" Text="Wants" />
                                        <TextBlock HorizontalAlignment="Right" FontFamily="{StaticResource Bold}" Foreground="{StaticResource Brush.Text.Primary}" Text="{Binding WantsPercent, StringFormat={}{0}%}" />
                                    </Grid>
                                    <Slider Margin="0,8,0,0" IsSnapToTickEnabled="True" Maximum="100" Minimum="0" Style="{StaticResource BudgetSliderStyle}" TickFrequency="1" Value="{Binding WantsPercent, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                </StackPanel>
                            </Border>

                            <Border Style="{StaticResource TableRowCardStyle}">
                                <StackPanel>
                                    <Grid>
                                        <TextBlock FontFamily="{StaticResource Bold}" FontSize="14" Foreground="{StaticResource Brush.Text.Primary}" Text="Invest" />
                                        <TextBlock HorizontalAlignment="Right" FontFamily="{StaticResource Bold}" Foreground="{StaticResource Brush.Text.Primary}" Text="{Binding InvestPercent, StringFormat={}{0}%}" />
                                    </Grid>
                                    <Slider Margin="0,8,0,0" IsSnapToTickEnabled="True" Maximum="100" Minimum="0" Style="{StaticResource BudgetSliderStyle}" TickFrequency="1" Value="{Binding InvestPercent, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                </StackPanel>
                            </Border>

                            <Border Padding="14" Background="{StaticResource Brush.Background.Surface}" BorderBrush="{StaticResource Brush.Border.Subtle}" BorderThickness="1" CornerRadius="14">
                                <StackPanel>
                                    <Grid>
                                        <TextBlock FontFamily="{StaticResource Bold}" FontSize="13" Foreground="{StaticResource Brush.Text.Primary}" Text="Allocation total" />
                                        <TextBlock x:Name="AllocationTotalText" HorizontalAlignment="Right" FontFamily="{StaticResource Bold}" FontSize="16" Foreground="{StaticResource Brush.Text.Primary}" />
                                    </Grid>
                                    <TextBlock x:Name="AllocationValidationHint" Margin="0,8,0,0" FontFamily="{StaticResource Medium}" FontSize="11" Foreground="{StaticResource Brush.Warning}" TextWrapping="Wrap" />
                                </StackPanel>
                            </Border>
                        </StackPanel>

                        <StackPanel x:Name="ExpensesStepPanel" Visibility="Collapsed">
                            <TextBlock FontFamily="{StaticResource Bold}" FontSize="16" Foreground="{StaticResource Brush.Text.Primary}" Text="Expenses" />
                            <TextBlock Margin="0,6,0,0" Style="{StaticResource SubtleTextStyle}" Text="Name each planned expense, enter the amount, and choose its allocation bucket." />

                            <CheckBox
                                Margin="0,12,0,14"
                                Checked="OnImportFixedExpensesChanged"
                                Content="Import Fixed Expenses"
                                Style="{StaticResource ItemCheckBoxWithContentStyle}"
                                Unchecked="OnImportFixedExpensesChanged" />

                            <Border Style="{StaticResource TableContainerStyle}">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="*" />
                                    </Grid.RowDefinitions>

                                    <Grid Margin="2,0,0,8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="2*" />
                                            <ColumnDefinition Width="12" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="12" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="36" />
                                        </Grid.ColumnDefinitions>

                                        <TextBlock Style="{StaticResource TableHeaderTextStyle}" Text="NAME" />
                                        <TextBlock Grid.Column="2" Style="{StaticResource TableHeaderTextStyle}" Text="AMOUNT" />
                                        <TextBlock Grid.Column="4" Style="{StaticResource TableHeaderTextStyle}" Text="ALLOCATION" />
                                    </Grid>

                                    <Border
                                        Grid.Row="1"
                                        Height="1"
                                        Margin="0,0,0,10"
                                        Background="{StaticResource Brush.Text.Muted}"
                                        Opacity="0.25" />

                                    <ItemsControl Grid.Row="2" ItemsSource="{Binding Expenses}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Style="{StaticResource TableRowCardStyle}">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="2*" />
                                                            <ColumnDefinition Width="8" />
                                                            <ColumnDefinition Width="*" />
                                                            <ColumnDefinition Width="8" />
                                                            <ColumnDefinition Width="*" />
                                                            <ColumnDefinition Width="8" />
                                                            <ColumnDefinition Width="Auto" />
                                                        </Grid.ColumnDefinitions>

                                                        <TextBox Style="{StaticResource RoundedTextInputStyle}" Text="{Binding Name, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                                                        <customControls:MoneyTextBox
                                                            Grid.Column="2"
                                                            Style="{StaticResource RoundedTextInputStyle}"
                                                            Text="{Binding Amount, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                                                        <ComboBox
                                                            Grid.Column="4"
                                                            DisplayMemberPath="Label"
                                                            ItemsSource="{Binding AllocationCategories, RelativeSource={RelativeSource AncestorType={x:Type local:PlanningPopup}}}"
                                                            SelectedValue="{Binding ExpenseCategory, Mode=TwoWay}"
                                                            SelectedValuePath="Value"
                                                            Style="{StaticResource FluxoComboBoxStyle}" />

                                                        <customControls:BalloonButton
                                                            Grid.Column="6"
                                                            Margin="0,6,0,6"
                                                            VerticalAlignment="Center"
                                                            ButtonIcon="{StaticResource PopupStyles.Close}"
                                                            Click="OnRemoveExpenseClick"
                                                            Style="{StaticResource PlannerDangerBalloonButtonStyle}" />
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </Grid>
                            </Border>

                            <Button
                                Margin="0,10,0,0"
                                Click="OnAddExpenseClick"
                                Content="Add Expense"
                                Style="{StaticResource PlannerAddRowButtonStyle}" />
                        </StackPanel>
                    </Grid>
                </ScrollViewer>

                <Grid Grid.Row="2" Margin="0,18,0,0">
                    <customControls:StepNavigatorControl
                        x:Name="StepNavigator"
                        VerticalAlignment="Center"
                        CurrentStep="1"
                        StepCount="3" />

                    <StackPanel HorizontalAlignment="Right" Orientation="Horizontal">
                        <customControls:BalloonButton
                            x:Name="BackButton"
                            Margin="0,0,8,0"
                            ButtonIcon="{StaticResource PlanningPopup.AngleLeftIcon}"
                            Click="OnBackClick"
                            Style="{StaticResource PlannerNavBackBalloonButtonStyle}" />
                        <customControls:BalloonButton
                            x:Name="NextButton"
                            ButtonIcon="{StaticResource PlanningPopup.AngleRightIcon}"
                            Click="OnNextOrFinishClick"
                            Style="{StaticResource PlannerNavNextBalloonButtonStyle}" />
                    </StackPanel>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</customControls:BasePopup>
