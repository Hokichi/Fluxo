<customControls:BasePopup
    x:Class="Fluxo.Views.Popups.Planning.PlanningPopup"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:converters="clr-namespace:Fluxo.Resources.Converters;assembly=Fluxo.Resources"
    xmlns:customControls="clr-namespace:Fluxo.Resources.CustomControls;assembly=Fluxo.Resources"
    xmlns:local="clr-namespace:Fluxo.Views.Popups.Planning"
    Width="760"
    MaxHeight="720"
    PopupTitle="Planning">

    <customControls:BasePopup.Resources>
        <converters:SourceSequenceLabelConverter x:Key="SourceSequenceLabelConverter" />

        <Style x:Key="TableRowCardStyle" TargetType="Border">
            <Setter Property="Padding" Value="10" />
            <Setter Property="Margin" Value="0,0,0,8" />
            <Setter Property="Background" Value="{StaticResource Brush.Background.Surface}" />
            <Setter Property="BorderBrush" Value="{StaticResource Brush.Border.Subtle}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="10" />
        </Style>

        <Style x:Key="SubtleTextStyle" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="{StaticResource Medium}" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="Foreground" Value="{StaticResource Brush.Text.Secondary}" />
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>

        <Style x:Key="TableHeaderTextStyle" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="{StaticResource Bold}" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="Foreground" Value="{StaticResource Brush.Text.Muted}" />
            <Setter Property="TextAlignment" Value="Left" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
        </Style>

        <Style
            x:Key="PlannerDangerBalloonButtonStyle"
            BasedOn="{StaticResource {x:Type customControls:BalloonButton}}"
            TargetType="{x:Type customControls:BalloonButton}">
            <Setter Property="Width" Value="28" />
            <Setter Property="Height" Value="{Binding RelativeSource={RelativeSource Self}, Path=Width}" />
            <Setter Property="CurveHeight" Value="8" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="IconSize" Value="8" />
            <Setter Property="Foreground" Value="{StaticResource Brush.Text.Primary}" />
            <Setter Property="DefaultBackground" Value="{StaticResource Brush.Background.Surface}" />
            <Setter Property="HoveredBackground" Value="{StaticResource Brush.Danger}" />
        </Style>

        <Style x:Key="PlannerAddRowButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="34" />
            <Setter Property="Padding" Value="12,0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="{StaticResource Brush.Border.Subtle}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="FontFamily" Value="{StaticResource Bold}" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Foreground" Value="{StaticResource Brush.Text.Secondary}" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border
                            x:Name="AddRowButtonBorder"
                            Padding="{TemplateBinding Padding}"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="10">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="AddRowButtonBorder" Property="Background" Value="{StaticResource Brush.Background.Hover}" />
                                <Setter Property="Foreground" Value="{StaticResource Brush.Text.Primary}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="AddRowButtonBorder" Property="Opacity" Value="0.4" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <DataTemplate x:Key="PlanningIncomeItemTemplate">
            <Grid Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="110" />
                    <ColumnDefinition Width="8" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="8" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock
                    VerticalAlignment="Center"
                    FontFamily="{StaticResource Bold}"
                    FontSize="11"
                    Foreground="{StaticResource Brush.Text.Secondary}"
                    Text="{Binding RelativeSource={RelativeSource AncestorType=ContentPresenter}, Path=(ItemsControl.AlternationIndex), Converter={StaticResource SourceSequenceLabelConverter}}" />

                <customControls:MoneyTextBox
                    Grid.Column="2"
                    AllowDecimal="False"
                    Language="en-US"
                    Style="{StaticResource RoundedMoneyTextInputStyle}"
                    Text="{Binding Amount, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, Converter={StaticResource MoneyAmountToCanonicalConverter}, ConverterParameter='NoDecimal;Comma'}"
                    UseCommaAsGroupSeparator="True" />

                <customControls:BalloonButton
                    Grid.Column="4"
                    Margin="0,6,0,6"
                    VerticalAlignment="Center"
                    ButtonIcon="{StaticResource Close}"
                    Click="OnRemoveIncomeClick"
                    Style="{StaticResource PlannerDangerBalloonButtonStyle}" />
            </Grid>
        </DataTemplate>

        <DataTemplate x:Key="PlanningExpenseItemTemplate">
            <Grid Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*" />
                    <ColumnDefinition Width="8" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="8" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="8" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBox Style="{StaticResource RoundedTextInputStyle}" Text="{Binding Name, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                <customControls:MoneyTextBox
                    Grid.Column="2"
                    Language="en-US"
                    Style="{StaticResource RoundedMoneyTextInputStyle}"
                    Text="{Binding Amount, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, Converter={StaticResource MoneyAmountToCanonicalConverter}}" />

                <ComboBox
                    Grid.Column="4"
                    DisplayMemberPath="Label"
                    ItemsSource="{Binding AllocationCategories, RelativeSource={RelativeSource AncestorType={x:Type local:PlanningPopup}}}"
                    SelectedValue="{Binding ExpenseCategory, Mode=TwoWay}"
                    SelectedValuePath="Value"
                    Style="{StaticResource FluxoComboBoxStyle}" />

                <customControls:BalloonButton
                    Grid.Column="6"
                    Margin="0,6,0,6"
                    VerticalAlignment="Center"
                    ButtonIcon="{StaticResource Close}"
                    Click="OnRemoveExpenseClick"
                    Style="{StaticResource PlannerDangerBalloonButtonStyle}" />
            </Grid>
        </DataTemplate>
    </customControls:BasePopup.Resources>

    <Grid Margin="24,0,24,24" PreviewKeyDown="OnPopupPreviewKeyDown">
        <Border
            Padding="18"
            Background="{StaticResource Brush.Background.Elevated}"
            BorderBrush="{StaticResource Brush.Border.Subtle}"
            BorderThickness="1"
            CornerRadius="18">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <StackPanel>
                    <TextBlock
                        FontFamily="{StaticResource Bold}"
                        FontSize="18"
                        Foreground="{StaticResource Brush.Text.Primary}"
                        Text="Plan your cash flow" />
                    <TextBlock
                        Margin="0,8,0,0"
                        Style="{StaticResource SubtleTextStyle}"
                        Text="Add expected income, tune the allocation split, then list planned expenses for this cycle." />
                </StackPanel>

                <customControls:FadingScrollViewer
                    Grid.Row="1"
                    MaxHeight="470"
                    Margin="0,18,0,0"
                    VerticalScrollBarVisibility="Auto">
                    <Grid>
                        <StackPanel x:Name="IncomesStepPanel">
                            <TextBlock
                                FontFamily="{StaticResource Bold}"
                                FontSize="16"
                                Foreground="{StaticResource Brush.Text.Primary}"
                                Text="Incomes" />
                            <TextBlock
                                Margin="0,6,0,16"
                                Style="{StaticResource SubtleTextStyle}"
                                Text="Enter each income amount expected for this plan." />
                            <StackPanel>
                                <Grid Margin="2,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="110" />
                                        <ColumnDefinition Width="12" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="36" />
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Style="{StaticResource TableHeaderTextStyle}" Text="SOURCE" />
                                    <TextBlock
                                        Grid.Column="2"
                                        Style="{StaticResource TableHeaderTextStyle}"
                                        Text="AMOUNT" />
                                </Grid>

                                <Border
                                    Height="1"
                                    Margin="0,0,0,10"
                                    Background="{StaticResource Brush.Text.Muted}"
                                    Opacity="0.25" />

                                <customControls:FadingScrollViewer
                                    Height="240"
                                    Margin="0"
                                    HorizontalScrollBarVisibility="Disabled"
                                    VerticalScrollBarVisibility="Auto">
                                    <ItemsControl
                                        AlternationCount="1000"
                                        ItemTemplate="{StaticResource PlanningIncomeItemTemplate}"
                                        ItemsSource="{Binding Incomes}" />
                                </customControls:FadingScrollViewer>

                                <Button
                                    x:Name="AddIncomeButton"
                                    Margin="0,10,0,0"
                                    Click="OnAddIncomeClick"
                                    Content="Add Income"
                                    Style="{StaticResource PlannerAddRowButtonStyle}" />

                                <Border
                                    Height="1"
                                    Margin="0,12,0,12"
                                    Background="{StaticResource Brush.Text.Muted}"
                                    Opacity="0.2" />

                                <Grid>
                                    <TextBlock
                                        FontFamily="{StaticResource Bold}"
                                        FontSize="13"
                                        Foreground="{StaticResource Brush.Text.Primary}"
                                        Text="Total income" />
                                    <TextBlock
                                        HorizontalAlignment="Right"
                                        FontFamily="{StaticResource Bold}"
                                        FontSize="16"
                                        Foreground="{StaticResource Brush.Success}"
                                        Text="{Binding TotalIncome, StringFormat={}{0:N0}}" />
                                </Grid>
                            </StackPanel>
                        </StackPanel>

                        <StackPanel x:Name="ExpensesStepPanel" Visibility="Collapsed">
                            <TextBlock
                                FontFamily="{StaticResource Bold}"
                                FontSize="16"
                                Foreground="{StaticResource Brush.Text.Primary}"
                                Text="Expenses" />
                            <TextBlock
                                Margin="0,6,0,0"
                                Style="{StaticResource SubtleTextStyle}"
                                Text="Name each planned expense, enter the amount, and choose its allocation bucket." />

                            <CheckBox
                                x:Name="FixedExpenseImportCB"
                                Margin="0,12,0,14"
                                Checked="OnImportFixedExpensesChanged"
                                Content="Import Recurring Expense"
                                Style="{StaticResource ItemCheckBoxWithContentStyle}"
                                Unchecked="OnImportFixedExpensesChanged" />
                            <Grid Visibility="{Binding ElementName=FixedExpenseImportCB, Path=IsChecked, Converter={StaticResource BoolToVisibilityConverter}}">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>

                                <Grid Margin="2,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="2*" />
                                        <ColumnDefinition Width="12" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="12" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="36" />
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Style="{StaticResource TableHeaderTextStyle}" Text="NAME" />
                                    <TextBlock
                                        Grid.Column="2"
                                        Style="{StaticResource TableHeaderTextStyle}"
                                        Text="AMOUNT" />
                                    <TextBlock
                                        Grid.Column="4"
                                        Style="{StaticResource TableHeaderTextStyle}"
                                        Text="ALLOCATION" />
                                </Grid>

                                <Border
                                    Grid.Row="1"
                                    Height="1"
                                    Margin="0,0,0,10"
                                    Background="{StaticResource Brush.Text.Muted}"
                                    Opacity="0.25" />

                                <customControls:FadingScrollViewer
                                    Grid.Row="2"
                                    MaxHeight="240"
                                    Margin="0"
                                    HorizontalScrollBarVisibility="Disabled"
                                    VerticalScrollBarVisibility="Auto">
                                    <ItemsControl ItemTemplate="{StaticResource PlanningExpenseItemTemplate}" ItemsSource="{Binding Expenses}" />
                                </customControls:FadingScrollViewer>
                            </Grid>
                        </StackPanel>

                        <StackPanel x:Name="AllocationStepPanel" Visibility="Collapsed">
                            <TextBlock
                                FontFamily="{StaticResource Bold}"
                                FontSize="16"
                                Foreground="{StaticResource Brush.Text.Primary}"
                                Text="Allocation" />
                            <TextBlock
                                Margin="0,6,0,16"
                                Style="{StaticResource SubtleTextStyle}"
                                Text="Split income between Needs, Wants, and Invest. The total should equal 100%." />

                            <Border Style="{StaticResource TableRowCardStyle}">
                                <StackPanel>
                                    <Grid>
                                        <TextBlock
                                            FontFamily="{StaticResource Bold}"
                                            FontSize="14"
                                            Foreground="{StaticResource Brush.Text.Primary}"
                                            Text="Needs" />
                                        <TextBlock
                                            HorizontalAlignment="Right"
                                            FontFamily="{StaticResource Bold}"
                                            Foreground="{StaticResource Brush.Text.Primary}"
                                            Text="{Binding NeedsPercent, StringFormat={}{0}%}" />
                                    </Grid>
                                    <Slider
                                        Margin="0,8,0,0"
                                        IsSnapToTickEnabled="True"
                                        Maximum="100"
                                        Minimum="0"
                                        Style="{StaticResource BudgetSliderStyle}"
                                        TickFrequency="1"
                                        Value="{Binding NeedsPercent, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                </StackPanel>
                            </Border>

                            <Border Style="{StaticResource TableRowCardStyle}">
                                <StackPanel>
                                    <Grid>
                                        <TextBlock
                                            FontFamily="{StaticResource Bold}"
                                            FontSize="14"
                                            Foreground="{StaticResource Brush.Text.Primary}"
                                            Text="Wants" />
                                        <TextBlock
                                            HorizontalAlignment="Right"
                                            FontFamily="{StaticResource Bold}"
                                            Foreground="{StaticResource Brush.Text.Primary}"
                                            Text="{Binding WantsPercent, StringFormat={}{0}%}" />
                                    </Grid>
                                    <Slider
                                        Margin="0,8,0,0"
                                        IsSnapToTickEnabled="True"
                                        Maximum="100"
                                        Minimum="0"
                                        Style="{StaticResource BudgetSliderStyle}"
                                        TickFrequency="1"
                                        Value="{Binding WantsPercent, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                </StackPanel>
                            </Border>

                            <Border Style="{StaticResource TableRowCardStyle}">
                                <StackPanel>
                                    <Grid>
                                        <TextBlock
                                            FontFamily="{StaticResource Bold}"
                                            FontSize="14"
                                            Foreground="{StaticResource Brush.Text.Primary}"
                                            Text="Invest" />
                                        <TextBlock
                                            HorizontalAlignment="Right"
                                            FontFamily="{StaticResource Bold}"
                                            Foreground="{StaticResource Brush.Text.Primary}"
                                            Text="{Binding InvestPercent, StringFormat={}{0}%}" />
                                    </Grid>
                                    <Slider
                                        Margin="0,8,0,0"
                                        IsSnapToTickEnabled="True"
                                        Maximum="100"
                                        Minimum="0"
                                        Style="{StaticResource BudgetSliderStyle}"
                                        TickFrequency="1"
                                        Value="{Binding InvestPercent, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                </StackPanel>
                            </Border>

                            <Border
                                Padding="14"
                                Background="{StaticResource Brush.Background.Surface}"
                                BorderBrush="{StaticResource Brush.Border.Subtle}"
                                BorderThickness="1"
                                CornerRadius="14">
                                <StackPanel>
                                    <Grid>
                                        <TextBlock
                                            FontFamily="{StaticResource Bold}"
                                            FontSize="13"
                                            Foreground="{StaticResource Brush.Text.Primary}"
                                            Text="Allocation total" />
                                        <TextBlock
                                            x:Name="AllocationTotalText"
                                            HorizontalAlignment="Right"
                                            FontFamily="{StaticResource Bold}"
                                            FontSize="16"
                                            Foreground="{StaticResource Brush.Text.Primary}" />
                                    </Grid>
                                    <TextBlock
                                        x:Name="AllocationValidationHint"
                                        Margin="0,8,0,0"
                                        FontFamily="{StaticResource Medium}"
                                        FontSize="11"
                                        Foreground="{StaticResource Brush.Warning}"
                                        TextWrapping="Wrap" />
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Grid>
                </customControls:FadingScrollViewer>
                <Grid Grid.Row="2" Margin="0,18,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <customControls:StepNavigatorControl
                        x:Name="StepNavigator"
                        Grid.Column="0"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Center"
                        CurrentStep="1"
                        IsHitTestVisible="False"
                        StepCount="3" />

                    <StackPanel
                        Grid.Column="2"
                        HorizontalAlignment="Right"
                        Orientation="Horizontal">
                        <customControls:BalloonButton
                            x:Name="BackButton"
                            Width="36"
                            Height="36"
                            Margin="0,0,8,0"
                            ButtonIcon="{StaticResource AngleLeft}"
                            Click="OnBackClick"
                            CornerRadius="8"
                            CurveHeight="8"
                            DefaultBackground="{StaticResource Brush.Mint}"
                            Foreground="{StaticResource Brush.Background.Surface}"
                            HoveredBackground="{StaticResource Brush.Mint.Muted}"
                            IconSize="11" />
                        <customControls:BalloonButton
                            x:Name="NextButton"
                            Width="36"
                            Height="36"
                            ButtonIcon="{StaticResource AngleRight}"
                            Click="OnNextOrFinishClick"
                            CornerRadius="8"
                            CurveHeight="8"
                            DefaultBackground="{StaticResource Brush.Mint}"
                            Foreground="{StaticResource Brush.Background.Surface}"
                            HoveredBackground="{StaticResource Brush.Mint.Muted}"
                            IconSize="11" />
                    </StackPanel>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</customControls:BasePopup>
