<customControls:BasePopup
    x:Class="Fluxo.Views.Popups.MessageBoxPopup"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    
    xmlns:customControls="clr-namespace:Fluxo.Resources.CustomControls;assembly=Fluxo.Resources"
    xmlns:components="clr-namespace:Fluxo.Resources.Components;assembly=Fluxo.Resources"
    Width="420"
    MinWidth="420"
    MaxWidth="420"
    ShowInTaskbar="False">
<Grid Margin="24,8,24,24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="24" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="16" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border
                x:Name="IconBadge"
                Width="48"
                Height="48"
                VerticalAlignment="Top"
                CornerRadius="24">
                <components:Icon Margin="12" x:Name="MessageIcon" />
            </Border>

            <StackPanel Grid.Column="2">
                <TextBlock
                    FontFamily="{DynamicResource Bold}"
                    FontSize="14"
                    Foreground="{DynamicResource Brush.Text.Primary}"
                    Text="{Binding PopupTitle, RelativeSource={RelativeSource AncestorType=customControls:BasePopup}}"
                    TextWrapping="Wrap" />
                <TextBlock
                    x:Name="MessageTextBlock"
                    Margin="0,10,0,0"
                    FontFamily="{DynamicResource Regular}"
                    FontSize="12"
                    Foreground="{DynamicResource Brush.Text.Secondary}"
                    LineHeight="20"
                    TextWrapping="Wrap" />
            </StackPanel>
        </Grid>

        <StackPanel
            Grid.Row="2"
            HorizontalAlignment="Right"
            Orientation="Horizontal">
            <Button
                x:Name="TertiaryButton"
                Margin="0,0,8,0"
                Click="OnTertiaryButtonClick"
                Style="{StaticResource DialogActionButtonStyle}"
                Visibility="Collapsed" />
            <Button
                x:Name="SecondaryButton"
                Margin="0,0,8,0"
                Click="OnSecondaryButtonClick"
                Style="{StaticResource DialogActionButtonStyle}"
                Visibility="Collapsed" />
            <Button
                x:Name="PrimaryButton"
                Click="OnPrimaryButtonClick"
                Style="{StaticResource PrimaryDialogActionButtonStyle}" />
        </StackPanel>
    </Grid>
</customControls:BasePopup>





