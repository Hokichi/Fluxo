<c:BasePopup
    x:Class="Fluxo.Views.Popups.MessageBoxPopup"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:c="clr-namespace:Fluxo.Resources.CustomControls"
    Width="420"
    MinWidth="420"
    MaxWidth="420"
    ShowInTaskbar="False">

    <c:BasePopup.Resources>
        <Style x:Key="DialogActionButtonStyle" TargetType="Button">
            <Setter Property="MinWidth" Value="92" />
            <Setter Property="Margin" Value="0,0,0,0" />
            <Setter Property="Padding" Value="16,10" />
            <Setter Property="Background" Value="{DynamicResource Brush.Background.Surface}" />
            <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border.Subtle}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="FontFamily" Value="{DynamicResource Bold}" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Foreground" Value="{DynamicResource Brush.Text.Primary}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border
                            Padding="{TemplateBinding Padding}"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="12">
                            <ContentPresenter
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource Brush.Background.Hover}" />
                </Trigger>
                <Trigger Property="IsKeyboardFocused" Value="True">
                    <Setter Property="BorderBrush" Value="{DynamicResource Brush.Mint}" />
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Opacity" Value="0.45" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style
            x:Key="PrimaryDialogActionButtonStyle"
            BasedOn="{StaticResource DialogActionButtonStyle}"
            TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource Brush.Mint}" />
            <Setter Property="BorderBrush" Value="{DynamicResource Brush.Mint}" />
            <Setter Property="Foreground" Value="{DynamicResource Brush.Background.Surface}" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource Brush.Mint.Muted}" />
                    <Setter Property="BorderBrush" Value="{DynamicResource Brush.Mint.Muted}" />
                </Trigger>
                <Trigger Property="IsKeyboardFocused" Value="True">
                    <Setter Property="BorderBrush" Value="{DynamicResource Brush.Text.Primary}" />
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Opacity" Value="0.45" />
                </Trigger>
            </Style.Triggers>
        </Style>
    </c:BasePopup.Resources>

    <Grid Margin="24,8,24,24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="24" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="16" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border
                x:Name="IconBadge"
                Width="48"
                Height="48"
                VerticalAlignment="Top"
                CornerRadius="24">
                <Viewbox Margin="12">
                    <Path
                        x:Name="MessageIcon"
                        Stretch="Uniform" />
                </Viewbox>
            </Border>

            <StackPanel Grid.Column="2">
                <TextBlock
                    FontFamily="{DynamicResource Bold}"
                    FontSize="14"
                    Foreground="{DynamicResource Brush.Text.Primary}"
                    Text="{Binding PopupTitle, RelativeSource={RelativeSource AncestorType=c:BasePopup}}"
                    TextWrapping="Wrap" />
                <TextBlock
                    x:Name="MessageTextBlock"
                    Margin="0,10,0,0"
                    FontFamily="{DynamicResource Regular}"
                    FontSize="12"
                    Foreground="{DynamicResource Brush.Text.Secondary}"
                    LineHeight="20"
                    TextWrapping="Wrap" />
            </StackPanel>
        </Grid>

        <StackPanel
            Grid.Row="2"
            HorizontalAlignment="Right"
            Orientation="Horizontal">
            <Button
                x:Name="TertiaryButton"
                Margin="0,0,8,0"
                Click="OnTertiaryButtonClick"
                Style="{StaticResource DialogActionButtonStyle}"
                Visibility="Collapsed" />
            <Button
                x:Name="SecondaryButton"
                Margin="0,0,8,0"
                Click="OnSecondaryButtonClick"
                Style="{StaticResource DialogActionButtonStyle}"
                Visibility="Collapsed" />
            <Button
                x:Name="PrimaryButton"
                Click="OnPrimaryButtonClick"
                Style="{StaticResource PrimaryDialogActionButtonStyle}" />
        </StackPanel>
    </Grid>
</c:BasePopup>
