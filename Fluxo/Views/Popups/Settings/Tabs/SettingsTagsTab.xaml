<UserControl
    x:Class="Fluxo.Views.Popups.Settings.Tabs.SettingsTagsTab"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:customControls="clr-namespace:Fluxo.Views.CustomControls">
    <UserControl.Resources>
        <ItemsPanelTemplate x:Key="SettingsTagsItemsPanelTemplate">
            <WrapPanel />
        </ItemsPanelTemplate>

        <DataTemplate x:Key="SettingsTagDeleteButtonTemplate">
            <Button Click="OnTagDeleteClick" Style="{StaticResource TagDeleteButtonStyle}" />
        </DataTemplate>
    </UserControl.Resources>

    <Border Style="{StaticResource PanelStyle}">
        <StackPanel>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock
                    FontFamily="{StaticResource Bold}"
                    FontSize="16"
                    Foreground="{StaticResource Brush.Text.Primary}"
                    Text="Tags" />
                <customControls:BalloonButton
                    Grid.Column="1"
                    ButtonIcon="{StaticResource ButtonStyles.PlusSolid}"
                    Click="OnAddTagClick"
                    HoveredBackground="{StaticResource Brush.Mint}"
                    Style="{StaticResource ToolbarActionBalloonButtonStyle}"
                    ToolTip="Add tag" />
            </Grid>
            <TextBlock
                Margin="0,8,0,16"
                FontFamily="{StaticResource Medium}"
                FontSize="11"
                Foreground="{StaticResource Brush.Text.Secondary}"
                Text="Click to remove tags." />
            <ItemsControl
                ItemTemplate="{StaticResource SettingsTagDeleteButtonTemplate}"
                ItemsPanel="{StaticResource SettingsTagsItemsPanelTemplate}"
                ItemsSource="{Binding Tags}" />
        </StackPanel>
    </Border>
</UserControl>
