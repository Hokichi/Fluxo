<UserControl
    x:Class="Fluxo.Views.Popups.Settings.Tabs.SettingsTagsTab"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:customControls="clr-namespace:Fluxo.Resources.CustomControls;assembly=Fluxo.Resources"
    xmlns:settings="clr-namespace:Fluxo.ViewModels.Popups.Settings">
    <UserControl.Resources>
        <ItemsPanelTemplate x:Key="SettingsTagsItemsPanelTemplate">
            <customControls:SpacedUniformGrid
                Columns="2"
                HorizontalGap="16"
                VerticalGap="16" />
        </ItemsPanelTemplate>

        <DataTemplate x:Key="SettingsTagCardTemplate">
            <Border Height="120" Style="{StaticResource CardBorderStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="24" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="3" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <Ellipse
                            Width="9"
                            Height="9"
                            VerticalAlignment="Center"
                            Fill="{Binding HexCode}" />
                        <TextBlock
                            Grid.Column="1"
                            Margin="8,0"
                            VerticalAlignment="Center"
                            FontFamily="{StaticResource Bold}"
                            FontSize="13"
                            Foreground="{StaticResource Brush.Text.Primary}"
                            Text="{Binding Name}"
                            TextTrimming="CharacterEllipsis" />
                    </Grid>

                    <Grid Grid.Row="1" Margin="0,8">
                        <TextBlock
                            VerticalAlignment="Center"
                            FontFamily="{StaticResource Bold}"
                            FontSize="14"
                            Foreground="{StaticResource Brush.Text.Primary}"
                            Text="{Binding SpentText}" />
                        <TextBlock
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center"
                            FontFamily="{StaticResource Medium}"
                            FontSize="11"
                            Foreground="{StaticResource Brush.Text.Secondary}"
                            Text="{Binding LimitText}"
                            Visibility="{Binding HasSpendingLimit, Converter={StaticResource BoolToVisibilityConverter}}" />
                    </Grid>

                    <ProgressBar
                        x:Name="SpendingProgress"
                        Grid.Row="2"
                        Foreground="{StaticResource Brush.Success}"
                        Maximum="100"
                        Style="{StaticResource RoundedProgressBarStyle}"
                        Value="{Binding ProgressPercentage, Mode=OneWay}" />

                    <Grid Grid.Row="3" Margin="0,8,0,0">
                        <TextBlock
                            VerticalAlignment="Center"
                            FontFamily="{StaticResource Medium}"
                            FontSize="11"
                            Foreground="{StaticResource Brush.Text.Secondary}"
                            Text="{Binding RemainderText}"
                            Visibility="{Binding HasSpendingLimit, Converter={StaticResource BoolToVisibilityConverter}}" />
                        <Border
                            x:Name="StatusBadge"
                            Padding="7,3"
                            HorizontalAlignment="Right"
                            Background="{StaticResource Brush.Success.Dark}"
                            CornerRadius="10">
                            <TextBlock
                                x:Name="StatusText"
                                FontFamily="{StaticResource Bold}"
                                FontSize="10"
                                Foreground="{StaticResource Brush.Success}"
                                Text="{Binding PercentageText}" />
                        </Border>
                    </Grid>

                    <StackPanel
                        Grid.RowSpan="4"
                        Margin="-8,0"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Top"
                        Orientation="Horizontal">
                        <customControls:BalloonButton
                            Margin="0,0,4,0"
                            ButtonIcon="{StaticResource Pen}"
                            Click="OnEditTagClick"
                            DefaultBackground="{StaticResource Brush.BalloonButton.Background.Neutral}"
                            HoveredBackground="{StaticResource Brush.BalloonButton.Background.Neutral.Hovered}"
                            Style="{StaticResource ToolbarActionBalloonButtonStyle}"
                            ToolTip="Edit" />
                        <customControls:BalloonButton
                            ButtonIcon="{StaticResource Delete}"
                            Click="OnDeleteTagClick"
                            DefaultBackground="{StaticResource Brush.BalloonButton.Background.Neutral}"
                            HoveredBackground="{StaticResource Brush.BalloonButton.Background.Neutral.Hovered}"
                            Style="{StaticResource ToolbarActionBalloonButtonStyle}"
                            ToolTip="Delete" />
                    </StackPanel>
                </Grid>
            </Border>
            <DataTemplate.Triggers>
                <DataTrigger Binding="{Binding SpendingState}" Value="{x:Static settings:SettingsTagSpendingState.Warning}">
                    <Setter TargetName="SpendingProgress" Property="Foreground" Value="{StaticResource Brush.Warning}" />
                    <Setter TargetName="StatusBadge" Property="Background" Value="{StaticResource Brush.Warning.Dark}" />
                    <Setter TargetName="StatusText" Property="Foreground" Value="{StaticResource Brush.Warning}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding SpendingState}" Value="{x:Static settings:SettingsTagSpendingState.Danger}">
                    <Setter TargetName="SpendingProgress" Property="Foreground" Value="{StaticResource Brush.Danger}" />
                    <Setter TargetName="StatusBadge" Property="Background" Value="{StaticResource Brush.Danger.Dark}" />
                    <Setter TargetName="StatusText" Property="Foreground" Value="{StaticResource Brush.Danger}" />
                </DataTrigger>
            </DataTemplate.Triggers>
        </DataTemplate>
    </UserControl.Resources>

    <Border>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock
                    FontFamily="{StaticResource Bold}"
                    FontSize="16"
                    Foreground="{StaticResource Brush.Text.Primary}"
                    Text="Tags" />
                <customControls:BalloonButton
                    Grid.Column="1"
                    ButtonIcon="{StaticResource PlusSolid}"
                    Click="OnAddTagClick"
                    DefaultBackground="{StaticResource Brush.BalloonButton.Background.Default}"
                    HoveredBackground="{StaticResource Brush.BalloonButton.Background.Default.Hovered}"
                    Style="{StaticResource ToolbarActionBalloonButtonStyle}"
                    ToolTip="Add tag" />
            </Grid>
            <customControls:FadingScrollViewer Grid.Row="1" HorizontalScrollBarVisibility="Disabled">
                <ItemsControl
                    Margin="0,16,0,0"
                    ItemTemplate="{StaticResource SettingsTagCardTemplate}"
                    ItemsPanel="{StaticResource SettingsTagsItemsPanelTemplate}"
                    ItemsSource="{Binding Tags}"
                    Visibility="{Binding HasTags, Converter={StaticResource BoolToVisibilityConverter}}">
                    <ItemsControl.ItemContainerStyle>
                        <Style TargetType="ContentPresenter">
                            <Setter Property="HorizontalAlignment" Value="Stretch" />
                        </Style>
                    </ItemsControl.ItemContainerStyle>
                </ItemsControl>
            </customControls:FadingScrollViewer>

            <TextBlock
                Grid.Row="1"
                Margin="0,24,0,0"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                FontFamily="{StaticResource Medium}"
                FontSize="12"
                Foreground="{StaticResource Brush.Text.Secondary}"
                Text="No tags yet — add one to get started."
                Visibility="{Binding HasTags, Converter={StaticResource BoolToVisibilityInvertedConverter}}" />
        </Grid>
    </Border>
</UserControl>
