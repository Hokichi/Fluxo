<UserControl
    x:Class="Fluxo.Views.Popups.Settings.Tabs.SettingsAccountsTab"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:behaviors="clr-namespace:Fluxo.Views.Behaviors"
    xmlns:components="clr-namespace:Fluxo.Resources.Components;assembly=Fluxo.Resources"
    xmlns:customControls="clr-namespace:Fluxo.Resources.CustomControls;assembly=Fluxo.Resources">
    <UserControl.Resources>
        <DataTemplate x:Key="SettingsSourceItemTemplate">
            <StackPanel>
                <Border
                    x:Name="ItemRoot"
                    Padding="12"
                    Background="Transparent"
                    BorderBrush="Transparent"
                    BorderThickness="1"
                    CornerRadius="14"
                    PreviewMouseLeftButtonDown="OnItemMouseLeftButtonDown">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <CheckBox
                            Margin="0,0,12,0"
                            VerticalAlignment="Center"
                            IsChecked="{Binding IsChecked, Mode=TwoWay}"
                            Style="{StaticResource ItemCheckBoxStyle}"
                            Visibility="{Binding DataContext.IsAccountChecksEnabled, RelativeSource={RelativeSource AncestorType={x:Type UserControl}}, Converter={StaticResource BoolToVisibilityConverter}}" />
                        <StackPanel Grid.Column="1">
                            <TextBlock
                                FontFamily="{StaticResource Bold}"
                                Foreground="{StaticResource Brush.Text.Primary}"
                                Text="{Binding Name}" />
                            <TextBlock
                                Margin="0,5,0,0"
                                FontFamily="{StaticResource Medium}"
                                Foreground="{StaticResource Brush.Text.Secondary}"
                                Text="{Binding TypeDisplayName}" />
                        </StackPanel>
                        <TextBlock
                            Grid.Column="2"
                            Margin="16,0,0,0"
                            VerticalAlignment="Center"
                            FontFamily="{StaticResource Bold}"
                            Foreground="{StaticResource Brush.Text.Primary}"
                            ToolTip="{Binding PrimaryAmount, Mode=OneWay, Converter={StaticResource MoneyFullDisplayConverter}}">
                            <Run Text="{Binding PrimaryAmount, Mode=OneWay, Converter={StaticResource NumberWithCommasConverter}}" />
                        </TextBlock>
                        <StackPanel
                            Grid.Column="3"
                            Margin="10,0,0,0"
                            VerticalAlignment="Center"
                            Orientation="Horizontal">
                            <Border>
                                <Border.Style>
                                    <Style BasedOn="{StaticResource StateIconBadgeStyle}" TargetType="Border">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                        <Style.Triggers>
                                            <MultiDataTrigger>
                                                <MultiDataTrigger.Conditions>
                                                    <Condition Binding="{Binding IsUnpinned}" Value="True" />
                                                    <Condition Binding="{Binding IsEnabled}" Value="True" />
                                                </MultiDataTrigger.Conditions>
                                                <Setter Property="Visibility" Value="Visible" />
                                            </MultiDataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <components:Icon
                                    Margin="6"
                                    Path="{StaticResource Unpin}"
                                    Color="{StaticResource Brush.Warning}" />
                            </Border>
                            <Border Style="{StaticResource StateIconBadgeStyle}" Visibility="{Binding IsEnabled, Converter={StaticResource BoolToVisibilityInvertedConverter}}">
                                <components:Icon
                                    Margin="6"
                                    Path="{StaticResource LightningSlashFill}"
                                    Color="{StaticResource Brush.Danger}" />
                            </Border>
                        </StackPanel>
                        <StackPanel
                            x:Name="RowActions"
                            Grid.Column="4"
                            Margin="8,0,0,0"
                            VerticalAlignment="Center"
                            IsHitTestVisible="False"
                            Opacity="0"
                            Orientation="Horizontal"
                            Visibility="Collapsed">
                            <customControls:BalloonButton
                                ButtonIcon="{StaticResource Delete}"
                                Click="OnRowActionClick"
                                DefaultBackground="{StaticResource Brush.BalloonButton.Background.Destructive}"
                                HoveredBackground="{StaticResource Brush.BalloonButton.Background.Destructive.Hovered}"
                                Style="{StaticResource ToolbarActionBalloonButtonStyle}"
                                Tag="Accounts:Delete"
                                ToolTip="Delete" />
                            <customControls:BalloonButton
                                ButtonIcon="{StaticResource Unpin}"
                                Click="OnRowActionClick"
                                DefaultBackground="{StaticResource Brush.BalloonButton.Background.Surface}"
                                HoveredBackground="{StaticResource Brush.BalloonButton.Background.Surface.Hovered}"
                                Style="{StaticResource ToolbarActionBalloonButtonStyle}"
                                Tag="Accounts:Unpin"
                                ToolTip="Unpin"
                                Visibility="{Binding IsUnpinned, Converter={StaticResource BoolToVisibilityInvertedConverter}}" />
                            <customControls:BalloonButton
                                ButtonIcon="{StaticResource Pin}"
                                Click="OnRowActionClick"
                                DefaultBackground="{StaticResource Brush.BalloonButton.Background.Surface}"
                                HoveredBackground="{StaticResource Brush.BalloonButton.Background.Surface.Hovered}"
                                Style="{StaticResource ToolbarActionBalloonButtonStyle}"
                                Tag="Accounts:Pin"
                                ToolTip="Pin"
                                Visibility="{Binding IsUnpinned, Converter={StaticResource BoolToVisibilityConverter}}" />
                            <customControls:BalloonButton
                                ButtonIcon="{StaticResource LightningSlashFill}"
                                Click="OnRowActionClick"
                                DefaultBackground="{StaticResource Brush.BalloonButton.Background.Caution}"
                                HoveredBackground="{StaticResource Brush.BalloonButton.Background.Caution.Hovered}"
                                Style="{StaticResource ToolbarActionBalloonButtonStyle}"
                                Tag="Accounts:Disable"
                                ToolTip="Disable"
                                Visibility="{Binding IsEnabled, Converter={StaticResource BoolToVisibilityConverter}}" />
                            <customControls:BalloonButton
                                ButtonIcon="{StaticResource LightningFill}"
                                Click="OnRowActionClick"
                                DefaultBackground="{StaticResource Brush.BalloonButton.Background.ConfirmSave}"
                                HoveredBackground="{StaticResource Brush.BalloonButton.Background.ConfirmSave.Hovered}"
                                Style="{StaticResource ToolbarActionBalloonButtonStyle}"
                                Tag="Accounts:Enable"
                                ToolTip="Enable"
                                Visibility="{Binding IsEnabled, Converter={StaticResource BoolToVisibilityInvertedConverter}}" />
                        </StackPanel>
                    </Grid>
                </Border>
                <Border
                    Height="1.5"
                    Margin="12"
                    Background="{StaticResource Brush.Border.Subtle}" />
            </StackPanel>
            <DataTemplate.Triggers>
                <Trigger SourceName="ItemRoot" Property="IsMouseOver" Value="True">
                    <Setter TargetName="ItemRoot" Property="Background" Value="{StaticResource Brush.Background.Hover}" />
                    <Setter TargetName="ItemRoot" Property="BorderBrush" Value="{StaticResource Brush.Border.Subtle}" />
                    <Setter TargetName="RowActions" Property="Visibility" Value="Visible" />
                    <Setter TargetName="RowActions" Property="Opacity" Value="1" />
                    <Setter TargetName="RowActions" Property="IsHitTestVisible" Value="True" />
                </Trigger>
                <DataTrigger Binding="{Binding IsSelected}" Value="True">
                    <Setter TargetName="ItemRoot" Property="BorderBrush" Value="{StaticResource Brush.Mint}" />
                </DataTrigger>
            </DataTemplate.Triggers>
        </DataTemplate>
    </UserControl.Resources>

    <Border>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock
                    FontFamily="{StaticResource Bold}"
                    FontSize="16"
                    Foreground="{StaticResource Brush.Text.Primary}"
                    Text="Accounts" />
                <StackPanel
                    Grid.Column="1"
                    HorizontalAlignment="Right"
                    Orientation="Horizontal">
                    <customControls:BalloonButton
                        ButtonIcon="{StaticResource Delete}"
                        Click="OnBatchActionClick"
                        DefaultBackground="{StaticResource Brush.BalloonButton.Background.Destructive}"
                        HoveredBackground="{StaticResource Brush.BalloonButton.Background.Destructive.Hovered}"
                        Style="{StaticResource ToolbarActionBalloonButtonStyle}"
                        Tag="Accounts:Delete"
                        ToolTip="Delete selected"
                        Visibility="{Binding IsAccountChecksEnabled, Converter={StaticResource BoolToVisibilityConverter}}" />
                    <customControls:BalloonButton
                        ButtonIcon="{StaticResource Unpin}"
                        Click="OnBatchActionClick"
                        DefaultBackground="{StaticResource Brush.BalloonButton.Background.Surface}"
                        HoveredBackground="{StaticResource Brush.BalloonButton.Background.Surface.Hovered}"
                        Style="{StaticResource ToolbarActionBalloonButtonStyle}"
                        Tag="Accounts:Unpin"
                        ToolTip="Unpin selected"
                        Visibility="{Binding ShowAccountUnpinActionButton, Converter={StaticResource BoolToVisibilityConverter}}" />
                    <customControls:BalloonButton
                        ButtonIcon="{StaticResource Pin}"
                        Click="OnBatchActionClick"
                        DefaultBackground="{StaticResource Brush.BalloonButton.Background.Surface}"
                        HoveredBackground="{StaticResource Brush.BalloonButton.Background.Surface.Hovered}"
                        Style="{StaticResource ToolbarActionBalloonButtonStyle}"
                        Tag="Accounts:Pin"
                        ToolTip="Pin selected"
                        Visibility="{Binding ShowAccountPinActionButton, Converter={StaticResource BoolToVisibilityConverter}}" />
                    <customControls:BalloonButton
                        ButtonIcon="{StaticResource LightningSlashFill}"
                        Click="OnBatchActionClick"
                        DefaultBackground="{StaticResource Brush.BalloonButton.Background.Caution}"
                        HoveredBackground="{StaticResource Brush.BalloonButton.Background.Caution.Hovered}"
                        Style="{StaticResource ToolbarActionBalloonButtonStyle}"
                        Tag="Accounts:Disable"
                        ToolTip="Disable selected"
                        Visibility="{Binding ShowAccountDisableActionButton, Converter={StaticResource BoolToVisibilityConverter}}" />
                    <customControls:BalloonButton
                        ButtonIcon="{StaticResource LightningFill}"
                        Click="OnBatchActionClick"
                        DefaultBackground="{StaticResource Brush.BalloonButton.Background.ConfirmSave}"
                        HoveredBackground="{StaticResource Brush.BalloonButton.Background.ConfirmSave.Hovered}"
                        Style="{StaticResource ToolbarActionBalloonButtonStyle}"
                        Tag="Accounts:Enable"
                        ToolTip="Enable selected"
                        Visibility="{Binding ShowAccountEnableActionButton, Converter={StaticResource BoolToVisibilityConverter}}" />
                    <customControls:BalloonButton
                        ButtonIcon="{StaticResource CheckAll}"
                        Click="OnSelectionActionClick"
                        DefaultBackground="{StaticResource Brush.BalloonButton.Background.Surface}"
                        HoveredBackground="{StaticResource Brush.BalloonButton.Background.Surface.Hovered}"
                        Style="{StaticResource ToolbarActionBalloonButtonStyle}"
                        Tag="Accounts:CheckAll"
                        ToolTip="Check all"
                        Visibility="{Binding ShowAccountCheckAllButton, Converter={StaticResource BoolToVisibilityConverter}}" />
                    <customControls:BalloonButton
                        ButtonIcon="{StaticResource UncheckAll}"
                        Click="OnSelectionActionClick"
                        DefaultBackground="{StaticResource Brush.BalloonButton.Background.Surface}"
                        HoveredBackground="{StaticResource Brush.BalloonButton.Background.Surface.Hovered}"
                        Style="{StaticResource ToolbarActionBalloonButtonStyle}"
                        Tag="Accounts:UncheckAll"
                        ToolTip="Uncheck all"
                        Visibility="{Binding ShowAccountUncheckAllButton, Converter={StaticResource BoolToVisibilityConverter}}" />
                    <customControls:BalloonButton
                        ButtonIcon="{StaticResource EnableChecks}"
                        Click="OnChecksToggleClick"
                        DefaultBackground="{StaticResource Brush.BalloonButton.Background.Surface}"
                        HoveredBackground="{StaticResource Brush.BalloonButton.Background.Surface.Hovered}"
                        Style="{StaticResource ToolbarActionBalloonButtonStyle}"
                        Tag="Accounts:EnableChecks"
                        ToolTip="Enable selection"
                        Visibility="{Binding ShowAccountEnableChecksButton, Converter={StaticResource BoolToVisibilityConverter}}" />
                    <customControls:BalloonButton
                        ButtonIcon="{StaticResource DisableChecks}"
                        Click="OnChecksToggleClick"
                        DefaultBackground="{StaticResource Brush.BalloonButton.Background.Surface}"
                        HoveredBackground="{StaticResource Brush.BalloonButton.Background.Surface.Hovered}"
                        Style="{StaticResource ToolbarActionBalloonButtonStyle}"
                        Tag="Accounts:DisableChecks"
                        ToolTip="Disable selection"
                        Visibility="{Binding IsAccountChecksEnabled, Converter={StaticResource BoolToVisibilityConverter}}" />
                    <customControls:BalloonButton
                        ButtonIcon="{StaticResource PlusSolid}"
                        Click="OnAddPlaceholderClick"
                        DefaultBackground="{StaticResource Brush.BalloonButton.Background.Default}"
                        HoveredBackground="{StaticResource Brush.BalloonButton.Background.Default.Hovered}"
                        Style="{StaticResource ToolbarActionBalloonButtonStyle}"
                        Tag="Add New Account"
                        ToolTip="Add source" />
                </StackPanel>
            </Grid>
            <TextBlock
                Grid.Row="1"
                Margin="0,0,0,16"
                FontFamily="{StaticResource Medium}"
                FontSize="11"
                Foreground="{StaticResource Brush.Text.Secondary}"
                Text="Modify, disable or unpin your accounts" />
            <customControls:FadingScrollViewer
                Grid.Row="2"
                Margin="-12,8,-20,0"
                VerticalScrollBarVisibility="Auto">
                <ItemsControl
                    behaviors:ScrollOnDemandBehavior.HasMoreItems="{Binding HasMoreItems}"
                    behaviors:ScrollOnDemandBehavior.IsEnabled="True"
                    behaviors:ScrollOnDemandBehavior.IsLoading="{Binding IsLoading}"
                    behaviors:ScrollOnDemandBehavior.LoadMoreCommand="{Binding LoadMoreCommand}"
                    ItemTemplate="{StaticResource SettingsSourceItemTemplate}"
                    ItemsSource="{Binding AccountsView}" />
            </customControls:FadingScrollViewer>
            <TextBlock
                Grid.RowSpan="3"
                Margin="0,24"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                FontFamily="{StaticResource Bold}"
                FontSize="13"
                Foreground="{StaticResource Brush.Text.Secondary}"
                Text="No Account Available"
                Visibility="{Binding HasAccounts, Converter={StaticResource BoolToVisibilityInvertedConverter}}" />
        </Grid>
    </Border>
</UserControl>
