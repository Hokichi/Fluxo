<UserControl
    x:Class="Fluxo.Views.Popups.Settings.Tabs.SettingsBudgetTab"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:customControls="clr-namespace:Fluxo.Resources.CustomControls;assembly=Fluxo.Resources"
    xmlns:enums="clr-namespace:Fluxo.Core.Enums;assembly=Fluxo.Core">
    <Border Style="{StaticResource PanelStyle}">
        <customControls:FadingScrollViewer>

            <Grid>
                <StackPanel>
                    <StackPanel.Style>
                        <Style TargetType="StackPanel">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding HasSpendingSources}" Value="False">
                                    <Setter Property="Effect">
                                        <Setter.Value>
                                            <BlurEffect Radius="15" />
                                        </Setter.Value>
                                    </Setter>
                                    <Setter Property="Opacity" Value="0.4" />
                                    <Setter Property="IsHitTestVisible" Value="False" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </StackPanel.Style>
                    <TextBlock
                        FontFamily="{StaticResource Bold}"
                        FontSize="16"
                        Foreground="{StaticResource Brush.Text.Primary}"
                        Text="Budget Allocation" />
                    <TextBlock
                        Margin="0,8,0,16"
                        FontFamily="{StaticResource Medium}"
                        FontSize="11"
                        Foreground="{StaticResource Brush.Text.Secondary}"
                        Text="Manage how you budget is allocated." />

                    <Border Style="{StaticResource RowCardStyle}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock
                                    FontFamily="{StaticResource Bold}"
                                    FontSize="14"
                                    Foreground="{StaticResource Brush.Text.Primary}"
                                    Text="Needs" />
                                <StackPanel Grid.Column="1" Orientation="Horizontal">
                                    <Button
                                        Click="OnAllocationAdjustButtonClick"
                                        Content="-"
                                        MouseLeave="OnAllocationAdjustButtonMouseLeave"
                                        PreviewMouseLeftButtonDown="OnAllocationAdjustButtonMouseDown"
                                        PreviewMouseLeftButtonUp="OnAllocationAdjustButtonMouseUp"
                                        Style="{StaticResource StepperButtonStyle}"
                                        Tag="Needs:-1" />
                                    <TextBlock
                                        Width="56"
                                        VerticalAlignment="Center"
                                        FontFamily="{StaticResource Bold}"
                                        Foreground="{StaticResource Brush.Text.Primary}"
                                        Text="{Binding NeedsAllocationPercentage, StringFormat={}{0}%}"
                                        TextAlignment="Center" />
                                    <Button
                                        Click="OnAllocationAdjustButtonClick"
                                        Content="+"
                                        MouseLeave="OnAllocationAdjustButtonMouseLeave"
                                        PreviewMouseLeftButtonDown="OnAllocationAdjustButtonMouseDown"
                                        PreviewMouseLeftButtonUp="OnAllocationAdjustButtonMouseUp"
                                        Style="{StaticResource StepperButtonStyle}"
                                        Tag="Needs:+1" />
                                </StackPanel>
                            </Grid>
                            <Slider
                                Grid.Row="1"
                                IsSnapToTickEnabled="True"
                                Maximum="100"
                                Minimum="0"
                                Style="{StaticResource BudgetSliderStyle}"
                                TickFrequency="1"
                                Value="{Binding NeedsAllocationPercentage, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            <TextBlock
                                Grid.Row="2"
                                HorizontalAlignment="Right"
                                FontFamily="{StaticResource Medium}"
                                Foreground="{StaticResource Brush.Text.Secondary}"
                                Text="{Binding NeedsAllocationAmountText, Converter={StaticResource MoneyDisplayConverter}}"
                                ToolTip="{Binding NeedsAllocationAmountText, Converter={StaticResource MoneyFullDisplayConverter}}" />
                        </Grid>
                    </Border>

                    <Border Style="{StaticResource RowCardStyle}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock
                                    FontFamily="{StaticResource Bold}"
                                    FontSize="14"
                                    Foreground="{StaticResource Brush.Text.Primary}"
                                    Text="Wants" />
                                <StackPanel Grid.Column="1" Orientation="Horizontal">
                                    <Button
                                        Click="OnAllocationAdjustButtonClick"
                                        Content="-"
                                        MouseLeave="OnAllocationAdjustButtonMouseLeave"
                                        PreviewMouseLeftButtonDown="OnAllocationAdjustButtonMouseDown"
                                        PreviewMouseLeftButtonUp="OnAllocationAdjustButtonMouseUp"
                                        Style="{StaticResource StepperButtonStyle}"
                                        Tag="Wants:-1" />
                                    <TextBlock
                                        Width="56"
                                        VerticalAlignment="Center"
                                        FontFamily="{StaticResource Bold}"
                                        Foreground="{StaticResource Brush.Text.Primary}"
                                        Text="{Binding WantsAllocationPercentage, StringFormat={}{0}%}"
                                        TextAlignment="Center" />
                                    <Button
                                        Click="OnAllocationAdjustButtonClick"
                                        Content="+"
                                        MouseLeave="OnAllocationAdjustButtonMouseLeave"
                                        PreviewMouseLeftButtonDown="OnAllocationAdjustButtonMouseDown"
                                        PreviewMouseLeftButtonUp="OnAllocationAdjustButtonMouseUp"
                                        Style="{StaticResource StepperButtonStyle}"
                                        Tag="Wants:+1" />
                                </StackPanel>
                            </Grid>
                            <Slider
                                Grid.Row="1"
                                IsSnapToTickEnabled="True"
                                Maximum="100"
                                Minimum="0"
                                Style="{StaticResource BudgetSliderStyle}"
                                TickFrequency="1"
                                Value="{Binding WantsAllocationPercentage, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            <TextBlock
                                Grid.Row="2"
                                HorizontalAlignment="Right"
                                FontFamily="{StaticResource Medium}"
                                Foreground="{StaticResource Brush.Text.Secondary}"
                                Text="{Binding WantsAllocationAmountText, Converter={StaticResource MoneyDisplayConverter}}"
                                ToolTip="{Binding WantsAllocationAmountText, Converter={StaticResource MoneyFullDisplayConverter}}" />
                        </Grid>
                    </Border>

                    <Border Style="{StaticResource RowCardStyle}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock
                                    FontFamily="{StaticResource Bold}"
                                    FontSize="14"
                                    Foreground="{StaticResource Brush.Text.Primary}"
                                    Text="Invest" />
                                <StackPanel Grid.Column="1" Orientation="Horizontal">
                                    <Button
                                        Click="OnAllocationAdjustButtonClick"
                                        Content="-"
                                        MouseLeave="OnAllocationAdjustButtonMouseLeave"
                                        PreviewMouseLeftButtonDown="OnAllocationAdjustButtonMouseDown"
                                        PreviewMouseLeftButtonUp="OnAllocationAdjustButtonMouseUp"
                                        Style="{StaticResource StepperButtonStyle}"
                                        Tag="Invest:-1" />
                                    <TextBlock
                                        Width="56"
                                        VerticalAlignment="Center"
                                        FontFamily="{StaticResource Bold}"
                                        Foreground="{StaticResource Brush.Text.Primary}"
                                        Text="{Binding InvestAllocationPercentage, StringFormat={}{0}%}"
                                        TextAlignment="Center" />
                                    <Button
                                        Click="OnAllocationAdjustButtonClick"
                                        Content="+"
                                        MouseLeave="OnAllocationAdjustButtonMouseLeave"
                                        PreviewMouseLeftButtonDown="OnAllocationAdjustButtonMouseDown"
                                        PreviewMouseLeftButtonUp="OnAllocationAdjustButtonMouseUp"
                                        Style="{StaticResource StepperButtonStyle}"
                                        Tag="Invest:+1" />
                                </StackPanel>
                            </Grid>
                            <Slider
                                Grid.Row="1"
                                IsSnapToTickEnabled="True"
                                Maximum="100"
                                Minimum="0"
                                Style="{StaticResource BudgetSliderStyle}"
                                TickFrequency="1"
                                Value="{Binding InvestAllocationPercentage, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            <TextBlock
                                Grid.Row="2"
                                HorizontalAlignment="Right"
                                FontFamily="{StaticResource Medium}"
                                Foreground="{StaticResource Brush.Text.Secondary}"
                                Text="{Binding InvestAllocationAmountText, Converter={StaticResource MoneyDisplayConverter}}"
                                ToolTip="{Binding InvestAllocationAmountText, Converter={StaticResource MoneyFullDisplayConverter}}" />
                        </Grid>
                    </Border>

                    <TextBlock
                        Margin="0,0,0,12"
                        FontFamily="{StaticResource Bold}"
                        Foreground="{StaticResource Brush.Danger}"
                        Text="{Binding BudgetAllocationErrorMessage}"
                        Visibility="{Binding HasBudgetAllocationError, Converter={StaticResource BoolToVisibilityConverter}}" />

                    <TextBlock
                        Margin="0,8,0,16"
                        FontFamily="{StaticResource Bold}"
                        FontSize="16"
                        Foreground="{StaticResource Brush.Text.Primary}"
                        Text="Configuration" />

                    <Border Style="{StaticResource RowCardStyle}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="180" />
                            </Grid.ColumnDefinitions>
                            <TextBlock
                                VerticalAlignment="Center"
                                FontFamily="{StaticResource Bold}"
                                Foreground="{StaticResource Brush.Text.Primary}"
                                Text="Spending Limit" />
                            <customControls:MoneyTextBox
                                Grid.Column="1"
                                Language="en-US"
                                Style="{StaticResource RoundedMoneyTextInputStyle}"
                                Text="{Binding AllocationLimit, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, Converter={StaticResource MoneyAmountToCanonicalConverter}}" />
                        </Grid>
                    </Border>

                    <Border Style="{StaticResource RowCardStyle}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="360" />
                            </Grid.ColumnDefinitions>
                            <TextBlock
                                VerticalAlignment="Center"
                                FontFamily="{StaticResource Bold}"
                                Foreground="{StaticResource Brush.Text.Primary}"
                                Text="Allocation Period" />
                            <customControls:SegmentedToggleGroup Grid.Column="1" SelectedValue="{Binding AllocationPeriod, Mode=TwoWay}">
                                <customControls:SegmentedToggleOption Content="Weekly" Value="{x:Static enums:AllocationPeriod.Weekly}" />
                                <customControls:SegmentedToggleOption Content="Biweekly" Value="{x:Static enums:AllocationPeriod.Biweekly}" />
                                <customControls:SegmentedToggleOption Content="Monthly" Value="{x:Static enums:AllocationPeriod.Monthly}" />
                                <customControls:SegmentedToggleOption Content="Quarterly" Value="{x:Static enums:AllocationPeriod.Quarterly}" />
                                <customControls:SegmentedToggleOption Content="Yearly" Value="{x:Static enums:AllocationPeriod.Yearly}" />
                            </customControls:SegmentedToggleGroup>
                        </Grid>
                    </Border>

                    <Border Style="{StaticResource RowCardStyle}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="300" />
                            </Grid.ColumnDefinitions>
                            <TextBlock
                                VerticalAlignment="Center"
                                FontFamily="{StaticResource Bold}"
                                Foreground="{StaticResource Brush.Text.Primary}"
                                Text="Budget Rollover" />
                            <customControls:SegmentedToggleGroup Grid.Column="1" SelectedValue="{Binding RolloverPolicy, Mode=TwoWay}">
                                <customControls:SegmentedToggleOption Content="Ignore" Value="{x:Static enums:RolloverPolicy.None}" />
                                <customControls:SegmentedToggleOption Content="Matching" Value="{x:Static enums:RolloverPolicy.Matching}" />
                                <customControls:SegmentedToggleOption Content="Pooled" Value="{x:Static enums:RolloverPolicy.Pooled}" />
                            </customControls:SegmentedToggleGroup>
                        </Grid>
                    </Border>

                    <Border Style="{StaticResource RowCardStyle}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="300" />
                            </Grid.ColumnDefinitions>
                            <TextBlock
                                VerticalAlignment="Center"
                                FontFamily="{StaticResource Bold}"
                                Foreground="{StaticResource Brush.Text.Primary}"
                                Text="Overspend Behavior" />
                            <customControls:SegmentedToggleGroup Grid.Column="1" SelectedValue="{Binding OverspendPolicy, Mode=TwoWay}">
                                <customControls:SegmentedToggleOption Content="Ignore" Value="{x:Static enums:OverspendPolicy.Ignore}" />
                                <customControls:SegmentedToggleOption Content="Soft Debt" Value="{x:Static enums:OverspendPolicy.SoftDebt}" />
                                <customControls:SegmentedToggleOption Content="Hard Stop" Value="{x:Static enums:OverspendPolicy.HardStop}" />
                            </customControls:SegmentedToggleGroup>
                        </Grid>
                    </Border>
                </StackPanel>
                <Button
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Click="OnSpendingAmountGateActionClick"
                    Content="Add An Income Source To Adjust Allocation"
                    FontFamily="{StaticResource Bold}"
                    FontSize="13"
                    Style="{StaticResource TextOnlyButtonStyle}"
                    Visibility="{Binding HasSpendingSources, Converter={StaticResource BoolToVisibilityInvertedConverter}}" />
            </Grid>
        </customControls:FadingScrollViewer>
    </Border>
</UserControl>

