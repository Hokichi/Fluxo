<UserControl
    x:Class="Fluxo.Views.Popups.Settings.Tabs.SettingsGoalsTab"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:c="clr-namespace:Fluxo.Resources.CustomControls">
            <Border Style="{StaticResource PanelStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <StackPanel HorizontalAlignment="Right" Orientation="Horizontal">
                        <c:BalloonButton
                            ButtonIcon="{StaticResource CircleMinusSolid}"
                            Click="OnBatchActionClick"
                            HoveredBackground="{StaticResource Brush.Danger}"
                            Style="{StaticResource ToolbarActionBalloonButtonStyle}"
                            Tag="Goals:Delete"
                            ToolTip="Delete selected"
                            Visibility="{Binding IsGoalChecksEnabled, Converter={StaticResource BoolToVisibilityConverter}}" />
                        <c:BalloonButton
                            ButtonIcon="{StaticResource EyeOff}"
                            Click="OnBatchActionClick"
                            Style="{StaticResource ToolbarActionBalloonButtonStyle}"
                            Tag="Goals:Hide"
                            ToolTip="Hide selected"
                            Visibility="{Binding ShowGoalHideActionButton, Converter={StaticResource BoolToVisibilityConverter}}" />
                        <c:BalloonButton
                            ButtonIcon="{StaticResource Eye}"
                            Click="OnBatchActionClick"
                            Style="{StaticResource ToolbarActionBalloonButtonStyle}"
                            Tag="Goals:Unhide"
                            ToolTip="Unhide selected"
                            Visibility="{Binding ShowGoalUnhideActionButton, Converter={StaticResource BoolToVisibilityConverter}}" />
                        <c:BalloonButton
                            ButtonIcon="{StaticResource LightningSlashFill}"
                            Click="OnBatchActionClick"
                            HoveredBackground="{StaticResource Brush.Warning}"
                            Style="{StaticResource ToolbarActionBalloonButtonStyle}"
                            Tag="Goals:Disable"
                            ToolTip="Disable selected"
                            Visibility="{Binding ShowGoalDisableActionButton, Converter={StaticResource BoolToVisibilityConverter}}" />
                        <c:BalloonButton
                            ButtonIcon="{StaticResource LightningFill}"
                            Click="OnBatchActionClick"
                            HoveredBackground="{StaticResource Brush.Mint}"
                            Style="{StaticResource ToolbarActionBalloonButtonStyle}"
                            Tag="Goals:Enable"
                            ToolTip="Enable selected"
                            Visibility="{Binding ShowGoalEnableActionButton, Converter={StaticResource BoolToVisibilityConverter}}" />
                        <c:BalloonButton
                            ButtonIcon="{StaticResource CheckAll}"
                            Click="OnSelectionActionClick"
                            Style="{StaticResource ToolbarActionBalloonButtonStyle}"
                            Tag="Goals:CheckAll"
                            ToolTip="Check all"
                            Visibility="{Binding ShowGoalCheckAllButton, Converter={StaticResource BoolToVisibilityConverter}}" />
                        <c:BalloonButton
                            ButtonIcon="{StaticResource UncheckAll}"
                            Click="OnSelectionActionClick"
                            Style="{StaticResource ToolbarActionBalloonButtonStyle}"
                            Tag="Goals:UncheckAll"
                            ToolTip="Uncheck all"
                            Visibility="{Binding ShowGoalUncheckAllButton, Converter={StaticResource BoolToVisibilityConverter}}" />
                        <c:BalloonButton
                            ButtonIcon="{StaticResource EnableChecks}"
                            Click="OnChecksToggleClick"
                            Style="{StaticResource ToolbarActionBalloonButtonStyle}"
                            Tag="Goals:EnableChecks"
                            ToolTip="Enable selection"
                            Visibility="{Binding ShowGoalEnableChecksButton, Converter={StaticResource BoolToVisibilityConverter}}" />
                        <c:BalloonButton
                            ButtonIcon="{StaticResource DisableChecks}"
                            Click="OnChecksToggleClick"
                            Style="{StaticResource ToolbarActionBalloonButtonStyle}"
                            Tag="Goals:DisableChecks"
                            ToolTip="Disable selection"
                            Visibility="{Binding IsGoalChecksEnabled, Converter={StaticResource BoolToVisibilityConverter}}" />
                        <c:BalloonButton
                            ButtonIcon="{StaticResource PlusSolid}"
                            Click="OnAddPlaceholderClick"
                            HoveredBackground="{StaticResource Brush.Mint}"
                            Style="{StaticResource ToolbarActionBalloonButtonStyle}"
                            Tag="Add New Goal"
                            ToolTip="Add goal" />
                    </StackPanel>
                    <ScrollViewer
                        Grid.Row="1"
                        Margin="0,8,0,0"
                        VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding SavingGoals}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border
                                        x:Name="ItemRoot"
                                        Margin="0,0,0,8"
                                        Padding="12"
                                        Background="Transparent"
                                        BorderBrush="Transparent"
                                        BorderThickness="1"
                                        CornerRadius="14">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="160" />
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <CheckBox
                                                Margin="0,0,12,0"
                                                VerticalAlignment="Center"
                                                IsChecked="{Binding IsChecked, Mode=TwoWay}"
                                                Style="{StaticResource ItemCheckBoxStyle}"
                                                Visibility="{Binding DataContext.IsGoalChecksEnabled, RelativeSource={RelativeSource AncestorType={x:Type c:BasePopup}}, Converter={StaticResource BoolToVisibilityConverter}}" />
                                            <StackPanel Grid.Column="1">
                                                <TextBlock
                                                    FontFamily="{StaticResource Bold}"
                                                    Foreground="{StaticResource Brush.Text.Primary}"
                                                    Text="{Binding Name}" />
                                                <TextBlock
                                                    Margin="0,5,0,0"
                                                    FontFamily="{StaticResource Medium}"
                                                    Foreground="{StaticResource Brush.Text.Secondary}"
                                                    Text="{Binding SavingEndDate, StringFormat=Ends {0:MMM d, yyyy}}" />
                                            </StackPanel>
                                            <StackPanel
                                                Grid.Column="2"
                                                Margin="16,0,0,0"
                                                VerticalAlignment="Center">
                                                <TextBlock
                                                    HorizontalAlignment="Right"
                                                    FontFamily="{StaticResource Bold}"
                                                    Foreground="{Binding ProgressRatio, Converter={StaticResource GoalProgressToBrushConverter}}"
                                                    Text="{Binding ProgressPercentage, StringFormat={}{0}%}" />
                                                <TextBlock
                                                    Margin="0,5,0,0"
                                                    HorizontalAlignment="Right"
                                                    FontFamily="{StaticResource Medium}"
                                                    Foreground="{StaticResource Brush.Text.Muted}">
                                                    <Run Text="{Binding DataContext.SelectedCurrencySymbol, Mode=OneWay, RelativeSource={RelativeSource AncestorType={x:Type c:BasePopup}}}" />
                                                    <Run Text="{Binding CurrentAmount, Mode=OneWay, Converter={StaticResource NumberWithCommasConverter}}" />
                                                </TextBlock>
                                            </StackPanel>
                                            <StackPanel
                                                Grid.Column="3"
                                                Margin="10,0,0,0"
                                                VerticalAlignment="Center"
                                                Orientation="Horizontal">
                                                <Border Style="{StaticResource StateIconBadgeStyle}" Visibility="{Binding IsHidden, Converter={StaticResource BoolToVisibilityConverter}}">
                                                    <Viewbox Margin="6" Stretch="Uniform">
                                                        <Path Data="{StaticResource EyeOff}" Fill="{StaticResource Brush.Warning}" />
                                                    </Viewbox>
                                                </Border>
                                                <Border Style="{StaticResource StateIconBadgeStyle}" Visibility="{Binding IsEnabled, Converter={StaticResource BoolToVisibilityInvertedConverter}}">
                                                    <Viewbox Margin="6" Stretch="Uniform">
                                                        <Path Data="{StaticResource LightningSlashFill}" Fill="{StaticResource Brush.Danger}" />
                                                    </Viewbox>
                                                </Border>
                                            </StackPanel>
                                            <StackPanel
                                                x:Name="RowActions"
                                                Grid.Column="4"
                                                Margin="8,0,0,0"
                                                VerticalAlignment="Center"
                                                IsHitTestVisible="False"
                                                Opacity="0"
                                                Orientation="Horizontal"
                                                Visibility="Collapsed">
                                                <c:BalloonButton
                                                    ButtonIcon="{StaticResource CircleMinusSolid}"
                                                    Click="OnRowActionClick"
                                                    HoveredBackground="{StaticResource Brush.Danger}"
                                                    Style="{StaticResource RowActionBalloonButtonStyle}"
                                                    Tag="Goals:Delete"
                                                    ToolTip="Delete" />
                                                <c:BalloonButton
                                                    ButtonIcon="{StaticResource EyeOff}"
                                                    Click="OnRowActionClick"
                                                    Style="{StaticResource RowActionBalloonButtonStyle}"
                                                    Tag="Goals:Hide"
                                                    ToolTip="Hide"
                                                    Visibility="{Binding IsHidden, Converter={StaticResource BoolToVisibilityInvertedConverter}}" />
                                                <c:BalloonButton
                                                    ButtonIcon="{StaticResource Eye}"
                                                    Click="OnRowActionClick"
                                                    Style="{StaticResource RowActionBalloonButtonStyle}"
                                                    Tag="Goals:Unhide"
                                                    ToolTip="Unhide"
                                                    Visibility="{Binding IsHidden, Converter={StaticResource BoolToVisibilityConverter}}" />
                                                <c:BalloonButton
                                                    ButtonIcon="{StaticResource LightningSlashFill}"
                                                    Click="OnRowActionClick"
                                                    HoveredBackground="{StaticResource Brush.Warning}"
                                                    Style="{StaticResource RowActionBalloonButtonStyle}"
                                                    Tag="Goals:Disable"
                                                    ToolTip="Disable"
                                                    Visibility="{Binding IsEnabled, Converter={StaticResource BoolToVisibilityConverter}}" />
                                                <c:BalloonButton
                                                    ButtonIcon="{StaticResource LightningFill}"
                                                    Click="OnRowActionClick"
                                                    HoveredBackground="{StaticResource Brush.Mint}"
                                                    Style="{StaticResource RowActionBalloonButtonStyle}"
                                                    Tag="Goals:Enable"
                                                    ToolTip="Enable"
                                                    Visibility="{Binding IsEnabled, Converter={StaticResource BoolToVisibilityInvertedConverter}}" />
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                    <DataTemplate.Triggers>
                                        <Trigger SourceName="ItemRoot" Property="IsMouseOver" Value="True">
                                            <Setter TargetName="ItemRoot" Property="Background" Value="{StaticResource Brush.Background.Hovered}" />
                                            <Setter TargetName="ItemRoot" Property="BorderBrush" Value="{StaticResource Brush.Border.Subtle}" />
                                            <Setter TargetName="RowActions" Property="Visibility" Value="Visible" />
                                            <Setter TargetName="RowActions" Property="Opacity" Value="1" />
                                            <Setter TargetName="RowActions" Property="IsHitTestVisible" Value="True" />
                                        </Trigger>
                                    </DataTemplate.Triggers>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                    <TextBlock
                        Grid.RowSpan="2"
                        Margin="0,24"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        FontFamily="{StaticResource Bold}"
                        FontSize="13"
                        Foreground="{StaticResource Brush.Text.Secondary}"
                        Text="No Goal Available"
                        Visibility="{Binding HasSavingGoals, Converter={StaticResource BoolToVisibilityInvertedConverter}}" />
                </Grid>
            </Border>

</UserControl>

