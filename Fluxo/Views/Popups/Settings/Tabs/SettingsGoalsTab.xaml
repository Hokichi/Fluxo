<UserControl
    x:Class="Fluxo.Views.Popups.Settings.Tabs.SettingsGoalsTab"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:components="clr-namespace:Fluxo.Views.Components"
    xmlns:customControls="clr-namespace:Fluxo.Views.CustomControls">
            <Border Style="{StaticResource PanelStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <StackPanel HorizontalAlignment="Right" Orientation="Horizontal">
                        <customControls:BalloonButton
                            ButtonIcon="{StaticResource SettingsGoalsTab.CircleMinusSolid}"
                            Click="OnBatchActionClick"
                            HoveredBackground="{StaticResource Brush.Danger}"
                            Style="{StaticResource ToolbarActionBalloonButtonStyle}"
                            Tag="Goals:Delete"
                            ToolTip="Delete selected"
                            Visibility="{Binding IsGoalChecksEnabled, Converter={StaticResource BoolToVisibilityConverter}}" />
                        <customControls:BalloonButton
                            ButtonIcon="{StaticResource SettingsGoalsTab.LightningSlashFill}"
                            Click="OnBatchActionClick"
                            HoveredBackground="{StaticResource Brush.Warning}"
                            Style="{StaticResource ToolbarActionBalloonButtonStyle}"
                            Tag="Goals:Disable"
                            ToolTip="Disable selected"
                            Visibility="{Binding ShowGoalDisableActionButton, Converter={StaticResource BoolToVisibilityConverter}}" />
                        <customControls:BalloonButton
                            ButtonIcon="{StaticResource SettingsGoalsTab.LightningFill}"
                            Click="OnBatchActionClick"
                            HoveredBackground="{StaticResource Brush.Mint}"
                            Style="{StaticResource ToolbarActionBalloonButtonStyle}"
                            Tag="Goals:Enable"
                            ToolTip="Enable selected"
                            Visibility="{Binding ShowGoalEnableActionButton, Converter={StaticResource BoolToVisibilityConverter}}" />
                        <customControls:BalloonButton
                            ButtonIcon="{StaticResource SettingsGoalsTab.CheckAll}"
                            Click="OnSelectionActionClick"
                            Style="{StaticResource ToolbarActionBalloonButtonStyle}"
                            Tag="Goals:CheckAll"
                            ToolTip="Check all"
                            Visibility="{Binding ShowGoalCheckAllButton, Converter={StaticResource BoolToVisibilityConverter}}" />
                        <customControls:BalloonButton
                            ButtonIcon="{StaticResource SettingsGoalsTab.UncheckAll}"
                            Click="OnSelectionActionClick"
                            Style="{StaticResource ToolbarActionBalloonButtonStyle}"
                            Tag="Goals:UncheckAll"
                            ToolTip="Uncheck all"
                            Visibility="{Binding ShowGoalUncheckAllButton, Converter={StaticResource BoolToVisibilityConverter}}" />
                        <customControls:BalloonButton
                            ButtonIcon="{StaticResource SettingsGoalsTab.EnableChecks}"
                            Click="OnChecksToggleClick"
                            Style="{StaticResource ToolbarActionBalloonButtonStyle}"
                            Tag="Goals:EnableChecks"
                            ToolTip="Enable selection"
                            Visibility="{Binding ShowGoalEnableChecksButton, Converter={StaticResource BoolToVisibilityConverter}}" />
                        <customControls:BalloonButton
                            ButtonIcon="{StaticResource SettingsGoalsTab.DisableChecks}"
                            Click="OnChecksToggleClick"
                            Style="{StaticResource ToolbarActionBalloonButtonStyle}"
                            Tag="Goals:DisableChecks"
                            ToolTip="Disable selection"
                            Visibility="{Binding IsGoalChecksEnabled, Converter={StaticResource BoolToVisibilityConverter}}" />
                        <customControls:BalloonButton
                            ButtonIcon="{StaticResource SettingsGoalsTab.PlusSolid}"
                            Click="OnAddPlaceholderClick"
                            HoveredBackground="{StaticResource Brush.Mint}"
                            Style="{StaticResource ToolbarActionBalloonButtonStyle}"
                            Tag="Add New Goal"
                            ToolTip="Add goal" />
                    </StackPanel>
                    <ScrollViewer
                        Grid.Row="1"
                        Margin="0,8,0,0"
                        VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding SavingGoals}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel>
                                        <Border
                                            x:Name="ItemRoot"
                                            Padding="12"
                                            Background="Transparent"
                                            BorderBrush="Transparent"
                                            BorderThickness="1"
                                            CornerRadius="14"
                                            PreviewMouseLeftButtonDown="OnItemMouseLeftButtonDown">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="160" />
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <CheckBox
                                                    Margin="0,0,12,0"
                                                    VerticalAlignment="Center"
                                                    IsChecked="{Binding IsChecked, Mode=TwoWay}"
                                                    Style="{StaticResource ItemCheckBoxStyle}"
                                                    Visibility="{Binding DataContext.IsGoalChecksEnabled, RelativeSource={RelativeSource AncestorType={x:Type UserControl}}, Converter={StaticResource BoolToVisibilityConverter}}" />
                                                <StackPanel Grid.Column="1">
                                                    <TextBlock
                                                        FontFamily="{StaticResource Bold}"
                                                        Foreground="{StaticResource Brush.Text.Primary}"
                                                        Text="{Binding Name}" />
                                                    <TextBlock
                                                        Margin="0,5,0,0"
                                                        FontFamily="{StaticResource Medium}"
                                                        Foreground="{StaticResource Brush.Text.Secondary}"
                                                        Text="{Binding SavingEndDate, StringFormat=Ends {0:MMM d, yyyy}}" />
                                                </StackPanel>
                                                <StackPanel
                                                    Grid.Column="2"
                                                    Margin="16,0,0,0"
                                                    VerticalAlignment="Center">
                                                    <TextBlock
                                                        HorizontalAlignment="Right"
                                                        FontFamily="{StaticResource Bold}"
                                                        Foreground="{Binding ProgressRatio, Converter={StaticResource GoalProgressToBrushConverter}}"
                                                        Text="{Binding ProgressPercentage, StringFormat={}{0}%}" />
                                                    <TextBlock
                                                        Margin="0,5,0,0"
                                                        HorizontalAlignment="Right"
                                                        FontFamily="{StaticResource Medium}"
                                                        Foreground="{StaticResource Brush.Text.Muted}"
                                                        ToolTip="{Binding CurrentAmount, Mode=OneWay, Converter={StaticResource MoneyFullDisplayConverter}}">
                                                        <Run Text="{Binding CurrentAmount, Mode=OneWay, Converter={StaticResource NumberWithCommasConverter}}" />
                                                    </TextBlock>
                                                </StackPanel>
                                                <StackPanel
                                                    Grid.Column="3"
                                                    Margin="10,0,0,0"
                                                    VerticalAlignment="Center"
                                                    Orientation="Horizontal">
                                                    <Border Style="{StaticResource StateIconBadgeStyle}" Visibility="{Binding IsEnabled, Converter={StaticResource BoolToVisibilityInvertedConverter}}">
                                                        <components:Icon Margin="6" Path="{StaticResource SettingsGoalsTab.LightningSlashFill}" Color="{StaticResource Brush.Danger}" />
                                                    </Border>
                                                </StackPanel>
                                                <StackPanel
                                                    x:Name="RowActions"
                                                    Grid.Column="4"
                                                    Margin="8,0,0,0"
                                                    VerticalAlignment="Center"
                                                    IsHitTestVisible="False"
                                                    Opacity="0"
                                                    Orientation="Horizontal"
                                                    Visibility="Collapsed">
                                                    <customControls:BalloonButton
                                                        ButtonIcon="{StaticResource SettingsGoalsTab.CircleMinusSolid}"
                                                        Click="OnRowActionClick"
                                                        HoveredBackground="{StaticResource Brush.Danger}"
                                                        Style="{StaticResource ToolbarActionBalloonButtonStyle}"
                                                        Tag="Goals:Delete"
                                                        ToolTip="Delete" />
                                                    <customControls:BalloonButton
                                                        ButtonIcon="{StaticResource SettingsGoalsTab.LightningSlashFill}"
                                                        Click="OnRowActionClick"
                                                        HoveredBackground="{StaticResource Brush.Warning}"
                                                        Style="{StaticResource ToolbarActionBalloonButtonStyle}"
                                                        Tag="Goals:Disable"
                                                        ToolTip="Disable"
                                                        Visibility="{Binding IsEnabled, Converter={StaticResource BoolToVisibilityConverter}}" />
                                                    <customControls:BalloonButton
                                                        ButtonIcon="{StaticResource SettingsGoalsTab.LightningFill}"
                                                        Click="OnRowActionClick"
                                                        HoveredBackground="{StaticResource Brush.Mint}"
                                                        Style="{StaticResource ToolbarActionBalloonButtonStyle}"
                                                        Tag="Goals:Enable"
                                                        ToolTip="Enable"
                                                        Visibility="{Binding IsEnabled, Converter={StaticResource BoolToVisibilityInvertedConverter}}" />
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                        <Border
                                            Height="1"
                                            Margin="12,8,12,8"
                                            Background="{StaticResource Brush.Border.Subtle}" />
                                    </StackPanel>
                                    <DataTemplate.Triggers>
                                        <Trigger SourceName="ItemRoot" Property="IsMouseOver" Value="True">
                                            <Setter TargetName="ItemRoot" Property="Background" Value="{StaticResource Brush.Background.Hovered}" />
                                            <Setter TargetName="ItemRoot" Property="BorderBrush" Value="{StaticResource Brush.Border.Subtle}" />
                                            <Setter TargetName="RowActions" Property="Visibility" Value="Visible" />
                                            <Setter TargetName="RowActions" Property="Opacity" Value="1" />
                                            <Setter TargetName="RowActions" Property="IsHitTestVisible" Value="True" />
                                        </Trigger>
                                        <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                            <Setter TargetName="ItemRoot" Property="BorderBrush" Value="{StaticResource Brush.Mint}" />
                                        </DataTrigger>
                                    </DataTemplate.Triggers>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                    <TextBlock
                        Grid.RowSpan="2"
                        Margin="0,24"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        FontFamily="{StaticResource Bold}"
                        FontSize="13"
                        Foreground="{StaticResource Brush.Text.Secondary}"
                        Text="No Goal Available"
                        Visibility="{Binding HasSavingGoals, Converter={StaticResource BoolToVisibilityInvertedConverter}}" />
                </Grid>
            </Border>

</UserControl>


