<UserControl
    x:Class="Fluxo.Views.Popups.Settings.Tabs.SettingsDebtIousTab"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:customControls="clr-namespace:Fluxo.Resources.CustomControls;assembly=Fluxo.Resources">
    <UserControl.Resources>
        <DataTemplate x:Key="DebtIouItemTemplate">
            <Border
                Margin="0,0,0,10"
                Padding="12"
                Background="Transparent"
                BorderBrush="{StaticResource Brush.Border.Subtle}"
                BorderThickness="1"
                CornerRadius="12">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel>
                        <TextBlock
                            FontFamily="{StaticResource Bold}"
                            Foreground="{StaticResource Brush.Text.Primary}"
                            Text="{Binding Name}"
                            TextTrimming="CharacterEllipsis" />
                        <TextBlock
                            Margin="0,5,0,0"
                            FontFamily="{StaticResource Medium}"
                            FontSize="11"
                            Foreground="{StaticResource Brush.Text.Secondary}">
                            <Run Text="{Binding TypeLabel}" />
                            <Run Text=" - " />
                            <Run Text="{Binding AccountName}" />
                            <Run Text=" - " />
                            <Run Text="{Binding Date, StringFormat={}{0:MMM d, yyyy}}" />
                        </TextBlock>
                    </StackPanel>

                    <TextBlock
                        Grid.Column="1"
                        Margin="16,0,0,0"
                        VerticalAlignment="Center"
                        FontFamily="{StaticResource Bold}"
                        Foreground="{StaticResource Brush.Text.Primary}"
                        Text="{Binding Amount, Converter={StaticResource NumberWithCommasConverter}}"
                        ToolTip="{Binding Amount, Converter={StaticResource MoneyFullDisplayConverter}}" />

                    <customControls:BalloonButton
                        Grid.Column="2"
                        Margin="10,0,0,0"
                        ButtonIcon="{StaticResource Check}"
                        Click="OnResolveClick"
                        HoveredBackground="{StaticResource Brush.Mint}"
                        Style="{StaticResource ToolbarActionBalloonButtonStyle}"
                        ToolTip="Resolve" />
                </Grid>
            </Border>
        </DataTemplate>
    </UserControl.Resources>

    <Border>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <TextBlock
                FontFamily="{StaticResource Bold}"
                FontSize="16"
                Foreground="{StaticResource Brush.Text.Primary}"
                Text="Debt/IoUs" />
            <TextBlock
                Grid.Row="1"
                Margin="0,0,0,16"
                FontFamily="{StaticResource Medium}"
                FontSize="11"
                Foreground="{StaticResource Brush.Text.Secondary}"
                Text="Resolve tracked debts and IOUs with balancing transactions." />

            <customControls:FadingScrollViewer
                Grid.Row="2"
                Margin="0,8,0,0"
                VerticalScrollBarVisibility="Auto">
                <ItemsControl
                    ItemTemplate="{StaticResource DebtIouItemTemplate}"
                    ItemsSource="{Binding Items}" />
            </customControls:FadingScrollViewer>

            <StackPanel
                Grid.RowSpan="3"
                Margin="0,24"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Visibility="{Binding HasItems, Converter={StaticResource BoolToVisibilityInvertedConverter}}">
                <TextBlock
                    FontFamily="{StaticResource Bold}"
                    FontSize="13"
                    Foreground="{StaticResource Brush.Text.Secondary}"
                    Text="No Debts Or IOUs" />
            </StackPanel>
        </Grid>
    </Border>
</UserControl>
