<UserControl
    x:Class="Fluxo.Views.Popups.Settings.Tabs.SettingsPersonalizationTab"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:coreEnums="clr-namespace:Fluxo.Core.Enums;assembly=Fluxo.Core">
    <UserControl.Resources>
        <DataTemplate x:Key="SettingsNotificationItemTemplate">
            <Border Style="{StaticResource RowCardStyle}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock
                            FontFamily="{StaticResource Bold}"
                            Foreground="{StaticResource Brush.Text.Primary}"
                            Text="{Binding Title}" />
                        <TextBlock
                            Margin="0,6,0,0"
                            FontFamily="{StaticResource Medium}"
                            Foreground="{StaticResource Brush.Text.Secondary}"
                            Text="{Binding Description}"
                            TextWrapping="Wrap" />
                    </StackPanel>
                    <ToggleButton
                        Grid.Column="1"
                        VerticalAlignment="Center"
                        IsChecked="{Binding IsEnabled, Mode=TwoWay}"
                        Style="{StaticResource ToggleSwitchStyle}" />
                </Grid>
            </Border>
        </DataTemplate>
    </UserControl.Resources>

    <Border Style="{StaticResource PanelStyle}">
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <TextBlock
                    FontFamily="{StaticResource Bold}"
                    FontSize="16"
                    Foreground="{StaticResource Brush.Text.Primary}"
                    Text="Personalization" />
                <TextBlock
                    Margin="0,8,0,16"
                    FontFamily="{StaticResource Medium}"
                    FontSize="11"
                    Foreground="{StaticResource Brush.Text.Secondary}"
                    Text="Set your app display preferences and notification behavior." />

                <StackPanel>
                    <TextBlock
                        FontFamily="{StaticResource Bold}"
                        Foreground="{StaticResource Brush.Text.Primary}"
                        Text="Username" />
                    <TextBox
                        Margin="0,8,0,0"
                        Background="{StaticResource Brush.Background.Surface}"
                        Style="{StaticResource RoundedTextInputStyle}"
                        Text="{Binding PreferredAppName, UpdateSourceTrigger=PropertyChanged}" />
                </StackPanel>

                <Border Margin="0,12,0,0" Style="{StaticResource RowCardStyle}">
                    <StackPanel>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock
                                    FontFamily="{StaticResource Bold}"
                                    Foreground="{StaticResource Brush.Text.Primary}"
                                    Text="Run with Windows" />
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock
                                        Margin="0,6,0,0"
                                        FontFamily="{StaticResource Medium}"
                                        Foreground="{StaticResource Brush.Text.Secondary}"
                                        TextWrapping="Wrap">
                                        <Run Text="Start " />
                                    </TextBlock>
                                    <TextBlock
                                        Margin="0,6,0,0"
                                        FontFamily="{StaticResource Bold}"
                                        Foreground="{StaticResource Brush.Text.Secondary}"
                                        Text="flux" />
                                    <TextBlock
                                        Margin="0,6,0,0"
                                        FontFamily="{StaticResource Bold}"
                                        Foreground="{StaticResource Brush.Mint.Muted}"
                                        Text="o" />
                                    <TextBlock
                                        Margin="0,6,0,0"
                                        FontFamily="{StaticResource Medium}"
                                        Foreground="{StaticResource Brush.Text.Secondary}"
                                        TextWrapping="Wrap">
                                        <Run Text=" in the system tray when Windows signs in." />
                                    </TextBlock>
                                </StackPanel>
                            </StackPanel>
                            <ToggleButton
                                Grid.Column="1"
                                VerticalAlignment="Center"
                                IsChecked="{Binding ShouldRunAtStartup, Mode=TwoWay}"
                                Style="{StaticResource ToggleSwitchStyle}" />
                        </Grid>

                        <Grid Margin="0,14,0,0">
                            <StackPanel VerticalAlignment="Center" Orientation="Horizontal">
                                <TextBlock
                                    FontFamily="{StaticResource Bold}"
                                    Foreground="{StaticResource Brush.Text.Primary}"
                                    Text="When closing " />
                                <TextBlock
                                    FontFamily="{StaticResource Bold}"
                                    Foreground="{StaticResource Brush.Text.Primary}"
                                    Text="flux" />
                                <TextBlock
                                    FontFamily="{StaticResource Bold}"
                                    Foreground="{StaticResource Brush.Mint}"
                                    Text="o" />
                            </StackPanel>
                            <Border
                                Height="32"
                                Padding="4"
                                HorizontalAlignment="Right"
                                Background="{StaticResource Brush.Background.Surface}"
                                BorderBrush="{StaticResource Brush.Border.Subtle}"
                                BorderThickness="1"
                                CornerRadius="14">
                                <StackPanel Orientation="Horizontal">
                                    <Button
                                        Width="120"
                                        Command="{Binding SetCloseBehaviorCommand}"
                                        CommandParameter="{x:Static coreEnums:AppCloseBehavior.MinimizeToTray}"
                                        Content="Minimize to tray"
                                        Style="{StaticResource MainContentViewToggleButtonStyle}"
                                        Tag="{Binding IsMinimizeToTrayCloseBehaviorSelected}" />
                                    <Button
                                        Width="120"
                                        Margin="4,0,0,0"
                                        Command="{Binding SetCloseBehaviorCommand}"
                                        CommandParameter="{x:Static coreEnums:AppCloseBehavior.Exit}"
                                        Content="Exit"
                                        Style="{StaticResource MainContentViewToggleButtonStyle}"
                                        Tag="{Binding IsExitCloseBehaviorSelected}" />
                                </StackPanel>
                            </Border>
                        </Grid>
                    </StackPanel>
                </Border>

                <Border
                    Height="0.5"
                    Margin="0,16"
                    Background="{StaticResource Brush.Border.Subtle}"
                    SnapsToDevicePixels="True" />

                <TextBlock
                    Margin="0,8,0,8"
                    FontFamily="{StaticResource Bold}"
                    Foreground="{StaticResource Brush.Text.Primary}"
                    Text="Notifications" />
                <ItemsControl ItemTemplate="{StaticResource SettingsNotificationItemTemplate}" ItemsSource="{Binding NotificationSettings}" />

                <Grid Margin="0,14,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition />
                        <ColumnDefinition Width="8" />
                        <ColumnDefinition />
                        <ColumnDefinition Width="8" />
                        <ColumnDefinition />
                    </Grid.ColumnDefinitions>
                    <Button
                        Grid.Column="0"
                        Click="OnRunSetupWizardClick"
                        Content="Run Setup Wizard"
                        Style="{StaticResource PopupTextButtonStyle}" />
                    <Button
                        Grid.Column="2"
                        Click="OnResetAllSettingsClick"
                        Content="Reset All Settings"
                        Style="{StaticResource PopupTextButtonStyle}" />
                    <Button
                        Grid.Column="4"
                        Click="OnDeleteAllDataClick"
                        Content="Delete All Data"
                        Foreground="{StaticResource Brush.Danger}"
                        Style="{StaticResource PopupTextButtonStyle}" />
                </Grid>
            </StackPanel>
        </ScrollViewer>
    </Border>
</UserControl>

