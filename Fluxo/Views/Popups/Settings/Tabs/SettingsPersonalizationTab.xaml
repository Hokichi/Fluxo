<UserControl
    x:Class="Fluxo.Views.Popups.Settings.Tabs.SettingsPersonalizationTab"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:customControls="clr-namespace:Fluxo.Resources.CustomControls;assembly=Fluxo.Resources">
    <UserControl.Resources>
        <DataTemplate x:Key="SettingsNotificationItemTemplate">
            <Border Style="{StaticResource RowCardStyle}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock
                            FontFamily="{StaticResource Bold}"
                            Foreground="{StaticResource Brush.Text.Primary}"
                            Text="{Binding Title}" />
                        <TextBlock
                            Margin="0,6,0,0"
                            FontFamily="{StaticResource Medium}"
                            Foreground="{StaticResource Brush.Text.Secondary}"
                            Text="{Binding Description}"
                            TextWrapping="Wrap" />
                    </StackPanel>
                    <ToggleButton
                        Grid.Column="1"
                        VerticalAlignment="Center"
                        IsChecked="{Binding IsEnabled, Mode=TwoWay}"
                        Style="{StaticResource ToggleSwitchStyle}" />
                </Grid>
            </Border>
        </DataTemplate>
    </UserControl.Resources>

    <Border Style="{StaticResource PanelStyle}">
        <customControls:FadingScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <TextBlock
                    FontFamily="{StaticResource Bold}"
                    FontSize="16"
                    Foreground="{StaticResource Brush.Text.Primary}"
                    Text="Personalization" />
                <TextBlock
                    Margin="0,8,0,16"
                    FontFamily="{StaticResource Medium}"
                    FontSize="11"
                    Foreground="{StaticResource Brush.Text.Secondary}"
                    Text="Set your app display preferences and notification behavior." />


                <TextBlock
                    FontFamily="{StaticResource Bold}"
                    Foreground="{StaticResource Brush.Text.Primary}"
                    Text="Username" />
                <TextBox
                    x:Name="UsernameTextBox"
                    Margin="0,8,0,0"
                    Background="{StaticResource Brush.Background.Surface}"
                    LostFocus="OnUsernameTextBoxLostFocus"
                    Style="{StaticResource RoundedTextInputStyle}"
                    Text="{Binding PreferredAppName, UpdateSourceTrigger=PropertyChanged}"
                    TextChanged="OnUsernameTextBoxTextChanged" />

                <TextBlock
                    Margin="0,24,0,0"
                    FontFamily="{StaticResource Bold}"
                    Foreground="{StaticResource Brush.Text.Primary}"
                    Text="Security" />

                <Border Margin="0,8,0,0" Style="{StaticResource RowCardStyle}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock
                                FontFamily="{StaticResource Bold}"
                                Foreground="{StaticResource Brush.Text.Primary}"
                                Text="Lock UI when away" />
                            <TextBlock
                                Margin="0,6,0,0"
                                FontFamily="{StaticResource Medium}"
                                Foreground="{StaticResource Brush.Text.Secondary}"
                                Text="Lock fluxo after inactivity."
                                TextWrapping="Wrap" />
                        </StackPanel>
                        <ToggleButton
                            Grid.Column="1"
                            VerticalAlignment="Center"
                            IsChecked="{Binding IsAppAutoLocked, Mode=TwoWay}"
                            Style="{StaticResource ToggleSwitchStyle}" />
                    </Grid>
                </Border>

                <StackPanel Margin="0,8,0,0" Visibility="{Binding HasAutoLockInterval, Converter={StaticResource BoolToVisibilityConverter}}">
                    <TextBlock
                        FontFamily="{StaticResource Bold}"
                        Foreground="{StaticResource Brush.Text.Primary}"
                        Text="Auto-lock after" />
                    <StackPanel Margin="0,8,0,0" Orientation="Horizontal">
                        <customControls:NumericUpDown
                            Width="120"
                            LowerLimit="1"
                            Value="{Binding AppAutoLockedInterval, Mode=TwoWay}" />
                        <TextBox
                            Width="96"
                            Margin="8,0,0,0"
                            IsReadOnly="True"
                            Style="{StaticResource RoundedTextInputStyle}"
                            Text="seconds" />
                    </StackPanel>
                </StackPanel>

                <TextBlock
                    Margin="0,16,0,0"
                    FontFamily="{StaticResource Bold}"
                    Foreground="{StaticResource Brush.Text.Primary}"
                    Text="Unlock password" />
                <Grid Margin="0,8,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <Grid>
                        <PasswordBox
                            x:Name="UiLockingPasswordBox"
                            Padding="12,8"
                            Background="{StaticResource Brush.Background.Surface}"
                            BorderBrush="{StaticResource Brush.Border.Subtle}"
                            BorderThickness="1"
                            PasswordChanged="OnUiLockingPasswordBoxPasswordChanged"
                            Visibility="{Binding IsUiLockingPasswordVisible, Converter={StaticResource BoolToVisibilityInvertedConverter}}" />
                        <TextBox
                            x:Name="UiLockingPasswordVisibleTextBox"
                            Background="{StaticResource Brush.Background.Surface}"
                            Style="{StaticResource RoundedTextInputStyle}"
                            Text="{Binding UiLockingPassword, UpdateSourceTrigger=PropertyChanged}"
                            TextChanged="OnUiLockingPasswordVisibleTextBoxTextChanged"
                            Visibility="{Binding IsUiLockingPasswordVisible, Converter={StaticResource BoolToVisibilityConverter}}" />
                    </Grid>
                    <customControls:BalloonCheckBox
                        Grid.Column="1"
                        Margin="8,0,0,0"
                        CheckedBackground="Transparent"
                        CheckedIcon="{StaticResource EyeOff}"
                        CheckedText="Hide password"
                        DefaultBackground="Transparent"
                        HoveredBackground="{StaticResource Brush.Background.Hover}"
                        IsChecked="{Binding IsUiLockingPasswordVisible, Mode=TwoWay}"
                        ShouldExpand="False"
                        UncheckedIcon="{StaticResource Eye}"
                        UncheckedText="Show password" />
                </Grid>

                <TextBlock
                    Margin="0,24,0,0"
                    FontFamily="{StaticResource Bold}"
                    Foreground="{StaticResource Brush.Text.Primary}"
                    Text="Data Management" />

                <Grid Margin="0,8,0,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="16" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Button
                        Grid.Column="0"
                        MinWidth="132"
                        VerticalAlignment="Center"
                        Click="OnDataManagementClick"
                        Content="Data Backup/Restore"
                        Style="{StaticResource PopupTextButtonStyle}" />
                    <Button
                        Grid.Column="2"
                        MinWidth="132"
                        VerticalAlignment="Center"
                        Click="OnRunSetupWizardClick"
                        Content="Run Setup Wizard"
                        Style="{StaticResource PopupTextButtonStyle}" />
                </Grid>

                <TextBlock
                    Margin="0,8,0,8"
                    FontFamily="{StaticResource Bold}"
                    Foreground="{StaticResource Brush.Text.Primary}"
                    Text="Notifications" />
                <ItemsControl ItemTemplate="{StaticResource SettingsNotificationItemTemplate}" ItemsSource="{Binding NotificationSettings}" />
            </StackPanel>
        </customControls:FadingScrollViewer>
    </Border>
</UserControl>

