<customControls:BasePopup
    x:Class="Fluxo.Views.Popups.Settings.SettingsPopup"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:components="clr-namespace:Fluxo.Views.Components"
    xmlns:tabs="clr-namespace:Fluxo.Views.Popups.Settings.Tabs"
    xmlns:customControls="clr-namespace:Fluxo.Views.CustomControls"
    PopupTitle="Settings"
    ShowRevertButton="True"
    ShowSaveButton="True">

    <customControls:BasePopup.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Fluxo;component/Resources/Styles/SettingsStyle.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </customControls:BasePopup.Resources>

    <Grid
        Width="800"
        Height="450"
        Margin="24,0,24,24">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220" />
            <ColumnDefinition Width="24" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Style="{StaticResource PanelStyle}">
            <StackPanel>
                <TextBlock
                    FontFamily="{StaticResource Bold}"
                    FontSize="14"
                    Foreground="{StaticResource Brush.Text.Primary}"
                    Text="Sections" />
                <TextBlock
                    Margin="0,6,0,16"
                    FontFamily="{StaticResource Medium}"
                    FontSize="11"
                    Foreground="{StaticResource Brush.Text.Muted}"
                    Text="Apply saves budget and personalization changes. List actions save immediately."
                    TextWrapping="Wrap" />
                <RadioButton
                    x:Name="BudgetTabButton"
                    GroupName="SettingsTabs"
                    IsChecked="True"
                    Style="{StaticResource TabButtonStyle}"
                    Tag="Budget Allocation">
                    <components:Icon
                        Width="12"
                        Color="{Binding RelativeSource={RelativeSource FindAncestor, AncestorType=RadioButton}, Path=Foreground}"
                        Path="/Fluxo;component/Resources/fluxo.ico" />
                </RadioButton>

                <RadioButton
                    x:Name="SourcesTabButton"
                    GroupName="SettingsTabs"
                    Style="{StaticResource TabButtonStyle}"
                    Tag="Spending Sources">
                    <components:Icon
                        Width="12"
                        Color="{Binding RelativeSource={RelativeSource FindAncestor, AncestorType=RadioButton}, Path=Foreground}"
                        Path="{StaticResource SettingsPopup.BookDollar}" />
                </RadioButton>

                <RadioButton
                    x:Name="FixedExpensesTabButton"
                    GroupName="SettingsTabs"
                    Style="{StaticResource TabButtonStyle}"
                    Tag="Fixed Expenses">
                    <components:Icon
                        Width="12"
                        Color="{Binding RelativeSource={RelativeSource FindAncestor, AncestorType=RadioButton}, Path=Foreground}"
                        Path="{StaticResource SettingsPopup.InvoiceLight}" />
                </RadioButton>

                <RadioButton
                    x:Name="GoalsTabButton"
                    GroupName="SettingsTabs"
                    Style="{StaticResource TabButtonStyle}"
                    Tag="Goals">
                    <components:Icon
                        Width="12"
                        Color="{Binding RelativeSource={RelativeSource FindAncestor, AncestorType=RadioButton}, Path=Foreground}"
                        Path="{StaticResource SettingsPopup.BullseyeSolid}" />
                </RadioButton>

                <RadioButton
                    x:Name="TagsTabButton"
                    GroupName="SettingsTabs"
                    Style="{StaticResource TabButtonStyle}"
                    Tag="Tags">
                    <components:Icon
                        Width="12"
                        Color="{Binding RelativeSource={RelativeSource FindAncestor, AncestorType=RadioButton}, Path=Foreground}"
                        Path="{StaticResource SettingsPopup.SolidPriceTagAlt}" />
                </RadioButton>

                <RadioButton
                    x:Name="PersonalizationTabButton"
                    GroupName="SettingsTabs"
                    Style="{StaticResource TabButtonStyle}"
                    Tag="Personalization">
                    <components:Icon
                        Width="12"
                        Color="{Binding RelativeSource={RelativeSource FindAncestor, AncestorType=RadioButton}, Path=Foreground}"
                        Path="{StaticResource SettingsPopup.AccountCircle}" />
                </RadioButton>
            </StackPanel>
        </Border>

        <Grid Grid.Column="2">
            <tabs:SettingsBudgetTab
                DataContext="{Binding BudgetTab}"
                Visibility="{Binding IsChecked, ElementName=BudgetTabButton, Converter={StaticResource BoolToVisibilityConverter}}" />
            <tabs:SettingsSourcesTab
                DataContext="{Binding SourcesTab}"
                Visibility="{Binding IsChecked, ElementName=SourcesTabButton, Converter={StaticResource BoolToVisibilityConverter}}" />
            <tabs:SettingsFixedExpensesTab
                DataContext="{Binding FixedExpensesTab}"
                Visibility="{Binding IsChecked, ElementName=FixedExpensesTabButton, Converter={StaticResource BoolToVisibilityConverter}}" />
            <tabs:SettingsGoalsTab
                DataContext="{Binding GoalsTab}"
                Visibility="{Binding IsChecked, ElementName=GoalsTabButton, Converter={StaticResource BoolToVisibilityConverter}}" />
            <tabs:SettingsTagsTab
                DataContext="{Binding TagsTab}"
                Visibility="{Binding IsChecked, ElementName=TagsTabButton, Converter={StaticResource BoolToVisibilityConverter}}" />

            <tabs:SettingsPersonalizationTab
                DataContext="{Binding PersonalizationTab}"
                Visibility="{Binding IsChecked, ElementName=PersonalizationTabButton, Converter={StaticResource BoolToVisibilityConverter}}" />
        </Grid>
    </Grid>
</customControls:BasePopup>

