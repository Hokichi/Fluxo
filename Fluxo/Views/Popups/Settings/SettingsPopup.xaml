<c:BasePopup
    x:Class="Fluxo.Views.Popups.Settings.SettingsPopup"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:c="clr-namespace:Fluxo.Resources.CustomControls"
    xmlns:tabs="clr-namespace:Fluxo.Views.Popups.Settings.Tabs"
    PopupTitle="Settings"
    ShowRevertButton="True"
    ShowSaveButton="True">

    <c:BasePopup.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Fluxo;component/Resources/Styles/SettingsStyle.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </c:BasePopup.Resources>

    <Grid
        Width="800"
        Height="450"
        Margin="24,0,24,24">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220" />
            <ColumnDefinition Width="24" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Style="{StaticResource PanelStyle}">
            <StackPanel>
                <TextBlock
                    FontFamily="{StaticResource Bold}"
                    FontSize="14"
                    Foreground="{StaticResource Brush.Text.Primary}"
                    Text="Sections" />
                <TextBlock
                    Margin="0,6,0,16"
                    FontFamily="{StaticResource Medium}"
                    FontSize="11"
                    Foreground="{StaticResource Brush.Text.Muted}"
                    Text="Apply saves budget and personalization changes. List actions save immediately."
                    TextWrapping="Wrap" />
                <RadioButton
                    x:Name="BudgetTabButton"
                    GroupName="SettingsTabs"
                    IsChecked="True"
                    Style="{StaticResource TabButtonStyle}"
                    Tag="Budget Allocation">
                    <Rectangle Width="12" Fill="{Binding RelativeSource={RelativeSource FindAncestor, AncestorType=RadioButton}, Path=Foreground}">
                        <Rectangle.OpacityMask>
                            <ImageBrush ImageSource="/Fluxo;component/Resources/fluxo.ico" Stretch="Uniform" />
                        </Rectangle.OpacityMask>
                    </Rectangle>
                </RadioButton>

                <RadioButton
                    x:Name="SourcesTabButton"
                    GroupName="SettingsTabs"
                    Style="{StaticResource TabButtonStyle}"
                    Tag="Spending Sources">
                    <Rectangle Width="12" Fill="{Binding RelativeSource={RelativeSource FindAncestor, AncestorType=RadioButton}, Path=Foreground}">
                        <Rectangle.OpacityMask>
                            <DrawingBrush Stretch="Uniform">
                                <DrawingBrush.Drawing>
                                    <GeometryDrawing Brush="Black" Geometry="{StaticResource SettingsPopup.BookDollar}" />
                                </DrawingBrush.Drawing>
                            </DrawingBrush>
                        </Rectangle.OpacityMask>
                    </Rectangle>
                </RadioButton>

                <RadioButton
                    x:Name="FixedExpensesTabButton"
                    GroupName="SettingsTabs"
                    Style="{StaticResource TabButtonStyle}"
                    Tag="Fixed Expenses">
                    <Rectangle Width="12" Fill="{Binding RelativeSource={RelativeSource FindAncestor, AncestorType=RadioButton}, Path=Foreground}">
                        <Rectangle.OpacityMask>
                            <DrawingBrush Stretch="Uniform">
                                <DrawingBrush.Drawing>
                                    <GeometryDrawing Brush="Black" Geometry="{StaticResource SettingsPopup.InvoiceLight}" />
                                </DrawingBrush.Drawing>
                            </DrawingBrush>
                        </Rectangle.OpacityMask>
                    </Rectangle>
                </RadioButton>

                <RadioButton
                    x:Name="GoalsTabButton"
                    GroupName="SettingsTabs"
                    Style="{StaticResource TabButtonStyle}"
                    Tag="Goals">
                    <Rectangle Width="12" Fill="{Binding RelativeSource={RelativeSource FindAncestor, AncestorType=RadioButton}, Path=Foreground}">
                        <Rectangle.OpacityMask>
                            <DrawingBrush Stretch="Uniform">
                                <DrawingBrush.Drawing>
                                    <GeometryDrawing Brush="Black" Geometry="{StaticResource SettingsPopup.BullseyeSolid}" />
                                </DrawingBrush.Drawing>
                            </DrawingBrush>
                        </Rectangle.OpacityMask>
                    </Rectangle>
                </RadioButton>

                <RadioButton
                    x:Name="TagsTabButton"
                    GroupName="SettingsTabs"
                    Style="{StaticResource TabButtonStyle}"
                    Tag="Tags">
                    <Rectangle Width="12" Fill="{Binding RelativeSource={RelativeSource FindAncestor, AncestorType=RadioButton}, Path=Foreground}">
                        <Rectangle.OpacityMask>
                            <DrawingBrush Stretch="Uniform">
                                <DrawingBrush.Drawing>
                                    <GeometryDrawing Brush="Black" Geometry="{StaticResource SettingsPopup.SolidPriceTagAlt}" />
                                </DrawingBrush.Drawing>
                            </DrawingBrush>
                        </Rectangle.OpacityMask>
                    </Rectangle>
                </RadioButton>

                <RadioButton
                    x:Name="PersonalizationTabButton"
                    GroupName="SettingsTabs"
                    Style="{StaticResource TabButtonStyle}"
                    Tag="Personalization">
                    <Rectangle Width="12" Fill="{Binding RelativeSource={RelativeSource FindAncestor, AncestorType=RadioButton}, Path=Foreground}">
                        <Rectangle.OpacityMask>
                            <DrawingBrush Stretch="Uniform">
                                <DrawingBrush.Drawing>
                                    <GeometryDrawing Brush="Black" Geometry="{StaticResource SettingsPopup.AccountCircle}" />
                                </DrawingBrush.Drawing>
                            </DrawingBrush>
                        </Rectangle.OpacityMask>
                    </Rectangle>
                </RadioButton>
            </StackPanel>
        </Border>

        <Grid Grid.Column="2">
            <tabs:SettingsBudgetTab Visibility="{Binding IsChecked, ElementName=BudgetTabButton, Converter={StaticResource BoolToVisibilityConverter}}" />
            <tabs:SettingsSourcesTab Visibility="{Binding IsChecked, ElementName=SourcesTabButton, Converter={StaticResource BoolToVisibilityConverter}}" />
            <tabs:SettingsFixedExpensesTab Visibility="{Binding IsChecked, ElementName=FixedExpensesTabButton, Converter={StaticResource BoolToVisibilityConverter}}" />
            <tabs:SettingsGoalsTab Visibility="{Binding IsChecked, ElementName=GoalsTabButton, Converter={StaticResource BoolToVisibilityConverter}}" />
            <tabs:SettingsTagsTab Visibility="{Binding IsChecked, ElementName=TagsTabButton, Converter={StaticResource BoolToVisibilityConverter}}" />

            <tabs:SettingsPersonalizationTab Visibility="{Binding IsChecked, ElementName=PersonalizationTabButton, Converter={StaticResource BoolToVisibilityConverter}}" />
        </Grid>
    </Grid>
</c:BasePopup>

