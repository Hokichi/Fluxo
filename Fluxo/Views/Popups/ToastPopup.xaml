<customControls:BasePopup
    x:Class="Fluxo.Views.Popups.ToastPopup"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    
    xmlns:customControls="clr-namespace:Fluxo.Resources.CustomControls;assembly=Fluxo.Resources"
Width="360"
    ShowHeader="False"
    ShowInTaskbar="False"
    SizeToContent="WidthAndHeight">
    <Grid Margin="120,24,120,24">
        <TextBlock
            x:Name="MessageTextBlock"
            MaxWidth="480"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            FontFamily="{DynamicResource Bold}"
            FontSize="12"
            Foreground="{DynamicResource Brush.Text.Primary}"
            TextWrapping="Wrap" />
    </Grid>
</customControls:BasePopup>



