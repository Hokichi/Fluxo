<customControls:BasePopup
    x:Class="Fluxo.Views.Popups.ToastPopup"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:customControls="clr-namespace:Fluxo.Resources.CustomControls;assembly=Fluxo.Resources"
    Width="360"
    ShowHeader="False"
    ShowInTaskbar="False"
    SizeToContent="WidthAndHeight">
    <Border
        MinWidth="320"
        Margin="20,20,20,20"
        Background="Transparent"
        BorderThickness="0">
        <TextBlock
            x:Name="MessageTextBlock"
            Margin="12,10,14,10"
            HorizontalAlignment="Center"
            FontFamily="{DynamicResource Bold}"
            FontSize="12"
            Foreground="{DynamicResource Brush.Text.Primary}"
            TextWrapping="Wrap" />
    </Border>
</customControls:BasePopup>