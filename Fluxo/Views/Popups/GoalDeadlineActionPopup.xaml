<customControls:BasePopup
    x:Class="Fluxo.Views.Popups.GoalDeadlineActionPopup"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:customControls="clr-namespace:Fluxo.Views.CustomControls"
    Width="500"
    PopupTitle="Goal Deadline Action">

    <Grid Margin="24,0,24,24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="8" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="12" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="8" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="16" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock
            FontFamily="{StaticResource Bold}"
            FontSize="14"
            Foreground="{StaticResource Brush.Text.Primary}"
            Text="Choose how to handle this goal" />

        <TextBlock
            Grid.Row="2"
            FontFamily="{StaticResource Medium}"
            Foreground="{StaticResource Brush.Text.Secondary}"
            Text="Entered Amount" />
        <TextBox
            Grid.Row="4"
            Text="{Binding EnteredAmount, UpdateSourceTrigger=PropertyChanged}" />

        <TextBlock
            Grid.Row="6"
            FontFamily="{StaticResource Medium}"
            Foreground="{StaticResource Brush.Text.Secondary}"
            Text="Source" />
        <ComboBox
            Grid.Row="8"
            DisplayMemberPath="Name"
            ItemsSource="{Binding EligibleSources}"
            SelectedItem="{Binding SelectedSource, Mode=TwoWay}" />

        <StackPanel
            Grid.Row="9"
            Margin="0,16,0,0"
            Orientation="Horizontal">
            <Button
                MinWidth="140"
                Command="{Binding MarkAsReachedCommand}"
                Content="Mark as reached" />
            <Button
                Margin="12,0,0,0"
                MinWidth="120"
                Command="{Binding AbandonGoalCommand}"
                Content="Abandon Goal" />
        </StackPanel>
    </Grid>
</customControls:BasePopup>
