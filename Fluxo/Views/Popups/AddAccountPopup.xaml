<customControls:BasePopup
    x:Class="Fluxo.Views.Popups.AddAccountPopup"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:customControls="clr-namespace:Fluxo.Resources.CustomControls;assembly=Fluxo.Resources"
    xmlns:enums="clr-namespace:Fluxo.Core.Enums;assembly=Fluxo.Core"
    IsSaveAndCreateNewButtonEnabled="{Binding CanSave}"
    IsSaveButtonEnabled="{Binding CanSave}"
    PopupTitle="{Binding PopupTitle}"
    ShowSaveAndCreateNewButton="True"
    ShowSaveButton="True">

    <customControls:BasePopup.Resources>
        <Style x:Key="FieldLabelStyle" TargetType="TextBlock">
            <Setter Property="Margin" Value="0,0,0,8" />
            <Setter Property="FontFamily" Value="{StaticResource Bold}" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Foreground" Value="{StaticResource Brush.Text.Primary}" />
        </Style>
        <Style x:Key="FieldHeaderGridStyle" TargetType="Grid">
            <Setter Property="Margin" Value="0,0,0,8" />
        </Style>
        <Style x:Key="FieldValidationHintStyle" TargetType="TextBlock">
            <Setter Property="HorizontalAlignment" Value="Right" />
            <Setter Property="FontFamily" Value="{StaticResource Bold}" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="Foreground" Value="{StaticResource Brush.Danger}" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
        </Style>
    </customControls:BasePopup.Resources>

    <Grid Width="640" Margin="24,0,24,24">
        <customControls:FadingScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="16" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <StackPanel>
                            <Grid Style="{StaticResource FieldHeaderGridStyle}">
                                <TextBlock
                                    Margin="0"
                                    Style="{StaticResource FieldLabelStyle}"
                                    Text="Source Name" />
                                <TextBlock Style="{StaticResource FieldValidationHintStyle}" Text="{Binding NameValidationHint}" />
                            </Grid>
                            <TextBox
                                x:Name="NameTextBox"
                                LostKeyboardFocus="OnNameTextBoxLostKeyboardFocus"
                                Style="{StaticResource RoundedTextInputStyle}"
                                Text="{Binding NameText, UpdateSourceTrigger=PropertyChanged}" />

                            <TextBlock
                                Margin="0,14,0,8"
                                Style="{StaticResource FieldLabelStyle}"
                                Text="Source Type" />
                            <ComboBox
                                DisplayMemberPath="Label"
                                IsEnabled="{Binding IsSourceTypeSelectionEnabled}"
                                ItemsSource="{Binding AccountTypes}"
                                SelectedValue="{Binding SelectedAccountType, Mode=TwoWay}"
                                SelectedValuePath="Value"
                                Style="{StaticResource FluxoComboBoxStyle}" />
                        </StackPanel>

                        <StackPanel Grid.Column="2">
                            <StackPanel Visibility="{Binding IsBalanceLike, Converter={StaticResource BoolToVisibilityConverter}}">
                                <TextBlock Style="{StaticResource FieldLabelStyle}" Text="Current Amount" />
                                <customControls:MoneyTextBox Style="{StaticResource RoundedMoneyTextInputStyle}" Text="{Binding PrimaryAmountText, UpdateSourceTrigger=PropertyChanged, Converter={StaticResource MoneyAmountToCanonicalConverter}}" />
                            </StackPanel>

                            <StackPanel Visibility="{Binding IsCredit, Converter={StaticResource BoolToVisibilityConverter}}">
                                <Grid Style="{StaticResource FieldHeaderGridStyle}">
                                    <TextBlock
                                        Margin="0"
                                        Style="{StaticResource FieldLabelStyle}"
                                        Text="Current Spent" />
                                    <TextBlock Style="{StaticResource FieldValidationHintStyle}" Text="{Binding SpentAmountValidationHint}" />
                                </Grid>
                                <customControls:MoneyTextBox
                                    LostKeyboardFocus="OnSpentAmountTextBoxLostKeyboardFocus"
                                    Style="{StaticResource RoundedMoneyTextInputStyle}"
                                    Text="{Binding SpentAmountText, UpdateSourceTrigger=PropertyChanged, Converter={StaticResource MoneyAmountToCanonicalConverter}}" />
                            </StackPanel>

                            <StackPanel Margin="0,14,0,0">
                                <StackPanel.Style>
                                    <Style TargetType="StackPanel">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding SelectedAccountType}" Value="{x:Static enums:AccountType.Checking}">
                                                <Setter Property="Visibility" Value="Visible" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding SelectedAccountType}" Value="{x:Static enums:AccountType.Cash}">
                                                <Setter Property="Visibility" Value="Visible" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding SelectedAccountType}" Value="{x:Static enums:AccountType.Credit}">
                                                <Setter Property="Visibility" Value="Visible" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </StackPanel.Style>
                                <Grid Style="{StaticResource FieldHeaderGridStyle}">
                                    <TextBlock
                                        Margin="0"
                                        Style="{StaticResource FieldLabelStyle}"
                                        Text="Maximum Spending" />
                                    <TextBlock Style="{StaticResource FieldValidationHintStyle}" Text="{Binding MaximumSpendingValidationHint}" />
                                </Grid>
                                <customControls:MoneyTextBox
                                    LostKeyboardFocus="OnMaximumSpendingTextBoxLostKeyboardFocus"
                                    PlaceholderText="{Binding MaximumSpendingPlaceholderText}"
                                    Style="{StaticResource RoundedMoneyTextInputStyle}"
                                    Text="{Binding MaximumSpendingText, UpdateSourceTrigger=PropertyChanged, Converter={StaticResource MoneyAmountToCanonicalConverter}}"
                                    TextChanged="OnMaximumSpendingTextBoxTextChanged" />
                            </StackPanel>

                            <StackPanel Margin="0,14,0,0" Visibility="{Binding IsCredit, Converter={StaticResource BoolToVisibilityConverter}}">
                                <TextBlock Style="{StaticResource FieldLabelStyle}" Text="Account Limit" />
                                <customControls:MoneyTextBox Style="{StaticResource RoundedMoneyTextInputStyle}" Text="{Binding AccountLimitText, UpdateSourceTrigger=PropertyChanged, Converter={StaticResource MoneyAmountToCanonicalConverter}}" />
                            </StackPanel>

                            <StackPanel Margin="0,14,0,0" Visibility="{Binding IsCredit, Converter={StaticResource BoolToVisibilityConverter}}">
                                <Grid Style="{StaticResource FieldHeaderGridStyle}">
                                    <TextBlock
                                        Margin="0"
                                        Style="{StaticResource FieldLabelStyle}"
                                        Text="Minimum Payment" />
                                    <TextBlock Style="{StaticResource FieldValidationHintStyle}" Text="{Binding MinimumPaymentValidationHint}" />
                                </Grid>
                                <customControls:SuffixTextBox
                                    LostKeyboardFocus="OnMinimumPaymentTextBoxLostKeyboardFocus"
                                    Style="{StaticResource RoundedSuffixTextInputStyle}"
                                    Suffix="%"
                                    Text="{Binding MinimumPaymentText, UpdateSourceTrigger=PropertyChanged, Converter={StaticResource MoneyAmountToCanonicalConverter}}" />
                            </StackPanel>

                            <StackPanel Margin="0,14,0,0" Visibility="{Binding IsCredit, Converter={StaticResource BoolToVisibilityConverter}}">
                                <TextBlock Style="{StaticResource FieldLabelStyle}" Text="Due Date" />
                                <customControls:NumericUpDown
                                    LowerLimit="1"
                                    Step="1"
                                    ToolTip="Enter a day between 1 and 28"
                                    UpperLimit="28"
                                    Value="{Binding MonthlyDueDateText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>

                            <StackPanel Margin="0,14,0,0" Visibility="{Binding IsCredit, Converter={StaticResource BoolToVisibilityConverter}}">
                                <TextBlock Style="{StaticResource FieldLabelStyle}" Text="Deduct Source" />
                                <ComboBox
                                    DisplayMemberPath="Name"
                                    ItemsSource="{Binding DeductSourcesView}"
                                    SelectedValue="{Binding SelectedDeductSource, Mode=TwoWay}"
                                    SelectedValuePath="Id"
                                    Style="{StaticResource FluxoComboBoxStyle}">
                                    <ComboBox.GroupStyle>
                                        <GroupStyle HeaderTemplate="{StaticResource AccountComboGroupHeaderTemplate}" />
                                    </ComboBox.GroupStyle>
                                </ComboBox>
                            </StackPanel>

                            <StackPanel Margin="0,12,0,0" Visibility="{Binding IsSaving, Converter={StaticResource BoolToVisibilityConverter}}">
                                <Grid Style="{StaticResource FieldHeaderGridStyle}">
                                    <TextBlock
                                        Margin="0"
                                        Style="{StaticResource FieldLabelStyle}"
                                        Text="APY" />
                                    <TextBlock Style="{StaticResource FieldValidationHintStyle}" Text="{Binding ApyValidationHint}" />
                                </Grid>
                                <customControls:SuffixTextBox
                                    LostKeyboardFocus="OnApyTextBoxLostKeyboardFocus"
                                    Style="{StaticResource RoundedSuffixTextInputStyle}"
                                    Suffix="%"
                                    Text="{Binding ApyText, UpdateSourceTrigger=PropertyChanged, Converter={StaticResource MoneyAmountToCanonicalConverter}}" />
                            </StackPanel>
                        </StackPanel>
                    </Grid>

                    <StackPanel Margin="0,16,0,0" Orientation="Horizontal">
                        <CheckBox
                            Margin="0,0,16,0"
                            Content="Pinned on dashboard"
                            IsChecked="{Binding PinnedOnUI, Mode=TwoWay}"
                            Style="{StaticResource ItemCheckBoxWithContentStyle}" />
                        <CheckBox
                            Content="Enabled"
                            IsChecked="{Binding IsEnabled, Mode=TwoWay}"
                            Style="{StaticResource ItemCheckBoxWithContentStyle}" />
                    </StackPanel>
            </StackPanel>
        </customControls:FadingScrollViewer>
    </Grid>
</customControls:BasePopup>
