<customControls:BasePopup
    x:Class="Fluxo.Views.Popups.AddSavingGoalPopup"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:components="clr-namespace:Fluxo.Resources.Components;assembly=Fluxo.Resources"
    xmlns:customControls="clr-namespace:Fluxo.Resources.CustomControls;assembly=Fluxo.Resources"
    IsSaveButtonEnabled="{Binding CanSave}"
    PopupTitle="{Binding PopupTitle}"
    Mode="SaveDiscard">

    <customControls:BasePopup.Resources>
        <Style x:Key="FieldLabelStyle" TargetType="TextBlock">
            <Setter Property="Margin" Value="0,0,0,8" />
            <Setter Property="FontFamily" Value="{StaticResource Bold}" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Foreground" Value="{StaticResource Brush.Text.Primary}" />
        </Style>
        <Style x:Key="EndDateInfinityToggleStyle" TargetType="ToggleButton">
            <Setter Property="Width" Value="36" />
            <Setter Property="Height" Value="36" />
            <Setter Property="Background" Value="{StaticResource Brush.Background.Surface}" />
            <Setter Property="BorderBrush" Value="{StaticResource Brush.Border.Subtle}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border
                            x:Name="RootBorder"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="12">
                            <Viewbox
                                Width="16"
                                Height="16"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center">
                                <Path
                                    x:Name="InfinityIcon"
                                    Data="{StaticResource Infinity}"
                                    Fill="{StaticResource Brush.Text.Secondary}"
                                    Stretch="Uniform" />
                            </Viewbox>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="RootBorder" Property="Background" Value="{StaticResource Brush.Background.Hover}" />
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="InfinityIcon" Property="Fill" Value="{StaticResource Brush.Mint}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="RootBorder" Property="Opacity" Value="0.4" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </customControls:BasePopup.Resources>

    <Grid Width="480" Margin="24,0,24,24">
        <StackPanel>
                <TextBlock Style="{StaticResource FieldLabelStyle}" Text="Goal Name" />
                <TextBox
                    x:Name="NameTextBox"
                    Style="{StaticResource RoundedTextInputStyle}"
                    Text="{Binding NameText, UpdateSourceTrigger=PropertyChanged}" />

                <Grid Margin="0,14,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="16" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <StackPanel>
                        <TextBlock Style="{StaticResource FieldLabelStyle}" Text="Target Amount" />
                        <customControls:MoneyTextBox Style="{StaticResource RoundedMoneyTextInputStyle}" Text="{Binding TargetAmountText, UpdateSourceTrigger=PropertyChanged, Converter={StaticResource MoneyAmountToCanonicalConverter}}" />
                    </StackPanel>

                    <StackPanel Grid.Column="2">
                        <TextBlock Style="{StaticResource FieldLabelStyle}" Text="Current Amount" />
                        <customControls:MoneyTextBox Style="{StaticResource RoundedMoneyTextInputStyle}" Text="{Binding CurrentAmountText, UpdateSourceTrigger=PropertyChanged, Converter={StaticResource MoneyAmountToCanonicalConverter}}" />
                    </StackPanel>
                </Grid>

                <TextBlock
                    Margin="0,14,0,8"
                    Style="{StaticResource FieldLabelStyle}"
                    Text="Target Date" />
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="16" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <components:DateSelector
                        x:Name="EndDateSelector"
                        IsEnabled="{Binding HasDefiniteEndDate}"
                        SelectedDate="{Binding EndDate, Mode=TwoWay}" />
                    <ToggleButton
                        Grid.Column="2"
                        Margin="0,0,0,0"
                        IsChecked="{Binding HasDefiniteEndDate, Mode=TwoWay, Converter={StaticResource BoolNegationConverter}}"
                        Style="{StaticResource EndDateInfinityToggleStyle}" />
                </Grid>
        </StackPanel>
    </Grid>
</customControls:BasePopup>



