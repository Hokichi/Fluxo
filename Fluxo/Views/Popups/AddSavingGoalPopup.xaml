<customControls:BasePopup
    x:Class="Fluxo.Views.Popups.AddSavingGoalPopup"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:components="clr-namespace:Fluxo.Views.Components"
    IsSaveButtonEnabled="{Binding CanSave}"
    PopupTitle="{Binding PopupTitle}"
    ShowSaveButton="True">

    <customControls:BasePopup.Resources>
        <Style x:Key="PanelStyle" TargetType="Border">
            <Setter Property="Padding" Value="18" />
            <Setter Property="Background" Value="{StaticResource Brush.Background.Elevated}" />
            <Setter Property="BorderBrush" Value="{StaticResource Brush.Border.Subtle}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="18" />
        </Style>
        <Style x:Key="FieldLabelStyle" TargetType="TextBlock">
            <Setter Property="Margin" Value="0,0,0,8" />
            <Setter Property="FontFamily" Value="{StaticResource Bold}" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Foreground" Value="{StaticResource Brush.Text.Primary}" />
        </Style>
    </customControls:BasePopup.Resources>

    <Grid Width="480" Margin="24,0,24,24">
        <Border Style="{StaticResource PanelStyle}">
            <StackPanel>
                <TextBlock Style="{StaticResource FieldLabelStyle}" Text="Goal Name" />
                <TextBox
                    x:Name="NameTextBox"
                    Style="{StaticResource RoundedTextInputStyle}"
                    Text="{Binding NameText, UpdateSourceTrigger=PropertyChanged}" />

                <Grid Margin="0,14,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="16" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <StackPanel>
                        <TextBlock Style="{StaticResource FieldLabelStyle}" Text="Target Amount" />
                        <customControls:MoneyTextBox Style="{StaticResource RoundedMoneyTextInputStyle}" Text="{Binding TargetAmountText, UpdateSourceTrigger=PropertyChanged, Converter={StaticResource MoneyAmountToCanonicalConverter}}" />
                    </StackPanel>

                    <StackPanel Grid.Column="2">
                        <TextBlock Style="{StaticResource FieldLabelStyle}" Text="Current Amount" />
                        <customControls:MoneyTextBox Style="{StaticResource RoundedMoneyTextInputStyle}" Text="{Binding CurrentAmountText, UpdateSourceTrigger=PropertyChanged, Converter={StaticResource MoneyAmountToCanonicalConverter}}" />
                    </StackPanel>
                </Grid>

                <TextBlock
                    Margin="0,14,0,8"
                    Style="{StaticResource FieldLabelStyle}"
                    Text="Target Date" />
                <components:DateSelector SelectedDate="{Binding EndDate, Mode=TwoWay}" />
            </StackPanel>
        </Border>
    </Grid>
</customControls:BasePopup>