<customControls:BasePopup
    x:Class="Fluxo.Views.Popups.AddNewTransaction"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:behaviors="clr-namespace:Fluxo.Resources.Behaviors;assembly=Fluxo.Resources"
    xmlns:components="clr-namespace:Fluxo.Resources.Components;assembly=Fluxo.Resources"
    xmlns:customControls="clr-namespace:Fluxo.Resources.CustomControls;assembly=Fluxo.Resources"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    CanContinue="True"
    CanDiscard="False"
    IsSaveAndCreateNewButtonEnabled="{Binding CanSave}"
    IsSaveButtonEnabled="{Binding CanSave}"
    Mode="SaveDiscard"
    PopupTitle="{Binding PopupTitle}"
    mc:Ignorable="d">

    <customControls:BasePopup.Resources>
        <Style x:Key="SectionLabelStyle" TargetType="TextBlock">
            <Setter Property="Margin" Value="0,0,0,8" />
            <Setter Property="FontFamily" Value="{DynamicResource Bold}" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="Foreground" Value="{DynamicResource Brush.Text.Muted}" />
        </Style>

        <Style x:Key="FieldHeaderGridStyle" TargetType="Grid">
            <Setter Property="Margin" Value="0,0,0,8" />
        </Style>

        <Style x:Key="FieldValidationHintStyle" TargetType="TextBlock">
            <Setter Property="HorizontalAlignment" Value="Right" />
            <Setter Property="FontFamily" Value="{DynamicResource Bold}" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="Foreground" Value="{DynamicResource Brush.Danger}" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
        </Style>

        <Style
            x:Key="AmountFieldHintStyle"
            BasedOn="{StaticResource FieldValidationHintStyle}"
            TargetType="TextBlock">
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsAmountWarning, Mode=OneWay}" Value="True">
                    <Setter Property="Foreground" Value="{DynamicResource Brush.Warning}" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="PopupFieldBorderStyle" TargetType="Border">
            <Setter Property="Padding" Value="12,10" />
            <Setter Property="Background" Value="{DynamicResource Brush.Background.Elevated}" />
            <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border.Subtle}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="12" />
        </Style>

        <Style x:Key="PopupTagListBoxStyle" TargetType="ListBox">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled" />
            <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Disabled" />
        </Style>

        <Style x:Key="PopupTagListBoxItemStyle" TargetType="ListBoxItem">
            <Setter Property="Margin" Value="0,0,8,0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <ContentPresenter />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style
            x:Key="PopupOtherTagListBoxItemStyle"
            BasedOn="{StaticResource PopupTagListBoxItemStyle}"
            TargetType="ListBoxItem">
            <Setter Property="Margin" Value="0,0,8,8" />
        </Style>

        <DataTemplate x:Key="PopupTagTemplate">
            <RadioButton
                Content="{Binding Name}"
                GroupName="AddNewTransactionTags"
                IsChecked="{Binding RelativeSource={RelativeSource AncestorType=ListBoxItem}, Path=IsSelected, Mode=TwoWay}"
                Style="{StaticResource PopupTagItemRadioStyle}" />
        </DataTemplate>

        <ItemsPanelTemplate x:Key="PopupVisibleTagsItemsPanelTemplate">
            <StackPanel Orientation="Horizontal" />
        </ItemsPanelTemplate>

        <ItemsPanelTemplate x:Key="PopupOverflowTagsItemsPanelTemplate">
            <WrapPanel />
        </ItemsPanelTemplate>

        <Style x:Key="TransactionNameSuggestionListBoxStyle" TargetType="ListBox">
            <Setter Property="MinWidth" Value="260" />
            <Setter Property="MaxHeight" Value="220" />
            <Setter Property="Padding" Value="6" />
            <Setter Property="Background" Value="{DynamicResource Brush.Background.Elevated}" />
            <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border.Subtle}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled" />
            <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Auto" />
        </Style>

        <Style x:Key="TransactionNameSuggestionListBoxItemStyle" TargetType="ListBoxItem">
            <Setter Property="Padding" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border
                            x:Name="ItemBackground"
                            Padding="8,6"
                            Background="{TemplateBinding Background}"
                            CornerRadius="8">
                            <ContentPresenter />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ItemBackground" Property="Background" Value="{DynamicResource Brush.Background.Hover}" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="ItemBackground" Property="Background" Value="{DynamicResource Brush.Background.Hover}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="TransactionHistoryListBoxStyle" TargetType="ListBox">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled" />
            <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Disabled" />
        </Style>

        <Style x:Key="TransactionHistoryListBoxItemStyle" TargetType="ListBoxItem">
            <Setter Property="Margin" Value="0,0,0,8" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border
                            x:Name="ItemBackground"
                            Padding="10,8"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{DynamicResource Brush.Border.Default}"
                            BorderThickness="1"
                            CornerRadius="8">
                            <ContentPresenter />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ItemBackground" Property="Background" Value="{DynamicResource Brush.Background.Hover}" />
                                <Setter TargetName="ItemBackground" Property="BorderBrush" Value="{DynamicResource Brush.Border.Accent.Muted}" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="False">
                                <Setter TargetName="ItemBackground" Property="Background" Value="{DynamicResource Brush.Background.Elevated}" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="ItemBackground" Property="BorderBrush" Value="{DynamicResource Brush.Border.Focus}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <DataTemplate x:Key="TransactionHistoryItemTemplate">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <Ellipse
                    Width="8"
                    Height="8"
                    Margin="0,5,10,0"
                    VerticalAlignment="Top"
                    Fill="{Binding TagHexCode, FallbackValue={StaticResource Brush.Mint}, TargetNullValue={StaticResource Brush.Mint}}" />
                <StackPanel Grid.Column="1">
                    <TextBlock
                        FontFamily="{DynamicResource Bold}"
                        FontSize="13"
                        Foreground="{DynamicResource Brush.Text.Primary}"
                        Text="{Binding Name}"
                        TextTrimming="CharacterEllipsis" />
                    <TextBlock
                        Margin="0,3,0,0"
                        FontFamily="{DynamicResource Regular}"
                        FontSize="11"
                        Foreground="{DynamicResource Brush.Text.Muted}"
                        Text="{Binding AccountName}"
                        TextTrimming="CharacterEllipsis" />
                </StackPanel>
                <StackPanel Grid.Column="2" Margin="12,0,0,0">
                    <TextBlock
                        HorizontalAlignment="Right"
                        FontFamily="{DynamicResource Bold}"
                        FontSize="13"
                        Foreground="{DynamicResource Brush.Text.Primary}"
                        Text="{Binding Amount, StringFormat={}{0:N2}}" />
                    <TextBlock
                        Margin="0,3,0,0"
                        HorizontalAlignment="Right"
                        FontFamily="{DynamicResource Regular}"
                        FontSize="11"
                        Foreground="{DynamicResource Brush.Text.Muted}"
                        Text="{Binding Date, Converter={StaticResource DateTimeToRelativeDateConverter}}" />
                </StackPanel>
            </Grid>
        </DataTemplate>

        <Style
            x:Key="ExpenseCategoryComboBoxItemStyle"
            BasedOn="{StaticResource FluxoComboBoxItemStyle}"
            TargetType="ComboBoxItem">
            <Setter Property="IsEnabled" Value="{Binding IsEnabled}" />
            <Setter Property="Opacity" Value="1" />
            <Style.Triggers>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Opacity" Value="0.4" />
                </Trigger>
                <DataTrigger Binding="{Binding IsEnabled}" Value="False">
                    <Setter Property="Opacity" Value="0.45" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <DataTemplate x:Key="TransactionNameSuggestionTemplate">
            <Grid Width="320" Margin="0,0,0,2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock
                        FontFamily="{DynamicResource Bold}"
                        FontSize="13"
                        Foreground="{DynamicResource Brush.Text.Primary}"
                        Text="{Binding Name}"
                        TextTrimming="CharacterEllipsis" />
                    <TextBlock
                        FontFamily="{DynamicResource Regular}"
                        FontSize="11"
                        Foreground="{DynamicResource Brush.Text.Muted}"
                        Text="{Binding AccountName}"
                        TextTrimming="CharacterEllipsis" />
                </StackPanel>
                <TextBlock
                    Grid.Column="1"
                    Margin="12,0,0,0"
                    VerticalAlignment="Center"
                    FontFamily="{DynamicResource Bold}"
                    FontSize="12"
                    Foreground="{DynamicResource Brush.Text.Primary}"
                    Text="{Binding Amount, StringFormat={}{0:N2}}" />
            </Grid>
        </DataTemplate>
    </customControls:BasePopup.Resources>

    <Border Padding="20,4,20,20">
        <Grid>
            <Grid.Style>
                <Style TargetType="Grid">
                    <Setter Property="Width" Value="560" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsHistoryOpen}" Value="True">
                            <Setter Property="Width" Value="Auto" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Grid.Style>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="720" />
                <ColumnDefinition Width="20" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Grid.Column="0">
                <customControls:SegmentedToggleGroup
                    Width="520"
                    HorizontalAlignment="Center"
                    IsEnabled="{Binding CanChangeTransactionType}">
                    <customControls:SegmentedToggleOption
                        x:Name="ExpenseRadioButton"
                        Content="Expense"
                        IsSelected="{Binding IsExpense, Mode=TwoWay}" />
                    <customControls:SegmentedToggleOption
                        x:Name="IncomeRadioButton"
                        Content="Income"
                        IsSelected="{Binding IsIncome, Mode=TwoWay}" />
                    <customControls:SegmentedToggleOption
                        x:Name="GoalRadioButton"
                        Content="Goal Update"
                        IsSelected="{Binding IsGoal, Mode=TwoWay}" />
                    <customControls:SegmentedToggleOption
                        x:Name="RepaymentRadioButton"
                        Content="Repayment"
                        IsSelected="{Binding IsRepayment, Mode=TwoWay}" />
                </customControls:SegmentedToggleGroup>
            </StackPanel>

            <Grid
                Grid.Row="1"
                Grid.Column="0"
                Margin="0,16,0,0">
                <StackPanel>
                    <StackPanel>
                        <Grid Style="{StaticResource FieldHeaderGridStyle}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="8" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="8" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock
                                Margin="0"
                                Style="{StaticResource SectionLabelStyle}"
                                Text="Name" />
                        </Grid>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="8" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="8" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBox
                                x:Name="ExpenseNameTextBox"
                                GotKeyboardFocus="OnTransactionNameTextBoxFocusChanged"
                                IsEnabled="{Binding CanEditTransactionName}"
                                LostKeyboardFocus="OnTransactionNameTextBoxLostKeyboardFocus"
                                Style="{StaticResource RoundedTextInputStyle}"
                                Text="{Binding NameText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            <customControls:BalloonCheckBox
                                Grid.Column="2"
                                ButtonIcon="{StaticResource CreditCardOff}"
                                ButtonSize="38"
                                CornerRadius="12"
                                DefaultBackground="{StaticResource Brush.BalloonButton.Background.Surface}"
                                HoveredBackground="{StaticResource Brush.BalloonButton.Background.Surface.Hovered}"
                                IconSize="14"
                                IsChecked="{Binding IsBudgetExcluded, Mode=TwoWay}"
                                IsEnabled="{Binding CanToggleBudgetExclusion}"
                                ToolTip="Exclude from budget"
                                UncheckedText="Exclude" />
                            <customControls:BalloonCheckBox
                                Grid.Column="4"
                                ButtonIcon="{StaticResource Pin}"
                                ButtonSize="38"
                                CheckedBackground="{StaticResource Brush.BalloonButton.Background.ConfirmSave}"
                                CornerRadius="12"
                                DefaultBackground="{StaticResource Brush.BalloonButton.Background.Surface}"
                                HoveredBackground="{StaticResource Brush.BalloonButton.Background.Surface.Hovered}"
                                IconSize="14"
                                IsChecked="{Binding IsPinned, Mode=TwoWay}"
                                IsEnabled="{Binding CanPinTransaction}"
                                ToolTip="Pin transaction"
                                UncheckedText="Pinned" />
                        </Grid>
                        <Popup
                            x:Name="ExpenseNameSuggestionsPopup"
                            AllowsTransparency="True"
                            Placement="Bottom"
                            PlacementTarget="{Binding ElementName=ExpenseNameTextBox}"
                            PopupAnimation="Fade"
                            StaysOpen="False"
                            VerticalOffset="6">
                            <ListBox
                                x:Name="ExpenseNameSuggestionsListBox"
                                ItemContainerStyle="{StaticResource TransactionNameSuggestionListBoxItemStyle}"
                                ItemTemplate="{StaticResource TransactionNameSuggestionTemplate}"
                                ItemsSource="{Binding TransactionNameSuggestions}"
                                SelectionChanged="OnTransactionNameSuggestionSelectionChanged"
                                Style="{StaticResource TransactionNameSuggestionListBoxStyle}" />
                        </Popup>

                        <Grid Margin="0,16,0,0" Visibility="{Binding ShowTransactionModes, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="16" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <Grid Style="{StaticResource FieldHeaderGridStyle}">
                                    <TextBlock
                                        Margin="0"
                                        Style="{StaticResource SectionLabelStyle}"
                                        Text="Amount" />
                                </Grid>
                                <customControls:MoneyTextBox
                                    x:Name="ExpenseAmountTextBox"
                                    LostKeyboardFocus="OnTransactionAmountTextBoxLostKeyboardFocus"
                                    Style="{StaticResource RoundedMoneyTextInputStyle}"
                                    Text="{Binding AmountText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, Converter={StaticResource MoneyAmountToCanonicalConverter}}"
                                    TextChanged="OnTransactionAmountTextBoxTextChanged" />
                            </StackPanel>

                            <StackPanel Grid.Column="2" IsEnabled="{Binding ShowDateSelector}">
                                <TextBlock Style="{StaticResource SectionLabelStyle}" Text="Date" />
                                <components:DateSelector x:Name="ExpenseTransactionDateSelector" SelectedDate="{Binding SelectedDate, Mode=TwoWay}" />
                            </StackPanel>
                        </Grid>

                        <StackPanel Margin="0,16,0,0" Visibility="{Binding IsRepayment, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                            <Grid Style="{StaticResource FieldHeaderGridStyle}">
                                <TextBlock
                                    Margin="0"
                                    Style="{StaticResource SectionLabelStyle}"
                                    Text="Amount" />
                                <TextBlock Style="{StaticResource AmountFieldHintStyle}" Text="{Binding AmountFieldHint, Mode=OneWay}" />
                            </Grid>
                            <customControls:MoneyTextBox
                                x:Name="RepaymentAmountTextBox"
                                LostKeyboardFocus="OnTransactionAmountTextBoxLostKeyboardFocus"
                                Style="{StaticResource RoundedMoneyTextInputStyle}"
                                Text="{Binding AmountText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, Converter={StaticResource MoneyAmountToCanonicalConverter}}"
                                TextChanged="OnTransactionAmountTextBoxTextChanged" />
                        </StackPanel>

                        <Grid Margin="0,16,0,0" HorizontalAlignment="Center">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="12" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="12" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="12" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="12" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <customControls:BalloonRadioButton
                                Grid.Column="0"
                                CheckedBackground="{StaticResource Brush.Success}"
                                CornerRadius="8"
                                DefaultBackground="{StaticResource Brush.BalloonButton.Background.Neutral}"
                                GroupName="AddTransactionMode"
                                HoveredBackground="{StaticResource Brush.BalloonButton.Background.Neutral.Hovered}"
                                IconSize="14"
                                IsChecked="{Binding IsRegularMode, Mode=TwoWay}"
                                IsEnabled="{Binding CanToggleRecurring}"
                                ShouldShowText="True"
                                UncheckedIcon="{StaticResource CreditCardAlt}"
                                UncheckedText="Regular" />
                            <customControls:BalloonRadioButton
                                Grid.Column="2"
                                Margin="8,0,0,0"
                                CheckedBackground="{StaticResource Brush.Success}"
                                CornerRadius="8"
                                DefaultBackground="{StaticResource Brush.BalloonButton.Background.Neutral}"
                                GroupName="AddTransactionMode"
                                HoveredBackground="{StaticResource Brush.BalloonButton.Background.Neutral.Hovered}"
                                IconSize="14"
                                IsChecked="{Binding IsRecurring, Mode=TwoWay}"
                                IsEnabled="{Binding CanToggleRecurring}"
                                ShouldShowText="True"
                                UncheckedIcon="{StaticResource RegularRepeat}"
                                UncheckedText="Recurring" />
                            <customControls:BalloonRadioButton
                                Grid.Column="4"
                                Margin="8,0,0,0"
                                CheckedBackground="{StaticResource Brush.Success}"
                                CornerRadius="8"
                                DefaultBackground="{StaticResource Brush.BalloonButton.Background.Neutral}"
                                GroupName="AddTransactionMode"
                                HoveredBackground="{StaticResource Brush.BalloonButton.Background.Neutral.Hovered}"
                                IconSize="14"
                                IsChecked="{Binding IsInstallments, Mode=TwoWay}"
                                IsEnabled="{Binding CanUseInstallments}"
                                ShouldShowText="True"
                                UncheckedIcon="{StaticResource CreditCardClockOutline}"
                                UncheckedText="Installment" />
                            <customControls:BalloonRadioButton
                                Grid.Column="6"
                                Margin="8,0,0,0"
                                CheckedBackground="{StaticResource Brush.Success}"
                                CornerRadius="8"
                                DefaultBackground="{StaticResource Brush.BalloonButton.Background.Neutral}"
                                GroupName="AddTransactionMode"
                                HoveredBackground="{StaticResource Brush.BalloonButton.Background.Neutral.Hovered}"
                                IconSize="14"
                                IsChecked="{Binding IsUnpostedIoUMode, Mode=TwoWay}"
                                IsEnabled="{Binding CanUseIoU}"
                                ShouldShowText="True"
                                UncheckedIcon="{StaticResource CreditCardMinusSolid}"
                                UncheckedText="Unposted IoU" />
                            <customControls:BalloonRadioButton
                                Grid.Column="8"
                                Margin="8,0,0,0"
                                CheckedBackground="{StaticResource Brush.Success}"
                                CornerRadius="8"
                                DefaultBackground="{StaticResource Brush.BalloonButton.Background.Neutral}"
                                GroupName="AddTransactionMode"
                                HoveredBackground="{StaticResource Brush.BalloonButton.Background.Neutral.Hovered}"
                                IconSize="14"
                                IsChecked="{Binding IsPostedIoUMode, Mode=TwoWay}"
                                IsEnabled="{Binding CanUseIoU}"
                                ShouldShowText="True"
                                UncheckedIcon="{StaticResource CreditCardMinusSolid}"
                                UncheckedText="Posted IoU" />
                        </Grid>
                        <TextBlock
                            Margin="0,12,0,0"
                            HorizontalAlignment="Center"
                            FontFamily="{StaticResource Bold}"
                            FontSize="11"
                            Foreground="{StaticResource Brush.Text.Secondary}"
                            Text="{Binding TransactionModeDescription, Mode=OneWay}"
                            TextWrapping="Wrap" />
                    </StackPanel>

                    <Border
                        Margin="0,16,0,0"
                        Padding="16"
                        Background="{DynamicResource Brush.Background.Surface}"
                        BorderBrush="{DynamicResource Brush.Border.Subtle}"
                        BorderThickness="1"
                        CornerRadius="12"
                        Visibility="{Binding ShowRecurringDayInput, Converter={StaticResource BoolToVisibilityConverter}}">
                        <StackPanel>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="16" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <StackPanel>
                                    <TextBlock Style="{StaticResource SectionLabelStyle}" Text="Recurrence" />
                                    <ComboBox
                                        ItemsSource="{Binding RecurringPeriods}"
                                        SelectedItem="{Binding SelectedRecurringPeriod, Mode=TwoWay}"
                                        Style="{StaticResource FluxoComboBoxStyle}" />
                                </StackPanel>

                                <StackPanel Grid.Column="2">
                                    <TextBlock Style="{StaticResource SectionLabelStyle}" Text="Schedule" />
                                    <ComboBox
                                        DisplayMemberPath="Label"
                                        ItemsSource="{Binding WeekdayOptions}"
                                        SelectedValue="{Binding RecurringTimeText, Mode=TwoWay}"
                                        SelectedValuePath="Value"
                                        Style="{StaticResource FluxoComboBoxStyle}"
                                        Visibility="{Binding ShowRecurringWeekdayInput, Converter={StaticResource BoolToVisibilityConverter}}" />
                                    <customControls:NumericUpDown
                                        LowerLimit="1"
                                        Step="1"
                                        UpperLimit="28"
                                        Visibility="{Binding ShowRecurringMonthlyInput, Converter={StaticResource BoolToVisibilityConverter}}"
                                        Value="{Binding RecurringTimeText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                </StackPanel>
                                <StackPanel
                                    Grid.Row="1"
                                    Margin="0,16,0,0"
                                    Visibility="{Binding ShowInstallmentEndDate, Converter={StaticResource BoolToVisibilityConverter}}">
                                    <TextBlock Style="{StaticResource SectionLabelStyle}" Text="Start Date" />
                                    <components:DateSelector SelectedDate="{Binding StartDate, Mode=TwoWay}" />
                                </StackPanel>
                                <StackPanel
                                    Grid.Row="1"
                                    Grid.Column="2"
                                    Margin="0,16,0,0"
                                    Visibility="{Binding ShowInstallmentEndDate, Converter={StaticResource BoolToVisibilityConverter}}">
                                    <TextBlock Style="{StaticResource SectionLabelStyle}" Text="End Date" />
                                    <components:DateSelector SelectedDate="{Binding InstallmentEndDate, Mode=TwoWay}" />
                                </StackPanel>
                            </Grid>
                            <TextBlock
                                Margin="0,16,0,0"
                                FontFamily="{DynamicResource Regular}"
                                FontSize="12"
                                Foreground="{DynamicResource Brush.Mint.Muted}"
                                Text="{Binding InstallmentSummaryText}"
                                TextWrapping="Wrap"
                                Visibility="{Binding ShowInstallmentEndDate, Converter={StaticResource BoolToVisibilityConverter}}" />
                        </StackPanel>
                    </Border>

                    <Border Margin="0,16,0,0" Style="{StaticResource CardBorderStyle}">
                        <Grid x:Name="CategoryAccountGrid">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition>
                                    <ColumnDefinition.Style>
                                        <Style TargetType="ColumnDefinition">
                                            <Setter Property="Width" Value="*" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding DataContext.ShowCategoryOrRepaymentField, ElementName=CategoryAccountGrid}" Value="False">
                                                    <Setter Property="Width" Value="0" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </ColumnDefinition.Style>
                                </ColumnDefinition>
                                <ColumnDefinition>
                                    <ColumnDefinition.Style>
                                        <Style TargetType="ColumnDefinition">
                                            <Setter Property="Width" Value="16" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding DataContext.ShowCategoryOrRepaymentField, ElementName=CategoryAccountGrid}" Value="False">
                                                    <Setter Property="Width" Value="0" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </ColumnDefinition.Style>
                                </ColumnDefinition>
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <TextBlock
                                Grid.Row="0"
                                Grid.Column="0"
                                Style="{StaticResource SectionLabelStyle}"
                                Text="{Binding CategoryFieldLabel}"
                                Visibility="{Binding ShowCategoryOrRepaymentField, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}" />
                            <TextBlock
                                Grid.Row="0"
                                Grid.Column="2"
                                Style="{StaticResource SectionLabelStyle}"
                                Text="Account" />

                            <Grid
                                Grid.Row="1"
                                Grid.Column="0"
                                Visibility="{Binding ShowCategoryOrRepaymentField, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                                <StackPanel Visibility="{Binding ShowCategoryField, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                                    <StackPanel Orientation="Horizontal">
                                        <customControls:BalloonRadioButton
                                            ButtonIcon="{StaticResource Home}"
                                            CheckedBackground="{StaticResource Brush.Mint}"
                                            CornerRadius="8"
                                            DefaultBackground="{StaticResource Brush.BalloonButton.Background.Surface}"
                                            GroupName="ExpenseCategory"
                                            HoveredBackground="{StaticResource Brush.BalloonButton.Background.Surface.Hovered}"
                                            IconSize="12"
                                            IsChecked="{Binding IsNeedsCategory, Mode=TwoWay}"
                                            IsEnabled="{Binding CanEditCategory}"
                                            ShouldShowText="True"
                                            UncheckedText="Needs" />
                                        <customControls:BalloonRadioButton
                                            Margin="8,0,0,0"
                                            ButtonIcon="{StaticResource ShoppingBag}"
                                            CheckedBackground="{StaticResource Brush.Mint}"
                                            CornerRadius="8"
                                            DefaultBackground="{StaticResource Brush.BalloonButton.Background.Surface}"
                                            GroupName="ExpenseCategory"
                                            HoveredBackground="{StaticResource Brush.BalloonButton.Background.Surface.Hovered}"
                                            IconSize="12"
                                            IsChecked="{Binding IsWantsCategory, Mode=TwoWay}"
                                            IsEnabled="{Binding CanEditCategory}"
                                            ShouldShowText="True"
                                            UncheckedText="Wants" />
                                        <customControls:BalloonRadioButton
                                            Margin="8,0,0,0"
                                            ButtonIcon="{StaticResource TrendingUp}"
                                            CheckedBackground="{StaticResource Brush.Mint}"
                                            CornerRadius="8"
                                            DefaultBackground="{StaticResource Brush.BalloonButton.Background.Surface}"
                                            GroupName="ExpenseCategory"
                                            HoveredBackground="{StaticResource Brush.BalloonButton.Background.Surface.Hovered}"
                                            IconSize="12"
                                            IsChecked="{Binding IsInvestCategory, Mode=TwoWay}"
                                            IsEnabled="{Binding CanEditCategory}"
                                            ShouldShowText="True"
                                            UncheckedText="Invest" />
                                    </StackPanel>
                                </StackPanel>

                                <ComboBox
                                    DisplayMemberPath="Name"
                                    IsEnabled="{Binding CanChangeRepaymentAccount}"
                                    ItemsSource="{Binding RepaymentAccounts}"
                                    SelectedItem="{Binding SelectedRepaymentAccount, Mode=TwoWay}"
                                    Style="{StaticResource FluxoComboBoxStyle}"
                                    Visibility="{Binding ShowRepaymentAccountField, Converter={StaticResource BoolToVisibilityConverter}}" />
                            </Grid>

                            <ComboBox
                                x:Name="ExpenseAccountComboBox"
                                Grid.Row="1"
                                Grid.Column="2"
                                DisplayMemberPath="Name"
                                ItemsSource="{Binding AccountsView}"
                                SelectedItem="{Binding SelectedAccount, Mode=TwoWay}"
                                Style="{StaticResource FluxoComboBoxStyle}">
                                <ComboBox.GroupStyle>
                                    <GroupStyle HeaderTemplate="{StaticResource AccountComboGroupHeaderTemplate}" />
                                </ComboBox.GroupStyle>
                            </ComboBox>

                            <StackPanel
                                Grid.Row="2"
                                Grid.Column="0"
                                Margin="0,12,24,0"
                                Orientation="Horizontal"
                                Visibility="{Binding ShowCategoryImpact, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                                <TextBlock
                                    FontFamily="{StaticResource Medium}"
                                    Foreground="{StaticResource Brush.Text.Primary}"
                                    Text="{Binding CategoryCurrent, StringFormat=N0}" />
                                <components:Icon
                                    Width="6"
                                    Margin="16,0"
                                    Path="{StaticResource AngleRight}"
                                    Color="{StaticResource Brush.Text.Primary}" />
                                <TextBlock FontFamily="{StaticResource Medium}" Text="{Binding CategoryToBe, StringFormat=N0}">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="{StaticResource Brush.Danger}" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsIncome, Mode=OneWay}" Value="True">
                                                    <Setter Property="Foreground" Value="{StaticResource Brush.Success}" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </StackPanel>

                            <StackPanel
                                Grid.Row="2"
                                Grid.Column="2"
                                Margin="0,12,24,0"
                                Orientation="Horizontal"
                                Visibility="{Binding ShowAccountImpact, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                                <TextBlock
                                    FontFamily="{StaticResource Medium}"
                                    Foreground="{StaticResource Brush.Text.Primary}"
                                    Text="{Binding AccountCurrent, StringFormat=N0}" />
                                <components:Icon
                                    Width="6"
                                    Margin="16,0"
                                    Path="{StaticResource AngleRight}"
                                    Color="{StaticResource Brush.Text.Primary}" />
                                <TextBlock FontFamily="{StaticResource Medium}" Text="{Binding AccountToBe, StringFormat=N0}">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="{StaticResource Brush.Danger}" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsIncome, Mode=OneWay}" Value="True">
                                                    <Setter Property="Foreground" Value="{StaticResource Brush.Success}" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </StackPanel>

                            <ItemsControl
                                Grid.Row="3"
                                Grid.ColumnSpan="3"
                                Margin="0,12,0,0"
                                ItemsSource="{Binding TransactionWarnings, Mode=OneWay}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock
                                            FontFamily="{StaticResource Medium}"
                                            FontSize="12"
                                            Foreground="{StaticResource Brush.Danger}"
                                            Text="{Binding Message}"
                                            TextWrapping="Wrap" />
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </Grid>
                    </Border>

                </StackPanel>

                <StackPanel Visibility="Collapsed">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="16" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <Grid Style="{StaticResource FieldHeaderGridStyle}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="8" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="8" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock
                                    Margin="0"
                                    Style="{StaticResource SectionLabelStyle}"
                                    Text="Name" />
                                <TextBlock
                                    Grid.Column="0"
                                    Style="{StaticResource FieldValidationHintStyle}"
                                    Text="{Binding NameValidationHint}" />
                            </Grid>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="8" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="8" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBox
                                    x:Name="IncomeNameTextBox"
                                    GotKeyboardFocus="OnTransactionNameTextBoxFocusChanged"
                                    LostKeyboardFocus="OnTransactionNameTextBoxLostKeyboardFocus"
                                    Style="{StaticResource RoundedTextInputStyle}"
                                    Text="{Binding NameText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                <customControls:BalloonToggle
                                    Grid.Column="2"
                                    ButtonSize="38"
                                    CornerRadius="12"
                                    DefaultBackground="{StaticResource Brush.BalloonButton.Background.Surface}"
                                    HoveredBackground="{StaticResource Brush.BalloonButton.Background.Surface.Hovered}"
                                    IconSize="14"
                                    IsEnabled="{Binding CanToggleRecurring}"
                                    ToolTip="Transaction mode">
                                    <customControls:BalloonToggle.States>
                                        <customControls:BalloonToggleState
                                            ButtonIcon="{StaticResource RegularRepeat}"
                                            ButtonText="Recurring"
                                            DefaultBackground="{StaticResource Brush.BalloonButton.Background.Default}"
                                            HoverBackground="{StaticResource Brush.BalloonButton.Background.Surface.Hovered}"
                                            OnChecked="{Binding HandleRecurringModeClickCommand}" />
                                        <customControls:BalloonToggleState
                                            ButtonIcon="{StaticResource CreditCardClockOutline}"
                                            ButtonText="Installments"
                                            DefaultBackground="{StaticResource Brush.BalloonButton.Background.Default}"
                                            HoverBackground="{StaticResource Brush.BalloonButton.Background.Surface.Hovered}"
                                            OnChecked="{Binding HandleInstallmentsModeClickCommand}" />
                                        <customControls:BalloonToggleState
                                            ButtonIcon="{StaticResource CreditCardMinusSolid}"
                                            ButtonText="{Binding IoUTooltip}"
                                            DefaultBackground="{StaticResource Brush.BalloonButton.Background.Caution}"
                                            HoverBackground="{StaticResource Brush.BalloonButton.Background.Surface.Hovered}"
                                            OnChecked="{Binding HandleIoUModeClickCommand}" />
                                        <customControls:BalloonToggleState
                                            ButtonIcon="{StaticResource CreditCardOff}"
                                            ButtonText="Exclude"
                                            DefaultBackground="{StaticResource Brush.BalloonButton.Background.Caution}"
                                            HoverBackground="{StaticResource Brush.BalloonButton.Background.Surface.Hovered}"
                                            OnChecked="{Binding HandleExcludeModeClickCommand}" />
                                        <customControls:BalloonToggleState
                                            ButtonIcon="{StaticResource CreditCardXRegular}"
                                            ButtonText="Set as Debt and Exclude"
                                            DefaultBackground="{StaticResource Brush.BalloonButton.Background.Caution}"
                                            HoverBackground="{StaticResource Brush.BalloonButton.Background.Surface.Hovered}"
                                            OnChecked="{Binding HandleExcludedIoUModeClickCommand}" />
                                    </customControls:BalloonToggle.States>
                                </customControls:BalloonToggle>
                                <customControls:BalloonCheckBox
                                    Grid.Column="4"
                                    ButtonSize="38"
                                    CheckedBackground="{StaticResource Brush.BalloonButton.Background.Surface}"
                                    DefaultBackground="{StaticResource Brush.BalloonButton.Background.Surface}"
                                    HoveredBackground="{StaticResource Brush.BalloonButton.Background.Surface.Hovered}"
                                    IsChecked="{Binding IsPinned, Mode=TwoWay}"
                                    IsEnabled="{Binding CanPinTransaction}"
                                    ToolTip="Pinned"
                                    UncheckedIcon="{StaticResource Pin}"
                                    UncheckedText="Pinned" />
                            </Grid>
                            <Popup
                                x:Name="IncomeNameSuggestionsPopup"
                                AllowsTransparency="True"
                                Placement="Bottom"
                                PlacementTarget="{Binding ElementName=IncomeNameTextBox}"
                                PopupAnimation="Fade"
                                StaysOpen="False"
                                VerticalOffset="6">
                                <ListBox
                                    x:Name="IncomeNameSuggestionsListBox"
                                    ItemContainerStyle="{StaticResource TransactionNameSuggestionListBoxItemStyle}"
                                    ItemTemplate="{StaticResource TransactionNameSuggestionTemplate}"
                                    ItemsSource="{Binding TransactionNameSuggestions}"
                                    SelectionChanged="OnTransactionNameSuggestionSelectionChanged"
                                    Style="{StaticResource TransactionNameSuggestionListBoxStyle}" />
                            </Popup>
                        </StackPanel>

                        <StackPanel Grid.Column="2">
                            <Grid Style="{StaticResource FieldHeaderGridStyle}">
                                <TextBlock
                                    Margin="0"
                                    Style="{StaticResource SectionLabelStyle}"
                                    Text="Amount" />
                                <TextBlock Style="{StaticResource AmountFieldHintStyle}" Text="{Binding AmountFieldHint, Mode=OneWay}" />
                            </Grid>
                            <customControls:MoneyTextBox
                                x:Name="IncomeAmountTextBox"
                                LostKeyboardFocus="OnTransactionAmountTextBoxLostKeyboardFocus"
                                Style="{StaticResource RoundedMoneyTextInputStyle}"
                                Text="{Binding AmountText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, Converter={StaticResource MoneyAmountToCanonicalConverter}}"
                                TextChanged="OnTransactionAmountTextBoxTextChanged" />
                            <StackPanel Margin="0,16,0,0" Visibility="{Binding ShowInstallmentEndDate, Converter={StaticResource BoolToVisibilityConverter}}">
                                <TextBlock Style="{StaticResource SectionLabelStyle}" Text="End Date" />
                                <components:DateSelector SelectedDate="{Binding InstallmentEndDate, Mode=TwoWay}" />
                                <TextBlock
                                    Margin="0,8,0,0"
                                    FontFamily="{DynamicResource Regular}"
                                    FontSize="11"
                                    Foreground="{DynamicResource Brush.Text.Muted}"
                                    Text="{Binding InstallmentSummaryText}"
                                    TextWrapping="Wrap" />
                            </StackPanel>
                        </StackPanel>
                    </Grid>

                    <Grid Margin="0,16,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="16" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <TextBlock Style="{StaticResource SectionLabelStyle}" Text="Account" />
                            <ComboBox
                                x:Name="IncomeAccountComboBox"
                                DisplayMemberPath="Name"
                                ItemsSource="{Binding AccountsView}"
                                SelectedItem="{Binding SelectedAccount, Mode=TwoWay}"
                                Style="{StaticResource FluxoComboBoxStyle}">
                                <ComboBox.GroupStyle>
                                    <GroupStyle HeaderTemplate="{StaticResource AccountComboGroupHeaderTemplate}" />
                                </ComboBox.GroupStyle>
                            </ComboBox>
                        </StackPanel>

                        <StackPanel Grid.Column="2">
                            <TextBlock Style="{StaticResource SectionLabelStyle}" Text="{Binding DateOrRecurrenceLabel}" />
                            <components:DateSelector
                                x:Name="IncomeTransactionDateSelector"
                                SelectedDate="{Binding SelectedDate, Mode=TwoWay}"
                                Visibility="{Binding ShowDateSelector, Converter={StaticResource BoolToVisibilityConverter}}" />
                            <StackPanel Visibility="{Binding ShowRecurringDayInput, Converter={StaticResource BoolToVisibilityConverter}}">
                                <ComboBox
                                    ItemsSource="{Binding RecurringPeriods}"
                                    SelectedItem="{Binding SelectedRecurringPeriod, Mode=TwoWay}"
                                    Style="{StaticResource FluxoComboBoxStyle}" />
                                <ComboBox
                                    Margin="0,8,0,0"
                                    DisplayMemberPath="Label"
                                    ItemsSource="{Binding WeekdayOptions}"
                                    SelectedValue="{Binding RecurringTimeText, Mode=TwoWay}"
                                    SelectedValuePath="Value"
                                    Style="{StaticResource FluxoComboBoxStyle}"
                                    Visibility="{Binding ShowRecurringWeekdayInput, Converter={StaticResource BoolToVisibilityConverter}}" />
                                <customControls:NumericUpDown
                                    Margin="0,8,0,0"
                                    LowerLimit="1"
                                    Step="1"
                                    UpperLimit="28"
                                    Visibility="{Binding ShowRecurringMonthlyInput, Converter={StaticResource BoolToVisibilityConverter}}"
                                    Value="{Binding RecurringTimeText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>
                        </StackPanel>
                    </Grid>
                </StackPanel>

                <StackPanel Visibility="Collapsed">
                    <StackPanel>
                        <Grid Style="{StaticResource FieldHeaderGridStyle}">
                            <TextBlock
                                Margin="0"
                                Style="{StaticResource SectionLabelStyle}"
                                Text="Amount" />
                            <TextBlock Style="{StaticResource AmountFieldHintStyle}" Text="{Binding AmountFieldHint, Mode=OneWay}" />
                        </Grid>
                        <customControls:MoneyTextBox
                            x:Name="GoalAmountTextBox"
                            LostKeyboardFocus="OnTransactionAmountTextBoxLostKeyboardFocus"
                            Style="{StaticResource RoundedMoneyTextInputStyle}"
                            Text="{Binding AmountText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, Converter={StaticResource MoneyAmountToCanonicalConverter}}"
                            TextChanged="OnTransactionAmountTextBoxTextChanged" />
                    </StackPanel>

                    <Grid Margin="0,16,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="16" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <TextBlock Style="{StaticResource SectionLabelStyle}" Text="{Binding DateOrRecurrenceLabel}" />
                            <components:DateSelector
                                x:Name="GoalTransactionDateSelector"
                                SelectedDate="{Binding SelectedDate, Mode=TwoWay}"
                                Visibility="{Binding ShowDateSelector, Converter={StaticResource BoolToVisibilityConverter}}" />
                            <StackPanel Visibility="{Binding ShowRecurringDayInput, Converter={StaticResource BoolToVisibilityConverter}}">
                                <ComboBox
                                    ItemsSource="{Binding RecurringPeriods}"
                                    SelectedItem="{Binding SelectedRecurringPeriod, Mode=TwoWay}"
                                    Style="{StaticResource FluxoComboBoxStyle}" />
                                <ComboBox
                                    Margin="0,8,0,0"
                                    DisplayMemberPath="Label"
                                    ItemsSource="{Binding WeekdayOptions}"
                                    SelectedValue="{Binding RecurringTimeText, Mode=TwoWay}"
                                    SelectedValuePath="Value"
                                    Style="{StaticResource FluxoComboBoxStyle}"
                                    Visibility="{Binding ShowRecurringWeekdayInput, Converter={StaticResource BoolToVisibilityConverter}}" />
                                <customControls:NumericUpDown
                                    Margin="0,8,0,0"
                                    LowerLimit="1"
                                    Step="1"
                                    UpperLimit="28"
                                    Visibility="{Binding ShowRecurringMonthlyInput, Converter={StaticResource BoolToVisibilityConverter}}"
                                    Value="{Binding RecurringTimeText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>
                        </StackPanel>

                        <StackPanel Grid.Column="2">
                            <TextBlock Style="{StaticResource SectionLabelStyle}" Text="Account" />
                            <ComboBox
                                x:Name="GoalAccountComboBox"
                                DisplayMemberPath="Name"
                                ItemsSource="{Binding AccountsView}"
                                SelectedItem="{Binding SelectedAccount, Mode=TwoWay}"
                                Style="{StaticResource FluxoComboBoxStyle}">
                                <ComboBox.GroupStyle>
                                    <GroupStyle HeaderTemplate="{StaticResource AccountComboGroupHeaderTemplate}" />
                                </ComboBox.GroupStyle>
                            </ComboBox>
                        </StackPanel>
                    </Grid>

                    <StackPanel Margin="0,16,0,0">
                        <TextBlock Style="{StaticResource SectionLabelStyle}" Text="Goal" />
                        <ComboBox
                            x:Name="GoalComboBox"
                            DisplayMemberPath="Name"
                            ItemsSource="{Binding Goals}"
                            SelectedItem="{Binding SelectedGoal, Mode=TwoWay}"
                            Style="{StaticResource FluxoComboBoxStyle}" />
                    </StackPanel>
                </StackPanel>
            </Grid>

            <StackPanel
                x:Name="TagsPanel"
                Grid.Row="2"
                Grid.Column="0"
                Margin="0,16,0,0"
                IsEnabled="{Binding CanEditTags}"
                Visibility="{Binding CanEditTags, Converter={StaticResource BoolToVisibilityConverter}}">
                <TextBlock Style="{StaticResource SectionLabelStyle}" Text="Tags" />
                <DockPanel x:Name="TagsDockPanel" LastChildFill="False">
                    <Button
                        x:Name="AddTagButton"
                        Margin="0,0,8,0"
                        Click="OnAddTagClick"
                        Content="+ Add Tag"
                        DockPanel.Dock="Left"
                        Style="{StaticResource PopupTagButtonStyle}" />

                    <ListBox
                        x:Name="VisibleTagsListBox"
                        DockPanel.Dock="Left"
                        ItemContainerStyle="{StaticResource PopupTagListBoxItemStyle}"
                        ItemTemplate="{StaticResource PopupTagTemplate}"
                        ItemsPanel="{StaticResource PopupVisibleTagsItemsPanelTemplate}"
                        ItemsSource="{Binding VisibleTags}"
                        SelectedItem="{Binding SelectedTag, Mode=TwoWay}"
                        SelectionChanged="OnTagSelectionChanged"
                        Style="{StaticResource PopupTagListBoxStyle}" />

                    <ToggleButton
                        x:Name="MoreTagsButton"
                        Margin="4,0,0,0"
                        Checked="OnMoreTagsButtonChecked"
                        Content="More"
                        IsChecked="{Binding IsMoreTagsOpen, Mode=TwoWay}"
                        MouseEnter="OnMoreTagsHoverChanged"
                        MouseLeave="OnMoreTagsHoverChanged"
                        Style="{StaticResource PopupTagToggleStyle}"
                        Unchecked="OnMoreTagsButtonUnchecked"
                        Visibility="{Binding HasMoreTags, Converter={StaticResource BoolToVisibilityConverter}}" />
                </DockPanel>

                <Popup
                    x:Name="MoreTagsPopup"
                    AllowsTransparency="True"
                    Closed="OnMoreTagsPopupClosed"
                    Placement="Bottom"
                    PlacementTarget="{Binding ElementName=MoreTagsButton}"
                    PopupAnimation="Fade"
                    StaysOpen="True"
                    VerticalOffset="8">
                    <Border
                        x:Name="MoreTagsPopupContent"
                        MaxWidth="360"
                        Padding="12"
                        Background="{DynamicResource Brush.Background.Elevated}"
                        BorderBrush="{DynamicResource Brush.Border.Subtle}"
                        BorderThickness="1"
                        CornerRadius="16"
                        MouseEnter="OnMoreTagsHoverChanged"
                        MouseLeave="OnMoreTagsHoverChanged">
                        <StackPanel>
                            <TextBlock
                                Margin="0,0,0,10"
                                FontFamily="{DynamicResource Bold}"
                                FontSize="12"
                                Foreground="{DynamicResource Brush.Text.Primary}"
                                Text="More Tags" />
                            <ListBox
                                x:Name="MoreTagsListBox"
                                ItemContainerStyle="{StaticResource PopupOtherTagListBoxItemStyle}"
                                ItemTemplate="{StaticResource PopupTagTemplate}"
                                ItemsPanel="{StaticResource PopupOverflowTagsItemsPanelTemplate}"
                                ItemsSource="{Binding OverflowTags}"
                                SelectedItem="{Binding SelectedTag, Mode=TwoWay}"
                                SelectionChanged="OnTagSelectionChanged"
                                Style="{StaticResource PopupTagListBoxStyle}" />
                        </StackPanel>
                    </Border>
                </Popup>
            </StackPanel>

            <StackPanel
                Grid.Row="3"
                Grid.Column="0"
                Margin="0,16,0,0">
                <StackPanel Visibility="{Binding ShowNoteField, Converter={StaticResource BoolToVisibilityConverter}}">
                    <TextBlock Style="{StaticResource SectionLabelStyle}" Text="Note" />
                    <Border Style="{StaticResource PopupFieldBorderStyle}">
                        <TextBox
                            x:Name="NoteRichTextBox"
                            Background="Transparent"
                            BorderThickness="0"
                            CaretBrush="{DynamicResource Brush.Text.Primary}"
                            FontFamily="{DynamicResource Regular}"
                            FontSize="13"
                            Foreground="{DynamicResource Brush.Text.Primary}"
                            TextChanged="OnNoteTextChanged"
                            VerticalScrollBarVisibility="Auto" />
                    </Border>
                </StackPanel>

                <StackPanel Visibility="{Binding ShowGoalField, Converter={StaticResource BoolToVisibilityConverter}}">
                    <TextBlock Style="{StaticResource SectionLabelStyle}" Text="Goal" />
                    <ComboBox
                        x:Name="SharedGoalComboBox"
                        VerticalAlignment="Top"
                        DisplayMemberPath="Name"
                        ItemsSource="{Binding Goals}"
                        SelectedItem="{Binding SelectedGoal, Mode=TwoWay}"
                        Style="{StaticResource FluxoComboBoxStyle}" />
                </StackPanel>
            </StackPanel>

            <Grid
                x:Name="HistoryPanel"
                Grid.Row="0"
                Grid.RowSpan="4"
                Grid.Column="2"
                Width="400"
                Visibility="{Binding IsHistoryOpen, Converter={StaticResource BoolToVisibilityConverter}}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="16" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <customControls:CollapsingCard Grid.Row="0" HeaderText="Pinned">
                    <Grid>
                        <customControls:FadingScrollViewer VerticalScrollBarVisibility="Auto">
                            <ListBox
                                behaviors:ScrollOnDemandBehavior.HasMoreItems="{Binding PinnedHistory.HasMoreItems}"
                                behaviors:ScrollOnDemandBehavior.IsEnabled="True"
                                behaviors:ScrollOnDemandBehavior.IsLoading="False"
                                behaviors:ScrollOnDemandBehavior.LoadMoreCommand="{Binding PinnedHistory.LoadMoreCommand}"
                                ItemContainerStyle="{StaticResource TransactionHistoryListBoxItemStyle}"
                                ItemTemplate="{StaticResource TransactionHistoryItemTemplate}"
                                ItemsSource="{Binding PinnedHistory.Items}"
                                PreviewMouseWheel="OnHistoryListPreviewMouseWheel"
                                SelectedItem="{Binding SelectedPinnedHistoryItem, Mode=TwoWay}"
                                Style="{StaticResource TransactionHistoryListBoxStyle}" />
                        </customControls:FadingScrollViewer>
                        <TextBlock
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            FontFamily="{DynamicResource Regular}"
                            FontSize="12"
                            Foreground="{DynamicResource Brush.Text.Muted}"
                            Text="No pinned items"
                            Visibility="{Binding PinnedHistory.IsEmpty, Converter={StaticResource BoolToVisibilityConverter}}" />
                    </Grid>
                </customControls:CollapsingCard>

                <customControls:CollapsingCard Grid.Row="2" HeaderText="History">
                    <customControls:FadingScrollViewer MaxHeight="220" VerticalScrollBarVisibility="Hidden">
                        <ListBox
                            behaviors:ScrollOnDemandBehavior.HasMoreItems="{Binding TransactionHistory.HasMoreItems}"
                            behaviors:ScrollOnDemandBehavior.IsEnabled="True"
                            behaviors:ScrollOnDemandBehavior.IsLoading="False"
                            behaviors:ScrollOnDemandBehavior.LoadMoreCommand="{Binding TransactionHistory.LoadMoreCommand}"
                            ItemContainerStyle="{StaticResource TransactionHistoryListBoxItemStyle}"
                            ItemTemplate="{StaticResource TransactionHistoryItemTemplate}"
                            ItemsSource="{Binding TransactionHistory.Items}"
                            PreviewMouseWheel="OnHistoryListPreviewMouseWheel"
                            SelectedItem="{Binding SelectedHistoryItem, Mode=TwoWay}"
                            Style="{StaticResource TransactionHistoryListBoxStyle}" />
                    </customControls:FadingScrollViewer>
                </customControls:CollapsingCard>
            </Grid>
        </Grid>
    </Border>
</customControls:BasePopup>
