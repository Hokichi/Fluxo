<customControls:BasePopup
    x:Class="Fluxo.Views.Popups.TransferFundsPopup"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:components="clr-namespace:Fluxo.Views.Components"
    xmlns:customControls="clr-namespace:Fluxo.Views.CustomControls"
    Width="460"
    Height="420"
    PopupTitle="Transfer Funds"
    ShowApplyButton="True">

    <customControls:BasePopup.Resources>
        <Style x:Key="FieldLabelStyle" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="{StaticResource Bold}" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="Foreground" Value="{StaticResource Brush.Text.Primary}" />
        </Style>
    </customControls:BasePopup.Resources>

    <Grid Margin="24,0,24,24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="12" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="12" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="12" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="12" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TextBlock Style="{StaticResource FieldLabelStyle}" Text="Transfer From" />
        <TextBlock
            Grid.Row="2"
            FontFamily="{StaticResource Medium}"
            Foreground="{StaticResource Brush.Text.Secondary}"
            Text="{Binding SourceName}" />

        <TextBlock
            Grid.Row="4"
            Style="{StaticResource FieldLabelStyle}"
            Text="Transfer To" />
        <ComboBox
            Grid.Row="6"
            DisplayMemberPath="Name"
            ItemsSource="{Binding TargetsView}"
            SelectedItem="{Binding SelectedTarget, Mode=TwoWay}"
            Style="{StaticResource FluxoComboBoxStyle}">
            <ComboBox.GroupStyle>
                <GroupStyle HeaderTemplate="{StaticResource SpendingSourceComboGroupHeaderTemplate}" />
            </ComboBox.GroupStyle>
        </ComboBox>

        <Grid Grid.Row="8">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="12" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="12" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="12" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <TextBlock Style="{StaticResource FieldLabelStyle}" Text="Amount" />
            <customControls:MoneyTextBox
                x:Name="AmountTextBox"
                Grid.Row="2"
                Style="{StaticResource RoundedMoneyTextInputStyle}"
                Text="{Binding AmountText, UpdateSourceTrigger=PropertyChanged, Converter={StaticResource MoneyAmountToCanonicalConverter}}" />

            <TextBlock
                Grid.Row="4"
                Style="{StaticResource FieldLabelStyle}"
                Text="Date" />
            <components:DateSelector Grid.Row="6" SelectedDate="{Binding SelectedDate, Mode=TwoWay}" />
        </Grid>
    </Grid>
</customControls:BasePopup>
