<customControls:BasePopup
    x:Class="Fluxo.Views.Popups.AddTagColorPickerPopup"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:customControls="clr-namespace:Fluxo.Views.CustomControls"
    Width="460"
    PopupTitle="Custom Tag Color">

    <customControls:BasePopup.Resources>
        <Style x:Key="PanelStyle" TargetType="Border">
            <Setter Property="Padding" Value="18" />
            <Setter Property="Background" Value="{StaticResource Brush.Background.Elevated}" />
            <Setter Property="BorderBrush" Value="{StaticResource Brush.Border.Subtle}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="18" />
        </Style>

        

        

        <Style x:Key="HueSliderThumbStyle" TargetType="Thumb">
            <Setter Property="Width" Value="18" />
            <Setter Property="Height" Value="8" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Thumb">
                        <Border
                            Background="{StaticResource Brush.Background.Surface}"
                            BorderBrush="{StaticResource Brush.Text.Primary}"
                            BorderThickness="1"
                            CornerRadius="4" />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="HueSliderStyle" TargetType="Slider">
            <Setter Property="Width" Value="20" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Slider">
                        <Grid>
                            <Border Margin="5,0" CornerRadius="8">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0.5,0" EndPoint="0.5,1">
                                        <GradientStop Offset="0" Color="#FFFF0000" />
                                        <GradientStop Offset="0.17" Color="#FFFFFF00" />
                                        <GradientStop Offset="0.33" Color="#FF00FF00" />
                                        <GradientStop Offset="0.5" Color="#FF00FFFF" />
                                        <GradientStop Offset="0.67" Color="#FF0000FF" />
                                        <GradientStop Offset="0.83" Color="#FFFF00FF" />
                                        <GradientStop Offset="1" Color="#FFFF0000" />
                                    </LinearGradientBrush>
                                </Border.Background>
                            </Border>
                            <Track
                                x:Name="PART_Track"
                                IsDirectionReversed="True"
                                Orientation="Vertical">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton
                                        Command="Slider.DecreaseLarge"
                                        IsHitTestVisible="False"
                                        Opacity="0" />
                                </Track.DecreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb Style="{StaticResource HueSliderThumbStyle}" />
                                </Track.Thumb>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton
                                        Command="Slider.IncreaseLarge"
                                        IsHitTestVisible="False"
                                        Opacity="0" />
                                </Track.IncreaseRepeatButton>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </customControls:BasePopup.Resources>

    <Grid Margin="24,0,24,24">
        <Border Style="{StaticResource PanelStyle}">
            <StackPanel>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="16" />
                        <ColumnDefinition Width="20" />
                    </Grid.ColumnDefinitions>
                    <Border
                        x:Name="SaturationValueSurface"
                        Grid.Column="0"
                        Height="200"
                        MouseDown="OnSaturationSurfaceMouseDown"
                        MouseMove="OnSaturationSurfaceMouseMove"
                        MouseUp="OnSaturationSurfaceMouseUp"
                        PreviewMouseLeftButtonDown="OnSaturationSurfaceMouseLeftButtonDown"
                        PreviewMouseLeftButtonUp="OnSaturationSurfaceMouseLeftButtonUp">
                        <Grid>
                            <Border x:Name="HuePreviewSurface" CornerRadius="10" />
                            <Rectangle RadiusX="10" RadiusY="10">
                                <Rectangle.Fill>
                                    <LinearGradientBrush StartPoint="0,0.5" EndPoint="1,0.5">
                                        <GradientStop Offset="0" Color="#FFFFFFFF" />
                                        <GradientStop Offset="1" Color="#00FFFFFF" />
                                    </LinearGradientBrush>
                                </Rectangle.Fill>
                            </Rectangle>
                            <Rectangle RadiusX="10" RadiusY="10">
                                <Rectangle.Fill>
                                    <LinearGradientBrush StartPoint="0.5,0" EndPoint="0.5,1">
                                        <GradientStop Offset="0" Color="#00FFFFFF" />
                                        <GradientStop Offset="1" Color="#FF000000" />
                                    </LinearGradientBrush>
                                </Rectangle.Fill>
                            </Rectangle>
                            <Canvas ClipToBounds="True">
                                <Ellipse
                                    x:Name="ColorHandle"
                                    Width="14"
                                    Height="14"
                                    Stroke="{StaticResource Brush.Background.Surface}"
                                    StrokeThickness="2" />
                            </Canvas>
                        </Grid>
                    </Border>

                    <Slider
                        x:Name="HueSlider"
                        Grid.Column="2"
                        Minimum="0"
                        Maximum="360"
                        Orientation="Vertical"
                        Style="{StaticResource HueSliderStyle}"
                        TickFrequency="1"
                        ValueChanged="OnHueSliderValueChanged" />
                </Grid>

                <TextBox
                    x:Name="HexCodeTextBox"
                    Margin="0,12,0,0"
                    Style="{StaticResource RoundedTextInputStyle}"
                    TextChanged="OnHexCodeTextChanged" />

                <StackPanel Margin="0,12,0,0" HorizontalAlignment="Right" Orientation="Horizontal">
                    <Button
                        Click="OnCancelClick"
                        Content="Cancel"
                        Style="{StaticResource ActionTextButtonStyle}" />
                    <Button
                        Margin="8,0,0,0"
                        Click="OnConfirmClick"
                        Content="Confirm"
                        Style="{StaticResource ActionTextButtonStyle}" />
                </StackPanel>
            </StackPanel>
        </Border>
    </Grid>
</customControls:BasePopup>


