<c:BasePopup
    x:Class="Fluxo.Views.Popups.StartupWizardPopup"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:c="clr-namespace:Fluxo.Resources.CustomControls"
    xmlns:primitives="clr-namespace:System.Windows.Controls.Primitives;assembly=PresentationFramework"
    PopupTitle="Welcome to Fluxo">

    <c:BasePopup.Resources>
        <Style x:Key="PanelStyle" TargetType="Border">
            <Setter Property="Padding" Value="18" />
            <Setter Property="Background" Value="{StaticResource Brush.Background.Elevated}" />
            <Setter Property="BorderBrush" Value="{StaticResource Brush.Border.Subtle}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="18" />
        </Style>

        <Style x:Key="CardStyle" TargetType="Border">
            <Setter Property="Padding" Value="16" />
            <Setter Property="Background" Value="{StaticResource Brush.Background.Surface}" />
            <Setter Property="BorderBrush" Value="{StaticResource Brush.Border.Subtle}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="16" />
        </Style>

        <Style x:Key="AddTileButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border
                            Height="80"
                            Background="{StaticResource Brush.Background.Surface}"
                            BorderBrush="{StaticResource Brush.Border.Subtle}"
                            BorderThickness="1"
                            CornerRadius="16">
                            <Grid>
                                <Rectangle
                                    RadiusX="16"
                                    RadiusY="16"
                                    Stroke="{StaticResource Brush.Text.Muted}"
                                    StrokeDashArray="6,4"
                                    StrokeThickness="1" />
                                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <Viewbox
                                        Width="24"
                                        Height="24"
                                        Stretch="Uniform">
                                        <Path x:Name="AddIcon" Data="{StaticResource PlusSolid}" Fill="{StaticResource Brush.Text.Muted}" />
                                    </Viewbox>
                                    <TextBlock
                                        x:Name="AddLabel"
                                        Margin="0,10,0,0"
                                        HorizontalAlignment="Center"
                                        FontFamily="{StaticResource Bold}"
                                        Foreground="{StaticResource Brush.Text.Secondary}"
                                        Text="Add" />
                                </StackPanel>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="AddIcon" Property="Fill" Value="{StaticResource Brush.Text.Primary}" />
                                <Setter TargetName="AddLabel" Property="Foreground" Value="{StaticResource Brush.Text.Primary}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ActionButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="40" />
            <Setter Property="MinWidth" Value="120" />
            <Setter Property="Padding" Value="18,0" />
            <Setter Property="Background" Value="{StaticResource Brush.Background.Surface}" />
            <Setter Property="BorderBrush" Value="{StaticResource Brush.Border.Subtle}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FontFamily" Value="{StaticResource Bold}" />
            <Setter Property="Foreground" Value="{StaticResource Brush.Text.Primary}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border
                            Padding="{TemplateBinding Padding}"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="12">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style
            x:Key="PrimaryActionButtonStyle"
            BasedOn="{StaticResource ActionButtonStyle}"
            TargetType="Button">
            <Setter Property="Background" Value="{StaticResource Brush.Mint}" />
            <Setter Property="BorderBrush" Value="{StaticResource Brush.Mint}" />
            <Setter Property="Foreground" Value="{StaticResource Brush.Background.Surface}" />
        </Style>
        <Style x:Key="FieldLabelStyle" TargetType="TextBlock">
            <Setter Property="Margin" Value="0,0,0,8" />
            <Setter Property="FontFamily" Value="{StaticResource Bold}" />
            <Setter Property="Foreground" Value="{StaticResource Brush.Text.Primary}" />
        </Style>
        <Style
            x:Key="FieldTextBoxStyle"
            BasedOn="{StaticResource PopupTextInputStyle}"
            TargetType="TextBox">
            <Setter Property="Padding" Value="12,10" />
            <Setter Property="Background" Value="{StaticResource Brush.Background.Surface}" />
            <Setter Property="BorderBrush" Value="{StaticResource Brush.Border.Subtle}" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>
        <Style x:Key="ToggleSwitchStyle" TargetType="ToggleButton">
            <Setter Property="Width" Value="40" />
            <Setter Property="Height" Value="20" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border
                            x:Name="Track"
                            Background="{StaticResource Brush.Background.Hover}"
                            BorderBrush="{StaticResource Brush.Border.Subtle}"
                            BorderThickness="1"
                            CornerRadius="10">
                            <Ellipse
                                x:Name="Thumb"
                                Width="8"
                                Height="8"
                                Margin="4"
                                HorizontalAlignment="Left"
                                Fill="{StaticResource Brush.Text.Primary}">
                                <Ellipse.RenderTransform>
                                    <TranslateTransform x:Name="ThumbTransform" X="0" />
                                </Ellipse.RenderTransform>
                            </Ellipse>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Track" Property="Background" Value="{StaticResource Brush.Mint}" />
                                <Setter TargetName="Thumb" Property="Fill" Value="{StaticResource Brush.Background.Surface}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SidebarStepStyle" TargetType="Border">
            <Setter Property="Height" Value="38" />
            <Setter Property="Margin" Value="0,0,0,4" />
            <Setter Property="CornerRadius" Value="10" />
            <Setter Property="Background" Value="Transparent" />
        </Style>

        <Style x:Key="CardActionButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="28" />
            <Setter Property="Height" Value="28" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Background" Value="{StaticResource Brush.Background.Surface}" />
            <Setter Property="BorderBrush" Value="{StaticResource Brush.Border.Subtle}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border
                            x:Name="Bd"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource Brush.Background.Hovered}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </c:BasePopup.Resources>

    <Grid
        Width="860"
        Height="560"
        Margin="24,0,24,24">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid x:Name="ContentContainer">
        <!--  Greeting Page (Step 0)  -->
        <Border
            Style="{StaticResource PanelStyle}"
            Visibility="{Binding IsGreetingStep, Converter={StaticResource BoolToVisibilityConverter}}">
            <Grid>
                <StackPanel
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center">
                    <Border
                        Width="84"
                        Height="84"
                        HorizontalAlignment="Center"
                        Background="{StaticResource Brush.Background.Surface}"
                        BorderBrush="{StaticResource Brush.Border.Subtle}"
                        BorderThickness="1"
                        CornerRadius="42">
                        <Viewbox Margin="20" Stretch="Uniform">
                            <Path Data="{StaticResource AccountBalanceWallet}" Fill="{StaticResource Brush.Mint}" />
                        </Viewbox>
                    </Border>
                    <TextBlock
                        Margin="0,24,0,0"
                        HorizontalAlignment="Center"
                        FontFamily="{StaticResource Bold}"
                        FontSize="28"
                        Foreground="{StaticResource Brush.Text.Primary}"
                        Text="{Binding CurrentStepTitle}" />
                    <TextBlock
                        Margin="0,12,0,0"
                        HorizontalAlignment="Center"
                        FontFamily="{StaticResource Medium}"
                        FontSize="13"
                        Foreground="{StaticResource Brush.Text.Secondary}"
                        Text="{Binding CurrentStepDescription}"
                        TextAlignment="Center"
                        TextWrapping="Wrap"
                        MaxWidth="420" />
                    <TextBlock
                        Margin="0,24,0,0"
                        HorizontalAlignment="Center"
                        FontFamily="{StaticResource Medium}"
                        FontSize="11"
                        Foreground="{StaticResource Brush.Text.Muted}"
                        Text="We'll walk you through a few quick steps to set things up." />
                </StackPanel>
            </Grid>
        </Border>

        <!--  Middle Steps (1-6): Sidebar + Content  -->
        <Grid Visibility="{Binding IsMiddleStep, Converter={StaticResource BoolToVisibilityConverter}}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="200" />
                <ColumnDefinition Width="20" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!--  Sidebar  -->
            <Border Style="{StaticResource PanelStyle}">
                <StackPanel>
                    <TextBlock
                        FontFamily="{StaticResource Bold}"
                        FontSize="14"
                        Foreground="{StaticResource Brush.Text.Primary}"
                        Text="Setup Steps" />
                    <TextBlock
                        Margin="0,6,0,16"
                        FontFamily="{StaticResource Medium}"
                        FontSize="11"
                        Foreground="{StaticResource Brush.Text.Muted}"
                        Text="{Binding StepCounterText}" />

                    <!--  Step 1  -->
                    <Border Style="{StaticResource SidebarStepStyle}">
                        <Border.Resources>
                            <Style TargetType="Border" BasedOn="{StaticResource SidebarStepStyle}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsStep1Active}" Value="True">
                                        <Setter Property="Background" Value="{StaticResource Brush.Background.Hovered}" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Resources>
                        <Grid>
                            <Border
                                x:Name="Step1Stripe"
                                Width="4"
                                HorizontalAlignment="Left"
                                Background="{StaticResource Brush.Mint}"
                                CornerRadius="2"
                                Opacity="1" />
                            <StackPanel Margin="14,0,0,0" VerticalAlignment="Center" Orientation="Horizontal">
                                <Viewbox Width="12" Height="12">
                                    <Path Data="{StaticResource AccountCircle}" Fill="{StaticResource Brush.Text.Secondary}" />
                                </Viewbox>
                                <TextBlock
                                    Margin="10,0,0,0"
                                    FontFamily="{StaticResource Bold}"
                                    FontSize="12"
                                    Foreground="{StaticResource Brush.Text.Secondary}"
                                    Text="About you" />
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!--  Step 2  -->
                    <Border Style="{StaticResource SidebarStepStyle}">
                        <Border.Resources>
                            <Style TargetType="Border" BasedOn="{StaticResource SidebarStepStyle}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsStep2Active}" Value="True">
                                        <Setter Property="Background" Value="{StaticResource Brush.Background.Hovered}" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Resources>
                        <Grid>
                            <Border
                                Width="4"
                                HorizontalAlignment="Left"
                                Background="{StaticResource Brush.Mint}"
                                CornerRadius="2"
                                Opacity="0" x:Name="Step2Stripe" />
                            <StackPanel Margin="14,0,0,0" VerticalAlignment="Center" Orientation="Horizontal">
                                <Viewbox Width="12" Height="12">
                                    <Path Data="{StaticResource BookDollar}" Fill="{StaticResource Brush.Text.Secondary}" />
                                </Viewbox>
                                <TextBlock
                                    Margin="10,0,0,0"
                                    FontFamily="{StaticResource Bold}"
                                    FontSize="12"
                                    Foreground="{StaticResource Brush.Text.Secondary}"
                                    Text="Spending sources" />
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!--  Step 3  -->
                    <Border Style="{StaticResource SidebarStepStyle}">
                        <Border.Resources>
                            <Style TargetType="Border" BasedOn="{StaticResource SidebarStepStyle}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsStep3Active}" Value="True">
                                        <Setter Property="Background" Value="{StaticResource Brush.Background.Hovered}" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Resources>
                        <Grid>
                            <Border
                                Width="4"
                                HorizontalAlignment="Left"
                                Background="{StaticResource Brush.Mint}"
                                CornerRadius="2"
                                Opacity="0" x:Name="Step3Stripe" />
                            <StackPanel Margin="14,0,0,0" VerticalAlignment="Center" Orientation="Horizontal">
                                <Viewbox Width="12" Height="12">
                                    <Path Data="{StaticResource InvoiceLight}" Fill="{StaticResource Brush.Text.Secondary}" />
                                </Viewbox>
                                <TextBlock
                                    Margin="10,0,0,0"
                                    FontFamily="{StaticResource Bold}"
                                    FontSize="12"
                                    Foreground="{StaticResource Brush.Text.Secondary}"
                                    Text="Fixed expenses" />
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!--  Step 4  -->
                    <Border Style="{StaticResource SidebarStepStyle}">
                        <Border.Resources>
                            <Style TargetType="Border" BasedOn="{StaticResource SidebarStepStyle}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsStep4Active}" Value="True">
                                        <Setter Property="Background" Value="{StaticResource Brush.Background.Hovered}" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Resources>
                        <Grid>
                            <Border
                                Width="4"
                                HorizontalAlignment="Left"
                                Background="{StaticResource Brush.Mint}"
                                CornerRadius="2"
                                Opacity="0" x:Name="Step4Stripe" />
                            <StackPanel Margin="14,0,0,0" VerticalAlignment="Center" Orientation="Horizontal">
                                <Viewbox Width="12" Height="12">
                                    <Path Data="{StaticResource BullseyeSolid}" Fill="{StaticResource Brush.Text.Secondary}" />
                                </Viewbox>
                                <TextBlock
                                    Margin="10,0,0,0"
                                    FontFamily="{StaticResource Bold}"
                                    FontSize="12"
                                    Foreground="{StaticResource Brush.Text.Secondary}"
                                    Text="Savings goals" />
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!--  Step 5  -->
                    <Border Style="{StaticResource SidebarStepStyle}">
                        <Border.Resources>
                            <Style TargetType="Border" BasedOn="{StaticResource SidebarStepStyle}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsStep5Active}" Value="True">
                                        <Setter Property="Background" Value="{StaticResource Brush.Background.Hovered}" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Resources>
                        <Grid>
                            <Border
                                Width="4"
                                HorizontalAlignment="Left"
                                Background="{StaticResource Brush.Mint}"
                                CornerRadius="2"
                                Opacity="0" x:Name="Step5Stripe" />
                            <StackPanel Margin="14,0,0,0" VerticalAlignment="Center" Orientation="Horizontal">
                                <Viewbox Width="12" Height="12">
                                    <Path Data="{StaticResource AccountBalanceWallet}" Fill="{StaticResource Brush.Text.Secondary}" />
                                </Viewbox>
                                <TextBlock
                                    Margin="10,0,0,0"
                                    FontFamily="{StaticResource Bold}"
                                    FontSize="12"
                                    Foreground="{StaticResource Brush.Text.Secondary}"
                                    Text="Budget allocation" />
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!--  Step 6  -->
                    <Border Style="{StaticResource SidebarStepStyle}">
                        <Border.Resources>
                            <Style TargetType="Border" BasedOn="{StaticResource SidebarStepStyle}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsStep6Active}" Value="True">
                                        <Setter Property="Background" Value="{StaticResource Brush.Background.Hovered}" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Resources>
                        <Grid>
                            <Border
                                Width="4"
                                HorizontalAlignment="Left"
                                Background="{StaticResource Brush.Mint}"
                                CornerRadius="2"
                                Opacity="0" x:Name="Step6Stripe" />
                            <StackPanel Margin="14,0,0,0" VerticalAlignment="Center" Orientation="Horizontal">
                                <Viewbox Width="12" Height="12">
                                    <Path Data="{StaticResource RegularBell}" Fill="{StaticResource Brush.Text.Secondary}" />
                                </Viewbox>
                                <TextBlock
                                    Margin="10,0,0,0"
                                    FontFamily="{StaticResource Bold}"
                                    FontSize="12"
                                    Foreground="{StaticResource Brush.Text.Secondary}"
                                    Text="Notifications" />
                            </StackPanel>
                        </Grid>
                    </Border>
                </StackPanel>
            </Border>

            <!--  Content Area  -->
            <Border x:Name="ContentColumn" Grid.Column="2" Style="{StaticResource PanelStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <StackPanel>
                        <TextBlock
                            FontFamily="{StaticResource Bold}"
                            FontSize="22"
                            Foreground="{StaticResource Brush.Text.Primary}"
                            Text="{Binding CurrentStepTitle}" />
                        <TextBlock
                            Margin="0,8,0,0"
                            FontFamily="{StaticResource Medium}"
                            Foreground="{StaticResource Brush.Text.Secondary}"
                            Text="{Binding CurrentStepDescription}"
                            TextWrapping="Wrap" />
                    </StackPanel>

                    <ScrollViewer
                        Grid.Row="1"
                        Margin="0,22,0,0"
                        VerticalScrollBarVisibility="Auto">
                        <Grid>
                            <!--  Step 1: Personalization  -->
                            <Grid Visibility="{Binding IsStep1Active, Converter={StaticResource BoolToVisibilityConverter}}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="20" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="0" Style="{StaticResource CardStyle}">
                                    <StackPanel>
                                        <TextBlock Style="{StaticResource FieldLabelStyle}" Text="Username" />
                                        <TextBox Style="{StaticResource FieldTextBoxStyle}" Text="{Binding UsernameText, UpdateSourceTrigger=PropertyChanged}" />
                                    </StackPanel>
                                </Border>
                                <Border Grid.Column="2" Style="{StaticResource CardStyle}">
                                    <StackPanel>
                                        <TextBlock Style="{StaticResource FieldLabelStyle}" Text="Salary (Optional)" />
                                        <TextBox Style="{StaticResource FieldTextBoxStyle}" Text="{Binding SalaryText, UpdateSourceTrigger=PropertyChanged}" />
                                        <TextBlock
                                            Margin="0,12,0,0"
                                            FontFamily="{StaticResource Medium}"
                                            FontSize="11"
                                            Foreground="{StaticResource Brush.Text.Secondary}"
                                            Text="This helps Fluxo preview your starting budget allocation." />
                                    </StackPanel>
                                </Border>
                            </Grid>

                            <!--  Step 2: Spending Sources  -->
                            <StackPanel Visibility="{Binding IsStep2Active, Converter={StaticResource BoolToVisibilityConverter}}">
                                <Button Click="OnAddSpendingSourceClick" Style="{StaticResource AddTileButtonStyle}" />
                                <ItemsControl Margin="0,16,0,0" ItemsSource="{Binding SpendingSources}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <primitives:UniformGrid Columns="2" />
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemContainerStyle>
                                        <Style TargetType="ContentPresenter">
                                            <Setter Property="Margin" Value="0,0,12,12" />
                                        </Style>
                                    </ItemsControl.ItemContainerStyle>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Style="{StaticResource CardStyle}">
                                                <Grid>
                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="Auto" />
                                                        <RowDefinition Height="*" />
                                                    </Grid.RowDefinitions>
                                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                                        <Button
                                                            Click="OnEditSpendingSourceClick"
                                                            Style="{StaticResource CardActionButtonStyle}"
                                                            Tag="{Binding Id}">
                                                            <Viewbox Width="10" Height="10">
                                                                <Path Data="{StaticResource Edit}" Fill="{StaticResource Brush.Text.Muted}" />
                                                            </Viewbox>
                                                        </Button>
                                                        <Button
                                                            Margin="4,0,0,0"
                                                            Click="OnDeleteSpendingSourceClick"
                                                            Style="{StaticResource CardActionButtonStyle}"
                                                            Tag="{Binding Id}">
                                                            <Viewbox Width="10" Height="10">
                                                                <Path Data="{StaticResource Close}" Fill="{StaticResource Brush.Text.Muted}" />
                                                            </Viewbox>
                                                        </Button>
                                                    </StackPanel>
                                                    <StackPanel Grid.Row="1" Margin="0,4,0,0">
                                                        <TextBlock
                                                            FontFamily="{StaticResource Bold}"
                                                            FontSize="15"
                                                            Foreground="{StaticResource Brush.Text.Primary}"
                                                            Text="{Binding Name}" />
                                                        <TextBlock
                                                            Margin="0,8,0,0"
                                                            FontFamily="{StaticResource Medium}"
                                                            Foreground="{StaticResource Brush.Text.Secondary}"
                                                            Text="{Binding TypeLabel}" />
                                                        <TextBlock
                                                            Margin="0,12,0,0"
                                                            FontFamily="{StaticResource Bold}"
                                                            Foreground="{StaticResource Brush.Mint}">
                                                            <Run Text="{Binding PrimaryAmountLabel}" />
                                                            <Run Text=": " />
                                                            <Run Text="{Binding PrimaryAmount, StringFormat={}{0:N2}}" />
                                                        </TextBlock>
                                                    </StackPanel>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>

                            <!--  Step 3: Fixed Expenses  -->
                            <StackPanel Visibility="{Binding IsStep3Active, Converter={StaticResource BoolToVisibilityConverter}}">
                                <Button Click="OnAddFixedExpenseClick" Style="{StaticResource AddTileButtonStyle}" />
                                <ItemsControl Margin="0,16,0,0" ItemsSource="{Binding FixedExpenses}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <primitives:UniformGrid Columns="2" />
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemContainerStyle>
                                        <Style TargetType="ContentPresenter">
                                            <Setter Property="Margin" Value="0,0,12,12" />
                                        </Style>
                                    </ItemsControl.ItemContainerStyle>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Style="{StaticResource CardStyle}">
                                                <Grid>
                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="Auto" />
                                                        <RowDefinition Height="*" />
                                                    </Grid.RowDefinitions>
                                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                                        <Button
                                                            Click="OnEditFixedExpenseClick"
                                                            Style="{StaticResource CardActionButtonStyle}"
                                                            Tag="{Binding Id}">
                                                            <Viewbox Width="10" Height="10">
                                                                <Path Data="{StaticResource Edit}" Fill="{StaticResource Brush.Text.Muted}" />
                                                            </Viewbox>
                                                        </Button>
                                                        <Button
                                                            Margin="4,0,0,0"
                                                            Click="OnDeleteFixedExpenseClick"
                                                            Style="{StaticResource CardActionButtonStyle}"
                                                            Tag="{Binding Id}">
                                                            <Viewbox Width="10" Height="10">
                                                                <Path Data="{StaticResource Close}" Fill="{StaticResource Brush.Text.Muted}" />
                                                            </Viewbox>
                                                        </Button>
                                                    </StackPanel>
                                                    <StackPanel Grid.Row="1" Margin="0,4,0,0">
                                                        <TextBlock
                                                            FontFamily="{StaticResource Bold}"
                                                            FontSize="15"
                                                            Foreground="{StaticResource Brush.Text.Primary}"
                                                            Text="{Binding Name}" />
                                                        <TextBlock
                                                            Margin="0,8,0,0"
                                                            FontFamily="{StaticResource Medium}"
                                                            Foreground="{StaticResource Brush.Text.Secondary}">
                                                            <Run Text="{Binding CategoryLabel}" />
                                                            <Run Text=" · " />
                                                            <Run Text="{Binding SpendingSourceName}" />
                                                        </TextBlock>
                                                        <TextBlock
                                                            Margin="0,12,0,0"
                                                            FontFamily="{StaticResource Bold}"
                                                            Foreground="{StaticResource Brush.Warning}"
                                                            Text="{Binding Amount, StringFormat={}{0:N2}}" />
                                                        <TextBlock
                                                            Margin="0,8,0,0"
                                                            FontFamily="{StaticResource Medium}"
                                                            Foreground="{StaticResource Brush.Text.Secondary}"
                                                            Text="{Binding DueDate, StringFormat=Due {0:MMM d}}" />
                                                    </StackPanel>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>

                            <!--  Step 4: Savings Goals  -->
                            <StackPanel Visibility="{Binding IsStep4Active, Converter={StaticResource BoolToVisibilityConverter}}">
                                <Button Click="OnAddSavingGoalClick" Style="{StaticResource AddTileButtonStyle}" />
                                <ItemsControl Margin="0,16,0,0" ItemsSource="{Binding SavingGoals}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <primitives:UniformGrid Columns="2" />
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemContainerStyle>
                                        <Style TargetType="ContentPresenter">
                                            <Setter Property="Margin" Value="0,0,12,12" />
                                        </Style>
                                    </ItemsControl.ItemContainerStyle>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Style="{StaticResource CardStyle}">
                                                <Grid>
                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="Auto" />
                                                        <RowDefinition Height="*" />
                                                    </Grid.RowDefinitions>
                                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                                        <Button
                                                            Click="OnEditSavingGoalClick"
                                                            Style="{StaticResource CardActionButtonStyle}"
                                                            Tag="{Binding Id}">
                                                            <Viewbox Width="10" Height="10">
                                                                <Path Data="{StaticResource Edit}" Fill="{StaticResource Brush.Text.Muted}" />
                                                            </Viewbox>
                                                        </Button>
                                                        <Button
                                                            Margin="4,0,0,0"
                                                            Click="OnDeleteSavingGoalClick"
                                                            Style="{StaticResource CardActionButtonStyle}"
                                                            Tag="{Binding Id}">
                                                            <Viewbox Width="10" Height="10">
                                                                <Path Data="{StaticResource Close}" Fill="{StaticResource Brush.Text.Muted}" />
                                                            </Viewbox>
                                                        </Button>
                                                    </StackPanel>
                                                    <StackPanel Grid.Row="1" Margin="0,4,0,0">
                                                        <TextBlock
                                                            FontFamily="{StaticResource Bold}"
                                                            FontSize="15"
                                                            Foreground="{StaticResource Brush.Text.Primary}"
                                                            Text="{Binding Name}" />
                                                        <TextBlock
                                                            Margin="0,8,0,0"
                                                            FontFamily="{StaticResource Medium}"
                                                            Foreground="{StaticResource Brush.Text.Secondary}"
                                                            Text="{Binding SavingEndDate, StringFormat=Target {0:MMM d, yyyy}}" />
                                                        <TextBlock
                                                            Margin="0,12,0,0"
                                                            FontFamily="{StaticResource Bold}"
                                                            Foreground="{StaticResource Brush.Mint}">
                                                            <Run Text="{Binding CurrentAmount, StringFormat={}{0:N2}}" />
                                                            <Run Text=" / " />
                                                            <Run Text="{Binding TargetAmount, StringFormat={}{0:N2}}" />
                                                        </TextBlock>
                                                    </StackPanel>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>

                            <!--  Step 5: Budget Allocation  -->
                            <StackPanel Visibility="{Binding IsStep5Active, Converter={StaticResource BoolToVisibilityConverter}}">
                                <Border Style="{StaticResource CardStyle}">
                                    <StackPanel>
                                        <TextBlock
                                            FontFamily="{StaticResource Bold}"
                                            Foreground="{StaticResource Brush.Text.Primary}"
                                            Text="Needs" />
                                        <Slider
                                            Margin="0,14,0,0"
                                            Maximum="100"
                                            Minimum="0"
                                            Style="{StaticResource BudgetSliderStyle}"
                                            TickFrequency="1"
                                            Value="{Binding NeedsAllocationPercentage, Mode=TwoWay}" />
                                        <DockPanel Margin="0,8,0,0">
                                            <TextBlock
                                                DockPanel.Dock="Left"
                                                FontFamily="{StaticResource Bold}"
                                                Foreground="{StaticResource Brush.Text.Primary}"
                                                Text="{Binding NeedsAllocationPercentage, StringFormat={}{0}%}" />
                                            <TextBlock
                                                HorizontalAlignment="Right"
                                                FontFamily="{StaticResource Medium}"
                                                Foreground="{StaticResource Brush.Text.Secondary}"
                                                Text="{Binding NeedsAllocationAmountText}" />
                                        </DockPanel>
                                    </StackPanel>
                                </Border>
                                <Border Margin="0,12,0,0" Style="{StaticResource CardStyle}">
                                    <StackPanel>
                                        <TextBlock
                                            FontFamily="{StaticResource Bold}"
                                            Foreground="{StaticResource Brush.Text.Primary}"
                                            Text="Wants" />
                                        <Slider
                                            Margin="0,14,0,0"
                                            Maximum="100"
                                            Minimum="0"
                                            Style="{StaticResource BudgetSliderStyle}"
                                            TickFrequency="1"
                                            Value="{Binding WantsAllocationPercentage, Mode=TwoWay}" />
                                        <DockPanel Margin="0,8,0,0">
                                            <TextBlock
                                                DockPanel.Dock="Left"
                                                FontFamily="{StaticResource Bold}"
                                                Foreground="{StaticResource Brush.Text.Primary}"
                                                Text="{Binding WantsAllocationPercentage, StringFormat={}{0}%}" />
                                            <TextBlock
                                                HorizontalAlignment="Right"
                                                FontFamily="{StaticResource Medium}"
                                                Foreground="{StaticResource Brush.Text.Secondary}"
                                                Text="{Binding WantsAllocationAmountText}" />
                                        </DockPanel>
                                    </StackPanel>
                                </Border>
                                <Border Margin="0,12,0,0" Style="{StaticResource CardStyle}">
                                    <StackPanel>
                                        <TextBlock
                                            FontFamily="{StaticResource Bold}"
                                            Foreground="{StaticResource Brush.Text.Primary}"
                                            Text="Invest" />
                                        <Slider
                                            Margin="0,14,0,0"
                                            Maximum="100"
                                            Minimum="0"
                                            Style="{StaticResource BudgetSliderStyle}"
                                            TickFrequency="1"
                                            Value="{Binding InvestAllocationPercentage, Mode=TwoWay}" />
                                        <DockPanel Margin="0,8,0,0">
                                            <TextBlock
                                                DockPanel.Dock="Left"
                                                FontFamily="{StaticResource Bold}"
                                                Foreground="{StaticResource Brush.Text.Primary}"
                                                Text="{Binding InvestAllocationPercentage, StringFormat={}{0}%}" />
                                            <TextBlock
                                                HorizontalAlignment="Right"
                                                FontFamily="{StaticResource Medium}"
                                                Foreground="{StaticResource Brush.Text.Secondary}"
                                                Text="{Binding InvestAllocationAmountText}" />
                                        </DockPanel>
                                    </StackPanel>
                                </Border>

                                <TextBlock
                                    Margin="0,12,0,0"
                                    FontFamily="{StaticResource Bold}"
                                    Foreground="{StaticResource Brush.Danger}"
                                    Text="{Binding BudgetAllocationErrorMessage}"
                                    Visibility="{Binding HasBudgetAllocationError, Converter={StaticResource BoolToVisibilityConverter}}" />
                            </StackPanel>

                            <!--  Step 6: Notifications  -->
                            <ItemsControl ItemsSource="{Binding NotificationSettings}" Visibility="{Binding IsStep6Active, Converter={StaticResource BoolToVisibilityConverter}}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Margin="0,0,0,12" Style="{StaticResource CardStyle}">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <StackPanel>
                                                    <TextBlock
                                                        FontFamily="{StaticResource Bold}"
                                                        Foreground="{StaticResource Brush.Text.Primary}"
                                                        Text="{Binding Title}" />
                                                    <TextBlock
                                                        Margin="0,6,0,0"
                                                        FontFamily="{StaticResource Medium}"
                                                        Foreground="{StaticResource Brush.Text.Secondary}"
                                                        Text="{Binding Description}"
                                                        TextWrapping="Wrap" />
                                                </StackPanel>
                                                <ToggleButton
                                                    Grid.Column="1"
                                                    VerticalAlignment="Center"
                                                    IsChecked="{Binding IsEnabled, Mode=TwoWay}"
                                                    Style="{StaticResource ToggleSwitchStyle}" />
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </Grid>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>

        <!--  Loading Page (Step 7)  -->
        <Border
            Style="{StaticResource PanelStyle}"
            Visibility="{Binding IsLoadingStep, Converter={StaticResource BoolToVisibilityConverter}}">
            <Grid>
                <StackPanel
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center">
                    <Border
                        Width="84"
                        Height="84"
                        HorizontalAlignment="Center"
                        Background="{StaticResource Brush.Background.Surface}"
                        BorderBrush="{StaticResource Brush.Border.Subtle}"
                        BorderThickness="1"
                        CornerRadius="42">
                        <Viewbox Margin="20" Stretch="Uniform">
                            <Path Data="{StaticResource AccountBalanceWallet}" Fill="{StaticResource Brush.Mint}" />
                        </Viewbox>
                    </Border>
                    <TextBlock
                        Margin="0,24,0,0"
                        HorizontalAlignment="Center"
                        FontFamily="{StaticResource Bold}"
                        FontSize="28"
                        Foreground="{StaticResource Brush.Text.Primary}"
                        Text="{Binding CurrentStepTitle}" />
                    <TextBlock
                        Margin="0,12,0,0"
                        HorizontalAlignment="Center"
                        FontFamily="{StaticResource Medium}"
                        FontSize="13"
                        Foreground="{StaticResource Brush.Text.Secondary}"
                        Text="{Binding CurrentStepDescription}"
                        TextAlignment="Center" />
                    <ProgressBar
                        Width="240"
                        Height="8"
                        Margin="0,28,0,0"
                        Foreground="{StaticResource Brush.Mint}"
                        IsIndeterminate="True" />
                </StackPanel>
            </Grid>
        </Border>

        <!--  Welcome Page (Step 8)  -->
        <Border
            Style="{StaticResource PanelStyle}"
            Visibility="{Binding IsFinalStep, Converter={StaticResource BoolToVisibilityConverter}}">
            <Grid>
                <StackPanel
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center">
                    <Border
                        Width="84"
                        Height="84"
                        HorizontalAlignment="Center"
                        Background="{StaticResource Brush.Background.Surface}"
                        BorderBrush="{StaticResource Brush.Border.Subtle}"
                        BorderThickness="1"
                        CornerRadius="42">
                        <Viewbox Margin="20" Stretch="Uniform">
                            <Path Data="{StaticResource AccountBalanceWallet}" Fill="{StaticResource Brush.Mint}" />
                        </Viewbox>
                    </Border>
                    <TextBlock
                        Margin="0,18,0,0"
                        HorizontalAlignment="Center"
                        FontFamily="{StaticResource Bold}"
                        FontSize="28"
                        Foreground="{StaticResource Brush.Text.Primary}">
                        <Run Text="Welcome to Fluxo, " />
                        <Run Text="{Binding ResolvedUsername, Mode=OneWay}" />
                    </TextBlock>
                    <TextBlock
                        Margin="0,12,0,0"
                        HorizontalAlignment="Center"
                        FontFamily="{StaticResource Medium}"
                        FontSize="12"
                        Foreground="{StaticResource Brush.Text.Secondary}"
                        Text="Your dashboard, goals, and reminders are ready to go."
                        TextAlignment="Center" />
                </StackPanel>
            </Grid>
        </Border>
        </Grid>

        <!--  Navigation Bar  -->
        <Grid
            Grid.Row="1"
            Margin="0,16,0,0"
            Visibility="{Binding IsLoadingStep, Converter={StaticResource BoolToVisibilityInvertedConverter}}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!--  Back Button  -->
            <Button
                HorizontalAlignment="Left"
                Click="OnBackClick"
                Content="&lt; Back"
                Style="{StaticResource ActionButtonStyle}"
                Visibility="{Binding IsGreetingStep, Converter={StaticResource BoolToVisibilityInvertedConverter}}" />

            <!--  Dot Navigator  -->
            <ItemsControl
                Grid.Column="1"
                VerticalAlignment="Center"
                ItemsSource="{Binding StepDots}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel Orientation="Horizontal" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Ellipse
                            Width="8"
                            Height="8"
                            Margin="3,0">
                            <Ellipse.Style>
                                <Style TargetType="Ellipse">
                                    <Setter Property="Fill" Value="{StaticResource Brush.Text.Muted}" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsActive}" Value="True">
                                            <Setter Property="Fill" Value="{StaticResource Brush.Mint}" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Ellipse.Style>
                        </Ellipse>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <!--  Next / Open Fluxo  -->
            <StackPanel
                Grid.Column="2"
                HorizontalAlignment="Right"
                Orientation="Horizontal">
                <Button
                    Click="OnNextClick"
                    Content="Next &gt;"
                    Style="{StaticResource PrimaryActionButtonStyle}"
                    Visibility="{Binding IsFinalStep, Converter={StaticResource BoolToVisibilityInvertedConverter}}" />
                <Button
                    Click="OnFinishClick"
                    Content="Open Fluxo"
                    Style="{StaticResource PrimaryActionButtonStyle}"
                    Visibility="{Binding IsFinalStep, Converter={StaticResource BoolToVisibilityConverter}}" />
            </StackPanel>
        </Grid>
    </Grid>
</c:BasePopup>
