<c:BasePopup
    x:Class="Fluxo.Views.Popups.StartupWizardPopup"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:c="clr-namespace:Fluxo.Resources.CustomControls"
    xmlns:primitives="clr-namespace:System.Windows.Controls.Primitives;assembly=PresentationFramework"
    PopupTitle="Welcome to Fluxo">

    <c:BasePopup.Resources>
        <Style x:Key="PanelStyle" TargetType="Border">
            <Setter Property="Padding" Value="18" />
            <Setter Property="Background" Value="{StaticResource Brush.Background.Elevated}" />
            <Setter Property="BorderBrush" Value="{StaticResource Brush.Border.Subtle}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="18" />
        </Style>
        <Style x:Key="StepPillStyle" TargetType="Border">
            <Setter Property="Height" Value="34" />
            <Setter Property="Margin" Value="0,0,8,0" />
            <Setter Property="Padding" Value="14,0" />
            <Setter Property="Background" Value="{StaticResource Brush.Background.Surface}" />
            <Setter Property="BorderBrush" Value="{StaticResource Brush.Border.Subtle}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="17" />
        </Style>
        <Style x:Key="CardStyle" TargetType="Border">
            <Setter Property="Margin" Value="0,0,0,16" />
            <Setter Property="Padding" Value="16" />
            <Setter Property="Background" Value="{StaticResource Brush.Background.Surface}" />
            <Setter Property="BorderBrush" Value="{StaticResource Brush.Border.Subtle}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="16" />
        </Style>
        <Style x:Key="AddTileButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border
                            Height="152"
                            Background="{StaticResource Brush.Background.Surface}"
                            BorderBrush="{StaticResource Brush.Border.Subtle}"
                            BorderThickness="1"
                            CornerRadius="16">
                            <Grid>
                                <Rectangle
                                    RadiusX="16"
                                    RadiusY="16"
                                    Stroke="{StaticResource Brush.Text.Muted}"
                                    StrokeDashArray="6,4"
                                    StrokeThickness="1" />
                                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <Viewbox
                                        Width="24"
                                        Height="24"
                                        Stretch="Uniform">
                                        <Path Data="{StaticResource PlusSolid}" Fill="{StaticResource Brush.Text.Muted}" />
                                    </Viewbox>
                                    <TextBlock
                                        Margin="0,10,0,0"
                                        HorizontalAlignment="Center"
                                        FontFamily="{StaticResource Bold}"
                                        Foreground="{StaticResource Brush.Text.Secondary}"
                                        Text="Add" />
                                </StackPanel>
                            </Grid>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="ActionButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="40" />
            <Setter Property="MinWidth" Value="120" />
            <Setter Property="Padding" Value="18,0" />
            <Setter Property="Background" Value="{StaticResource Brush.Background.Surface}" />
            <Setter Property="BorderBrush" Value="{StaticResource Brush.Border.Subtle}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FontFamily" Value="{StaticResource Bold}" />
            <Setter Property="Foreground" Value="{StaticResource Brush.Text.Primary}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border
                            Padding="{TemplateBinding Padding}"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="12">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style
            x:Key="PrimaryActionButtonStyle"
            BasedOn="{StaticResource ActionButtonStyle}"
            TargetType="Button">
            <Setter Property="Background" Value="{StaticResource Brush.Mint}" />
            <Setter Property="BorderBrush" Value="{StaticResource Brush.Mint}" />
            <Setter Property="Foreground" Value="{StaticResource Brush.Background.Surface}" />
        </Style>
        <Style x:Key="FieldLabelStyle" TargetType="TextBlock">
            <Setter Property="Margin" Value="0,0,0,8" />
            <Setter Property="FontFamily" Value="{StaticResource Bold}" />
            <Setter Property="Foreground" Value="{StaticResource Brush.Text.Primary}" />
        </Style>
        <Style
            x:Key="FieldTextBoxStyle"
            BasedOn="{StaticResource PopupTextInputStyle}"
            TargetType="TextBox">
            <Setter Property="Padding" Value="12,10" />
            <Setter Property="Background" Value="{StaticResource Brush.Background.Surface}" />
            <Setter Property="BorderBrush" Value="{StaticResource Brush.Border.Subtle}" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>
        <Style x:Key="ToggleSwitchStyle" TargetType="ToggleButton">
            <Setter Property="Width" Value="40" />
            <Setter Property="Height" Value="20" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border
                            x:Name="Track"
                            Background="{StaticResource Brush.Background.Hover}"
                            BorderBrush="{StaticResource Brush.Border.Subtle}"
                            BorderThickness="1"
                            CornerRadius="10">
                            <Ellipse
                                x:Name="Thumb"
                                Width="8"
                                Height="8"
                                Margin="4"
                                HorizontalAlignment="Left"
                                Fill="{StaticResource Brush.Text.Primary}">
                                <Ellipse.RenderTransform>
                                    <TranslateTransform x:Name="ThumbTransform" X="0" />
                                </Ellipse.RenderTransform>
                            </Ellipse>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Track" Property="Background" Value="{StaticResource Brush.Mint}" />
                                <Setter TargetName="Thumb" Property="Fill" Value="{StaticResource Brush.Background.Surface}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </c:BasePopup.Resources>

    <Grid
        Width="860"
        Height="560"
        Margin="24,0,24,24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Orientation="Horizontal">
            <Border Style="{StaticResource StepPillStyle}">
                <TextBlock
                    VerticalAlignment="Center"
                    FontFamily="{StaticResource Bold}"
                    Foreground="{StaticResource Brush.Text.Primary}"
                    Text="{Binding StepCounterText}" />
            </Border>
            <Border Style="{StaticResource StepPillStyle}">
                <TextBlock
                    VerticalAlignment="Center"
                    FontFamily="{StaticResource Medium}"
                    Foreground="{StaticResource Brush.Text.Secondary}"
                    Text="{Binding CurrentStepTitle}" />
            </Border>
        </StackPanel>

        <Border
            Grid.Row="1"
            Margin="0,16,0,16"
            Style="{StaticResource PanelStyle}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <StackPanel>
                    <TextBlock
                        FontFamily="{StaticResource Bold}"
                        FontSize="22"
                        Foreground="{StaticResource Brush.Text.Primary}"
                        Text="{Binding CurrentStepTitle}" />
                    <TextBlock
                        Margin="0,8,0,0"
                        FontFamily="{StaticResource Medium}"
                        Foreground="{StaticResource Brush.Text.Secondary}"
                        Text="{Binding CurrentStepDescription}"
                        TextWrapping="Wrap" />
                </StackPanel>

                <ScrollViewer
                    Grid.Row="1"
                    Margin="0,22,0,0"
                    VerticalScrollBarVisibility="Auto">
                    <Grid>
                        <Grid Visibility="{Binding IsStep1Active, Converter={StaticResource BoolToVisibilityConverter}}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="20" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" Style="{StaticResource CardStyle}">
                                <StackPanel>
                                    <TextBlock Style="{StaticResource FieldLabelStyle}" Text="Username" />
                                    <TextBox Style="{StaticResource FieldTextBoxStyle}" Text="{Binding UsernameText, UpdateSourceTrigger=PropertyChanged}" />
                                </StackPanel>
                            </Border>
                            <Border Grid.Column="2" Style="{StaticResource CardStyle}">
                                <StackPanel>
                                    <TextBlock Style="{StaticResource FieldLabelStyle}" Text="Salary (Optional)" />
                                    <TextBox Style="{StaticResource FieldTextBoxStyle}" Text="{Binding SalaryText, UpdateSourceTrigger=PropertyChanged}" />
                                    <TextBlock
                                        Margin="0,12,0,0"
                                        FontFamily="{StaticResource Medium}"
                                        FontSize="11"
                                        Foreground="{StaticResource Brush.Text.Secondary}"
                                        Text="This helps Fluxo preview your starting budget allocation." />
                                </StackPanel>
                            </Border>
                        </Grid>

                        <StackPanel Visibility="{Binding IsStep2Active, Converter={StaticResource BoolToVisibilityConverter}}">
                            <ItemsControl ItemsSource="{Binding SpendingSources}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <primitives:UniformGrid Columns="2" />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Style="{StaticResource CardStyle}">
                                            <StackPanel>
                                                <TextBlock
                                                    FontFamily="{StaticResource Bold}"
                                                    FontSize="15"
                                                    Foreground="{StaticResource Brush.Text.Primary}"
                                                    Text="{Binding Name}" />
                                                <TextBlock
                                                    Margin="0,8,0,0"
                                                    FontFamily="{StaticResource Medium}"
                                                    Foreground="{StaticResource Brush.Text.Secondary}"
                                                    Text="{Binding TypeLabel}" />
                                                <TextBlock
                                                    Margin="0,12,0,0"
                                                    FontFamily="{StaticResource Bold}"
                                                    Foreground="{StaticResource Brush.Mint}">
                                                    <Run Text="{Binding PrimaryAmountLabel}" />
                                                    <Run Text=": " />
                                                    <Run Text="{Binding PrimaryAmount, StringFormat={}{0:N2}}" />
                                                </TextBlock>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                            <Button Click="OnAddSpendingSourceClick" Style="{StaticResource AddTileButtonStyle}" />
                        </StackPanel>

                        <StackPanel Visibility="{Binding IsStep3Active, Converter={StaticResource BoolToVisibilityConverter}}">
                            <ItemsControl ItemsSource="{Binding FixedExpenses}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <primitives:UniformGrid Columns="2" />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Style="{StaticResource CardStyle}">
                                            <StackPanel>
                                                <TextBlock
                                                    FontFamily="{StaticResource Bold}"
                                                    FontSize="15"
                                                    Foreground="{StaticResource Brush.Text.Primary}"
                                                    Text="{Binding Name}" />
                                                <TextBlock
                                                    Margin="0,8,0,0"
                                                    FontFamily="{StaticResource Medium}"
                                                    Foreground="{StaticResource Brush.Text.Secondary}">
                                                    <Run Text="{Binding CategoryLabel}" />
                                                    <Run Text=" • " />
                                                    <Run Text="{Binding SpendingSourceName}" />
                                                </TextBlock>
                                                <TextBlock
                                                    Margin="0,12,0,0"
                                                    FontFamily="{StaticResource Bold}"
                                                    Foreground="{StaticResource Brush.Warning}"
                                                    Text="{Binding Amount, StringFormat={}{0:N2}}" />
                                                <TextBlock
                                                    Margin="0,8,0,0"
                                                    FontFamily="{StaticResource Medium}"
                                                    Foreground="{StaticResource Brush.Text.Secondary}"
                                                    Text="{Binding DueDate, StringFormat=Due {0:MMM d}}" />
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                            <Button Click="OnAddFixedExpenseClick" Style="{StaticResource AddTileButtonStyle}" />
                        </StackPanel>

                        <StackPanel Visibility="{Binding IsStep4Active, Converter={StaticResource BoolToVisibilityConverter}}">
                            <ItemsControl ItemsSource="{Binding SavingGoals}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <primitives:UniformGrid Columns="2" />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Style="{StaticResource CardStyle}">
                                            <StackPanel>
                                                <TextBlock
                                                    FontFamily="{StaticResource Bold}"
                                                    FontSize="15"
                                                    Foreground="{StaticResource Brush.Text.Primary}"
                                                    Text="{Binding Name}" />
                                                <TextBlock
                                                    Margin="0,8,0,0"
                                                    FontFamily="{StaticResource Medium}"
                                                    Foreground="{StaticResource Brush.Text.Secondary}"
                                                    Text="{Binding SavingEndDate, StringFormat=Target {0:MMM d, yyyy}}" />
                                                <TextBlock
                                                    Margin="0,12,0,0"
                                                    FontFamily="{StaticResource Bold}"
                                                    Foreground="{StaticResource Brush.Mint}">
                                                    <Run Text="{Binding CurrentAmount, StringFormat={}{0:N2}}" />
                                                    <Run Text=" / " />
                                                    <Run Text="{Binding TargetAmount, StringFormat={}{0:N2}}" />
                                                </TextBlock>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                            <Button Click="OnAddSavingGoalClick" Style="{StaticResource AddTileButtonStyle}" />
                        </StackPanel>

                        <StackPanel Visibility="{Binding IsStep5Active, Converter={StaticResource BoolToVisibilityConverter}}">
                            <Border Style="{StaticResource CardStyle}">
                                <StackPanel>
                                    <TextBlock
                                        FontFamily="{StaticResource Bold}"
                                        Foreground="{StaticResource Brush.Text.Primary}"
                                        Text="Needs" />
                                    <Slider
                                        Margin="0,14,0,0"
                                        Maximum="100"
                                        Minimum="0"
                                        TickFrequency="1"
                                        Value="{Binding NeedsAllocationPercentage, Mode=TwoWay}" />
                                    <DockPanel Margin="0,8,0,0">
                                        <TextBlock
                                            DockPanel.Dock="Left"
                                            FontFamily="{StaticResource Bold}"
                                            Foreground="{StaticResource Brush.Text.Primary}"
                                            Text="{Binding NeedsAllocationPercentage, StringFormat={}{0}%}" />
                                        <TextBlock
                                            HorizontalAlignment="Right"
                                            FontFamily="{StaticResource Medium}"
                                            Foreground="{StaticResource Brush.Text.Secondary}"
                                            Text="{Binding NeedsAllocationAmountText}" />
                                    </DockPanel>
                                </StackPanel>
                            </Border>
                            <Border Style="{StaticResource CardStyle}">
                                <StackPanel>
                                    <TextBlock
                                        FontFamily="{StaticResource Bold}"
                                        Foreground="{StaticResource Brush.Text.Primary}"
                                        Text="Wants" />
                                    <Slider
                                        Margin="0,14,0,0"
                                        Maximum="100"
                                        Minimum="0"
                                        TickFrequency="1"
                                        Value="{Binding WantsAllocationPercentage, Mode=TwoWay}" />
                                    <DockPanel Margin="0,8,0,0">
                                        <TextBlock
                                            DockPanel.Dock="Left"
                                            FontFamily="{StaticResource Bold}"
                                            Foreground="{StaticResource Brush.Text.Primary}"
                                            Text="{Binding WantsAllocationPercentage, StringFormat={}{0}%}" />
                                        <TextBlock
                                            HorizontalAlignment="Right"
                                            FontFamily="{StaticResource Medium}"
                                            Foreground="{StaticResource Brush.Text.Secondary}"
                                            Text="{Binding WantsAllocationAmountText}" />
                                    </DockPanel>
                                </StackPanel>
                            </Border>
                            <Border Style="{StaticResource CardStyle}">
                                <StackPanel>
                                    <TextBlock
                                        FontFamily="{StaticResource Bold}"
                                        Foreground="{StaticResource Brush.Text.Primary}"
                                        Text="Invest" />
                                    <Slider
                                        Margin="0,14,0,0"
                                        Maximum="100"
                                        Minimum="0"
                                        TickFrequency="1"
                                        Value="{Binding InvestAllocationPercentage, Mode=TwoWay}" />
                                    <DockPanel Margin="0,8,0,0">
                                        <TextBlock
                                            DockPanel.Dock="Left"
                                            FontFamily="{StaticResource Bold}"
                                            Foreground="{StaticResource Brush.Text.Primary}"
                                            Text="{Binding InvestAllocationPercentage, StringFormat={}{0}%}" />
                                        <TextBlock
                                            HorizontalAlignment="Right"
                                            FontFamily="{StaticResource Medium}"
                                            Foreground="{StaticResource Brush.Text.Secondary}"
                                            Text="{Binding InvestAllocationAmountText}" />
                                    </DockPanel>
                                </StackPanel>
                            </Border>
                        </StackPanel>

                        <ItemsControl ItemsSource="{Binding NotificationSettings}" Visibility="{Binding IsStep6Active, Converter={StaticResource BoolToVisibilityConverter}}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Style="{StaticResource CardStyle}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel>
                                                <TextBlock
                                                    FontFamily="{StaticResource Bold}"
                                                    Foreground="{StaticResource Brush.Text.Primary}"
                                                    Text="{Binding Title}" />
                                                <TextBlock
                                                    Margin="0,6,0,0"
                                                    FontFamily="{StaticResource Medium}"
                                                    Foreground="{StaticResource Brush.Text.Secondary}"
                                                    Text="{Binding Description}"
                                                    TextWrapping="Wrap" />
                                            </StackPanel>
                                            <ToggleButton
                                                Grid.Column="1"
                                                VerticalAlignment="Center"
                                                IsChecked="{Binding IsEnabled, Mode=TwoWay}"
                                                Style="{StaticResource ToggleSwitchStyle}" />
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <Border Style="{StaticResource CardStyle}" Visibility="{Binding IsStep7Active, Converter={StaticResource BoolToVisibilityConverter}}">
                            <StackPanel Margin="0,24,0,24" HorizontalAlignment="Center">
                                <Border
                                    Width="84"
                                    Height="84"
                                    Background="{StaticResource Brush.Background.Surface}"
                                    BorderBrush="{StaticResource Brush.Border.Subtle}"
                                    BorderThickness="1"
                                    CornerRadius="42">
                                    <Viewbox Margin="20" Stretch="Uniform">
                                        <Path Data="{StaticResource AccountBalanceWallet}" Fill="{StaticResource Brush.Mint}" />
                                    </Viewbox>
                                </Border>
                                <TextBlock
                                    Margin="0,18,0,0"
                                    HorizontalAlignment="Center"
                                    FontFamily="{StaticResource Bold}"
                                    FontSize="28"
                                    Foreground="{StaticResource Brush.Text.Primary}">
                                    <Run Text="Welcome to Fluxo, " />
                                    <Run Text="{Binding ResolvedUsername, Mode=OneWay}" />
                                    <Run Text="." />
                                </TextBlock>
                                <TextBlock
                                    Margin="0,12,0,0"
                                    HorizontalAlignment="Center"
                                    FontFamily="{StaticResource Medium}"
                                    FontSize="12"
                                    Foreground="{StaticResource Brush.Text.Secondary}"
                                    Text="Your dashboard, goals, and reminders are ready to go."
                                    TextAlignment="Center" />
                            </StackPanel>
                        </Border>
                    </Grid>
                </ScrollViewer>
            </Grid>
        </Border>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <Button
                Click="OnBackClick"
                Content="Back"
                Style="{StaticResource ActionButtonStyle}" />
            <Button
                Grid.Column="1"
                Margin="10,0,0,0"
                Click="OnNextClick"
                Content="Next"
                Style="{StaticResource PrimaryActionButtonStyle}"
                Visibility="{Binding IsFinalStep, Converter={StaticResource BoolToVisibilityInvertedConverter}}" />
            <Button
                Grid.Column="2"
                Margin="10,0,0,0"
                Click="OnFinishClick"
                Content="Open Fluxo"
                Style="{StaticResource PrimaryActionButtonStyle}"
                Visibility="{Binding IsFinalStep, Converter={StaticResource BoolToVisibilityConverter}}" />
        </Grid>
    </Grid>
</c:BasePopup>